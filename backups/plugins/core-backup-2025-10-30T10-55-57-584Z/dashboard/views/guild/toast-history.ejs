<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-bell me-2"></i>
                        Meine Toast-Benachrichtigungen
                    </h3>
                    <div class="card-tools">
                        <span class="badge badge-info" id="totalCount">0 Events</span>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Info-Text -->
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Hier siehst du deine letzten <strong>Toast-Benachrichtigungen</strong>. 
                        Diese werden automatisch gespeichert und helfen beim Debugging.
                    </div>

                    <!-- Filter -->
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <select class="form-control" id="filterType">
                                <option value="">Alle Typen</option>
                                <option value="success">Erfolg</option>
                                <option value="info">Info</option>
                                <option value="warning">Warnungen</option>
                                <option value="error">Fehler</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <input type="text" class="form-control" id="filterUrl" placeholder="URL filtern...">
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary btn-block" id="reloadToastsBtn">
                                <i class="fas fa-sync me-1"></i> Neu laden
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-danger btn-block" id="deleteAllToastsBtn">
                                <i class="fas fa-trash me-1"></i> Alle löschen
                            </button>
                        </div>
                    </div>

                    <!-- Toast-Liste -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Zeitstempel</th>
                                    <th>Typ</th>
                                    <th>Nachricht</th>
                                    <th>Seite</th>
                                    <th>Details</th>
                                    <th style="width: 100px;">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody id="toastTableBody">
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        <i class="fas fa-spinner fa-spin me-2"></i>
                                        Lade Benachrichtigungen...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
/**
 * Lädt Toast-History vom Server (nur eigene Toasts)
 */
async function loadToastHistory() {
    try {
        // Query-Parameter zusammenbauen
        const filterType = document.getElementById('filterType')?.value;
        const filterUrl = document.getElementById('filterUrl')?.value.toLowerCase();
        
        let url = '/api/core/toasts/history?limit=100';
        
        // Type-Filter an API übergeben (Server-seitig!)
        if (filterType) {
            url += `&type=${filterType}`;
        }
        
        const response = await fetch(url);
        const data = await response.json();
        
        if (data.success) {
            let toasts = data.toasts || [];
            
            // Client-seitiges URL-Filtern
            if (filterUrl) {
                toasts = toasts.filter(t => t.url && t.url.toLowerCase().includes(filterUrl));
            }
            
            renderToastTable(toasts);
            document.getElementById('totalCount').textContent = `${toasts.length} Events`;
        } else {
            showError('Fehler beim Laden der Benachrichtigungen');
        }
    } catch (error) {
        console.error('Fehler beim Laden:', error);
        showError('Fehler beim Laden: ' + error.message);
    }
}

/**
 * Rendert Toast-Tabelle (alle Toast-Typen)
 */
function renderToastTable(toasts) {
    const tbody = document.getElementById('toastTableBody');
    
    if (!toasts || toasts.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-check-circle text-success me-2" style="font-size: 2rem;"></i>
                    <div class="mt-2">Keine Benachrichtigungen gefunden</div>
                    <small class="text-muted">Toast-Benachrichtigungen werden hier angezeigt</small>
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = toasts.map(toast => {
        // Badge-Styling für alle Typen
        let typeBadge, typeIcon, typeName;
        
        switch(toast.type) {
            case 'error':
                typeBadge = 'danger';
                typeIcon = '<i class="bi bi-x-circle-fill"></i>';
                typeName = 'Fehler';
                break;
            case 'warning':
                typeBadge = 'warning';
                typeIcon = '<i class="bi bi-exclamation-triangle-fill"></i>';
                typeName = 'Warnung';
                break;
            case 'success':
                typeBadge = 'success';
                typeIcon = '<i class="bi bi-check-circle-fill"></i>';
                typeName = 'Erfolg';
                break;
            case 'info':
                typeBadge = 'info';
                typeIcon = '<i class="bi bi-info-circle-fill"></i>';
                typeName = 'Info';
                break;
            default:
                typeBadge = 'secondary';
                typeIcon = '<i class="bi bi-question-circle-fill"></i>';
                typeName = toast.type;
        }
        
        const timestamp = new Date(toast.timestamp).toLocaleString('de-DE', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
        
        // URL vereinfachen (nur Pfad ohne Domain)
        const urlPath = toast.url ? toast.url.replace(/^https?:\/\/[^/]+/, '') : '-';
        
        // Metadata NUR bei errors anzeigen
        let metadataHtml = '<small class="text-muted">-</small>';
        if (toast.type === 'error' && toast.metadata && Object.keys(toast.metadata).length > 0) {
            const metaKeys = Object.keys(toast.metadata);
            metadataHtml = `
                <button class="btn btn-sm btn-outline-danger show-metadata-btn" 
                        data-metadata='${JSON.stringify(toast.metadata).replace(/'/g, "&#39;")}'
                        title="Fehler-Details anzeigen">
                    <i class="bi bi-bug"></i> ${metaKeys.length} Details
                </button>
            `;
        }
        
        return `
            <tr data-toast-id="${toast.id}">
                <td><small>${timestamp}</small></td>
                <td><span class="badge badge-${typeBadge}">${typeIcon} ${typeName}</span></td>
                <td>${toast.message}</td>
                <td><small><code>${urlPath}</code></small></td>
                <td>${metadataHtml}</td>
                <td>
                    <button class="btn btn-sm btn-danger delete-toast-btn" 
                            data-id="${toast.id}" 
                            title="Löschen">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
        `;
    }).join('');
}

/**
 * Zeigt Metadata in Bootstrap Modal (einfache Alert-Version)
 */
window.showMetadata = function(metadata) {
    const formatted = JSON.stringify(metadata, null, 2);
    alert('Fehler-Details:\n\n' + formatted);
};

/**
 * Löscht einen einzelnen Toast
 */
async function deleteToast(toastId) {
    if (!confirm('Diesen Toast wirklich löschen?')) {
        return;
    }

    try {
        const response = await fetch(`/api/core/toasts/dismiss/${toastId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        const result = await response.json();

        if (result.success) {
            // Zeile aus Tabelle entfernen (fade out)
            const row = document.querySelector(`tr[data-toast-id="${toastId}"]`);
            if (row) {
                row.style.transition = 'opacity 0.3s';
                row.style.opacity = '0';
                setTimeout(() => {
                    row.remove();
                    // Wenn keine Toasts mehr: Neu laden
                    const tbody = document.getElementById('toastTableBody');
                    if (tbody.children.length === 0) {
                        loadToastHistory();
                    }
                }, 300);
            }
            
            // Badge aktualisieren
            const badge = document.getElementById('totalCount');
            const currentCount = parseInt(badge.textContent) || 0;
            badge.textContent = `${Math.max(0, currentCount - 1)} Events`;
            
            // ✅ Glocke in Navbar aktualisieren (falls vorhanden)
            updateNavbarBellIcon();
        } else {
            alert('Fehler beim Löschen: ' + (result.error || 'Unbekannter Fehler'));
        }
    } catch (error) {
        console.error('Fehler beim Löschen:', error);
        alert('Netzwerkfehler beim Löschen');
    }
}

/**
 * Löscht alle Toasts des Users
 */
async function deleteAllToasts() {
    if (!confirm('Wirklich ALLE Benachrichtigungen löschen?\n\nDies kann nicht rückgängig gemacht werden!')) {
        return;
    }

    try {
        const guildId = getCurrentGuildId();
        const response = await fetch('/api/core/toasts/dismiss-all', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ guildId })
        });

        const result = await response.json();

        if (result.success) {
            alert(`${result.count} Benachrichtigungen wurden gelöscht.`);
            loadToastHistory(); // Tabelle neu laden
            
            // ✅ Glocke in Navbar aktualisieren (falls vorhanden)
            updateNavbarBellIcon();
        } else {
            alert('Fehler beim Löschen: ' + (result.error || 'Unbekannter Fehler'));
        }
    } catch (error) {
        console.error('Fehler beim Löschen:', error);
        alert('Netzwerkfehler beim Löschen');
    }
}

/**
 * Zeigt Fehler-Nachricht an
 */
function showError(message) {
    const tbody = document.getElementById('toastTableBody');
    tbody.innerHTML = `
        <tr>
            <td colspan="6" class="text-center text-danger py-4">
                <i class="bi bi-exclamation-triangle me-2" style="font-size: 2rem;"></i>
                <div class="mt-2">${message}</div>
            </td>
        </tr>
    `;
}

/**
 * Ermittelt Guild-ID aus aktueller URL
 */
function getCurrentGuildId() {
    const guildMatch = window.location.pathname.match(/\/guild\/(\d+)/);
    return guildMatch ? guildMatch[1] : null;
}

/**
 * Aktualisiert die Glocke in der Navbar (falls auf gleicher Seite)
 * Ruft die loadToastNotifications() Funktion aus toast-notification-center.js auf
 */
function updateNavbarBellIcon() {
    console.log('[Toast-History] Aktualisiere Navbar-Glocke...');
    
    // Prüfe ob die globale Funktion verfügbar ist
    if (typeof window.loadToastNotifications === 'function') {
        window.loadToastNotifications();
        console.log('[Toast-History] ✅ Navbar-Glocke aktualisiert');
    } else {
        console.warn('[Toast-History] loadToastNotifications() nicht verfügbar');
        
        // Fallback: Badge manuell auf 0 setzen wenn alle gelöscht wurden
        const badge = document.getElementById('toastNotificationBadge');
        if (badge) {
            const tbody = document.getElementById('toastTableBody');
            if (tbody && tbody.children.length === 0) {
                badge.style.display = 'none';
                badge.textContent = '0';
                console.log('[Toast-History] ✅ Navbar-Badge auf 0 gesetzt (Fallback)');
            }
        }
    }
}

// Initial Load
document.addEventListener('DOMContentLoaded', () => {
    // Button-Handler registrieren
    const reloadBtn = document.getElementById('reloadToastsBtn');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', loadToastHistory);
    }
    
    // "Alle löschen" Button
    const deleteAllBtn = document.getElementById('deleteAllToastsBtn');
    if (deleteAllBtn) {
        deleteAllBtn.addEventListener('click', deleteAllToasts);
    }
    
    // ✅ Event-Delegation für Löschen-Buttons (CSP-konform)
    document.addEventListener('click', function(e) {
        const deleteBtn = e.target.closest('.delete-toast-btn');
        if (deleteBtn) {
            e.preventDefault();
            const toastId = parseInt(deleteBtn.getAttribute('data-id'));
            if (toastId) {
                deleteToast(toastId);
            }
        }
    });
    
    // ✅ Event-Delegation für Metadata-Buttons (CSP-konform)
    document.addEventListener('click', function(e) {
        const metadataBtn = e.target.closest('.show-metadata-btn');
        if (metadataBtn) {
            e.preventDefault();
            try {
                const metadata = JSON.parse(metadataBtn.getAttribute('data-metadata'));
                showMetadata(metadata);
            } catch (error) {
                console.error('Fehler beim Parsen der Metadata:', error);
            }
        }
    });
    
    // Filter-Handler registrieren
    const filterType = document.getElementById('filterType');
    const filterUrl = document.getElementById('filterUrl');
    
    if (filterType) {
        filterType.addEventListener('change', loadToastHistory);
    }
    
    if (filterUrl) {
        // Debounce für URL-Filter
        let urlFilterTimeout;
        filterUrl.addEventListener('input', () => {
            clearTimeout(urlFilterTimeout);
            urlFilterTimeout = setTimeout(loadToastHistory, 500);
        });
    }
    
    // Initial laden
    loadToastHistory();
    
    // Auto-Refresh alle 30 Sekunden
    setInterval(loadToastHistory, 30000);
});
</script>
