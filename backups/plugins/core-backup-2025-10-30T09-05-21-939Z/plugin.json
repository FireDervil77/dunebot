{
  "name": "core",
  "version": "6.6.0",
  "displayName": "FireBot Core-Plugin",
  "description": "Das Core-Plugin des FireBots. Wird automatisch in jeder neuen Guild aktiviert.",
  "author": "FireBot Team",
  "type": "system",
  "required": true,
  "icon": "fa-fire",
  "color": "#e74c3c",
  "repository": "https://github.com/firedervil77/dunebot-plugins",
  "homepage": "https://firebot.gg",
  "license": "MIT",
  
  "main": {
    "bot": "bot/index.js",
    "dashboard": "dashboard/index.js"
  },
  
  "migrations": {
    "6.6.0": "dashboard/migrations/6.6.0-permissions.js"
  },
  
  "permissions": [
    "core.admin",
    "core.settings.view",
    "core.settings.edit",
    "core.dashboard.access",
    "core.plugins.manage",
    "core.users.manage",
    "core.groups.manage"
  ],
  
  "dependencies": {
    "dunebot-sdk": "*"
  },
  
  "scripts": {
    "test": "echo 'No tests defined'"
  },
  
  "features": [
    "dashboard",
    "bot",
    "permissions",
    "navigation",
    "settings",
    "plugins",
    "themes"
  ],
  
  "config": {
    "autoEnable": true,
    "canBeDisabled": false,
    "requiresOwner": false
  }
}
