{
  "name": "dunebot-bot",
  "version": "0.1.0-beta",
  "description": "A Discord JS DuneBot",
  "author": "FireDervil",
  "license": "none",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "scripts": {
    "start": "npm run start:bot & npm run start:dashboard",
    "start:bot": "npm run start --workspace bot",
    "start:dashboard": "npm --trace-warnings run start --workspace dashboard",
    "dev": "npm run dev:bot & npm run dev:dashboard",
    "dev:bot": "npm run dev --workspace bot",
    "dev:dashboard": "npm run dev --workspace dashboard",
    "format": "prettier --write 'apps/**/*.{js,json,ejs}' 'plugins/**/*.{js,json,ejs}' 'packages/**/*.{js,json}'",
    "lint": "eslint --fix ."
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "homepage": "",
  "repository": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.32.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "npm": "^10.9.3",
    "prettier": "^3.6.2",
    "prettier-plugin-ejs": "^1.0.3"
  },
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "bot",
    "multipurpose",
    "multi-purpose-bot"
  ],
  "main": "index.js",
  "dependencies": {
    "admin-lte": "^4.0.0-rc3",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "canvas": "^3.2.0",
    "cookie-parser": "^1.4.7",
    "cryptr": "^6.3.0",
    "csrf-csrf": "^4.0.3",
    "discord-oauth2": "^2.12.1",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "enhanced-ms": "^4.1.0",
    "execa": "^9.6.0",
    "express": "^5.1.0",
    "express-ejs-layouts": "^2.5.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "i18next": "^25.3.2",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.3",
    "nodemon": "^3.1.10",
    "path": "^0.12.7",
    "pino-pretty": "^13.1.1",
    "semver": "^7.7.3",
    "sequelize": "^6.37.7",
    "simple-git": "^3.28.0",
    "stripe": "^19.1.0",
    "tar": "^7.5.1",
    "tinymce": "^8.2.0",
    "veza": "^1.2.0"
  }
}
