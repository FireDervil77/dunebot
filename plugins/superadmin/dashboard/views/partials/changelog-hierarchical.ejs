<%
/**
 * Hierarchische Changelog-Darstellung
 * 
 * Benötigte Locals:
 * - changesText: Der Rohtext mit Markdown-Struktur (# Header, ## Sub-Header, ! + - *)
 * - locale: Aktuelle Sprache (optional, für Icons/Labels)
 */

// Import der parseHierarchicalChangelog Funktion (wird vom Controller übergeben)
const { parseHierarchicalChangelog } = require('../../../../../apps/dashboard/helpers/changelogHelper');

// Parse den Changes-Text
const hierarchicalData = parseHierarchicalChangelog(changesText);

// Icon-Mapping für Item-Typen
const itemIcons = {
    fix: { icon: 'fa-bug', class: 'text-danger', label: 'Fix' },
    feature: { icon: 'fa-plus', class: 'text-success', label: 'Feature' },
    removed: { icon: 'fa-minus', class: 'text-warning', label: 'Removed' },
    change: { icon: 'fa-edit', class: 'text-info', label: 'Change' }
};
%>

<% if (hierarchicalData && hierarchicalData.length > 0) { %>
    <div class="changelog-hierarchical">
        <% hierarchicalData.forEach((group, groupIndex) => { %>
            <% if (group.type === 'group') { %>
                <!-- Hauptgruppe (# Header) -->
                <div class="changelog-group mb-4">
                    <h4 class="border-bottom pb-2 mb-3">
                        <i class="fas fa-layer-group mr-2 text-primary"></i>
                        <%= group.title %>
                    </h4>
                    
                    <% (group.children || []).forEach((subgroup, subIndex) => { %>
                        <% if (subgroup.type === 'subgroup') { %>
                            <!-- Untergruppe (## Sub-Header) -->
                            <div class="changelog-subgroup mb-3 ml-3">
                                <h5 class="text-muted mb-2">
                                    <i class="fas fa-folder-open mr-2"></i>
                                    <%= subgroup.title %>
                                </h5>
                                
                                <% if (subgroup.items && subgroup.items.length > 0) { %>
                                    <!-- Items gruppiert nach Kategorie -->
                                    <%
                                    // Gruppiere Items nach Kategorie (Fixes, Features, etc.)
                                    const itemsByCategory = {};
                                    subgroup.items.forEach(item => {
                                        const category = item.category || 'Other';
                                        if (!itemsByCategory[category]) {
                                            itemsByCategory[category] = [];
                                        }
                                        itemsByCategory[category].push(item);
                                    });
                                    
                                    // Sortiere Kategorien: Fixes -> Features -> Changes -> Removed
                                    const categoryOrder = ['Fixes', 'Features', 'Changes', 'Removed', 'Other'];
                                    const sortedCategories = Object.keys(itemsByCategory).sort((a, b) => {
                                        const indexA = categoryOrder.indexOf(a);
                                        const indexB = categoryOrder.indexOf(b);
                                        return (indexA === -1 ? 999 : indexA) - (indexB === -1 ? 999 : indexB);
                                    });
                                    %>
                                    
                                    <ul class="list-unstyled ml-4">
                                        <% sortedCategories.forEach(category => { %>
                                            <% itemsByCategory[category].forEach(item => { %>
                                                <li class="mb-2">
                                                    <i class="fas <%= item.icon %> <%= item.class %> mr-2"></i>
                                                    <strong class="<%= item.class %>"><%= item.category %>:</strong>
                                                    <%= item.text %>
                                                </li>
                                            <% }); %>
                                        <% }); %>
                                    </ul>
                                <% } else { %>
                                    <p class="text-muted ml-4"><em>Keine Änderungen</em></p>
                                <% } %>
                            </div>
                        <% } %>
                    <% }); %>
                </div>
            <% } %>
        <% }); %>
    </div>
<% } else { %>
    <p class="text-muted"><em>Keine Änderungen dokumentiert</em></p>
<% } %>

<style>
.changelog-hierarchical {
    font-size: 0.95em;
}

.changelog-group h4 {
    color: #333;
    font-weight: 600;
    font-size: 1.2em;
}

.changelog-subgroup h5 {
    font-size: 1.05em;
    font-weight: 500;
}

.changelog-hierarchical ul li {
    line-height: 1.6;
}

.changelog-hierarchical .fa-bug { margin-right: 8px; }
.changelog-hierarchical .fa-plus { margin-right: 8px; }
.changelog-hierarchical .fa-minus { margin-right: 8px; }
.changelog-hierarchical .fa-edit { margin-right: 8px; }
</style>
