<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-tags me-2"></i>Plugin Badge Management</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>/plugins/superadmin">SuperAdmin</a></li>
                    <li class="breadcrumb-item active">Plugin Badges</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        
        <!-- Info Alert -->
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            <strong>Plugin Badge System:</strong> Markiere neu veröffentlichte Plugins als "NEU" für 2 Wochen. 
            Badges sind global für alle Guilds sichtbar.
        </div>

        <!-- Badge hinzufügen -->
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-plus-circle me-2"></i>Neues Badge setzen</h3>
            </div>
            <form class="guild-ajax-form" data-form-type="plugin-badge-create" data-method="POST" action="/guild/<%= guildId %>/plugins/superadmin/plugin-badges" method="POST">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="pluginName">Plugin auswählen</label>
                                <select class="form-select" id="pluginName" name="pluginName" required>
                                    <option value="">-- Plugin wählen --</option>
                                    <% availablePlugins.forEach(pluginName => { %>
                                        <option value="<%= pluginName %>"><%= pluginName %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="badgeStatus">Badge-Status</label>
                                <select class="form-select" id="badgeStatus" name="badgeStatus" required>
                                    <option value="new">🟢 NEU (Neu veröffentlicht)</option>
                                    <option value="beta">🟡 BETA (In Testphase)</option>
                                    <option value="updated">🔵 UPDATED (Kürzlich aktualisiert)</option>
                                    <option value="deprecated">🔴 DEPRECATED (Veraltet)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="badgeUntil">Ablaufdatum (Optional)</label>
                                <input type="date" class="form-control" id="badgeUntil" name="badgeUntil" 
                                       value="<%= new Date(Date.now() + 14*24*60*60*1000).toISOString().split('T')[0] %>">
                                <small class="form-text text-muted">Leer lassen für permanentes Badge. Standard: +14 Tage</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="isFeatured">Featured (Hervorheben)</label>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="isFeatured" name="isFeatured" value="1">
                                    <label class="form-check-label" for="isFeatured">
                                        Plugin als Featured markieren (wird mit ⭐ hervorgehoben)
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Badge setzen
                    </button>
                </div>
            </form>
        </div>

        <!-- Aktive Badges Liste -->
        <div class="card card-success">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-list me-2"></i>Aktive Plugin-Badges</h3>
            </div>
            <div class="card-body">
                <% if (badges && badges.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Plugin</th>
                                    <th>Badge</th>
                                    <th>Ablaufdatum</th>
                                    <th>Featured</th>
                                    <th>Status</th>
                                    <th>Erstellt</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% badges.forEach(badge => { %>
                                    <tr>
                                        <td><strong><%= badge.plugin_name %></strong></td>
                                        <td>
                                            <span class="badge bg-<%= 
                                                badge.badge_status === 'new' ? 'success' : 
                                                badge.badge_status === 'beta' ? 'warning' : 
                                                badge.badge_status === 'updated' ? 'info' : 
                                                badge.badge_status === 'deprecated' ? 'danger' : 'secondary' 
                                            %>">
                                                <%= badge.badge_status === 'new' ? '🟢 NEU' : 
                                                    badge.badge_status === 'beta' ? '🟡 BETA' : 
                                                    badge.badge_status === 'updated' ? '🔵 UPDATE' : 
                                                    badge.badge_status === 'deprecated' ? '🔴 DEPRECATED' : 
                                                    badge.badge_status.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (badge.badge_until) { %>
                                                <%= new Date(badge.badge_until).toLocaleDateString('de-DE') %>
                                            <% } else { %>
                                                <span class="text-muted">Permanent</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (badge.is_featured) { %>
                                                <span class="text-warning"><i class="fas fa-star"></i> Featured</span>
                                            <% } else { %>
                                                <span class="text-muted">-</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (badge.is_active) { %>
                                                <span class="badge bg-success">✓ Aktiv</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Abgelaufen</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                <%= new Date(badge.created_at).toLocaleDateString('de-DE') %>
                                            </small>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-danger delete-badge" 
                                                    data-plugin="<%= badge.plugin_name %>">
                                                <i class="fas fa-trash"></i> Entfernen
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Noch keine Plugin-Badges vorhanden. Erstelle das erste Badge oben!
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</section>

<script>
// DELETE Badge Handler
document.querySelectorAll('.delete-badge').forEach(btn => {
    btn.addEventListener('click', async (e) => {
        const pluginName = e.currentTarget.dataset.plugin;
        const button = e.currentTarget;
        const row = button.closest('tr');
        
        if (!confirm(`Badge für Plugin "${pluginName}" wirklich entfernen?`)) return;
        
        // Button-Status während Request
        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Löschen...';
        
        try {
            const response = await fetch(`/guild/<%= guildId %>/plugins/superadmin/plugin-badges/${pluginName}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const result = await response.json();
            
            if (result.success) {
                GuildAjax.showToast('success', result.message);
                
                // Zeile mit Animation entfernen statt Page-Reload
                row.style.transition = 'opacity 0.3s';
                row.style.opacity = '0';
                setTimeout(() => {
                    row.remove();
                    
                    // Prüfen ob Tabelle jetzt leer ist
                    const tbody = document.querySelector('.table tbody');
                    if (tbody && tbody.children.length === 0) {
                        // Zeige "Keine Badges" Nachricht
                        document.querySelector('.card-success .card-body').innerHTML = `
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Noch keine Plugin-Badges vorhanden. Erstelle das erste Badge oben!
                            </div>
                        `;
                    }
                }, 300);
            } else {
                GuildAjax.showToast('error', result.message || 'Fehler beim Entfernen');
                button.disabled = false;
                button.innerHTML = originalHtml;
            }
        } catch (error) {
            console.error('Delete Badge Error:', error);
            GuildAjax.showToast('error', 'Netzwerkfehler beim Entfernen');
            button.disabled = false;
            button.innerHTML = originalHtml;
        }
    });
});
</script>
