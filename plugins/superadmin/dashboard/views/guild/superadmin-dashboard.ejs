<%# 
  * SuperAdmin Dashboard
  * Haupt-Übersicht für Bot-Owner
  %>

<div class="app-content">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fa-solid fa-shield-halved me-2"></i>
                    <strong>SuperAdmin Panel</strong> - Du bist als Bot-Owner angemeldet
                </div>
            </div>
        </div>

        <!-- Statistik-Karten -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Guilds</h5>
                        <p class="display-4"><%= stats.guilds %></p>
                        <p class="text-muted">Registrierte Server</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">User</h5>
                        <p class="display-4"><%= stats.users %></p>
                        <p class="text-muted">Registrierte Benutzer</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">News</h5>
                        <p class="display-4"><%= stats.news %></p>
                        <p class="text-muted">Veröffentlichte News</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Notifications</h5>
                        <p class="display-4"><%= stats.notifications %></p>
                        <p class="text-muted">Gesendete Benachrichtigungen</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">News verwalten</h5>
                    </div>
                    <div class="card-body">
                        <p>Erstelle und bearbeite globale News für alle Guilds.</p>
                        <a href="/guild/<%= guildId %>/plugins/superadmin/news" class="btn btn-primary">
                            <i class="fa-solid fa-newspaper me-2"></i>News öffnen
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Notifications senden</h5>
                    </div>
                    <div class="card-body">
                        <p>Sende globale Benachrichtigungen an alle oder einzelne Guilds.</p>
                        <a href="/guild/<%= guildId %>/plugins/superadmin/notifications" class="btn btn-warning">
                            <i class="fa-solid fa-bell me-2"></i>Notifications
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">System Stats</h5>
                    </div>
                    <div class="card-body">
                        <p>Detaillierte Statistiken über das gesamte Bot-System.</p>
                        <a href="/guild/<%= guildId %>/plugins/superadmin/stats" class="btn btn-info">
                            <i class="fa-solid fa-chart-line me-2"></i>Statistiken
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
