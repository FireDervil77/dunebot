<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><%= tr('NOTIFICATIONS.TITLE') %></h1>
            </div>
            <div class="col-sm-6">
                <div class="float-sm-right">
                    <a href="/guild/<%= guildId %>/plugins/superadmin/notifications/new" class="btn btn-primary">
                        <i class="fas fa-plus mr-2"></i><%= tr('NOTIFICATIONS.ADD_NEW') %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <% if (locals.toast) { %>
            <div class="alert alert-<%= toast.type %> alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <%= toast.message %>
            </div>
        <% } %>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><%= tr('NOTIFICATIONS.ALL_NOTIFICATIONS') %></h3>
            </div>
            <div class="card-body p-0">
                <% if (notifications && notifications.length > 0) { %>
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th style="width: 10px">#</th>
                                <th><%= tr('NOTIFICATIONS.TABLE.TITLE') %></th>
                                <th><%= tr('NOTIFICATIONS.TABLE.TYPE') %></th>
                                <th><%= tr('NOTIFICATIONS.TABLE.EXPIRES') %></th>
                                <th><%= tr('NOTIFICATIONS.TABLE.CREATED') %></th>
                                <th style="width: 120px"><%= tr('NOTIFICATIONS.TABLE.ACTIONS') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% notifications.forEach((notification, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>
                                        <strong><%= notification.title || 'Untitled' %></strong>
                                    </td>
                                    <td>
                                        <% 
                                        const typeIcons = {
                                            info: 'info-circle text-info',
                                            warning: 'exclamation-triangle text-warning',
                                            error: 'exclamation-circle text-danger',
                                            success: 'check-circle text-success'
                                        };
                                        const icon = typeIcons[notification.type] || 'bell';
                                        %>
                                        <i class="fas fa-<%= icon %>"></i>
                                        <span class="ml-1"><%= notification.type %></span>
                                    </td>
                                    <td>
                                        <% if (notification.expiry) { %>
                                            <%= new Date(notification.expiry).toLocaleDateString(currentLocale) %>
                                        <% } else { %>
                                            <span class="text-muted">—</span>
                                        <% } %>
                                    </td>
                                    <td><%= new Date(notification.created_at).toLocaleDateString(currentLocale) %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/guild/<%= guildId %>/plugins/superadmin/notifications/edit/<%= notification.id %>" 
                                               class="btn btn-info" 
                                               title="<%= tr('NOTIFICATIONS.EDIT') %>">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" 
                                                    class="btn btn-danger" 
                                                    onclick="deleteNotification('<%= notification.id %>')"
                                                    title="<%= tr('NOTIFICATIONS.DELETE') %>">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="p-4 text-center text-muted">
                        <i class="fas fa-bell fa-3x mb-3"></i>
                        <p><%= tr('NOTIFICATIONS.NO_NOTIFICATIONS') %></p>
                        <a href="/guild/<%= guildId %>/plugins/superadmin/notifications/new" class="btn btn-primary">
                            <i class="fas fa-plus mr-2"></i><%= tr('NOTIFICATIONS.ADD_FIRST') %>
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
console.log('[NOTIFICATION] Script loaded, guildId:', '<%= guildId %>');

function deleteNotification(id) {
    console.log('[NOTIFICATION] deleteNotification called with id:', id);
    console.log('[NOTIFICATION] Confirm message:', '<%= tr("NOTIFICATIONS.CONFIRM_DELETE") %>');
    
    if (!confirm('<%= tr("NOTIFICATIONS.CONFIRM_DELETE") %>')) {
        console.log('[NOTIFICATION] User cancelled deletion');
        return;
    }
    
    const url = `/guild/<%= guildId %>/plugins/superadmin/notifications/delete/${id}`;
    console.log('[NOTIFICATION] Fetching URL:', url);
    
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        }
    })
    .then(response => {
        console.log('[NOTIFICATION] Response status:', response.status);
        return response.json();
    })
    .then(data => {
        console.log('[NOTIFICATION] Response data:', data);
        if (data.success) {
            console.log('[NOTIFICATION] Deletion successful, reloading...');
            window.location.reload();
        } else {
            alert(data.message || '<%= tr("NOTIFICATIONS.DELETE_ERROR") %>');
        }
    })
    .catch(error => {
        console.error('[NOTIFICATION] Error:', error);
        alert('<%= tr("NOTIFICATIONS.DELETE_ERROR") %>');
    });
}

console.log('[NOTIFICATION] deleteNotification function defined:', typeof deleteNotification);
</script>

