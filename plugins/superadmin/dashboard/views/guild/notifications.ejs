<%# 
  * Notifications Interface
  * Globale Benachrichtigungen an Guilds senden
  %>

<div class="app-content">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-md-12">
                <h2>Notifications</h2>
                <p class="text-muted">Sende globale Benachrichtigungen an alle oder spezifische Guilds</p>
            </div>
        </div>

        <!-- Notification Formular -->
        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <form method="POST" 
                              action="/guild/<%= guildId %>/plugins/superadmin/notifications/send"
                              class="guild-ajax-form"
                              data-form-type="notification">
                            <!-- Notification Typ -->
                            <div class="mb-3">
                                <label for="type" class="form-label">Typ *</label>
                                <select class="form-select" id="type" name="type" required>
                                    <option value="info">Info</option>
                                    <option value="success">Erfolg</option>
                                    <option value="warning">Warnung</option>
                                    <option value="error">Fehler</option>
                                </select>
                            </div>

                            <!-- Titel -->
                            <div class="mb-3">
                                <label for="title" class="form-label">Titel *</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="title" 
                                       name="title" 
                                       placeholder="z.B. Wichtiges Update" 
                                       required>
                            </div>

                            <!-- Nachricht -->
                            <div class="mb-3">
                                <label for="message" class="form-label">Nachricht *</label>
                                <textarea class="form-control" 
                                          id="message" 
                                          name="message" 
                                          rows="5" 
                                          placeholder="Beschreibe die Notification..." 
                                          required></textarea>
                            </div>

                            <!-- Target Auswahl -->
                            <div class="mb-3">
                                <label class="form-label">Ziel *</label>
                                <div class="form-check">
                                    <input class="form-check-input" 
                                           type="radio" 
                                           name="target" 
                                           id="targetAll" 
                                           value="all" 
                                           checked 
                                           onchange="toggleGuildSelect()">
                                    <label class="form-check-label" for="targetAll">
                                        Alle Guilds
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" 
                                           type="radio" 
                                           name="target" 
                                           id="targetSpecific" 
                                           value="specific" 
                                           onchange="toggleGuildSelect()">
                                    <label class="form-check-label" for="targetSpecific">
                                        Spezifische Guild
                                    </label>
                                </div>
                            </div>

                            <!-- Guild Auswahl (versteckt standardmäßig) -->
                            <div class="mb-3" id="guildSelectContainer" style="display:none;">
                                <label for="target_guild_id" class="form-label">Guild auswählen</label>
                                <select class="form-select" id="target_guild_id" name="target_guild_id">
                                    <option value="">-- Bitte wählen --</option>
                                    <% if (guilds && guilds.length > 0) { %>
                                        <% guilds.forEach(guild => { %>
                                            <option value="<%= guild.id %>"><%= guild.name %></option>
                                        <% }); %>
                                    <% } %>
                                </select>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-success">
                                    <i class="fa-solid fa-paper-plane me-2"></i>Notification senden
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Letzte Notifications -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Letzte Notifications</h5>
                    </div>
                    <div class="card-body">
                        <% if (recentNotifications && recentNotifications.length > 0) { %>
                            <div class="list-group list-group-flush">
                                <% recentNotifications.forEach(notification => { %>
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <span class="badge bg-<%= notification.type === 'info' ? 'primary' : notification.type === 'success' ? 'success' : notification.type === 'warning' ? 'warning' : 'danger' %>">
                                                <%= notification.type %>
                                            </span>
                                            <small class="text-muted">
                                                <%= new Date(notification.created_at).toLocaleString('de-DE') %>
                                            </small>
                                        </div>
                                        <h6 class="mb-1"><%= notification.title %></h6>
                                        <p class="mb-1 text-muted small"><%= notification.message %></p>
                                        <small class="text-muted">
                                            <% if (notification.guild_id) { %>
                                                Spezifische Guild
                                            <% } else { %>
                                                Alle Guilds
                                            <% } %>
                                        </small>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center mb-0">Keine Notifications vorhanden</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function toggleGuildSelect() {
    const targetSpecific = document.getElementById('targetSpecific').checked;
    const guildSelectContainer = document.getElementById('guildSelectContainer');
    const guildSelect = document.getElementById('target_guild_id');
    
    if (targetSpecific) {
        guildSelectContainer.style.display = 'block';
        guildSelect.required = true;
    } else {
        guildSelectContainer.style.display = 'none';
        guildSelect.required = false;
        guildSelect.value = '';
    }
}
</script>
