<!-- SuperAdmin Donations Management Page -->

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-heart me-2"></i><%= tr('superadmin:DONATIONS.TITLE') %>
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>">Dashboard</a></li>
                    <li class="breadcrumb-item active"><%= tr('superadmin:DONATIONS.BREADCRUMB') %></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        
        <!-- Statistik Info-Boxen -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>€<%= stats.total_amount ? stats.total_amount.toFixed(2) : '0.00' %></h3>
                        <p><%= tr('superadmin:DONATIONS.STATS.TOTAL_AMOUNT') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-euro-sign"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3><%= stats.total_donations || 0 %></h3>
                        <p><%= tr('superadmin:DONATIONS.STATS.TOTAL_DONATIONS') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-hand-holding-heart"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>€<%= stats.average_donation ? stats.average_donation.toFixed(2) : '0.00' %></h3>
                        <p><%= tr('superadmin:DONATIONS.STATS.AVERAGE_DONATION') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3><%= stats.unique_supporters || 0 %></h3>
                        <p><%= tr('superadmin:DONATIONS.STATS.UNIQUE_SUPPORTERS') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <!-- Donations Liste -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-list me-2"></i><%= tr('superadmin:DONATIONS.TABLE.ALL_DONATIONS') %>
                        </h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-success" data-toggle="modal" data-target="#createDonationModal">
                                <i class="fas fa-plus me-1"></i><%= tr('superadmin:DONATIONS.TABLE.MANUAL_DONATION') %>
                            </button>
                        </div>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover table-striped" id="donationsTable">
                            <thead>
                                <tr>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.ID') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.USER') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.AMOUNT') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.STATUS') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.PROVIDER') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.DATE') %></th>
                                    <th><%= tr('superadmin:DONATIONS.TABLE.ACTIONS') %></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (donations && donations.length > 0) { %>
                                    <% donations.forEach(donation => { %>
                                    <tr>
                                        <td>#<%= donation.id %></td>
                                        <td>
                                            <% if (donation.avatar) { %>
                                            <img src="https://cdn.discordapp.com/avatars/<%= donation.user_id %>/<%= donation.avatar %>.png?size=32" 
                                                 class="img-circle elevation-2" 
                                                 width="25" height="25"
                                                 alt="Avatar">
                                            <% } %>
                                            <%= donation.full_username || donation.user_id %>
                                        </td>
                                        <td class="text-success font-weight-bold">€<%= donation.amount.toFixed(2) %></td>
                                        <td>
                                            <% if (donation.payment_status === 'completed') { %>
                                                <span class="badge badge-success"><%= tr('superadmin:DONATIONS.STATUS.COMPLETED') %></span>
                                            <% } else if (donation.payment_status === 'pending') { %>
                                                <span class="badge badge-warning"><%= tr('superadmin:DONATIONS.STATUS.PENDING') %></span>
                                            <% } else if (donation.payment_status === 'refunded') { %>
                                                <span class="badge badge-danger"><%= tr('superadmin:DONATIONS.STATUS.REFUNDED') %></span>
                                            <% } else if (donation.payment_status === 'expired') { %>
                                                <span class="badge badge-secondary"><%= tr('superadmin:DONATIONS.STATUS.EXPIRED') %></span>
                                            <% } else { %>
                                                <span class="badge badge-dark"><%= donation.payment_status %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (donation.payment_provider === 'stripe') { %>
                                                <i class="fab fa-stripe text-primary"></i> <%= tr('superadmin:DONATIONS.PROVIDERS.STRIPE') %>
                                            <% } else if (donation.payment_provider === 'manual') { %>
                                                <i class="fas fa-hand-paper text-info"></i> <%= tr('superadmin:DONATIONS.PROVIDERS.MANUAL') %>
                                            <% } else { %>
                                                <%= donation.payment_provider %>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(donation.created_at).toLocaleString('de-DE') %></td>
                                        <td>
                                            <% if (donation.payment_status === 'completed') { %>
                                            <button class="btn btn-sm btn-danger" onclick="refundDonation('<%= donation.id %>')">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">
                                            <i class="fas fa-info-circle me-2"></i><%= tr('superadmin:DONATIONS.TABLE.NO_DONATIONS') %>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Top Donors -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-trophy me-2"></i><%= tr('superadmin:DONATIONS.TOP_DONORS.TITLE') %>
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="products-list product-list-in-card pl-2 pr-2">
                            <% topDonors.forEach((donor, index) => { %>
                            <li class="item">
                                <div class="product-img">
                                    <% if (donor.avatar) { %>
                                    <img src="https://cdn.discordapp.com/avatars/<%= donor.user_id %>/<%= donor.avatar %>.png?size=64" 
                                         class="img-circle" 
                                         alt="Avatar">
                                    <% } else { %>
                                    <span class="img-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        #<%= index + 1 %>
                                    </span>
                                    <% } %>
                                </div>
                                <div class="product-info">
                                    <span class="product-title">
                                        <%= donor.full_username || donor.user_id %>
                                        <% if (donor.badge_level === 'platinum') { %>
                                            <i class="fas fa-crown text-info float-right"></i>
                                        <% } else if (donor.badge_level === 'gold') { %>
                                            <i class="fas fa-trophy text-warning float-right"></i>
                                        <% } else if (donor.badge_level === 'silver') { %>
                                            <i class="fas fa-medal text-secondary float-right"></i>
                                        <% } else if (donor.badge_level === 'bronze') { %>
                                            <i class="fas fa-award text-danger float-right"></i>
                                        <% } %>
                                    </span>
                                    <span class="product-description">
                                        <strong class="text-success">€<%= donor.total_donated.toFixed(2) %></strong>
                                        <small class="text-muted">(<%= donor.donation_count %> Donations)</small>
                                    </span>
                                </div>
                            </li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
                
                <!-- Badge Distribution -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-chart-pie me-2"></i><%= tr('superadmin:DONATIONS.BADGE_DISTRIBUTION.TITLE') %>
                        </h3>
                    </div>
                    <div class="card-body">
                        <% const badgeCounts = {}; badgeDistribution.forEach(b => badgeCounts[b.badge_level] = b.count); %>
                        <div class="progress-group">
                            <i class="fas fa-crown text-info me-2"></i> <%= tr('superadmin:DONATIONS.BADGE_DISTRIBUTION.PLATINUM') %>
                            <span class="float-right"><%= badgeCounts.platinum || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-info" style="width: <%= (badgeCounts.platinum || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-trophy text-warning me-2"></i> <%= tr('superadmin:DONATIONS.BADGE_DISTRIBUTION.GOLD') %>
                            <span class="float-right"><%= badgeCounts.gold || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-warning" style="width: <%= (badgeCounts.gold || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-medal text-secondary me-2"></i> <%= tr('superadmin:DONATIONS.BADGE_DISTRIBUTION.SILVER') %>
                            <span class="float-right"><%= badgeCounts.silver || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-secondary" style="width: <%= (badgeCounts.silver || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-award text-danger me-2"></i> <%= tr('superadmin:DONATIONS.BADGE_DISTRIBUTION.BRONZE') %>
                            <span class="float-right"><%= badgeCounts.bronze || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-danger" style="width: <%= (badgeCounts.bronze || 0) * 10 %>%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</section>

<!-- Create Donation Modal -->
<div class="modal fade" id="createDonationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><%= tr('superadmin:DONATIONS.MODAL.CREATE_TITLE') %></h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="createDonationForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label><%= tr('superadmin:DONATIONS.MODAL.USER_ID') %> <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="user_id" required 
                               placeholder="Discord User ID">
                        <small class="form-text text-muted">
                            <%= tr('superadmin:DONATIONS.MODAL.USER_ID_HELP') %>
                        </small>
                    </div>
                    <div class="form-group">
                        <label><%= tr('superadmin:DONATIONS.MODAL.AMOUNT') %> <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" name="amount" required 
                               min="0.01" step="0.01" placeholder="10.00">
                    </div>
                    <div class="form-group">
                        <label><%= tr('superadmin:DONATIONS.MODAL.PAYMENT_TYPE') %></label>
                        <select class="form-control" name="payment_provider">
                            <option value="manual"><%= tr('superadmin:DONATIONS.PROVIDERS.MANUAL') %></option>
                            <option value="bank_transfer"><%= tr('superadmin:DONATIONS.PROVIDERS.BANK_TRANSFER') %></option>
                            <option value="cash"><%= tr('superadmin:DONATIONS.PROVIDERS.CASH') %></option>
                            <option value="other"><%= tr('superadmin:DONATIONS.PROVIDERS.OTHER') %></option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label><%= tr('superadmin:DONATIONS.MODAL.NOTE') %></label>
                        <textarea class="form-control" name="note" rows="3" 
                                  placeholder="<%= tr('superadmin:DONATIONS.MODAL.NOTE_PLACEHOLDER') %>"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= tr('superadmin:DONATIONS.MODAL.CANCEL') %></button>
                    <button type="submit" class="btn btn-success"><%= tr('superadmin:DONATIONS.MODAL.CREATE') %></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// DataTable initialisieren
$(document).ready(function() {
    $('#donationsTable').DataTable({
        order: [[0, 'desc']],
        pageLength: 25,
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/de-DE.json'
        }
    });
});

// Manuelle Donation erstellen
document.getElementById('createDonationForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    try {
        const response = await fetch('/guild/<%= guildId %>/plugins/superadmin/donations/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            toastr.success(result.message);
            $('#createDonationModal').modal('hide');
            setTimeout(() => window.location.reload(), 1500);
        } else {
            toastr.error(result.message);
        }
    } catch (error) {
        console.error('Error creating donation:', error);
        toastr.error('Fehler beim Erstellen der Donation');
    }
});

// Donation erstatten
async function refundDonation(donationId) {
    const confirmMessage = '<%= tr("superadmin:DONATIONS.ACTIONS.REFUND_CONFIRM").replace(/\\n/g, "\\n") %>';
    if (!confirm(confirmMessage)) {
        return;
    }
    
    try {
        const response = await fetch(`/guild/<%= guildId %>/plugins/superadmin/donations/${donationId}`, {
            method: 'DELETE'
        });
        
        const result = await response.json();
        
        if (result.success) {
            toastr.success(result.message);
            setTimeout(() => window.location.reload(), 1500);
        } else {
            toastr.error(result.message);
        }
    } catch (error) {
        console.error('Error refunding donation:', error);
        toastr.error('Fehler beim Erstatten der Donation');
    }
}
</script>
