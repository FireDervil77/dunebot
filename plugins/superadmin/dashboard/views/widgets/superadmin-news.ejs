<!-- SuperAdmin News Verwaltung Widget -->
<div class="list-group list-group-flush">
  <% if (newsList && newsList.length > 0) { %>
    <% newsList.forEach(news => { %>
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <h6 class="mb-0"><%= news.title %></h6>
          <small class="text-muted">
            <i class="fas fa-calendar"></i> <%= new Date(news.date).toLocaleDateString('de-DE') %>
            <span class="badge badge-<%= news.status === 'published' ? 'success' : 'warning' %> ml-2">
              <%= news.status %>
            </span>
          </small>
        </div>
        <div>
          <button class="btn btn-sm btn-primary" onclick="editNews(<%= news._id %>)">
            <i class="fas fa-edit"></i>
          </button>
          <button class="btn btn-sm btn-danger" onclick="deleteNews(<%= news._id %>)">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="list-group-item text-center text-muted">
      <i class="fas fa-inbox fa-2x mb-2"></i>
      <p>Keine News vorhanden</p>
    </div>
  <% } %>
</div>

<div class="card-footer text-center">
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newsModal" onclick="createNews()">
    <i class="fas fa-plus"></i> Neue News erstellen
  </button>
</div>

<!-- News Modal -->
<div class="modal fade" id="newsModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="newsModalTitle">News bearbeiten</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="newsForm">
          <input type="hidden" id="news_id" name="_id">
          
          <div class="mb-3">
            <label for="news_title" class="form-label">Titel</label>
            <input type="text" class="form-control" id="news_title" name="title" required>
          </div>
          
          <div class="mb-3">
            <label for="news_slug" class="form-label">Slug</label>
            <input type="text" class="form-control" id="news_slug" name="slug" required>
          </div>
          
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="news_author" class="form-label">Autor</label>
                <input type="text" class="form-control" id="news_author" name="author" required>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label for="news_date" class="form-label">Datum</label>
                <input type="date" class="form-control" id="news_date" name="date" required>
              </div>
            </div>
          </div>
          
          <div class="mb-3">
            <label for="news_excerpt" class="form-label">Kurzbeschreibung</label>
            <textarea class="form-control" id="news_excerpt" name="excerpt" rows="2"></textarea>
          </div>
          
          <div class="mb-3">
            <label for="news_text" class="form-label">Inhalt</label>
            <textarea class="form-control" id="news_text" name="news_text" rows="5"></textarea>
          </div>
          
          <div class="mb-3">
            <label for="news_image" class="form-label">Bild-URL</label>
            <input type="url" class="form-control" id="news_image" name="image_url">
          </div>
          
          <div class="mb-3">
            <label for="news_status" class="form-label">Status</label>
            <select class="form-select" id="news_status" name="status">
              <option value="draft">Entwurf</option>
              <option value="published">Veröffentlicht</option>
            </select>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
        <button type="button" class="btn btn-primary" onclick="saveNews()">Speichern</button>
      </div>
    </div>
  </div>
</div>

<script>
function createNews() {
  document.getElementById('newsForm').reset();
  document.getElementById('newsModalTitle').textContent = 'Neue News erstellen';
  document.getElementById('news_date').valueAsDate = new Date();
}

async function editNews(id) {
  // Load news data via API and fill form
  const response = await fetch(`/api/guild/<%= guildId %>/plugins/superadmin/news/${id}`);
  const news = await response.json();
  
  document.getElementById('news_id').value = news._id;
  document.getElementById('news_title').value = news.title;
  document.getElementById('news_slug').value = news.slug;
  document.getElementById('news_author').value = news.author;
  document.getElementById('news_date').value = news.date.split('T')[0];
  document.getElementById('news_excerpt').value = news.excerpt;
  document.getElementById('news_text').value = news.news_text;
  document.getElementById('news_image').value = news.image_url;
  document.getElementById('news_status').value = news.status;
  
  document.getElementById('newsModalTitle').textContent = 'News bearbeiten';
  new bootstrap.Modal(document.getElementById('newsModal')).show();
}

async function saveNews() {
  const formData = new FormData(document.getElementById('newsForm'));
  const data = Object.fromEntries(formData.entries());
  
  const response = await fetch(`/api/guild/<%= guildId %>/plugins/superadmin/news/save`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  
  if (response.ok) {
    location.reload();
  } else {
    alert('Fehler beim Speichern!');
  }
}

async function deleteNews(id) {
  if (!confirm('News wirklich löschen?')) return;
  
  const response = await fetch(`/api/guild/<%= guildId %>/plugins/superadmin/news/delete/${id}`, {
    method: 'POST'
  });
  
  if (response.ok) {
    location.reload();
  }
}
</script>
