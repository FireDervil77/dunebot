<!-- Template Plugin Statistik-Widget -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fa-solid fa-chart-bar me-2"></i>
            <%= tr('template:WIDGETS.STATS_TITLE') %>
        </h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-6 text-center">
                <div class="mb-3">
                    <h5 class="text-muted"><%= tr('template:STATS.TOTAL_USES') %></h5>
                    <h2 class="text-primary"><%= stats?.total_uses || 0 %></h2>
                </div>
            </div>
            <div class="col-6 text-center">
                <div class="mb-3">
                    <h5 class="text-muted"><%= tr('template:STATS.ACTIVE_USERS') %></h5>
                    <h2 class="text-success"><%= stats?.active_users || 0 %></h2>
                </div>
            </div>
        </div>
        
        <% if (stats?.last_used) { %>
        <div class="mt-3">
            <small class="text-muted">
                <%= tr('template:STATS.LAST_USED') %>: 
                <%= new Date(stats.last_used).toLocaleString() %>
            </small>
        </div>
        <% } else { %>
        <div class="mt-3 text-center">
            <small class="text-muted"><%= tr('template:STATS.NO_DATA') %></small>
        </div>
        <% } %>
    </div>
    <div class="card-footer text-center">
        <a href="/guild/<%= guildId %>/template" class="btn btn-sm btn-outline-primary">
            Details anzeigen
        </a>
    </div>
</div>
