        <form 
          class="guild-ajax-form" 
          data-form-type="automod-settings" 
          data-method="PUT"
          action="/guild/<%= guildId %>/plugins/automod/settings"
          method="POST"
        >
          
          <!-- Tab Content -->
          <div class="tab-content" id="automodTabsContent">
            
            <!-- ==================== TAB 1: GRUNDEINSTELLUNGEN ==================== -->
            <div class="tab-pane fade show active" id="tab-basic" role="tabpanel" aria-labelledby="tab-basic-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-cog me-2 text-primary"></i>
                <%= tr('automod:TABS.BASIC.SUBTITLE') %>
              </h5>

              <!-- Log Channel -->
          <div class="mb-4">
            <label for="log_channel" class="form-label fw-bold">
              <i class="fa-solid fa-list-ul me-2"></i>
              <%= tr('automod:SETTINGS.LOG_CHANNEL.LABEL') %>
            </label>
            
            <% if (guildChannels && guildChannels.length > 0) { %>
              <select class="form-select" id="log_channel" name="log_channel">
                <option value=""><%= tr('automod:SETTINGS.LOG_CHANNEL.NO_SELECTION') %></option>
                <% 
                  let currentCategory = null;
                  const selectedChannelId = String(settings.log_channel || '');
                  
                  guildChannels.forEach(channel => { 
                    if (channel.parentName && channel.parentName !== currentCategory) {
                      currentCategory = channel.parentName;
                %>
                  <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                <%  } 
                    const isSelected = selectedChannelId === String(channel.id);
                %>
                  <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                    <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                  </option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" class="form-control" id="log_channel" name="log_channel" 
                     value="<%= settings.log_channel || '' %>" 
                     placeholder="Channel-ID eingeben">
            <% } %>
            <small class="text-muted"><%= tr('automod:SETTINGS.LOG_CHANNEL.HELP') %></small>
          </div>

          <!-- Max Strikes -->
          <div class="mb-4">
            <label for="max_strikes" class="form-label fw-bold">
              <i class="fa-solid fa-exclamation-triangle me-2"></i>
              <%= tr('automod:SETTINGS.MAX_STRIKES.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_strikes" name="max_strikes" 
                   value="<%= settings.max_strikes || 10 %>" min="1" max="100" required>
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_STRIKES.HELP') %></small>
          </div>

          <!-- Action on Max Strikes -->
          <div class="mb-4">
            <label for="action" class="form-label fw-bold">
              <i class="fa-solid fa-gavel me-2"></i>
              <%= tr('automod:SETTINGS.ACTION.LABEL') %>
            </label>
            <select class="form-select" id="action" name="action" required>
              <option value="TIMEOUT" <%= settings.action === 'TIMEOUT' ? 'selected' : '' %>>
                ⏱️ <%= tr('automod:SETTINGS.ACTION.TIMEOUT') %> (24h)
              </option>
              <option value="KICK" <%= settings.action === 'KICK' ? 'selected' : '' %>>
                👢 <%= tr('automod:SETTINGS.ACTION.KICK') %>
              </option>
              <option value="BAN" <%= settings.action === 'BAN' ? 'selected' : '' %>>
                🔨 <%= tr('automod:SETTINGS.ACTION.BAN') %>
              </option>
            </select>
            <small class="text-muted"><%= tr('automod:SETTINGS.ACTION.HELP') %></small>
          </div>

          <!-- Debug Mode -->
          <div class="mb-4">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="debug_mode" name="debug_mode" 
                     value="1" <%= settings.debug_mode ? 'checked' : '' %>>
              <label class="form-check-label fw-bold" for="debug_mode">
                <i class="fa-solid fa-bug me-2"></i>
                <%= tr('automod:SETTINGS.DEBUG_MODE.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.DEBUG_MODE.HELP') %></small>
          </div>

          <!-- DM Nachrichtenvorlage -->
          <div class="mb-4">
            <label class="form-label fw-bold">
              <i class="fa-solid fa-pen-to-square me-2"></i>
              DM Nachrichtenvorlage
            </label>
            <p class="text-muted small mb-2">Anpassbare DM-Nachricht an den User bei Strikes. Leer lassen für Standardtext.</p>
            <textarea class="form-control" id="dm_message" name="dm_message" rows="3" placeholder="Du hast auf {guild:name} einen Strike erhalten. Strikes: {strikes}/{max_strikes}"><%= settings.dm_message || '' %></textarea>
            <small class="form-text text-muted">
              Platzhalter:
              <code class="badge badge-light border" style="font-size: 0.75em;">{member:name}</code>
              <code class="badge badge-light border" style="font-size: 0.75em;">{guild:name}</code>
              <code class="badge badge-light border" style="font-size: 0.75em;">{strikes}</code>
              <code class="badge badge-light border" style="font-size: 0.75em;">{total_strikes}</code>
              <code class="badge badge-light border" style="font-size: 0.75em;">{max_strikes}</code>
            </small>
          </div>
            </div>
            <!-- END TAB 1 -->

            <!-- ==================== TAB 2: CONTENT-FILTER ==================== -->
            <div class="tab-pane fade" id="tab-content" role="tabpanel" aria-labelledby="tab-content-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-shield-halved me-2 text-primary"></i>
                <%= tr('automod:TABS.CONTENT.SUBTITLE') %>
              </h5>

          <!-- Anti Ghost Ping -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_ghostping" name="anti_ghostping" 
                     value="1" <%= settings.anti_ghostping ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_ghostping">
                👻 <%= tr('automod:SETTINGS.ANTI_GHOSTPING.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_GHOSTPING.HELP') %></small>
          </div>

          <!-- Anti Spam -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_spam" name="anti_spam" 
                     value="1" <%= settings.anti_spam ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_spam">
                🚫 <%= tr('automod:SETTINGS.ANTI_SPAM.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_SPAM.HELP') %></small>
          </div>

          <!-- Anti Mass Mention -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_massmention" name="anti_massmention" 
                     value="1" <%= settings.anti_massmention ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_massmention">
                @️ <%= tr('automod:SETTINGS.ANTI_MASSMENTION.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_MASSMENTION.HELP') %></small>
          </div>

          <!-- Mass Mention Threshold -->
          <div class="mb-4 ms-4">
            <label for="anti_massmention_threshold" class="form-label">
              <%= tr('automod:SETTINGS.ANTI_MASSMENTION_THRESHOLD.LABEL') %>
            </label>
            <input type="number" class="form-control" id="anti_massmention_threshold" 
                   name="anti_massmention_threshold" 
                   value="<%= settings.anti_massmention_threshold || 3 %>" 
                   min="1" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_MASSMENTION_THRESHOLD.HELP') %></small>
          </div>

          <!-- Anti Attachments -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_attachments" name="anti_attachments" 
                     value="1" <%= settings.anti_attachments ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_attachments">
                📎 <%= tr('automod:SETTINGS.ANTI_ATTACHMENTS.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_ATTACHMENTS.HELP') %></small>
          </div>

          <!-- Anti Invites -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_invites" name="anti_invites" 
                     value="1" <%= settings.anti_invites ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_invites">
                🔗 <%= tr('automod:SETTINGS.ANTI_INVITES.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_INVITES.HELP') %></small>
          </div>

          <!-- Anti Links -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_links" name="anti_links" 
                     value="1" <%= settings.anti_links ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_links">
                🌐 <%= tr('automod:SETTINGS.ANTI_LINKS.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_LINKS.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 2 -->

            <!-- ==================== TAB 3: LIMITS ==================== -->
            <div class="tab-pane fade" id="tab-limits" role="tabpanel" aria-labelledby="tab-limits-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-sliders me-2 text-primary"></i>
                <%= tr('automod:TABS.LIMITS.SUBTITLE') %>
              </h5>

          <!-- Max Lines -->
          <div class="mb-4">
            <label for="max_lines" class="form-label fw-bold">
              <i class="fa-solid fa-align-left me-2"></i>
              <%= tr('automod:SETTINGS.MAX_LINES.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_lines" name="max_lines" 
                   value="<%= settings.max_lines || 0 %>" min="0" max="100">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_LINES.HELP') %></small>
          </div>

          <!-- Max Mentions -->
          <div class="mb-4">
            <label for="max_mentions" class="form-label fw-bold">
              <i class="fa-solid fa-at me-2"></i>
              <%= tr('automod:SETTINGS.MAX_MENTIONS.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_mentions" name="max_mentions" 
                   value="<%= settings.max_mentions || 0 %>" min="0" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_MENTIONS.HELP') %></small>
          </div>

          <!-- Max Role Mentions -->
          <div class="mb-4">
            <label for="max_role_mentions" class="form-label fw-bold">
              <i class="fa-solid fa-user-tag me-2"></i>
              <%= tr('automod:SETTINGS.MAX_ROLE_MENTIONS.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_role_mentions" name="max_role_mentions" 
                   value="<%= settings.max_role_mentions || 0 %>" min="0" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_ROLE_MENTIONS.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 3 -->

            <!-- ==================== TAB 4: WHITELISTING ==================== -->
            <div class="tab-pane fade" id="tab-whitelist" role="tabpanel" aria-labelledby="tab-whitelist-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-user-check me-2 text-primary"></i>
                <%= tr('automod:TABS.WHITELIST.SUBTITLE') %>
              </h5>

              <!-- Whitelisted Channels (Existing Feature) -->
              <div class="mb-4">
                <label class="form-label fw-bold">
                  <i class="fa-solid fa-hashtag me-2"></i>
                  <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.LABEL') %>
                </label>
                
                <% if (guildChannels && guildChannels.length > 0) { %>
                  <select class="form-select" id="whitelisted_channels" name="whitelisted_channels" multiple size="8">
                    <% 
                      let currentCategory = null;
                      const whitelistedChannelIds = settings.whitelisted_channels 
                        ? (Array.isArray(settings.whitelisted_channels) 
                            ? settings.whitelisted_channels.map(id => String(id))
                            : JSON.parse(settings.whitelisted_channels || '[]').map(id => String(id)))
                        : [];
                      
                      guildChannels.forEach(channel => { 
                        if (channel.parentName && channel.parentName !== currentCategory) {
                          currentCategory = channel.parentName;
                    %>
                      <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                    <%  } 
                        const isSelected = whitelistedChannelIds.includes(String(channel.id));
                    %>
                      <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                        <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                      </option>
                    <% }); %>
                  </select>
                  <small class="text-muted">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.HELP') %>
                  </small>
                <% } else { %>
                  <div class="alert alert-warning">
                    <i class="fa-solid fa-exclamation-triangle me-2"></i>
                    <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.NO_CHANNELS') %>
                  </div>
                <% } %>
              </div>

              <!-- Exemptions: Rollen -->
              <div class="mb-4">
                <label class="form-label fw-bold">
                  <i class="fa-solid fa-user-shield me-2"></i>
                  Ausgenommene Rollen
                </label>
                <p class="text-muted small">Mitglieder mit diesen Rollen werden vom AutoMod ignoriert.</p>
                
                <div id="exemptions-roles-list" class="mb-2">
                  <% const roleExemptions = (exemptions || []).filter(e => e.type === 'role'); %>
                  <% if (roleExemptions.length === 0) { %>
                    <p class="text-muted small" id="no-role-exemptions">Keine Rollen-Exemptions konfiguriert.</p>
                  <% } else { %>
                    <% roleExemptions.forEach(ex => { 
                        const role = (guildRoles || []).find(r => String(r.id) === String(ex.target_id));
                    %>
                      <span class="badge bg-secondary me-1 mb-1" data-exemption-id="<%= ex.id %>">
                        <i class="fa-solid fa-user-tag me-1"></i>
                        <%= role ? role.name : ex.target_id %>
                        <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;" 
                                onclick="deleteExemption(<%= ex.id %>)"></button>
                      </span>
                    <% }); %>
                  <% } %>
                </div>
                
                <div class="input-group">
                  <select class="form-select" id="add-role-exemption">
                    <option value="">Rolle auswählen...</option>
                    <% (guildRoles || []).forEach(role => { %>
                      <option value="<%= role.id %>"><%= role.name %></option>
                    <% }); %>
                  </select>
                  <button type="button" class="btn btn-outline-success" onclick="addExemption('role', document.getElementById('add-role-exemption').value)">
                    <i class="fa-solid fa-plus"></i>
                  </button>
                </div>
              </div>

              <!-- Exemptions: Channels -->
              <div class="mb-4">
                <label class="form-label fw-bold">
                  <i class="fa-solid fa-hashtag me-2"></i>
                  Ausgenommene Channels
                </label>
                <p class="text-muted small">Diese Channels werden vom AutoMod komplett ignoriert (zusätzlich zur Whitelist oben).</p>
                
                <div id="exemptions-channels-list" class="mb-2">
                  <% const channelExemptions = (exemptions || []).filter(e => e.type === 'channel'); %>
                  <% if (channelExemptions.length === 0) { %>
                    <p class="text-muted small" id="no-channel-exemptions">Keine Channel-Exemptions konfiguriert.</p>
                  <% } else { %>
                    <% channelExemptions.forEach(ex => { 
                        const ch = (guildChannels || []).find(c => String(c.id) === String(ex.target_id));
                    %>
                      <span class="badge bg-info me-1 mb-1" data-exemption-id="<%= ex.id %>">
                        <i class="fa-solid fa-hashtag me-1"></i>
                        <%= ch ? ch.name : ex.target_id %>
                        <button type="button" class="btn-close btn-close-white ms-1" style="font-size: 0.6rem;" 
                                onclick="deleteExemption(<%= ex.id %>)"></button>
                      </span>
                    <% }); %>
                  <% } %>
                </div>
                
                <div class="input-group">
                  <select class="form-select" id="add-channel-exemption">
                    <option value="">Channel auswählen...</option>
                    <% (guildChannels || []).forEach(channel => { %>
                      <option value="<%= channel.id %>">#<%= channel.name %></option>
                    <% }); %>
                  </select>
                  <button type="button" class="btn btn-outline-success" onclick="addExemption('channel', document.getElementById('add-channel-exemption').value)">
                    <i class="fa-solid fa-plus"></i>
                  </button>
                </div>
              </div>
            </div>
            <!-- END TAB 4 -->

            <!-- ==================== TAB 5: RAID-SCHUTZ ==================== -->
            <div class="tab-pane fade" id="tab-raid" role="tabpanel" aria-labelledby="tab-raid-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-shield-virus me-2 text-danger"></i>
                <%= tr('automod:TABS.RAID.SUBTITLE') %>
              </h5>

              <!-- Raid Protection aktivieren -->
              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_protection_enabled" name="raid_protection_enabled" 
                         value="1" <%= settings.raid_protection_enabled ? 'checked' : '' %>>
                  <label class="form-check-label fw-bold" for="raid_protection_enabled">
                    <i class="fa-solid fa-shield-halved me-2"></i>
                    Raid-Schutz aktivieren
                  </label>
                </div>
                <small class="text-muted">Schützt vor massiven Join-Angriffen und jungen Accounts</small>
              </div>

              <hr class="my-4">

              <!-- Join-Spam Detection -->
              <h6 class="mb-3">
                <i class="fa-solid fa-users me-2"></i>
                Join-Spam Detection
              </h6>

              <div class="row mb-4">
                <div class="col-md-6">
                  <label for="raid_join_threshold" class="form-label fw-bold">
                    <i class="fa-solid fa-hashtag me-2"></i>
                    Max. Joins
                  </label>
                  <input type="number" class="form-control" id="raid_join_threshold" name="raid_join_threshold" 
                         value="<%= settings.raid_join_threshold || 5 %>" min="2" max="50">
                  <small class="text-muted">Anzahl User die in X Sekunden joinen dürfen</small>
                </div>

                <div class="col-md-6">
                  <label for="raid_join_timespan" class="form-label fw-bold">
                    <i class="fa-solid fa-clock me-2"></i>
                    Zeitfenster (Sekunden)
                  </label>
                  <input type="number" class="form-control" id="raid_join_timespan" name="raid_join_timespan" 
                         value="<%= settings.raid_join_timespan || 10 %>" min="5" max="60">
                  <small class="text-muted">Zeitspanne für Raid-Erkennung</small>
                </div>
              </div>

              <!-- Account-Age Filter -->
              <div class="mb-4">
                <label for="raid_min_account_age_days" class="form-label fw-bold">
                  <i class="fa-solid fa-calendar-check me-2"></i>
                  Min. Account-Alter (Tage)
                </label>
                <input type="number" class="form-control" id="raid_min_account_age_days" name="raid_min_account_age_days" 
                       value="<%= settings.raid_min_account_age_days || 7 %>" min="0" max="365">
                <small class="text-muted">User mit jüngerem Account werden gekickt (0 = deaktiviert)</small>
              </div>

              <hr class="my-4">

              <!-- Actions & Lockdown -->
              <h6 class="mb-3">
                <i class="fa-solid fa-gavel me-2"></i>
                Aktionen bei Raid
              </h6>

              <div class="mb-4">
                <label for="raid_action" class="form-label fw-bold">
                  <i class="fa-solid fa-bolt me-2"></i>
                  Standard-Aktion
                </label>
                <select class="form-select" id="raid_action" name="raid_action">
                  <option value="KICK" <%= settings.raid_action === 'KICK' ? 'selected' : '' %>>
                    👢 Kick (Automatisch)
                  </option>
                  <option value="BAN" <%= settings.raid_action === 'BAN' ? 'selected' : '' %>>
                    🔨 Ban (Manuell empfohlen)
                  </option>
                </select>
                <small class="text-muted">Kick wird automatisch ausgeführt, Ban ist für manuelle Nachbearbeitung gedacht</small>
              </div>

              <!-- Lockdown -->
              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_lockdown_enabled" name="raid_lockdown_enabled" 
                         value="1" <%= settings.raid_lockdown_enabled ? 'checked' : '' %>>
                  <label class="form-check-label fw-bold" for="raid_lockdown_enabled">
                    <i class="fa-solid fa-lock me-2"></i>
                    Lockdown bei Raid aktivieren
                  </label>
                </div>
                <small class="text-muted">Sperrt Server automatisch (Verification HIGH + @everyone Permissions entfernt)</small>
                
                <% if (settings.raid_lockdown_active) { %>
                  <div class="alert alert-danger mt-3 mb-0">
                    <div class="d-flex align-items-center">
                      <i class="fa-solid fa-lock fs-3 me-3"></i>
                      <div>
                        <strong>🔒 LOCKDOWN AKTIV!</strong><br>
                        <small>Der Server ist derzeit gesperrt. Nutze <code>/automod unlock</code> oder das Dashboard um den Lockdown zu deaktivieren.</small>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>

              <hr class="my-4">

              <!-- Alert-Benachrichtigungen -->
              <h6 class="mb-3">
                <i class="fa-solid fa-bell me-2"></i>
                Benachrichtigungen
              </h6>

              <div class="mb-4">
                <label for="raid_alert_channel" class="form-label fw-bold">
                  <i class="fa-solid fa-bullhorn me-2"></i>
                  Raid-Alert Channel
                </label>
                
                <% if (guildChannels && guildChannels.length > 0) { %>
                  <select class="form-select" id="raid_alert_channel" name="raid_alert_channel">
                    <option value="">Kein Channel ausgewählt</option>
                    <% 
                      let currentCategory = null;
                      const selectedChannelId = String(settings.raid_alert_channel || '');
                      
                      guildChannels.forEach(channel => { 
                        if (channel.parentName && channel.parentName !== currentCategory) {
                          currentCategory = channel.parentName;
                    %>
                      <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                    <%  } 
                        const isSelected = selectedChannelId === String(channel.id);
                    %>
                      <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                        <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                      </option>
                    <% }); %>
                  </select>
                <% } else { %>
                  <input type="text" class="form-control" id="raid_alert_channel" name="raid_alert_channel" 
                         value="<%= settings.raid_alert_channel || '' %>" 
                         placeholder="Channel-ID eingeben">
                <% } %>
                <small class="text-muted">Channel für Raid-Warnungen</small>
              </div>

              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_alert_mention_mods" name="raid_alert_mention_mods" 
                         value="1" <%= settings.raid_alert_mention_mods ? 'checked' : '' %>>
                  <label class="form-check-label" for="raid_alert_mention_mods">
                    <i class="fa-solid fa-at me-2"></i>
                    @Mods bei Raid erwähnen
                  </label>
                </div>
                <small class="text-muted">Erwähnt Moderator-Rollen im Alert-Channel</small>
              </div>

              <hr class="my-4">

              <!-- Trusted Invites -->
              <h6 class="mb-3">
                <i class="fa-solid fa-user-check me-2"></i>
                Trusted Invite-Links
              </h6>

              <div class="mb-4">
                <label for="raid_trusted_invites" class="form-label fw-bold">
                  <i class="fa-solid fa-link me-2"></i>
                  Whitelist von Invite-Codes
                </label>
                <textarea class="form-control" id="raid_trusted_invites" name="raid_trusted_invites" rows="4" 
                          placeholder="discord.gg/ABC123&#10;discord.gg/XYZ789&#10;(Ein Code pro Zeile)"><%= (settings.raid_trusted_invites || []).join('\n') %></textarea>
                <small class="text-muted">
                  <i class="fa-solid fa-info-circle me-1"></i>
                  User die über diese Invites joinen werden NICHT vom Raid-Check erfasst. Nur die Codes eingeben (z.B. <code>ABC123</code>), nicht die komplette URL.
                </small>
              </div>

              <!-- Info-Box -->
              <div class="alert alert-info">
                <div class="d-flex align-items-start">
                  <i class="fa-solid fa-lightbulb fs-3 me-3 mt-1"></i>
                  <div>
                    <strong>💡 Tipp:</strong><br>
                    <ul class="mb-0 ps-3">
                      <li>Trusted Invites sind ideal für Partner-Server oder offizielle Einladungen</li>
                      <li>Lockdown muss <strong>manuell</strong> deaktiviert werden (Sicherheit!)</li>
                      <li>Teste die Settings mit <code>debug_mode</code> im Basic-Tab</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <!-- END TAB 5 -->

            <!-- ==================== TAB 6: KEYWORD-LISTEN ==================== -->
            <div class="tab-pane fade" id="tab-keywords" role="tabpanel" aria-labelledby="tab-keywords-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-filter me-2 text-primary"></i>
                Keyword-Listen
              </h5>

              <p class="text-muted mb-4">
                Aktiviere vordefinierte Wortlisten um unerwünschte Inhalte automatisch zu filtern. 
                Nachrichten die Keywords enthalten werden gelöscht und es gibt einen Strike.
              </p>

              <% if (keywordLists && keywordLists.length > 0) { %>
                <div class="row">
                  <% keywordLists.forEach(list => { 
                      const isActive = (activeKeywordLists || []).includes(list.id);
                  %>
                    <div class="col-md-6 mb-3">
                      <div class="card <%= isActive ? 'border-success' : 'border-secondary' %>">
                        <div class="card-body">
                          <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" 
                                   id="kwl_<%= list.id %>" name="active_keyword_lists" 
                                   value="<%= list.id %>" <%= isActive ? 'checked' : '' %>>
                            <label class="form-check-label fw-bold" for="kwl_<%= list.id %>">
                              <%= list.name %>
                            </label>
                          </div>
                          <p class="small text-muted mb-1"><%= list.description %></p>
                          <div class="d-flex justify-content-between">
                            <span class="badge bg-secondary">
                              <i class="fa-solid fa-globe me-1"></i><%= list.language %>
                            </span>
                            <span class="badge bg-info">
                              <i class="fa-solid fa-list me-1"></i><%= list.count %> Keywords
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="alert alert-warning">
                  <i class="fa-solid fa-exclamation-triangle me-2"></i>
                  Keine Keyword-Listen verfügbar. Stelle sicher, dass die JSON-Dateien im Bot-Verzeichnis vorhanden sind.
                </div>
              <% } %>

              <div class="alert alert-info mt-3">
                <i class="fa-solid fa-info-circle me-2"></i>
                Keywords werden case-insensitive geprüft. Admin kann eigene Listen als JSON-Dateien hinzufügen.
              </div>
            </div>
            <!-- END TAB 6 -->

            <!-- ==================== TAB 7: REGEX-REGELN ==================== -->
            <div class="tab-pane fade" id="tab-regex" role="tabpanel" aria-labelledby="tab-regex-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-code me-2 text-primary"></i>
                Benutzerdefinierte Regex-Regeln
              </h5>

              <p class="text-muted mb-3">
                Erstelle eigene Regex-Filter für spezifische Muster. Patterns werden automatisch auf ReDoS-Sicherheit geprüft.
              </p>

              <!-- Neue Regel hinzufügen -->
              <div class="card mb-4">
                <div class="card-header bg-light">
                  <h6 class="mb-0"><i class="fa-solid fa-plus me-2"></i>Neue Regex-Regel</h6>
                </div>
                <div class="card-body">
                  <div class="row g-3">
                    <div class="col-md-4">
                      <label class="form-label">Name</label>
                      <input type="text" class="form-control" id="regex-new-name" placeholder="z.B. No Discord Tokens">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">Pattern (Regex)</label>
                      <input type="text" class="form-control font-monospace" id="regex-new-pattern" placeholder="z.B. [A-Za-z0-9]{24}\.[A-Za-z0-9]{6}\.">
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Aktion</label>
                      <select class="form-select" id="regex-new-action">
                        <option value="DELETE">Löschen</option>
                        <option value="WARN">Warnen</option>
                        <option value="STRIKE">Strike + Löschen</option>
                      </select>
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                      <button type="button" class="btn btn-success w-100" onclick="addRegexRule()">
                        <i class="fa-solid fa-plus"></i>
                      </button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Bestehende Regeln -->
              <div id="regex-rules-list">
                <% if (regexRules && regexRules.length > 0) { %>
                  <% regexRules.forEach(rule => { %>
                    <div class="card mb-2" id="regex-rule-<%= rule.id %>">
                      <div class="card-body d-flex align-items-center justify-content-between py-2">
                        <div class="d-flex align-items-center flex-grow-1">
                          <div class="form-check form-switch me-3">
                            <input class="form-check-input" type="checkbox" 
                                   <%= rule.enabled ? 'checked' : '' %>
                                   onchange="toggleRegexRule(<%= rule.id %>, this.checked)">
                          </div>
                          <div>
                            <strong><%= rule.name %></strong>
                            <br>
                            <code class="small"><%= rule.pattern %></code>
                          </div>
                        </div>
                        <div class="d-flex align-items-center">
                          <span class="badge bg-<%= rule.action === 'STRIKE' ? 'danger' : (rule.action === 'DELETE' ? 'warning' : 'info') %> me-2">
                            <%= rule.action %>
                          </span>
                          <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteRegexRule(<%= rule.id %>)">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <div class="alert alert-secondary" id="no-regex-rules">
                    <i class="fa-solid fa-info-circle me-2"></i>
                    Noch keine Regex-Regeln konfiguriert.
                  </div>
                <% } %>
              </div>
            </div>
            <!-- END TAB 7 -->

            <!-- ==================== TAB 8: ESKALATION ==================== -->
            <div class="tab-pane fade" id="tab-escalation" role="tabpanel" aria-labelledby="tab-escalation-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-stairs me-2 text-primary"></i>
                Eskalations-System
              </h5>

              <p class="text-muted mb-3">
                Definiere mehrstufige Bestrafungen basierend auf der Strike-Anzahl. 
                Wenn keine Stufen konfiguriert sind, wird die Standard-Aktion aus den Grundeinstellungen verwendet.
              </p>

              <!-- Default-Eskalation erstellen -->
              <div class="mb-4">
                <button type="button" class="btn btn-outline-primary" onclick="createDefaultEscalation()">
                  <i class="fa-solid fa-magic me-2"></i>
                  Standard-Eskalation erstellen (3→Timeout, 5→Kick, 8→Ban)
                </button>
              </div>

              <!-- Neue Stufe hinzufügen -->
              <div class="card mb-4">
                <div class="card-header bg-light">
                  <h6 class="mb-0"><i class="fa-solid fa-plus me-2"></i>Neue Eskalationsstufe</h6>
                </div>
                <div class="card-body">
                  <div class="row g-3">
                    <div class="col-md-3">
                      <label class="form-label">Strikes (Schwelle)</label>
                      <input type="number" class="form-control" id="esc-new-threshold" min="1" max="100" placeholder="z.B. 3">
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Aktion</label>
                      <select class="form-select" id="esc-new-action" onchange="toggleEscDuration()">
                        <option value="TIMEOUT">⏱️ Timeout</option>
                        <option value="KICK">👢 Kick</option>
                        <option value="BAN">🔨 Ban</option>
                      </select>
                    </div>
                    <div class="col-md-3" id="esc-duration-group">
                      <label class="form-label">Dauer (Minuten)</label>
                      <input type="number" class="form-control" id="esc-new-duration" min="1" max="40320" value="10" placeholder="Minuten">
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                      <button type="button" class="btn btn-success w-100" onclick="addEscalation()">
                        <i class="fa-solid fa-plus me-2"></i>Hinzufügen
                      </button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Bestehende Eskalationsstufen -->
              <div id="escalation-list">
                <% if (escalationConfig && escalationConfig.length > 0) { %>
                  <table class="table table-bordered">
                    <thead class="thead-light">
                      <tr>
                        <th>Strikes</th>
                        <th>Aktion</th>
                        <th>Dauer</th>
                        <th style="width: 80px;">Aktionen</th>
                      </tr>
                    </thead>
                    <tbody id="escalation-tbody">
                      <% escalationConfig.forEach(level => { %>
                        <tr id="esc-row-<%= level.id %>">
                          <td><strong><%= level.threshold %></strong> Strikes</td>
                          <td>
                            <span class="badge bg-<%= level.action === 'BAN' ? 'danger' : (level.action === 'KICK' ? 'warning' : 'info') %>">
                              <%= level.action === 'TIMEOUT' ? '⏱️' : (level.action === 'KICK' ? '👢' : '🔨') %> 
                              <%= level.action %>
                            </span>
                          </td>
                          <td><%= level.duration ? level.duration + ' Min.' : '-' %></td>
                          <td>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteEscalation(<%= level.id %>)">
                              <i class="fa-solid fa-trash"></i>
                            </button>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                <% } else { %>
                  <div class="alert alert-secondary" id="no-escalation">
                    <i class="fa-solid fa-info-circle me-2"></i>
                    Keine Eskalationsstufen konfiguriert. Es wird die Standard-Aktion aus den Grundeinstellungen verwendet.
                  </div>
                <% } %>
              </div>

              <div class="alert alert-info mt-3">
                <i class="fa-solid fa-lightbulb me-2"></i>
                <strong>Tipp:</strong> Die höchste Stufe deren Schwelle erreicht ist wird ausgeführt. 
                Beispiel: Bei 5 Strikes und Stufen [3→Timeout, 5→Kick] wird Kick ausgeführt.
              </div>
            </div>
            <!-- END TAB 8 -->

            <!-- ==================== TAB 9: KOMBINATIONS-REGELN ==================== -->
            <div class="tab-pane fade" id="tab-compound" role="tabpanel" aria-labelledby="tab-compound-btn">
              <h5 class="text-primary mb-2">
                <i class="fa-solid fa-diagram-project me-2"></i>
                <%= tr('automod:TABS.COMPOUND.TITLE') %>
              </h5>
              <p class="text-muted mb-4"><%= tr('automod:TABS.COMPOUND.SUBTITLE') %></p>

              <!-- Neue Compound-Regel erstellen -->
              <div class="card card-outline card-primary mb-4">
                <div class="card-header">
                  <h3 class="card-title"><i class="fa-solid fa-plus me-1"></i> <%= tr('automod:COMPOUND.ADD_TITLE') %></h3>
                </div>
                <div class="card-body">
                  <div class="row mb-3">
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('automod:COMPOUND.NAME') %></label>
                      <input type="text" id="compoundName" class="form-control" maxlength="100" placeholder="<%= tr('automod:COMPOUND.NAME_PLACEHOLDER') %>">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('automod:COMPOUND.LOGIC') %></label>
                      <select id="compoundLogic" class="form-control">
                        <option value="AND"><%= tr('automod:COMPOUND.LOGIC_AND') %></option>
                        <option value="OR"><%= tr('automod:COMPOUND.LOGIC_OR') %></option>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('automod:COMPOUND.ACTION') %></label>
                      <select id="compoundAction" class="form-control">
                        <option value="DELETE">DELETE</option>
                        <option value="WARN">WARN</option>
                        <option value="STRIKE" selected>STRIKE</option>
                        <option value="TIMEOUT">TIMEOUT</option>
                        <option value="KICK">KICK</option>
                        <option value="BAN">BAN</option>
                      </select>
                    </div>
                  </div>

                  <div class="row mb-3">
                    <div class="col-md-8">
                      <label class="form-label"><%= tr('automod:COMPOUND.DESCRIPTION') %></label>
                      <input type="text" id="compoundDesc" class="form-control" maxlength="500" placeholder="<%= tr('automod:COMPOUND.DESC_PLACEHOLDER') %>">
                    </div>
                    <div class="col-md-4" id="compoundDurationWrap" style="display:none;">
                      <label class="form-label"><%= tr('automod:COMPOUND.DURATION') %></label>
                      <input type="number" id="compoundDuration" class="form-control" min="1" max="40320" placeholder="Min.">
                    </div>
                  </div>

                  <!-- Bedingungen -->
                  <label class="form-label"><%= tr('automod:COMPOUND.CONDITIONS') %></label>
                  <div id="compoundConditions">
                    <!-- Dynamisch per JS -->
                  </div>
                  <button type="button" class="btn btn-outline-primary btn-sm mt-2" onclick="addCompoundCondition()">
                    <i class="fa-solid fa-plus me-1"></i> <%= tr('automod:COMPOUND.ADD_CONDITION') %>
                  </button>

                  <div class="mt-3">
                    <button type="button" class="btn btn-success" onclick="saveCompoundRule()">
                      <i class="fa-solid fa-save me-1"></i> <%= tr('automod:COMPOUND.BTN_SAVE') %>
                    </button>
                  </div>
                </div>
              </div>

              <!-- Bestehende Compound-Regeln -->
              <div id="compoundRulesList">
                <% if (compoundRules && compoundRules.length > 0) { %>
                  <% compoundRules.forEach(rule => { %>
                    <div class="card mb-2" id="compound-rule-<%= rule.id %>">
                      <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start">
                          <div class="flex-grow-1">
                            <h6 class="mb-1">
                              <i class="fa-solid fa-diagram-project text-primary me-1"></i>
                              <strong><%= rule.name %></strong>
                              <span class="badge bg-<%= rule.enabled ? 'success' : 'secondary' %> ml-2"><%= rule.enabled ? 'Aktiv' : 'Deaktiviert' %></span>
                              <span class="badge bg-info ml-1"><%= rule.logic %></span>
                              <span class="badge bg-warning ml-1"><%= rule.action %><%= rule.duration ? ' (' + rule.duration + 'min)' : '' %></span>
                            </h6>
                            <% if (rule.description) { %>
                              <p class="text-muted small mb-1"><%= rule.description %></p>
                            <% } %>
                            <div class="small">
                              <% rule.conditions.forEach((cond, i) => { %>
                                <span class="badge bg-light text-dark mr-1 mb-1">
                                  <%= cond.type %> <%= cond.operator %> <%= cond.value %>
                                </span>
                                <% if (i < rule.conditions.length - 1) { %>
                                  <span class="text-muted"><%= rule.logic %></span>
                                <% } %>
                              <% }); %>
                            </div>
                          </div>
                          <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-<%= rule.enabled ? 'warning' : 'success' %>" onclick="toggleCompoundRule(<%= rule.id %>, <%= !rule.enabled %>)" title="<%= rule.enabled ? 'Deaktivieren' : 'Aktivieren' %>">
                              <i class="fa-solid fa-<%= rule.enabled ? 'pause' : 'play' %>"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger" onclick="deleteCompoundRule(<%= rule.id %>)">
                              <i class="fa-solid fa-trash"></i>
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <div class="alert alert-info" id="noCompoundRulesMsg">
                    <i class="fa-solid fa-info-circle me-2"></i>
                    <%= tr('automod:COMPOUND.EMPTY') %>
                  </div>
                <% } %>
              </div>

              <div class="alert alert-info mt-3">
                <i class="fa-solid fa-lightbulb me-2"></i>
                <strong><%= tr('automod:COMPOUND.TIP_TITLE') %></strong> <%= tr('automod:COMPOUND.TIP_TEXT') %>
              </div>
            </div>
            <!-- END TAB 9 -->

          </div>
          <!-- END Tab Content -->

          <!-- Submit Button (Outside Tabs, always visible) -->
          <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="fa-solid fa-save me-2"></i>
              <%= tr('automod:SETTINGS.SAVE_BUTTON') %>
            </button>
          </div>

        </form>
        
        <!-- Checkbox Serialization Script -->
        <script>
        (function() {
            'use strict';
            
            // Form-Handler für AutoMod Settings
            const form = document.querySelector('form[data-form-type="automod-settings"]');
            if (!form) return;
            
            form.addEventListener('submit', function(e) {
                console.log('[AutoMod] Form submit intercepted for checkbox serialization');
                
                // Alle Checkboxen finden
                const checkboxes = form.querySelectorAll('input[type="checkbox"]');
                
                checkboxes.forEach(checkbox => {
                    // Für jede Checkbox: Setze explizit true/false
                    if (!checkbox.checked) {
                        // Erstelle Hidden-Input für unchecked Checkbox
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = checkbox.name;
                        hidden.value = '0'; // false
                        checkbox.parentNode.appendChild(hidden);
                        console.log(`[AutoMod] Added hidden input for unchecked: ${checkbox.name} = 0`);
                    } else {
                        console.log(`[AutoMod] Checkbox checked: ${checkbox.name} = 1`);
                    }
                });
                
                // Multi-Select Channels serialisieren
                const multiSelect = form.querySelector('select[multiple]');
                if (multiSelect) {
                    const selectedOptions = Array.from(multiSelect.selectedOptions).map(opt => opt.value);
                    console.log('[AutoMod] Whitelisted channels:', selectedOptions);
                    
                    // Entferne alte Inputs
                    form.querySelectorAll('input[name="whitelisted_channels"]').forEach(input => input.remove());
                    
                    // Füge jede ausgewählte Channel-ID als separates Input hinzu
                    selectedOptions.forEach(channelId => {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'whitelisted_channels';
                        hidden.value = channelId;
                        form.appendChild(hidden);
                    });
                    
                    // Deaktiviere Multi-Select (damit es nicht doppelt gesendet wird)
                    multiSelect.disabled = true;
                }

                // Keyword-Listen Checkboxen serialisieren
                const keywordChecks = form.querySelectorAll('input[name="active_keyword_lists"]:checked');
                const activeKwl = Array.from(keywordChecks).map(cb => cb.value);
                // Entferne alle keyword checkbox inputs und füge ein Hidden Input mit JSON ein
                form.querySelectorAll('input[name="active_keyword_lists"]').forEach(cb => {
                    cb.disabled = true; // Deaktivieren damit sie nicht gesendet werden
                });
                const kwlHidden = document.createElement('input');
                kwlHidden.type = 'hidden';
                kwlHidden.name = 'active_keyword_lists';
                kwlHidden.value = JSON.stringify(activeKwl);
                form.appendChild(kwlHidden);
                
                // Form fortfahren (guild.js übernimmt)
            });
        })();
        </script>

        <!-- AJAX Scripts für Exemptions, Regex Rules, Escalation -->
        <script>
        (function() {
            'use strict';
            const guildId = '<%= guildId %>';
            const baseUrl = `/guild/${guildId}/plugins/automod`;

            // Helper: AJAX Request
            function apiRequest(method, url, data) {
                return $.ajax({
                    url: baseUrl + url,
                    method: method,
                    contentType: 'application/json',
                    data: data ? JSON.stringify(data) : undefined
                });
            }

            // Helper: Toast
            function showToast(msg, type) {
                if (window.toastr) {
                    toastr[type || 'success'](msg);
                } else {
                    alert(msg);
                }
            }

            // ==================== EXEMPTIONS ====================
            window.addExemption = function(type, targetId) {
                if (!targetId) return showToast('Bitte eine Auswahl treffen.', 'warning');
                apiRequest('POST', '/exemptions', { type, target_id: targetId })
                    .done(() => { showToast('Exemption hinzugefügt!'); location.reload(); })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.deleteExemption = function(id) {
                if (!confirm('Exemption wirklich entfernen?')) return;
                apiRequest('DELETE', '/exemptions/' + id)
                    .done(() => { 
                        showToast('Exemption entfernt!'); 
                        $('[data-exemption-id="' + id + '"]').fadeOut(300, function() { $(this).remove(); });
                    })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            // ==================== REGEX RULES ====================
            window.addRegexRule = function() {
                const name = $('#regex-new-name').val().trim();
                const pattern = $('#regex-new-pattern').val().trim();
                const action = $('#regex-new-action').val();
                if (!name || !pattern) return showToast('Name und Pattern sind erforderlich.', 'warning');
                apiRequest('POST', '/regex-rules', { name, pattern, action })
                    .done(() => { showToast('Regex-Regel erstellt!'); location.reload(); })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.toggleRegexRule = function(id, enabled) {
                apiRequest('PUT', '/regex-rules/' + id, { enabled })
                    .done(() => showToast(enabled ? 'Regel aktiviert.' : 'Regel deaktiviert.'))
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.deleteRegexRule = function(id) {
                if (!confirm('Regex-Regel wirklich löschen?')) return;
                apiRequest('DELETE', '/regex-rules/' + id)
                    .done(() => { 
                        showToast('Regex-Regel gelöscht!'); 
                        $('#regex-rule-' + id).fadeOut(300, function() { $(this).remove(); });
                    })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            // ==================== ESCALATION ====================
            window.addEscalation = function() {
                const threshold = parseInt($('#esc-new-threshold').val());
                const action = $('#esc-new-action').val();
                const duration = parseInt($('#esc-new-duration').val()) || null;
                if (!threshold || threshold < 1) return showToast('Bitte einen gültigen Schwellenwert eingeben.', 'warning');
                apiRequest('POST', '/escalation', { threshold, action, duration: action === 'TIMEOUT' ? duration : null })
                    .done(() => { showToast('Eskalationsstufe hinzugefügt!'); location.reload(); })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.deleteEscalation = function(id) {
                if (!confirm('Eskalationsstufe wirklich löschen?')) return;
                apiRequest('DELETE', '/escalation/' + id)
                    .done(() => { 
                        showToast('Eskalationsstufe gelöscht!'); 
                        $('#esc-row-' + id).fadeOut(300, function() { $(this).remove(); });
                    })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.createDefaultEscalation = function() {
                if (!confirm('Standard-Eskalation erstellen? (Bestehende Stufen bleiben erhalten)')) return;
                apiRequest('POST', '/escalation/defaults')
                    .done(() => { showToast('Standard-Eskalation erstellt!'); location.reload(); })
                    .fail((xhr) => showToast(xhr.responseJSON?.message || 'Fehler', 'error'));
            };

            window.toggleEscDuration = function() {
                const action = $('#esc-new-action').val();
                if (action === 'TIMEOUT') {
                    $('#esc-duration-group').show();
                } else {
                    $('#esc-duration-group').hide();
                }
            };

            // ==================== COMPOUND RULES ====================
            const compoundBasePath = '/guild/<%= guildId %>/plugins/automod/compound-rules';
            const conditionTypes = <%- JSON.stringify(conditionTypes) %>;
            const guildRolesData = <%- JSON.stringify((guildRoles || []).map(r => ({id: r.id, name: r.name}))) %>;
            let conditionCounter = 0;

            // Action-Dropdown → Duration anzeigen
            $('#compoundAction').on('change', function() {
                $('#compoundDurationWrap').toggle($(this).val() === 'TIMEOUT');
            });

            window.addCompoundCondition = function() {
                conditionCounter++;
                const id = conditionCounter;
                const typeOptions = Object.entries(conditionTypes).map(([key, def]) =>
                    '<option value="' + key + '">' + def.label + '</option>'
                ).join('');

                const html = '<div class="row mb-2 align-items-center compound-condition" id="cond-' + id + '">' +
                    '<div class="col-md-4"><select class="form-control form-control-sm cond-type" data-id="' + id + '" onchange="updateConditionOperators(' + id + ')">' +
                    '<option value="">Bedingung wählen...</option>' + typeOptions + '</select></div>' +
                    '<div class="col-md-2"><select class="form-control form-control-sm cond-op" id="cond-op-' + id + '"><option value="">=</option></select></div>' +
                    '<div class="col-md-4"><input type="text" class="form-control form-control-sm cond-val" id="cond-val-' + id + '" placeholder="Wert"></div>' +
                    '<div class="col-md-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeCondition(' + id + ')"><i class="fa-solid fa-times"></i></button></div>' +
                    '</div>';
                $('#compoundConditions').append(html);
            };

            window.updateConditionOperators = function(id) {
                const type = $('#cond-' + id + ' .cond-type').val();
                const def = conditionTypes[type];
                const opSelect = $('#cond-op-' + id);
                opSelect.empty();

                if (def) {
                    def.operators.forEach(function(op) { opSelect.append('<option value="' + op + '">' + op + '</option>'); });
                    // Für boolean-Typen den Wert fest auf true setzen
                    if (def.valueType === 'boolean') {
                        $('#cond-val-' + id).val('true').prop('readonly', true);
                    } else if (def.valueType === 'role') {
                        const roleHtml = '<select class="form-control form-control-sm">' +
                            guildRolesData.map(function(r) { return '<option value="' + r.id + '">' + r.name + '</option>'; }).join('') +
                            '</select>';
                        $('#cond-val-' + id).replaceWith($(roleHtml).addClass('cond-val').attr('id', 'cond-val-' + id));
                    } else {
                        $('#cond-val-' + id).prop('readonly', false).attr('type', 'number');
                    }
                }
            };

            window.removeCondition = function(id) {
                $('#cond-' + id).remove();
            };

            window.saveCompoundRule = async function() {
                const name = $('#compoundName').val().trim();
                if (!name) return alert('Name erforderlich');

                const conditions = [];
                $('.compound-condition').each(function() {
                    const type = $(this).find('.cond-type').val();
                    const op = $(this).find('.cond-op').val();
                    const val = $(this).find('.cond-val').val();
                    if (type && op) {
                        conditions.push({ type: type, operator: op, value: val });
                    }
                });

                if (conditions.length === 0) return alert('Mindestens eine Bedingung erforderlich');

                const data = {
                    name: name,
                    description: $('#compoundDesc').val().trim() || null,
                    logic: $('#compoundLogic').val(),
                    action: $('#compoundAction').val(),
                    duration: $('#compoundAction').val() === 'TIMEOUT' ? parseInt($('#compoundDuration').val()) || null : null,
                    conditions: conditions
                };

                try {
                    const resp = await fetch(compoundBasePath, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await resp.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message || 'Fehler');
                    }
                } catch(e) {
                    console.error('[AutoMod] saveCompoundRule error:', e);
                }
            };

            window.toggleCompoundRule = async function(id, enabled) {
                try {
                    const resp = await fetch(compoundBasePath + '/' + id, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ enabled: enabled })
                    });
                    const result = await resp.json();
                    if (result.success) location.reload();
                } catch(e) {
                    console.error('[AutoMod] toggleCompoundRule error:', e);
                }
            };

            window.deleteCompoundRule = async function(id) {
                if (!confirm('Möchtest du diese Kombinations-Regel wirklich löschen?')) return;
                try {
                    const resp = await fetch(compoundBasePath + '/' + id, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await resp.json();
                    if (result.success) {
                        $('#compound-rule-' + id).remove();
                    }
                } catch(e) {
                    console.error('[AutoMod] deleteCompoundRule error:', e);
                }
            };

            // Initial eine leere Bedingung hinzufügen
            addCompoundCondition();
        })();
        </script>
      </div>
    </div>
  </div>

