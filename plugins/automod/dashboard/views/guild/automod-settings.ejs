            <i class="fa-solid fa-lightbulb text-warning me-3" style="font-size: 1.5rem;"></i>
            <div>
              <strong><%= tr('automod:SETTINGS.GUIDE.TIP.TITLE') %>:</strong>
              <%= tr('automod:SETTINGS.GUIDE.TIP.DESC') %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab-State JavaScript - Must be at the end after Bootstrap loads -->
<script>
(function() {
    'use strict';
    
    // Wait for DOM and Bootstrap to be ready
    function initTabs() {
        if (typeof bootstrap === 'undefined') {
            console.error('[AutoMod Tabs] Bootstrap not loaded yet! Retrying in 100ms...');
            setTimeout(initTabs, 100);
            return;
        }
        
        const tabButtons = document.querySelectorAll('#automodTabs button[data-bs-toggle="tab"]');
        const tabPanes = document.querySelectorAll('#automodTabsContent .tab-pane');
        const storageKey = 'automod_active_tab_<%= guildId %>';
        
        console.log('[AutoMod Tabs] Found', tabButtons.length, 'tab buttons');
        console.log('[AutoMod Tabs] Found', tabPanes.length, 'tab panes');
        
        if (tabButtons.length === 0) {
            console.error('[AutoMod Tabs] No tab buttons found!');
            return;
        }
        
        // Funktion zum Wechseln der Tabs
        function showTab(targetId, clickedButton) {
            console.log('[AutoMod Tabs] Switching to tab:', targetId);
            
            // Alle Tab-Buttons deaktivieren
            tabButtons.forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-selected', 'false');
            });
            
            // Alle Tab-Panes ausblenden
            tabPanes.forEach(pane => {
                pane.classList.remove('show', 'active');
            });
            
            // Angeklickten Button aktivieren
            if (clickedButton) {
                clickedButton.classList.add('active');
                clickedButton.setAttribute('aria-selected', 'true');
            }
            
            // Ziel-Pane anzeigen
            const targetPane = document.querySelector(targetId);
            if (targetPane) {
                targetPane.classList.add('show', 'active');
                console.log('[AutoMod Tabs] Tab switched successfully to:', targetId);
            } else {
                console.error('[AutoMod Tabs] Target pane not found:', targetId);
            }
            
            // In localStorage speichern
            localStorage.setItem(storageKey, targetId);
        }
        
        // Click-Handler für alle Tabs
        tabButtons.forEach(tabButton => {
            const targetId = tabButton.getAttribute('data-bs-target');
            console.log('[AutoMod Tabs] Attaching handler to:', targetId);
            
            tabButton.addEventListener('click', function(e) {
                e.preventDefault();
                console.log('[AutoMod Tabs] Tab clicked:', targetId);
                showTab(targetId, tabButton);
            });
        });
        
        // Letzten aktiven Tab wiederherstellen
        const lastActiveTab = localStorage.getItem(storageKey);
        console.log('[AutoMod Tabs] Last active tab from storage:', lastActiveTab);
        
        if (lastActiveTab) {
            const tabButton = document.querySelector(`button[data-bs-target="${lastActiveTab}"]`);
            if (tabButton) {
                console.log('[AutoMod Tabs] Restoring tab:', lastActiveTab);
                showTab(lastActiveTab, tabButton);
            }
        }
        
        console.log('[AutoMod Tabs] Tab system initialized successfully!');
    }
    
    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTabs);
    } else {
        initTabs();
    }
})();
</script>
<div class="row">
  <div class="col-lg-10">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
          <i class="fa-solid fa-shield-halved me-2"></i>
          <%= tr('automod:SETTINGS.PAGE_TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        
