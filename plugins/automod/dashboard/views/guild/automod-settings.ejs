                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP2.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP2.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 3 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">3</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP3.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP3.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 4 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">4</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP4.TITLE') %></h6>
