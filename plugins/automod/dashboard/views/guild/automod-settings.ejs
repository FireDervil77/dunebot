          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-basic-btn" data-bs-toggle="tab" data-bs-target="#tab-basic" type="button" role="tab" aria-controls="tab-basic" aria-selected="true">
              <i class="fa-solid fa-cog me-1"></i>
              <%= tr('automod:TABS.BASIC.TITLE') %>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-content-btn" data-bs-toggle="tab" data-bs-target="#tab-content" type="button" role="tab" aria-controls="tab-content" aria-selected="false">
              <i class="fa-solid fa-shield-halved me-1"></i>
              <%= tr('automod:TABS.CONTENT.TITLE') %>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-limits-btn" data-bs-toggle="tab" data-bs-target="#tab-limits" type="button" role="tab" aria-controls="tab-limits" aria-selected="false">
              <i class="fa-solid fa-sliders me-1"></i>
              <%= tr('automod:TABS.LIMITS.TITLE') %>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-whitelist-btn" data-bs-toggle="tab" data-bs-target="#tab-whitelist" type="button" role="tab" aria-controls="tab-whitelist" aria-selected="false">
              <i class="fa-solid fa-user-check me-1"></i>
              <%= tr('automod:TABS.WHITELIST.TITLE') %>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-raid-btn" data-bs-toggle="tab" data-bs-target="#tab-raid" type="button" role="tab" aria-controls="tab-raid" aria-selected="false">
              <i class="fa-solid fa-shield-virus me-1"></i>
              <%= tr('automod:TABS.RAID.TITLE') %>
              <span class="badge bg-warning text-dark ms-1"><%= tr('automod:TABS.COMING_SOON') %></span>
            </button>
          </li>
        </ul>

        <form 
          class="guild-ajax-form" 
          data-form-type="automod-settings" 
          data-method="PUT"
          action="/guild/<%= guildId %>/plugins/automod/settings"
          method="POST"
        >
          
          <!-- Tab Content -->
          <div class="tab-content" id="automodTabsContent">
            
            <!-- ==================== TAB 1: GRUNDEINSTELLUNGEN ==================== -->
            <div class="tab-pane fade show active" id="tab-basic" role="tabpanel" aria-labelledby="tab-basic-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-cog me-2 text-primary"></i>
                <%= tr('automod:TABS.BASIC.SUBTITLE') %>
              </h5>

              <!-- Log Channel -->
          <div class="mb-4">
            <label for="log_channel" class="form-label fw-bold">
              <i class="fa-solid fa-list-ul me-2"></i>
              <%= tr('automod:SETTINGS.LOG_CHANNEL.LABEL') %>
            </label>
            
            <% if (guildChannels && guildChannels.length > 0) { %>
              <select class="form-select" id="log_channel" name="log_channel">
                <option value=""><%= tr('automod:SETTINGS.LOG_CHANNEL.NO_SELECTION') %></option>
                <% 
                  let currentCategory = null;
                  const selectedChannelId = String(settings.log_channel || '');
                  
                  guildChannels.forEach(channel => { 
                    if (channel.parentName && channel.parentName !== currentCategory) {
                      currentCategory = channel.parentName;
                %>
                  <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                <%  } 
                    const isSelected = selectedChannelId === String(channel.id);
                %>
                  <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                    <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                  </option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" class="form-control" id="log_channel" name="log_channel" 
                     value="<%= settings.log_channel || '' %>" 
                     placeholder="Channel-ID eingeben">
            <% } %>
            <small class="text-muted"><%= tr('automod:SETTINGS.LOG_CHANNEL.HELP') %></small>
          </div>

          <!-- Max Strikes -->
          <div class="mb-4">
            <label for="max_strikes" class="form-label fw-bold">
              <i class="fa-solid fa-exclamation-triangle me-2"></i>
              <%= tr('automod:SETTINGS.MAX_STRIKES.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_strikes" name="max_strikes" 
                   value="<%= settings.max_strikes || 10 %>" min="1" max="100" required>
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_STRIKES.HELP') %></small>
          </div>

          <!-- Action on Max Strikes -->
          <div class="mb-4">
            <label for="action" class="form-label fw-bold">
              <i class="fa-solid fa-gavel me-2"></i>
              <%= tr('automod:SETTINGS.ACTION.LABEL') %>
            </label>
            <select class="form-select" id="action" name="action" required>
              <option value="TIMEOUT" <%= settings.action === 'TIMEOUT' ? 'selected' : '' %>>
                ⏱️ <%= tr('automod:SETTINGS.ACTION.TIMEOUT') %> (24h)
              </option>
              <option value="KICK" <%= settings.action === 'KICK' ? 'selected' : '' %>>
                👢 <%= tr('automod:SETTINGS.ACTION.KICK') %>
              </option>
              <option value="BAN" <%= settings.action === 'BAN' ? 'selected' : '' %>>
                🔨 <%= tr('automod:SETTINGS.ACTION.BAN') %>
              </option>
            </select>
            <small class="text-muted"><%= tr('automod:SETTINGS.ACTION.HELP') %></small>
          </div>

          <!-- Debug Mode -->
          <div class="mb-4">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="debug_mode" name="debug_mode" 
                     value="1" <%= settings.debug_mode ? 'checked' : '' %>>
              <label class="form-check-label fw-bold" for="debug_mode">
                <i class="fa-solid fa-bug me-2"></i>
                <%= tr('automod:SETTINGS.DEBUG_MODE.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.DEBUG_MODE.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 1 -->

            <!-- ==================== TAB 2: CONTENT-FILTER ==================== -->
            <div class="tab-pane fade" id="tab-content" role="tabpanel" aria-labelledby="tab-content-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-shield-halved me-2 text-primary"></i>
                <%= tr('automod:TABS.CONTENT.SUBTITLE') %>
              </h5>

          <!-- Anti Ghost Ping -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_ghostping" name="anti_ghostping" 
