                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP1.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 2 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">2</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP2.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP2.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 3 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">3</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP3.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP3.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 4 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">4</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP4.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP4.DESC') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Tipp -->
        <div class="alert alert-light border-warning mt-3 mb-0">
          <div class="d-flex align-items-center">
            <i class="fa-solid fa-lightbulb text-warning me-3" style="font-size: 1.5rem;"></i>
            <div>
              <strong><%= tr('automod:SETTINGS.GUIDE.TIP.TITLE') %>:</strong>
              <%= tr('automod:SETTINGS.GUIDE.TIP.DESC') %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab-State JavaScript for Bootstrap 4 -->
<script>
(function() {
    'use strict';
    
    // Wait for DOM and jQuery to be ready
    $(document).ready(function() {
        const storageKey = 'automod_active_tab_<%= guildId %>';
        
        // Tab-Wechsel speichern
        $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
            const activeTab = $(e.target).attr('href'); // e.g. #tab-basic
            localStorage.setItem(storageKey, activeTab);
            console.log('[AutoMod Tabs] Switched to:', activeTab);
        });
        
        // Letzten aktiven Tab wiederherstellen
        const lastActiveTab = localStorage.getItem(storageKey);
        if (lastActiveTab) {
            $(`a[href="${lastActiveTab}"]`).tab('show');
            console.log('[AutoMod Tabs] Restored tab:', lastActiveTab);
        }
    });
})();
</script>
<div class="row">
  <div class="col-lg-10">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
          <i class="fa-solid fa-shield-halved me-2"></i>
          <%= tr('automod:SETTINGS.PAGE_TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        
        <!-- Tab Navigation - Bootstrap 4 Syntax! -->
        <ul class="nav nav-tabs mb-4" id="automodTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <a class="nav-link active" id="tab-basic-btn" data-toggle="tab" href="#tab-basic" role="tab" aria-controls="tab-basic" aria-selected="true">
              <i class="fa-solid fa-cog me-1"></i>
              <%= tr('automod:TABS.BASIC.TITLE') %>
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-content-btn" data-toggle="tab" href="#tab-content" role="tab" aria-controls="tab-content" aria-selected="false">
              <i class="fa-solid fa-shield-halved me-1"></i>
              <%= tr('automod:TABS.CONTENT.TITLE') %>
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-limits-btn" data-toggle="tab" href="#tab-limits" role="tab" aria-controls="tab-limits" aria-selected="false">
              <i class="fa-solid fa-sliders me-1"></i>
              <%= tr('automod:TABS.LIMITS.TITLE') %>
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-whitelist-btn" data-toggle="tab" href="#tab-whitelist" role="tab" aria-controls="tab-whitelist" aria-selected="false">
              <i class="fa-solid fa-user-check me-1"></i>
              <%= tr('automod:TABS.WHITELIST.TITLE') %>
            </a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-raid-btn" data-toggle="tab" href="#tab-raid" role="tab" aria-controls="tab-raid" aria-selected="false">
              <i class="fa-solid fa-shield-virus me-1"></i>
              <%= tr('automod:TABS.RAID.TITLE') %>
              <span class="badge bg-success text-white ms-1">NEU</span>
            </a>
          </li>
        </ul>

        <form 
          class="guild-ajax-form" 
          data-form-type="automod-settings" 
          data-method="PUT"
          action="/guild/<%= guildId %>/plugins/automod/settings"
          method="POST"
        >
          
          <!-- Tab Content -->
          <div class="tab-content" id="automodTabsContent">
            
            <!-- ==================== TAB 1: GRUNDEINSTELLUNGEN ==================== -->
            <div class="tab-pane fade show active" id="tab-basic" role="tabpanel" aria-labelledby="tab-basic-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-cog me-2 text-primary"></i>
                <%= tr('automod:TABS.BASIC.SUBTITLE') %>
              </h5>

              <!-- Log Channel -->
          <div class="mb-4">
            <label for="log_channel" class="form-label fw-bold">
              <i class="fa-solid fa-list-ul me-2"></i>
              <%= tr('automod:SETTINGS.LOG_CHANNEL.LABEL') %>
            </label>
            
            <% if (guildChannels && guildChannels.length > 0) { %>
              <select class="form-select" id="log_channel" name="log_channel">
                <option value=""><%= tr('automod:SETTINGS.LOG_CHANNEL.NO_SELECTION') %></option>
                <% 
                  let currentCategory = null;
                  const selectedChannelId = String(settings.log_channel || '');
                  
                  guildChannels.forEach(channel => { 
                    if (channel.parentName && channel.parentName !== currentCategory) {
                      currentCategory = channel.parentName;
                %>
                  <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                <%  } 
                    const isSelected = selectedChannelId === String(channel.id);
                %>
                  <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                    <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                  </option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" class="form-control" id="log_channel" name="log_channel" 
                     value="<%= settings.log_channel || '' %>" 
                     placeholder="Channel-ID eingeben">
            <% } %>
            <small class="text-muted"><%= tr('automod:SETTINGS.LOG_CHANNEL.HELP') %></small>
          </div>

          <!-- Max Strikes -->
          <div class="mb-4">
            <label for="max_strikes" class="form-label fw-bold">
              <i class="fa-solid fa-exclamation-triangle me-2"></i>
              <%= tr('automod:SETTINGS.MAX_STRIKES.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_strikes" name="max_strikes" 
                   value="<%= settings.max_strikes || 10 %>" min="1" max="100" required>
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_STRIKES.HELP') %></small>
          </div>

          <!-- Action on Max Strikes -->
          <div class="mb-4">
            <label for="action" class="form-label fw-bold">
              <i class="fa-solid fa-gavel me-2"></i>
              <%= tr('automod:SETTINGS.ACTION.LABEL') %>
            </label>
            <select class="form-select" id="action" name="action" required>
              <option value="TIMEOUT" <%= settings.action === 'TIMEOUT' ? 'selected' : '' %>>
                ⏱️ <%= tr('automod:SETTINGS.ACTION.TIMEOUT') %> (24h)
              </option>
              <option value="KICK" <%= settings.action === 'KICK' ? 'selected' : '' %>>
                👢 <%= tr('automod:SETTINGS.ACTION.KICK') %>
              </option>
              <option value="BAN" <%= settings.action === 'BAN' ? 'selected' : '' %>>
                🔨 <%= tr('automod:SETTINGS.ACTION.BAN') %>
              </option>
            </select>
            <small class="text-muted"><%= tr('automod:SETTINGS.ACTION.HELP') %></small>
          </div>

          <!-- Debug Mode -->
          <div class="mb-4">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="debug_mode" name="debug_mode" 
                     value="1" <%= settings.debug_mode ? 'checked' : '' %>>
              <label class="form-check-label fw-bold" for="debug_mode">
                <i class="fa-solid fa-bug me-2"></i>
                <%= tr('automod:SETTINGS.DEBUG_MODE.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.DEBUG_MODE.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 1 -->

            <!-- ==================== TAB 2: CONTENT-FILTER ==================== -->
            <div class="tab-pane fade" id="tab-content" role="tabpanel" aria-labelledby="tab-content-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-shield-halved me-2 text-primary"></i>
                <%= tr('automod:TABS.CONTENT.SUBTITLE') %>
              </h5>

          <!-- Anti Ghost Ping -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_ghostping" name="anti_ghostping" 
                     value="1" <%= settings.anti_ghostping ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_ghostping">
                👻 <%= tr('automod:SETTINGS.ANTI_GHOSTPING.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_GHOSTPING.HELP') %></small>
          </div>

          <!-- Anti Spam -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_spam" name="anti_spam" 
                     value="1" <%= settings.anti_spam ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_spam">
                🚫 <%= tr('automod:SETTINGS.ANTI_SPAM.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_SPAM.HELP') %></small>
          </div>

          <!-- Anti Mass Mention -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_massmention" name="anti_massmention" 
                     value="1" <%= settings.anti_massmention ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_massmention">
                @️ <%= tr('automod:SETTINGS.ANTI_MASSMENTION.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_MASSMENTION.HELP') %></small>
          </div>

          <!-- Mass Mention Threshold -->
          <div class="mb-4 ms-4">
            <label for="anti_massmention_threshold" class="form-label">
              <%= tr('automod:SETTINGS.ANTI_MASSMENTION_THRESHOLD.LABEL') %>
            </label>
            <input type="number" class="form-control" id="anti_massmention_threshold" 
                   name="anti_massmention_threshold" 
                   value="<%= settings.anti_massmention_threshold || 3 %>" 
                   min="1" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_MASSMENTION_THRESHOLD.HELP') %></small>
          </div>

          <!-- Anti Attachments -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_attachments" name="anti_attachments" 
                     value="1" <%= settings.anti_attachments ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_attachments">
                📎 <%= tr('automod:SETTINGS.ANTI_ATTACHMENTS.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_ATTACHMENTS.HELP') %></small>
          </div>

          <!-- Anti Invites -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_invites" name="anti_invites" 
                     value="1" <%= settings.anti_invites ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_invites">
                🔗 <%= tr('automod:SETTINGS.ANTI_INVITES.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_INVITES.HELP') %></small>
          </div>

          <!-- Anti Links -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="anti_links" name="anti_links" 
                     value="1" <%= settings.anti_links ? 'checked' : '' %>>
              <label class="form-check-label" for="anti_links">
                🌐 <%= tr('automod:SETTINGS.ANTI_LINKS.LABEL') %>
              </label>
            </div>
            <small class="text-muted"><%= tr('automod:SETTINGS.ANTI_LINKS.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 2 -->

            <!-- ==================== TAB 3: LIMITS ==================== -->
            <div class="tab-pane fade" id="tab-limits" role="tabpanel" aria-labelledby="tab-limits-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-sliders me-2 text-primary"></i>
                <%= tr('automod:TABS.LIMITS.SUBTITLE') %>
              </h5>

          <!-- Max Lines -->
          <div class="mb-4">
            <label for="max_lines" class="form-label fw-bold">
              <i class="fa-solid fa-align-left me-2"></i>
              <%= tr('automod:SETTINGS.MAX_LINES.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_lines" name="max_lines" 
                   value="<%= settings.max_lines || 0 %>" min="0" max="100">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_LINES.HELP') %></small>
          </div>

          <!-- Max Mentions -->
          <div class="mb-4">
            <label for="max_mentions" class="form-label fw-bold">
              <i class="fa-solid fa-at me-2"></i>
              <%= tr('automod:SETTINGS.MAX_MENTIONS.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_mentions" name="max_mentions" 
                   value="<%= settings.max_mentions || 0 %>" min="0" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_MENTIONS.HELP') %></small>
          </div>

          <!-- Max Role Mentions -->
          <div class="mb-4">
            <label for="max_role_mentions" class="form-label fw-bold">
              <i class="fa-solid fa-user-tag me-2"></i>
              <%= tr('automod:SETTINGS.MAX_ROLE_MENTIONS.LABEL') %>
            </label>
            <input type="number" class="form-control" id="max_role_mentions" name="max_role_mentions" 
                   value="<%= settings.max_role_mentions || 0 %>" min="0" max="50">
            <small class="text-muted"><%= tr('automod:SETTINGS.MAX_ROLE_MENTIONS.HELP') %></small>
          </div>
            </div>
            <!-- END TAB 3 -->

            <!-- ==================== TAB 4: WHITELISTING ==================== -->
            <div class="tab-pane fade" id="tab-whitelist" role="tabpanel" aria-labelledby="tab-whitelist-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-user-check me-2 text-primary"></i>
                <%= tr('automod:TABS.WHITELIST.SUBTITLE') %>
              </h5>

              <!-- Whitelisted Channels (Existing Feature) -->
              <div class="mb-4">
                <label class="form-label fw-bold">
                  <i class="fa-solid fa-hashtag me-2"></i>
                  <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.LABEL') %>
                </label>
                
                <% if (guildChannels && guildChannels.length > 0) { %>
                  <select class="form-select" id="whitelisted_channels" name="whitelisted_channels" multiple size="8">
                    <% 
                      let currentCategory = null;
                      const whitelistedChannelIds = settings.whitelisted_channels 
                        ? (Array.isArray(settings.whitelisted_channels) 
                            ? settings.whitelisted_channels.map(id => String(id))
                            : JSON.parse(settings.whitelisted_channels || '[]').map(id => String(id)))
                        : [];
                      
                      guildChannels.forEach(channel => { 
                        if (channel.parentName && channel.parentName !== currentCategory) {
                          currentCategory = channel.parentName;
                    %>
                      <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                    <%  } 
                        const isSelected = whitelistedChannelIds.includes(String(channel.id));
                    %>
                      <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                        <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                      </option>
                    <% }); %>
                  </select>
                  <small class="text-muted">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.HELP') %>
                  </small>
                <% } else { %>
                  <div class="alert alert-warning">
                    <i class="fa-solid fa-exclamation-triangle me-2"></i>
                    <%= tr('automod:SETTINGS.WHITELISTED_CHANNELS.NO_CHANNELS') %>
                  </div>
                <% } %>
              </div>

              <!-- Coming Soon: Role Whitelist -->
              <div class="alert alert-info">
                <div class="d-flex align-items-center">
                  <i class="fa-solid fa-user-tag me-3" style="font-size: 2rem;"></i>
                  <div>
                    <h6 class="mb-1">
                      <span class="badge bg-warning text-dark me-2"><%= tr('automod:TABS.COMING_SOON') %></span>
                      <%= tr('automod:TABS.WHITELIST.ROLE_WHITELIST_TITLE') %>
                    </h6>
                    <p class="mb-0 small">
                      <%= tr('automod:TABS.WHITELIST.ROLE_WHITELIST_DESC') %>
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <!-- END TAB 4 -->

            <!-- ==================== TAB 5: RAID-SCHUTZ ==================== -->
            <div class="tab-pane fade" id="tab-raid" role="tabpanel" aria-labelledby="tab-raid-btn">
              <h5 class="mb-4">
                <i class="fa-solid fa-shield-virus me-2 text-danger"></i>
                <%= tr('automod:TABS.RAID.SUBTITLE') %>
              </h5>

              <!-- Raid Protection aktivieren -->
              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_protection_enabled" name="raid_protection_enabled" 
                         value="1" <%= settings.raid_protection_enabled ? 'checked' : '' %>>
                  <label class="form-check-label fw-bold" for="raid_protection_enabled">
                    <i class="fa-solid fa-shield-halved me-2"></i>
                    Raid-Schutz aktivieren
                  </label>
                </div>
                <small class="text-muted">Schützt vor massiven Join-Angriffen und jungen Accounts</small>
              </div>

              <hr class="my-4">

              <!-- Join-Spam Detection -->
              <h6 class="mb-3">
                <i class="fa-solid fa-users me-2"></i>
                Join-Spam Detection
              </h6>

              <div class="row mb-4">
                <div class="col-md-6">
                  <label for="raid_join_threshold" class="form-label fw-bold">
                    <i class="fa-solid fa-hashtag me-2"></i>
                    Max. Joins
                  </label>
                  <input type="number" class="form-control" id="raid_join_threshold" name="raid_join_threshold" 
                         value="<%= settings.raid_join_threshold || 5 %>" min="2" max="50">
                  <small class="text-muted">Anzahl User die in X Sekunden joinen dürfen</small>
                </div>

                <div class="col-md-6">
                  <label for="raid_join_timespan" class="form-label fw-bold">
                    <i class="fa-solid fa-clock me-2"></i>
                    Zeitfenster (Sekunden)
                  </label>
                  <input type="number" class="form-control" id="raid_join_timespan" name="raid_join_timespan" 
                         value="<%= settings.raid_join_timespan || 10 %>" min="5" max="60">
                  <small class="text-muted">Zeitspanne für Raid-Erkennung</small>
                </div>
              </div>

              <!-- Account-Age Filter -->
              <div class="mb-4">
                <label for="raid_min_account_age_days" class="form-label fw-bold">
                  <i class="fa-solid fa-calendar-check me-2"></i>
                  Min. Account-Alter (Tage)
                </label>
                <input type="number" class="form-control" id="raid_min_account_age_days" name="raid_min_account_age_days" 
                       value="<%= settings.raid_min_account_age_days || 7 %>" min="0" max="365">
                <small class="text-muted">User mit jüngerem Account werden gekickt (0 = deaktiviert)</small>
              </div>

              <hr class="my-4">

              <!-- Actions & Lockdown -->
              <h6 class="mb-3">
                <i class="fa-solid fa-gavel me-2"></i>
                Aktionen bei Raid
              </h6>

              <div class="mb-4">
                <label for="raid_action" class="form-label fw-bold">
                  <i class="fa-solid fa-bolt me-2"></i>
                  Standard-Aktion
                </label>
                <select class="form-select" id="raid_action" name="raid_action">
                  <option value="KICK" <%= settings.raid_action === 'KICK' ? 'selected' : '' %>>
                    👢 Kick (Automatisch)
                  </option>
                  <option value="BAN" <%= settings.raid_action === 'BAN' ? 'selected' : '' %>>
                    🔨 Ban (Manuell empfohlen)
                  </option>
                </select>
                <small class="text-muted">Kick wird automatisch ausgeführt, Ban ist für manuelle Nachbearbeitung gedacht</small>
              </div>

              <!-- Lockdown -->
              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_lockdown_enabled" name="raid_lockdown_enabled" 
                         value="1" <%= settings.raid_lockdown_enabled ? 'checked' : '' %>>
                  <label class="form-check-label fw-bold" for="raid_lockdown_enabled">
                    <i class="fa-solid fa-lock me-2"></i>
                    Lockdown bei Raid aktivieren
                  </label>
                </div>
                <small class="text-muted">Sperrt Server automatisch (Verification HIGH + @everyone Permissions entfernt)</small>
                
                <% if (settings.raid_lockdown_active) { %>
                  <div class="alert alert-danger mt-3 mb-0">
                    <div class="d-flex align-items-center">
                      <i class="fa-solid fa-lock fs-3 me-3"></i>
                      <div>
                        <strong>🔒 LOCKDOWN AKTIV!</strong><br>
                        <small>Der Server ist derzeit gesperrt. Nutze <code>/automod unlock</code> oder das Dashboard um den Lockdown zu deaktivieren.</small>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>

              <hr class="my-4">

              <!-- Alert-Benachrichtigungen -->
              <h6 class="mb-3">
                <i class="fa-solid fa-bell me-2"></i>
                Benachrichtigungen
              </h6>

              <div class="mb-4">
                <label for="raid_alert_channel" class="form-label fw-bold">
                  <i class="fa-solid fa-bullhorn me-2"></i>
                  Raid-Alert Channel
                </label>
                
                <% if (guildChannels && guildChannels.length > 0) { %>
                  <select class="form-select" id="raid_alert_channel" name="raid_alert_channel">
                    <option value="">Kein Channel ausgewählt</option>
                    <% 
                      let currentCategory = null;
                      const selectedChannelId = String(settings.raid_alert_channel || '');
                      
                      guildChannels.forEach(channel => { 
                        if (channel.parentName && channel.parentName !== currentCategory) {
                          currentCategory = channel.parentName;
                    %>
                      <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                    <%  } 
                        const isSelected = selectedChannelId === String(channel.id);
                    %>
                      <option value="<%= channel.id %>" <%= isSelected ? 'selected' : '' %>>
                        <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                      </option>
                    <% }); %>
                  </select>
                <% } else { %>
                  <input type="text" class="form-control" id="raid_alert_channel" name="raid_alert_channel" 
                         value="<%= settings.raid_alert_channel || '' %>" 
                         placeholder="Channel-ID eingeben">
                <% } %>
                <small class="text-muted">Channel für Raid-Warnungen</small>
              </div>

              <div class="mb-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="raid_alert_mention_mods" name="raid_alert_mention_mods" 
                         value="1" <%= settings.raid_alert_mention_mods ? 'checked' : '' %>>
                  <label class="form-check-label" for="raid_alert_mention_mods">
                    <i class="fa-solid fa-at me-2"></i>
                    @Mods bei Raid erwähnen
                  </label>
                </div>
                <small class="text-muted">Erwähnt Moderator-Rollen im Alert-Channel</small>
              </div>

              <hr class="my-4">

              <!-- Trusted Invites -->
              <h6 class="mb-3">
                <i class="fa-solid fa-user-check me-2"></i>
                Trusted Invite-Links
              </h6>

              <div class="mb-4">
                <label for="raid_trusted_invites" class="form-label fw-bold">
                  <i class="fa-solid fa-link me-2"></i>
                  Whitelist von Invite-Codes
                </label>
                <textarea class="form-control" id="raid_trusted_invites" name="raid_trusted_invites" rows="4" 
                          placeholder="discord.gg/ABC123&#10;discord.gg/XYZ789&#10;(Ein Code pro Zeile)"><%= (settings.raid_trusted_invites || []).join('\n') %></textarea>
                <small class="text-muted">
                  <i class="fa-solid fa-info-circle me-1"></i>
                  User die über diese Invites joinen werden NICHT vom Raid-Check erfasst. Nur die Codes eingeben (z.B. <code>ABC123</code>), nicht die komplette URL.
                </small>
              </div>

              <!-- Info-Box -->
              <div class="alert alert-info">
                <div class="d-flex align-items-start">
                  <i class="fa-solid fa-lightbulb fs-3 me-3 mt-1"></i>
                  <div>
                    <strong>💡 Tipp:</strong><br>
                    <ul class="mb-0 ps-3">
                      <li>Trusted Invites sind ideal für Partner-Server oder offizielle Einladungen</li>
                      <li>Lockdown muss <strong>manuell</strong> deaktiviert werden (Sicherheit!)</li>
                      <li>Teste die Settings mit <code>debug_mode</code> im Basic-Tab</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <!-- END TAB 5 -->

          </div>
          <!-- END Tab Content -->

          <!-- Submit Button (Outside Tabs, always visible) -->
          <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="fa-solid fa-save me-2"></i>
              <%= tr('automod:SETTINGS.SAVE_BUTTON') %>
            </button>
          </div>

        </form>
        
        <!-- Checkbox Serialization Script -->
        <script>
        (function() {
            'use strict';
            
            // Form-Handler für AutoMod Settings
            const form = document.querySelector('form[data-form-type="automod-settings"]');
            if (!form) return;
            
            form.addEventListener('submit', function(e) {
                console.log('[AutoMod] Form submit intercepted for checkbox serialization');
                
                // Alle Checkboxen finden
                const checkboxes = form.querySelectorAll('input[type="checkbox"]');
                
                checkboxes.forEach(checkbox => {
                    // Für jede Checkbox: Setze explizit true/false
                    if (!checkbox.checked) {
                        // Erstelle Hidden-Input für unchecked Checkbox
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = checkbox.name;
                        hidden.value = '0'; // false
                        checkbox.parentNode.appendChild(hidden);
                        console.log(`[AutoMod] Added hidden input for unchecked: ${checkbox.name} = 0`);
                    } else {
                        console.log(`[AutoMod] Checkbox checked: ${checkbox.name} = 1`);
                    }
                });
                
                // Multi-Select Channels serialisieren
                const multiSelect = form.querySelector('select[multiple]');
                if (multiSelect) {
                    const selectedOptions = Array.from(multiSelect.selectedOptions).map(opt => opt.value);
                    console.log('[AutoMod] Whitelisted channels:', selectedOptions);
                    
                    // Entferne alte Inputs
                    form.querySelectorAll('input[name="whitelisted_channels"]').forEach(input => input.remove());
                    
                    // Füge jede ausgewählte Channel-ID als separates Input hinzu
                    selectedOptions.forEach(channelId => {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'whitelisted_channels';
                        hidden.value = channelId;
                        form.appendChild(hidden);
                    });
                    
                    // Deaktiviere Multi-Select (damit es nicht doppelt gesendet wird)
                    multiSelect.disabled = true;
                }
                
                // Form fortfahren (guild.js übernimmt)
            });
        })();
        </script>
      </div>
    </div>
  </div>

  <!-- Sidebar: Info Card -->
  <div class="col-lg-2">
    <div class="card">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-info-circle me-2"></i>
          <%= tr('automod:SETTINGS.INFO.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <p class="small mb-2">
          <%= tr('automod:SETTINGS.INFO.DESC') %>
        </p>
        <hr>
        <p class="small mb-0">
          <strong><%= tr('automod:SETTINGS.INFO.VERSION') %>:</strong> 1.0.0
        </p>
      </div>
    </div>
  </div>
</div>
