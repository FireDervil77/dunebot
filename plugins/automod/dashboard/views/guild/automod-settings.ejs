<!-- AutoMod Settings -->

<!-- AutoMod Tab-System CSS -->
<link rel="stylesheet" href="/plugins/automod/css/automod.css">

<!-- Anleitungsbox -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card border-info">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0">
          <%= tr('automod:SETTINGS.GUIDE.TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <!-- Schritt 1 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">1</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP1.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP1.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 2 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">2</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP2.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP2.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 3 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">3</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP3.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP3.DESC') %></p>
              </div>
            </div>
          </div>

          <!-- Schritt 4 -->
          <div class="col-md-6 mb-3">
            <div class="d-flex align-items-start">
              <div class="flex-shrink-0">
                <span class="badge bg-info rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">4</span>
              </div>
              <div class="flex-grow-1 ms-3">
                <h6 class="mb-1"><%= tr('automod:SETTINGS.GUIDE.STEP4.TITLE') %></h6>
                <p class="text-muted small mb-0"><%= tr('automod:SETTINGS.GUIDE.STEP4.DESC') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Tipp -->
        <div class="alert alert-light border-warning mt-3 mb-0">
          <div class="d-flex align-items-center">
            <i class="fa-solid fa-lightbulb text-warning me-3" style="font-size: 1.5rem;"></i>
            <div>
              <strong><%= tr('automod:SETTINGS.GUIDE.TIP.TITLE') %>:</strong>
              <%= tr('automod:SETTINGS.GUIDE.TIP.DESC') %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab-State JavaScript for Bootstrap 4 -->
<script>
(function() {
    'use strict';
    
    // Wait for DOM and jQuery to be ready
    $(document).ready(function() {
        const storageKey = 'automod_active_tab_<%= guildId %>';
        
        // Tab-Wechsel speichern
        $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
            const activeTab = $(e.target).attr('href'); // e.g. #tab-basic
            localStorage.setItem(storageKey, activeTab);
            console.log('[AutoMod Tabs] Switched to:', activeTab);
        });
        
        // Letzten aktiven Tab wiederherstellen
        const lastActiveTab = localStorage.getItem(storageKey);
        if (lastActiveTab) {
            $(`a[href="${lastActiveTab}"]`).tab('show');
            console.log('[AutoMod Tabs] Restored tab:', lastActiveTab);
        }
    });
})();
</script>
