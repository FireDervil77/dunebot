                            <i class="fa-solid fa-check-circle text-success me-2"></i>
                            <%= tr('automod:TABS.RAID.FEATURE_1') %>
                          </li>
                          <li class="mb-2">
                            <i class="fa-solid fa-check-circle text-success me-2"></i>
                            <%= tr('automod:TABS.RAID.FEATURE_2') %>
                          </li>
                          <li class="mb-2">
                            <i class="fa-solid fa-check-circle text-success me-2"></i>
                            <%= tr('automod:TABS.RAID.FEATURE_3') %>
                          </li>
                          <li class="mb-0">
                            <i class="fa-solid fa-check-circle text-success me-2"></i>
                            <%= tr('automod:TABS.RAID.FEATURE_4') %>
                          </li>
                        </ul>
                      </div>
                    </div>
                    <p class="text-muted mt-3 mb-0">
                      <i class="fa-solid fa-calendar-alt me-2"></i>
                      <%= tr('automod:TABS.RAID.ETA') %>
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <!-- END TAB 5 -->

          </div>
          <!-- END Tab Content -->

          <!-- Submit Button (Outside Tabs, always visible) -->
          <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="fa-solid fa-save me-2"></i>
              <%= tr('automod:SETTINGS.SAVE_BUTTON') %>
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>

  <!-- Sidebar: Info Card -->
  <div class="col-lg-2">
    <div class="card">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-info-circle me-2"></i>
          <%= tr('automod:SETTINGS.INFO.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <p class="small mb-2">
          <%= tr('automod:SETTINGS.INFO.DESC') %>
        </p>
        <hr>
        <p class="small mb-0">
          <strong><%= tr('automod:SETTINGS.INFO.VERSION') %>:</strong> 1.0.0
        </p>
      </div>
    </div>
  </div>
</div>
