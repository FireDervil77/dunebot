<% if (type === 'welcome') { %>
<!-- ===== WELCOME ===== -->
<div class="card card-outline card-primary">
  <div class="card-body">
    <form id="welcomeForm">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label"><i class="fa-solid fa-hashtag me-1"></i> <%= tr('greeting:CHANNEL_TITLE') %></label>
          <select class="form-control" name="welcome_channel" required>
            <option value=""><%= tr('greeting:CHANNEL_SELECT') %></option>
            <% channels.forEach(ch => { %>
              <option value="<%= ch.id %>" <%= settings.welcome.channel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label"><i class="fa-solid fa-circle-info me-1"></i> <%= tr('greeting:STATUS') %></label>
          <div>
            <div class="custom-control custom-switch">
              <input type="checkbox" class="custom-control-input" id="welcomeEnabledToggle"
                     <%= settings.welcome.enabled ? 'checked' : '' %>
                     onchange="toggleGreeting('welcome', this.checked)">
              <label class="custom-control-label" for="welcomeEnabledToggle">
                <span class="badge <%= settings.welcome.enabled ? 'badge-success' : 'badge-secondary' %>">
                  <%= settings.welcome.enabled ? tr('greeting:STATUS_ENABLED') : tr('greeting:STATUS_DISABLED') %>
                </span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- Nachrichtentyp-Auswahl -->
      <% const welcomeMode = (settings.welcome.embed && (settings.welcome.embed.title || settings.welcome.embed.description)) ? 'embed' : 'text'; %>
      <div class="mb-3">
        <label class="form-label"><i class="fa-solid fa-toggle-on me-1"></i> Nachrichtentyp</label>
        <div class="btn-group btn-group-toggle" data-toggle="buttons">
          <label class="btn btn-outline-primary btn-sm <%= welcomeMode === 'text' ? 'active' : '' %>">
            <input type="radio" name="welcome_message_mode" value="text" <%= welcomeMode === 'text' ? 'checked' : '' %>> <i class="fa-solid fa-align-left me-1"></i> Nachricht
          </label>
          <label class="btn btn-outline-primary btn-sm <%= welcomeMode === 'embed' ? 'active' : '' %>">
            <input type="radio" name="welcome_message_mode" value="embed" <%= welcomeMode === 'embed' ? 'checked' : '' %>> <i class="fa-solid fa-code me-1"></i> Embed
          </label>
        </div>
      </div>

      <div id="welcome_text_section" style="<%= welcomeMode === 'embed' ? 'display:none' : '' %>">
        <div class="mb-3">
          <label class="form-label"><i class="fa-solid fa-message me-1"></i> <%= tr('greeting:WELCOME.MESSAGE') %></label>
          <textarea class="form-control msg-input" name="welcome_content" rows="3" data-preview-type="welcome"><%= settings.welcome.content || '' %></textarea>
          <small class="form-text text-muted"><%= tr('greeting:PLACEHOLDERS_HINT') %></small>
        </div>
      </div>

      <div id="welcome_embed_section" style="<%= welcomeMode === 'text' ? 'display:none' : '' %>">
        <%- include('../partials/embed-builder', { prefix: 'welcome', embed: settings.welcome.embed }) %>
      </div>

      <!-- Welcome Image Section -->
      <hr>
      <h6><i class="fa-solid fa-image me-1"></i> <%= tr('greeting:IMAGE.TITLE') %></h6>
      <p class="text-muted small"><%= tr('greeting:IMAGE.DESC') %></p>
      <div class="row">
        <div class="col-md-3 mb-3">
          <div class="custom-control custom-switch">
            <input type="checkbox" class="custom-control-input" id="welcomeImageToggle"
                   name="welcome_image_enabled" <%= settings.welcome_image.enabled ? 'checked' : '' %>>
            <label class="custom-control-label" for="welcomeImageToggle"><%= tr('greeting:IMAGE.ENABLE') %></label>
          </div>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label"><%= tr('greeting:IMAGE.BG_TITLE') %></label>
          <select class="form-control" name="welcome_image_bg">
            <option value="default" <%= settings.welcome_image.bg === 'default' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_DEFAULT') %></option>
            <option value="dark" <%= settings.welcome_image.bg === 'dark' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_DARK') %></option>
            <option value="blue" <%= settings.welcome_image.bg === 'blue' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_BLUE') %></option>
            <option value="purple" <%= settings.welcome_image.bg === 'purple' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_PURPLE') %></option>
            <option value="green" <%= settings.welcome_image.bg === 'green' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_GREEN') %></option>
            <option value="sunset" <%= settings.welcome_image.bg === 'sunset' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_SUNSET') %></option>
            <option value="ocean" <%= settings.welcome_image.bg === 'ocean' ? 'selected' : '' %>><%= tr('greeting:IMAGE.BG_OCEAN') %></option>
          </select>
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label"><%= tr('greeting:IMAGE.TEXT_TITLE') %></label>
          <input type="text" class="form-control" name="welcome_image_text"
                 value="<%= settings.welcome_image.text || '' %>"
                 placeholder="<%= tr('greeting:IMAGE.TEXT_PLACEHOLDER') %>">
        </div>
        <div class="col-md-3 mb-3">
          <label class="form-label"><%= tr('greeting:IMAGE.COLOR_TITLE') %></label>
          <input type="color" class="form-control form-control-color" name="welcome_image_color"
                 value="<%= settings.welcome_image.color || '#5865f2' %>" style="height: 38px;">
        </div>
      </div>

      <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-primary" onclick="updateGreeting('welcome', 'save')">
          <i class="fa-solid fa-save me-1"></i> <%= tr('greeting:BTN_SAVE') %>
        </button>
      </div>
    </form>
  </div>
</div>

