<% } else if (type === 'autorole') { %>
<!-- ===== AUTOROLE (Multi) ===== -->
<div class="card card-outline card-success">
  <div class="card-body">
    <form id="autoroleForm">
      <div class="mb-3">
        <label class="form-label"><i class="fa-solid fa-user-shield me-1"></i> <%= tr('greeting:AUTOROLE_SELECT') %></label>
        <p class="text-muted small"><%= tr('greeting:AUTOROLE_MULTI_HINT') %></p>
        <select class="form-control" name="autorole_ids" multiple size="8">
          <% roles.forEach(role => { %>
            <option value="<%= role.id %>"
              <%= (settings.autorole_ids && settings.autorole_ids.includes(role.id)) ? 'selected' : '' %>>
              <%= role.name %>
            </option>
          <% }); %>
        </select>
      </div>

      <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-2"></i> <%= tr('greeting:AUTOROLE_INFO') %>
      </div>

      <% if (settings.autorole_ids && settings.autorole_ids.length > 0) { %>
        <div class="mb-3">
          <strong>Aktive Rollen:</strong>
          <div class="mt-1">
            <% settings.autorole_ids.forEach(rid => { %>
              <% const roleName = (roles.find(r => r.id === rid) || {}).name || rid; %>
              <span class="badge badge-info mr-1"><%= roleName %></span>
            <% }); %>
          </div>
        </div>
      <% } %>

      <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-primary" onclick="updateGreeting('autorole', 'save')">
          <i class="fa-solid fa-save me-1"></i> <%= tr('greeting:BTN_SAVE') %>
        </button>
      </div>
    </form>
  </div>
</div>

