<% } else if (type === 'autorole') { %>
<!-- Autorole Tab Content -->
<div class="card">
  <div class="card-body">
    <form id="autoroleForm">
      <div class="mb-3">
        <label class="form-label">
          <i class="fa-solid fa-user-shield me-1"></i>
          <%= tr('greeting:AUTOROLE_SELECT', 'Rolle auswählen') %>
        </label>
        <select class="form-select" name="autorole_id">
          <option value=""><%= tr('greeting:AUTOROLE_NONE', 'Keine automatische Rolle') %></option>
          <% if (roles && roles.length > 0) { %>
            <% roles.forEach(role => { %>
              <option value="<%= role.id %>" <%= settings.autorole_id === role.id ? 'selected' : '' %>>
                <%= role.name %>
              </option>
            <% }); %>
          <% } %>
        </select>
        <small class="form-text text-muted">
          <%= tr('greeting:AUTOROLE_DESC', 'Diese Rolle wird neuen Mitgliedern automatisch zugewiesen') %>
        </small>
      </div>

      <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-2"></i>
        <%= tr('greeting:AUTOROLE_INFO', 'Die ausgewählte Rolle wird allen neuen Mitgliedern beim Beitritt automatisch gegeben.') %>
      </div>

      <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-primary" onclick="updateGreeting('autorole', 'save')">
          <i class="fa-solid fa-save me-1"></i>
          <%= tr('greeting:BTN_SAVE', 'Speichern') %>
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>
