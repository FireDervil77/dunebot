<!-- Greeting Plugin Settings Page v2.0 -->
<div class="container-fluid">
  <div class="row">
    <!-- Main Panel (8 Spalten) -->
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fa-solid fa-hand-wave me-2"></i>
            <%= tr('greeting:SETTINGS.PAGE_TITLE') %>
          </h3>
          <p class="text-muted mb-0 mt-2"><%= tr('greeting:SETTINGS.PAGE_DESC') %></p>
        </div>

        <div class="card-body">
          <!-- 5 Tabs -->
          <ul class="nav nav-tabs" id="greetingTabs" role="tablist">
            <li class="nav-item">
              <a class="nav-link active" data-toggle="tab" href="#welcome-pane" role="tab">
                <i class="fa-solid fa-hand-wave me-1"></i> <%= tr('greeting:TAB_WELCOME') %>
                <% if (settings.welcome.enabled) { %><span class="badge badge-success ml-1">ON</span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#farewell-pane" role="tab">
                <i class="fa-solid fa-door-open me-1"></i> <%= tr('greeting:TAB_FAREWELL') %>
                <% if (settings.farewell.enabled) { %><span class="badge badge-success ml-1">ON</span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#dm-pane" role="tab">
                <i class="fa-solid fa-envelope me-1"></i> <%= tr('greeting:TAB_DM_WELCOME') %>
                <% if (settings.dm_welcome.enabled) { %><span class="badge badge-success ml-1">ON</span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#autorole-pane" role="tab">
                <i class="fa-solid fa-user-shield me-1"></i> <%= tr('greeting:TAB_AUTOROLE') %>
                <% if (settings.autorole_ids && settings.autorole_ids.length > 0) { %><span class="badge badge-info ml-1"><%= settings.autorole_ids.length %></span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#boost-pane" role="tab">
                <i class="fa-solid fa-rocket me-1"></i> <%= tr('greeting:TAB_BOOST') %>
                <% if (settings.boost.enabled) { %><span class="badge badge-success ml-1">ON</span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#verification-pane" role="tab">
                <i class="fa-solid fa-shield-check me-1"></i> <%= tr('greeting:TAB_VERIFICATION') %>
                <% if (settings.verification.enabled) { %><span class="badge badge-success ml-1">ON</span><% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#invite-tracking-pane" role="tab">
                <i class="fa-solid fa-link me-1"></i> <%= tr('greeting:TAB_INVITE_TRACKING') %>
                <% if (inviteMappings && inviteMappings.length > 0) { %><span class="badge badge-info ml-1"><%= inviteMappings.length %></span><% } %>
              </a>
            </li>
          </ul>

          <div class="tab-content mt-4" id="greetingTabContent">

            <!-- ==================== WELCOME TAB ==================== -->
            <div class="tab-pane fade show active" id="welcome-pane" role="tabpanel">
              <%- include('greeting-content', { type: 'welcome', channels, roles, settings, guildId }) %>
            </div>

            <!-- ==================== FAREWELL TAB ==================== -->
            <div class="tab-pane fade" id="farewell-pane" role="tabpanel">
              <%- include('greeting-content', { type: 'farewell', channels, roles, settings, guildId }) %>
            </div>

            <!-- ==================== DM WELCOME TAB ==================== -->
            <div class="tab-pane fade" id="dm-pane" role="tabpanel">
              <%- include('greeting-content', { type: 'dm_welcome', channels, roles, settings, guildId }) %>
            </div>

            <!-- ==================== AUTOROLE TAB ==================== -->
            <div class="tab-pane fade" id="autorole-pane" role="tabpanel">
              <%- include('greeting-content', { type: 'autorole', channels, roles, settings, guildId }) %>
            </div>

            <!-- ==================== BOOST TAB ==================== -->
            <div class="tab-pane fade" id="boost-pane" role="tabpanel">
              <%- include('greeting-content', { type: 'boost', channels, roles, settings, guildId }) %>
            </div>

            <!-- ==================== VERIFICATION TAB ==================== -->
            <div class="tab-pane fade" id="verification-pane" role="tabpanel">
              <h4><i class="fa-solid fa-shield-check text-success me-2"></i><%= tr('greeting:VERIFICATION.TITLE') %></h4>
              <p class="text-muted mb-4"><%= tr('greeting:VERIFICATION.DESC') %></p>

              <div class="card card-outline card-success">
                <div class="card-body">
                  <!-- Enable Toggle -->
                  <div class="form-group">
                    <div class="custom-control custom-switch">
                      <input type="checkbox" class="custom-control-input" id="verificationEnabled" <%= settings.verification.enabled ? 'checked' : '' %>>
                      <label class="custom-control-label" for="verificationEnabled"><%= tr('greeting:VERIFICATION.ENABLE') %></label>
                    </div>
                  </div>

                  <!-- Verification Type -->
                  <div class="form-group">
                    <label><%= tr('greeting:VERIFICATION.TYPE') %></label>
                    <select id="verificationType" class="form-control">
                      <option value="button" <%= settings.verification.type === 'button' ? 'selected' : '' %>><%= tr('greeting:VERIFICATION.TYPE_BUTTON') %></option>
                      <option value="captcha" <%= settings.verification.type === 'captcha' ? 'selected' : '' %>><%= tr('greeting:VERIFICATION.TYPE_CAPTCHA') %></option>
                    </select>
                  </div>

                  <!-- Verification Channel -->
                  <div class="form-group">
                    <label><%= tr('greeting:VERIFICATION.CHANNEL') %></label>
                    <select id="verificationChannel" class="form-control">
                      <option value=""><%= tr('greeting:CHANNEL_SELECT') %></option>
                      <% channels.forEach(ch => { %>
                        <option value="<%= ch.id %>" <%= settings.verification.channel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                      <% }); %>
                    </select>
                    <small class="text-muted"><%= tr('greeting:VERIFICATION.CHANNEL_DESC') %></small>
                  </div>

                  <!-- Verified Role -->
                  <div class="form-group">
                    <label><%= tr('greeting:VERIFICATION.VERIFIED_ROLE') %></label>
                    <select id="verificationRoleId" class="form-control">
                      <option value="">—</option>
                      <% roles.forEach(r => { %>
                        <option value="<%= r.id %>" <%= settings.verification.role_id === r.id ? 'selected' : '' %>><%= r.name %></option>
                      <% }); %>
                    </select>
                    <small class="text-muted"><%= tr('greeting:VERIFICATION.VERIFIED_ROLE_DESC') %></small>
                  </div>

                  <!-- Unverified Role -->
                  <div class="form-group">
                    <label><%= tr('greeting:VERIFICATION.UNVERIFIED_ROLE') %></label>
                    <select id="verificationRemoveRoleId" class="form-control">
                      <option value="">—</option>
                      <% roles.forEach(r => { %>
                        <option value="<%= r.id %>" <%= settings.verification.remove_role_id === r.id ? 'selected' : '' %>><%= r.name %></option>
                      <% }); %>
                    </select>
                    <small class="text-muted"><%= tr('greeting:VERIFICATION.UNVERIFIED_ROLE_DESC') %></small>
                  </div>

                  <!-- Verification Message -->
                  <div class="form-group">
                    <label><%= tr('greeting:VERIFICATION.MESSAGE') %></label>
                    <textarea id="verificationMessage" class="form-control" rows="3" placeholder="<%= tr('greeting:VERIFICATION.MESSAGE_PH') %>"><%= settings.verification.message %></textarea>
                    <small class="text-muted">
                      Platzhalter: <code>{guild:name}</code> <code>{server}</code> <code>{guild:memberCount}</code> <code>{count}</code>
                    </small>
                  </div>

                  <!-- Info -->
                  <div class="alert alert-info small mb-3">
                    <i class="fa-solid fa-info-circle me-1"></i> <%= tr('greeting:VERIFICATION.INFO') %>
                  </div>

                  <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-success" onclick="saveVerification()">
                      <i class="fa-solid fa-save me-1"></i> <%= tr('greeting:BTN_SAVE') %>
                    </button>
                    <button type="button" class="btn btn-outline-primary" onclick="sendVerificationPanel()">
                      <i class="fa-solid fa-paper-plane me-1"></i> <%= tr('greeting:VERIFICATION.SEND_PANEL') %>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- ==================== INVITE TRACKING TAB ==================== -->
            <div class="tab-pane fade" id="invite-tracking-pane" role="tabpanel">
              <h4><i class="fa-solid fa-link text-info me-2"></i><%= tr('greeting:INVITE_TRACKING.TITLE') %></h4>
              <p class="text-muted mb-4"><%= tr('greeting:INVITE_TRACKING.DESC') %></p>

              <!-- Add New Mapping -->
              <div class="card card-outline card-info">
                <div class="card-header">
                  <h3 class="card-title"><i class="fa-solid fa-plus me-1"></i> <%= tr('greeting:INVITE_TRACKING.ADD_TITLE') %></h3>
                </div>
                <div class="card-body">
                  <div class="row">
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('greeting:INVITE_TRACKING.INVITE_CODE') %></label>
                      <input type="text" id="inviteCode" class="form-control" maxlength="50" placeholder="<%= tr('greeting:INVITE_TRACKING.INVITE_CODE_PH') %>">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('greeting:INVITE_TRACKING.LABEL') %></label>
                      <input type="text" id="inviteLabel" class="form-control" maxlength="100" placeholder="<%= tr('greeting:INVITE_TRACKING.LABEL_PH') %>">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label"><%= tr('greeting:INVITE_TRACKING.CONTENT') %></label>
                      <input type="text" id="inviteContent" class="form-control" placeholder="<%= tr('greeting:INVITE_TRACKING.CONTENT_PH') %>">
                    </div>
                  </div>
                  <div class="mt-3 text-right">
                    <button type="button" class="btn btn-info" onclick="addInviteMapping()">
                      <i class="fa-solid fa-plus me-1"></i> <%= tr('greeting:INVITE_TRACKING.BTN_ADD') %>
                    </button>
                  </div>
                </div>
              </div>

              <!-- Existing Mappings -->
              <div class="card">
                <div class="card-body">
                  <% if (inviteMappings && inviteMappings.length > 0) { %>
                    <table class="table table-hover table-sm">
                      <thead>
                        <tr>
                          <th><%= tr('greeting:INVITE_TRACKING.INVITE_CODE') %></th>
                          <th><%= tr('greeting:INVITE_TRACKING.LABEL') %></th>
                          <th><%= tr('greeting:INVITE_TRACKING.CONTENT') %></th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% inviteMappings.forEach(m => { %>
                          <tr id="invite-mapping-<%= m.id %>">
                            <td><code><%= m.invite_code %></code></td>
                            <td><%= m.label || '—' %></td>
                            <td><small class="text-muted"><%= (m.welcome_content || '').substring(0, 60) %><%= (m.welcome_content || '').length > 60 ? '...' : '' %></small></td>
                            <td class="text-right">
                              <button class="btn btn-sm btn-outline-danger" onclick="deleteInviteMapping(<%= m.id %>)">
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  <% } else { %>
                    <p class="text-muted text-center mb-0"><%= tr('greeting:INVITE_TRACKING.EMPTY') %></p>
                  <% } %>
                </div>
              </div>

              <!-- Info -->
              <div class="alert alert-info small">
                <i class="fa-solid fa-info-circle me-1"></i> <%= tr('greeting:INVITE_TRACKING.INFO') %>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar (4 Spalten) -->
    <div class="col-lg-4">
      <!-- Help Card -->
      <div class="card card-outline card-info">
        <div class="card-header">
          <h3 class="card-title"><i class="fa-solid fa-circle-info me-2"></i><%= tr('greeting:HELP.TITLE') %></h3>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <h6><i class="fa-solid fa-hand-wave text-primary me-1"></i> <%= tr('greeting:HELP.WELCOME_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.WELCOME_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-door-open text-warning me-1"></i> <%= tr('greeting:HELP.FAREWELL_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.FAREWELL_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-envelope text-info me-1"></i> <%= tr('greeting:HELP.DM_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.DM_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-user-shield text-success me-1"></i> <%= tr('greeting:HELP.AUTOROLE_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.AUTOROLE_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-rocket text-danger me-1"></i> <%= tr('greeting:HELP.BOOST_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.BOOST_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-image text-secondary me-1"></i> <%= tr('greeting:HELP.IMAGE_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.IMAGE_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-shield-check text-success me-1"></i> <%= tr('greeting:HELP.VERIFICATION_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.VERIFICATION_TEXT') %></p>
          </div>
          <div class="mb-3">
            <h6><i class="fa-solid fa-link text-info me-1"></i> <%= tr('greeting:HELP.INVITE_TRACKING_TITLE') %></h6>
            <p class="text-muted small mb-2"><%= tr('greeting:HELP.INVITE_TRACKING_TEXT') %></p>
          </div>
          <hr>
          <h6><i class="fa-solid fa-code me-2"></i><%= tr('greeting:HELP.PLACEHOLDERS_TITLE') %></h6>
          <div class="d-flex flex-wrap" style="gap: 4px;">
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{member:name}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{member:nick}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{member:mention}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{member:avatar}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{guild:name}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{guild:memberCount}</code>
            <code class="badge badge-light border" style="cursor:pointer; font-size: 0.8em; color: #000;" onclick="copyPH(this)">{inviter:name}</code>
          </div>
          <small class="text-muted d-block mt-1">Klicke zum Kopieren</small>
        </div>
      </div>

      <!-- Live Preview Card -->
      <div class="card card-outline card-dark" id="previewCard">
        <div class="card-header">
          <h3 class="card-title"><i class="fa-solid fa-eye me-2"></i><%= tr('greeting:PREVIEW.TITLE') %></h3>
        </div>
        <div class="card-body p-0">
          <div id="livePreview" style="background: #36393f; padding: 12px; border-radius: 0 0 4px 4px; min-height: 80px;">
            <div style="display: flex; gap: 12px;">
              <div style="width: 40px; height: 40px; border-radius: 50%; background: #5865f2; display: flex; align-items: center; justify-content: center;">
                <span style="color: #fff; font-weight: 700; font-size: 1rem;">D</span>
              </div>
              <div style="flex: 1;">
                <div style="display: flex; align-items: baseline; gap: 6px; margin-bottom: 2px;">
                  <span style="color: #fff; font-weight: 600;">FireBot</span>
                  <span style="background: #5865f2; color: #fff; font-size: 0.55rem; padding: 1px 4px; border-radius: 3px;">BOT</span>
                  <span style="color: #72767d; font-size: 0.7rem;">Heute um 12:00</span>
                </div>
                <div id="previewContent" style="color: #dcddde; font-size: 0.9rem; white-space: pre-wrap;"></div>
                <div id="previewEmbed" style="margin-top: 4px;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

<%- includePluginPartial('greeting', 'greeting-scripts', locals) %>
</div>
