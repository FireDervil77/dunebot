<!-- Welcome Tab Content -->
<div x-show="activeTab === 'Welcome'" x-cloak>
  <div class="card">
    <div class="card-body">
      <h5 class="card-title">
        <i class="fa-solid fa-hand-wave me-2"></i>
        <%= tr('greeting:WELCOME.TITLE', 'Willkommensnachrichten') %>
      </h5>
      <p class="text-muted"><%= tr('greeting:WELCOME.DESC', 'Konfiguriere Willkommensnachrichten für neue Mitglieder') %></p>
      
      <form id="welcomeForm">
        <div class="mb-3">
          <label class="form-label"><%= tr('greeting:CHANNEL_TITLE', 'Kanal') %></label>
          <select class="form-select" name="welcome_channel">
            <option value=""><%= tr('greeting:CHANNEL_SELECT', 'Kanal wählen...') %></option>
            <% if (channels && channels.length > 0) { %>
              <% channels.forEach(channel => { %>
                <option value="<%= channel.id %>" <%= settings.welcome.channel === channel.id ? 'selected' : '' %>>
                  #<%= channel.name %>
                </option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label"><%= tr('greeting:WELCOME.MESSAGE', 'Willkommensnachricht') %></label>
          <textarea class="form-control" name="welcome_content" rows="3"><%= settings.welcome.content || '' %></textarea>
          <small class="form-text text-muted">
            <%= tr('greeting:PLACEHOLDERS', 'Verfügbar: {member:name}, {member:mention}, {guild:name}, {guild:memberCount}') %>
          </small>
        </div>

        <div class="d-flex justify-content-between">
          <% if (settings.welcome.enabled) { %>
            <button type="button" class="btn btn-danger" onclick="updateWelcome('disable')">
              <%= tr('greeting:BTN_DISABLE', 'Deaktivieren') %>
            </button>
            <button type="button" class="btn btn-primary" onclick="updateWelcome('update')">
              <%= tr('greeting:BTN_SAVE', 'Speichern') %>
            </button>
          <% } else { %>
            <button type="button" class="btn btn-success" onclick="updateWelcome('enable')">
              <%= tr('greeting:BTN_ENABLE', 'Aktivieren') %>
            </button>
          <% } %>
        </div>
      </form>
    </div>
  </div>
</div>

