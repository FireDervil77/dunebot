<!-- DuneMap Settings -->

<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
          <i class="fa-solid fa-cog me-2"></i>
          <%= tr('dunemap:SETTINGS.PAGE_TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        <form id="dunemap-settings-form"
          class="guild-ajax-form" 
          data-form-type="dunemap-settings" 
          data-method="POST"
          action="/guild/<%= guildId %>/plugins/dunemap/settings"
        >
          
          <!-- Coriolis Storm Region -->
          <div class="mb-4">
            <label for="coriolis_region" class="form-label fw-bold">
              <i class="fa-solid fa-hurricane me-2"></i>
              <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.LABEL') %>
            </label>
            <select class="form-select" id="coriolis_region" name="coriolis_region">
              <option value="EU" <%= (settings.coriolis_region || 'EU') === 'EU' ? 'selected' : '' %>>
                🇪🇺 <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.EU') %> (19:00 - 05:00)
              </option>
              <option value="NA" <%= settings.coriolis_region === 'NA' ? 'selected' : '' %>>
                🇺🇸 <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.NA') %> (02:00 - 12:00)
              </option>
              <option value="SA" <%= settings.coriolis_region === 'SA' ? 'selected' : '' %>>
                🇧🇷 <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.SA') %> (00:00 - 10:00)
              </option>
              <option value="AS" <%= settings.coriolis_region === 'AS' ? 'selected' : '' %>>
                🇨🇳 <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.AS') %> (13:00 - 23:00)
              </option>
              <option value="OCE" <%= settings.coriolis_region === 'OCE' ? 'selected' : '' %>>
                🇦🇺 <%= tr('dunemap:SETTINGS.CORIOLIS_REGION.OCE') %> (11:00 - 21:00)
              </option>
            </select>
            <small class="text-muted"><%= tr('dunemap:SETTINGS.CORIOLIS_REGION.HELP') %></small>
          </div>

          <!-- Map Channel ID -->
          <div class="mb-4">
            <label for="MAP_CHANNEL_ID" class="form-label fw-bold">
              <i class="fa-brands fa-discord me-2"></i>
              <%= tr('dunemap:SETTINGS.CHANNEL.LABEL') %>
            </label>
            
            <% if (guildChannels && guildChannels.length > 0) { %>
              <!-- Dropdown wenn Channels verfügbar -->
              <select 
                class="form-select" 
                id="MAP_CHANNEL_ID" 
                name="MAP_CHANNEL_ID"
              >
                <option value=""><%= tr('dunemap:SETTINGS.CHANNEL.NO_SELECTION') %></option>
                <% 
                  let currentCategory = null;
                  // Type-safe Vergleich: Settings-Wert als String
                  const selectedChannelId = String(settings.MAP_CHANNEL_ID || '');
                  
                  guildChannels.forEach(channel => { 
                    // Kategorie-Header wenn neue Category
                    if (channel.parentName && channel.parentName !== currentCategory) {
                      currentCategory = channel.parentName;
                %>
                  <option disabled>━━━━ <%= currentCategory %> ━━━━</option>
                <%  } 
                    // Type-safe Vergleich
                    const isSelected = selectedChannelId === String(channel.id);
                %>
                  <option 
                    value="<%= channel.id %>" 
                    <%= isSelected ? 'selected' : '' %>
                  >
                    <%= channel.parentName ? '  └─ ' : '' %>#<%= channel.name %>
                  </option>
                <% }) %>
              </select>
              <small class="text-muted">
                <%= tr('dunemap:SETTINGS.CHANNEL.HELP') %>
                <% if (settings.MAP_CHANNEL_ID) { %>
                  <br><strong><%= tr('dunemap:SETTINGS.CHANNEL.CURRENT') %></strong> 
                  <% 
                    const currentChannel = guildChannels.find(ch => String(ch.id) === String(settings.MAP_CHANNEL_ID));
                  %>
                  <code>#<%= currentChannel ? currentChannel.name : settings.MAP_CHANNEL_ID %></code>
                <% } %>
              </small>
            <% } else { %>
              <!-- Fallback: Text-Input wenn IPC fehlschlägt -->
              <input 
                type="text" 
                class="form-control font-monospace" 
                id="MAP_CHANNEL_ID" 
                name="MAP_CHANNEL_ID"
                value="<%= settings.MAP_CHANNEL_ID %>"
                placeholder="<%= tr('dunemap:SETTINGS.CHANNEL.PLACEHOLDER') %>"
                pattern="[0-9]{17,20}"
              >
              <small class="text-muted text-warning">
                <i class="fa-solid fa-exclamation-triangle me-1"></i>
                <%= tr('dunemap:SETTINGS.CHANNEL.ERROR') %>
              </small>
            <% } %>
          </div>

          <!-- Submit-Button -->
          <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="fa-solid fa-save me-2"></i>
              <%= tr('dunemap:SETTINGS.SAVE_BUTTON') %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Hilfe-Sidebar -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-info-circle me-2"></i>
          <%= tr('dunemap:SETTINGS.HELP.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <h6 class="fw-bold">🌪️ <%= tr('dunemap:SETTINGS.HELP.STORM_TITLE') %></h6>
        <p class="small">
          Wähle deine Dune: Awakening Server-Region. Der Storm-Timer wird automatisch basierend auf den offiziellen Zeiten berechnet (wöchentlicher Reset, 10 Stunden Dauer).
        </p>

        <h6 class="fw-bold mt-3">💬 <%= tr('dunemap:SETTINGS.HELP.CHANNEL_TITLE') %></h6>
        <p class="small">
          <%= tr('dunemap:SETTINGS.HELP.CHANNEL_TEXT') %>
        </p>

        <h6 class="fw-bold mt-3">🗺️ <%= tr('dunemap:SETTINGS.HELP.SECTORS_TITLE') %></h6>
        <p class="small">
          <%- tr('dunemap:SETTINGS.HELP.SECTORS_TEXT') %>
        </p>
      </div>
    </div>

    <!-- Aktuelle Konfiguration -->
    <div class="card mt-3">
      <div class="card-header bg-secondary text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-list me-2"></i>
          <%= tr('dunemap:SETTINGS.CURRENT_CONFIG.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <table class="table table-sm table-borderless mb-0">
          <tbody>
            <tr>
              <td class="text-muted small"><%= tr('dunemap:SETTINGS.CURRENT_CONFIG.REGION') %></td>
              <td class="small">
                <% const regionFlags = { NA: '🇺🇸', SA: '🇧🇷', EU: '🇪🇺', AS: '🇨🇳', OCE: '🇦🇺' }; %>
                <% const regionNames = { NA: 'North America', SA: 'South America', EU: 'Europe', AS: 'Asia', OCE: 'Oceania' }; %>
                <% const currentRegion = settings.coriolis_region || 'EU'; %>
                <code><%= regionFlags[currentRegion] %> <%= regionNames[currentRegion] %></code>
              </td>
            </tr>
            <tr>
              <td class="text-muted small"><%= tr('dunemap:SETTINGS.CURRENT_CONFIG.CHANNEL') %></td>
              <td class="small font-monospace" style="font-size: 0.7rem;">
                <%= settings.MAP_CHANNEL_ID || tr('dunemap:SETTINGS.CURRENT_CONFIG.NOT_SET') %>
              </td>
            </tr>
          </tbody>
        </table>
        <hr class="my-2">
        <small class="text-muted d-block">
          <i class="fa-solid fa-info-circle me-1"></i>
          Storm-Zeiten werden automatisch basierend auf deiner Region berechnet (wöchentlicher Reset, 10h Dauer).
        </small>
      </div>
    </div>
  </div>
</div>

