<!-- DuneMap Admin - Interaktive Sektor-Karte -->

<div class="row mb-3">
  <div class="col-12">
    <div class="alert alert-info">
      <h5 class="mb-2">
        <i class="fa-solid fa-map-marked-alt me-2"></i>
        <%= tr('dunemap:ADMIN.TITLE') %>
      </h5>
      <p class="mb-0">
        <%= tr('dunemap:ADMIN.DESCRIPTION') %>
        <strong><%= tr('dunemap:ADMIN.MAX_MARKERS') %></strong>
      </p>
    </div>
  </div>
</div>

<div class="row">
  <!-- Karte -->
  <div class="col-lg-9">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
          <i class="fa-solid fa-th me-2"></i>
          <%= tr('dunemap:ADMIN.GRID_TITLE') %>
        </h5>
      </div>
      <div class="card-body p-2">
        <!-- Grid-Container (Koordinatensystem wie im Bot: A1 unten links, I9 oben rechts) -->
        <!-- WICHTIG: Keine data-* Attribute - Daten via AssetManager localize -->
        <div id="sectorGrid" 
             data-guild-id="<%= guildId %>"
             data-markers='<%- JSON.stringify(markers) %>'
             style="display: grid; grid-template-columns: 40px repeat(9, 1fr); gap: 2px; max-width: 100%;">
          <!-- Grid-Zeilen von oben nach unten (I -> A) -->
          <% const rows = ['I', 'H', 'G', 'F', 'E', 'D', 'C', 'B', 'A']; %>
          <% rows.forEach((row, rowIndex) => { %>
            <!-- Zeilen-Label (links) -->
            <div class="text-center fw-bold bg-secondary text-white p-2" style="font-size: 0.9rem;">
              <%= row %>
            </div>
            
            <!-- Sektoren dieser Zeile (1-9 von links nach rechts) -->
            <% for (let col = 1; col <= 9; col++) { %>
              <% 
                const sectorId = row + col;
                const sectorMarkers = markers.filter(m => m.sector_x === row && m.sector_y === col);
                // PvE-Zone: Reihen A-E, alle Spalten (grüner Rahmen)
                const isPvE = ['A', 'B', 'C', 'D', 'E'].includes(row);
                // Trennlinie nach Reihe E (horizontal durch die Mitte)
                const isLastPvERow = row === 'E';
              %>
              <div 
                class="sector-cell <%= isLastPvERow ? 'pve-border' : '' %>" 
                data-sector-x="<%= row %>" 
                data-sector-y="<%= col %>"
                style="
                  border: 3px solid <%= isPvE ? '#28a745' : '#dee2e6' %>;
                  background: <%= isLastPvERow 
                    ? (sectorMarkers.length > 0 
                        ? 'linear-gradient(to bottom, #d4edda 0%, #d4edda 50%, #e7f3ff 50%, #e7f3ff 100%)' 
                        : 'linear-gradient(to bottom, #f0f9f4 0%, #f0f9f4 50%, #fff 50%, #fff 100%)')
                    : (sectorMarkers.length > 0 ? (isPvE ? '#d4edda' : '#e7f3ff') : (isPvE ? '#f0f9f4' : '#fff')) 
                  %>;
                  min-height: 70px;
                  cursor: pointer;
                  position: relative;
                  transition: all 0.2s;
                "
              >
                <!-- Marker-Anzeige mit Icons -->
                <% if (sectorMarkers.length > 0) { %>
                  <div class="p-1 d-flex flex-wrap gap-1 justify-content-center align-items-center" style="pointer-events: none;">
                    <% sectorMarkers.forEach(marker => { %>
                      <img 
                        src="/assets/plugins/dunemap/icons/<%= marker.marker_type %>.png" 
                        alt="<%= marker.marker_type %>"
                        title="<%= marker.marker_type %>"
                        style="width: 24px; height: 24px; object-fit: contain; pointer-events: none;"
                      >
                    <% }); %>
                  </div>
                <% } %>
                
                <!-- Sektor-Label (beim Hover) -->
                <div class="sector-label" style="
                  position: absolute;
                  bottom: 2px;
                  right: 2px;
                  font-size: 0.7rem;
                  color: #6c757d;
                  opacity: 0.5;
                  font-weight: bold;
                ">
                  <%= sectorId %>
                </div>
                
                <!-- PvE-Marker (optional) -->
                <% if (isPvE && col === 1) { %>
                  <div style="
                    position: absolute;
                    top: 2px;
                    left: 2px;
                    font-size: 0.6rem;
                    color: #28a745;
                    font-weight: bold;
                    pointer-events: none;
                  ">
                    PvE
                  </div>
                <% } %>
              </div>
            <% } %>
          <% }); %>
          
          <!-- Footer-Zeile (Zahlen 1-9 unten) -->
          <div></div>
          <% for (let col = 1; col <= 9; col++) { %>
            <div class="text-center fw-bold bg-secondary text-white p-2" style="font-size: 0.9rem;">
              <%= col %>
            </div>
          <% } %>
        </div>
        
        <!-- Legende -->
        <div class="mt-3 p-2 bg-light border rounded">
          <small class="fw-bold"><%= tr('dunemap:ADMIN.LEGEND_TITLE') %></small>
          <div class="d-flex gap-3 mt-1">
            <small>
              <span style="display: inline-block; width: 12px; height: 12px; background: #28a745; border: 2px solid #28a745;"></span>
              <%= tr('dunemap:ADMIN.PVE_ZONE') %>
            </small>
            <small>
              <span style="display: inline-block; width: 12px; height: 12px; background: #dee2e6; border: 2px solid #dee2e6;"></span>
              <%= tr('dunemap:ADMIN.PVP_ZONE') %>
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Marker-Editor Sidebar -->
  <div class="col-lg-3">
    <div class="card" id="markerEditor" style="display: none;">
      <div class="card-header bg-success text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-edit me-2"></i>
          <%= tr('dunemap:ADMIN.EDITOR.TITLE') %> <span id="currentSector">-</span>
        </h6>
      </div>
      <div class="card-body">
        <!-- Aktuelle Marker -->
        <div id="currentMarkers" class="mb-3">
          <h6 class="fw-bold"><%= tr('dunemap:ADMIN.EDITOR.CURRENT_MARKERS') %></h6>
          <div id="markerList" class="mb-2">
            <p class="text-muted small"><%= tr('dunemap:ADMIN.EDITOR.NO_MARKERS') %></p>
          </div>
        </div>

        <!-- Marker hinzufügen -->
        <div class="mb-3">
          <h6 class="fw-bold"><%= tr('dunemap:ADMIN.EDITOR.ADD_MARKER') %></h6>
          
          <!-- Custom Dropdown mit Icons -->
          <div class="custom-marker-select mb-2">
            <input type="hidden" id="markerTypeSelect" value="">
            <div class="marker-select-display" id="markerSelectDisplay">
              <span class="placeholder-text"><%= tr('dunemap:ADMIN.EDITOR.SELECT_TYPE') %></span>
              <i class="fa-solid fa-chevron-down float-end mt-1"></i>
            </div>
            <div class="marker-select-dropdown" id="markerSelectDropdown" style="display: none;">
              
              <!-- Resources -->
              <div class="marker-group-label"><%= tr('dunemap:ADMIN.EDITOR.RESOURCES') %></div>
              <div class="marker-option" data-value="titan">
                <img src="/assets/plugins/dunemap/icons/titan.png" alt="Titan" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.TITAN') %></span>
              </div>
              <div class="marker-option" data-value="spice">
                <img src="/assets/plugins/dunemap/icons/spice.png" alt="Spice" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.SPICE') %></span>
              </div>
              <div class="marker-option" data-value="stravidium">
                <img src="/assets/plugins/dunemap/icons/stravidium.png" alt="Stravidium" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.STRAVIDIUM') %></span>
              </div>
              <div class="marker-option" data-value="aluminium">
                <img src="/assets/plugins/dunemap/icons/aluminium.png" alt="Aluminium" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.ALUMINIUM') %></span>
              </div>
              <div class="marker-option" data-value="eisen">
                <img src="/assets/plugins/dunemap/icons/eisen.png" alt="Eisen" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.EISEN') %></span>
              </div>
              
              <!-- Other -->
              <div class="marker-group-label"><%= tr('dunemap:ADMIN.EDITOR.OTHER') %></div>
              <div class="marker-option" data-value="basalt">
                <img src="/assets/plugins/dunemap/icons/basalt.png" alt="Basalt" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.BASALT') %></span>
              </div>
              <div class="marker-option" data-value="karbon">
                <img src="/assets/plugins/dunemap/icons/karbon.png" alt="Karbon" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.KARBON') %></span>
              </div>
              <div class="marker-option" data-value="hoele">
                <img src="/assets/plugins/dunemap/icons/hoele.png" alt="Höhle" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.HOELE') %></span>
              </div>
              <div class="marker-option" data-value="hole">
                <img src="/assets/plugins/dunemap/icons/hole.png" alt="Hole" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.HOLE') %></span>
              </div>
              
              <!-- Structures -->
              <div class="marker-group-label"><%= tr('dunemap:ADMIN.EDITOR.STRUCTURES') %></div>
              <div class="marker-option" data-value="base">
                <img src="/assets/plugins/dunemap/icons/base.png" alt="Base" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.BASE') %></span>
              </div>
              <div class="marker-option" data-value="wrack">
                <img src="/assets/plugins/dunemap/icons/wrack.png" alt="Wrack" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.WRACK') %></span>
              </div>
              <div class="marker-option" data-value="kontrollpunkt">
                <img src="/assets/plugins/dunemap/icons/kontrollpunkt.png" alt="Kontrollpunkt" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.KONTROLLPUNKT') %></span>
              </div>
              
              <!-- Utilities -->
              <div class="marker-group-label"><%= tr('dunemap:ADMIN.EDITOR.UTILITIES') %></div>
              <div class="marker-option" data-value="taxi">
                <img src="/assets/plugins/dunemap/icons/taxi.png" alt="Taxi" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.TAXI') %></span>
              </div>
              <div class="marker-option" data-value="test">
                <img src="/assets/plugins/dunemap/icons/test.png" alt="Test" class="marker-icon-sm">
                <span><%= tr('dunemap:ADMIN.MARKER_TYPES.TEST') %></span>
              </div>
            </div>
          </div>
          
          <!-- Icon-Vorschau (behalten wir als Backup) -->
          <div id="iconPreview" class="text-center mb-2" style="display: none;">
            <img id="previewImg" src="" alt="" style="width: 48px; height: 48px; object-fit: contain;">
          </div>
          <button class="btn btn-success btn-sm w-100" id="addMarkerBtn" disabled>
            <i class="fa-solid fa-plus me-1"></i>
            <%= tr('dunemap:ADMIN.EDITOR.BTN_ADD') %>
          </button>
        </div>

        <button class="btn btn-secondary btn-sm w-100" id="closeEditorBtn">
          <i class="fa-solid fa-times me-1"></i>
          <%= tr('dunemap:ADMIN.EDITOR.BTN_CLOSE') %>
        </button>
      </div>
    </div>

    <!-- Statistiken -->
    <div class="card mt-3">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-chart-bar me-2"></i>
          <%= tr('dunemap:ADMIN.STATS.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <p class="mb-2 small">
          <strong><%= tr('dunemap:ADMIN.STATS.TOTAL_MARKERS') %></strong> <%= markers.length %>
        </p>
        <p class="mb-2 small">
          <strong><%= tr('dunemap:ADMIN.STATS.OCCUPIED_SECTORS') %></strong> 
          <%= [...new Set(markers.map(m => m.sector_x + m.sector_y))].length %>
        </p>
        <p class="mb-0 small">
          <strong><%= tr('dunemap:ADMIN.STATS.AVAILABLE') %></strong> 
          <%= 81 - [...new Set(markers.map(m => m.sector_x + m.sector_y))].length %>
        </p>
      </div>
    </div>
    
    <!-- Coriolis Storm Timer -->
    <div class="card mt-3">
      <div class="card-header bg-warning text-dark">
        <h6 class="mb-0">
          <i class="fa-solid fa-wind me-2"></i>
          <%= tr('dunemap:ADMIN.STORM.TITLE') %>
          <span id="storm-active-badge" class="badge bg-danger float-end" style="display: none;">
            ⚡ AKTIV
          </span>
        </h6>
      </div>
      <div class="card-body p-3">
        <div id="stormTimer" class="text-center">
          <!-- Region Info -->
          <div class="mb-2">
            <small class="text-muted d-block mb-1"><%= tr('dunemap:ADMIN.STORM.REGION_LABEL') %></small>
            <div id="storm-region-name" class="fw-bold" style="font-size: 0.9rem;">
              🇪🇺 Europe
            </div>
          </div>
          
          <!-- Countdown -->
          <div class="mb-2">
            <strong class="d-block mb-1" style="font-size: 0.75rem;">
              <%= tr('dunemap:ADMIN.STORM.NEXT_RESET') %>
            </strong>
            <div id="countdown" class="badge bg-danger" style="font-size: 1.1rem; font-family: monospace; padding: 0.5rem 1rem;">
              --d --h --m --s
            </div>
          </div>
          
          <!-- Storm-Zeit -->
          <hr class="my-2">
          <div style="font-size: 0.75rem;" class="text-muted">
            <i class="fa-solid fa-clock me-1"></i>
            <%= tr('dunemap:ADMIN.STORM.TIME_LABEL') %>
            <strong id="storm-time" class="text-dark">19:00 - 05:00</strong>
          </div>
          
          <!-- Hinweis -->
          <div class="mt-2 p-2 bg-light rounded" style="font-size: 0.7rem;">
            <i class="fa-solid fa-info-circle me-1"></i>
            <%= tr('dunemap:ADMIN.STORM.HELP_TEXT') %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 
  Assets werden jetzt via AssetManager geladen!
  Siehe: plugins/dunemap/dashboard/index.js -> _registerAssets()
  
  Registrierte Scripts:
  - dunemap-admin.js (enqueued in /admin route)
  
  Rendering erfolgt automatisch im Layout:
  - CSS in guild/header.ejs via assetManager.renderStyles()
  - JS in guild.ejs footer via assetManager.renderScripts(true)
-->

<style>
.sector-cell {
  border-radius: 4px;
}

/* Custom Marker Select Dropdown */
.custom-marker-select {
  position: relative;
}

.marker-select-display {
  background: white;
  border: 1px solid #ced4da;
  border-radius: 0.25rem;
  padding: 0.375rem 0.75rem;
  cursor: pointer;
  font-size: 0.875rem;
  transition: border-color 0.15s ease-in-out;
}

.marker-select-display:hover {
  border-color: #86b7fe;
}

.marker-select-display.active {
  border-color: #86b7fe;
  box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.marker-select-display .placeholder-text {
  color: #6c757d;
}

.marker-select-display img {
  margin-right: 8px;
}

.marker-select-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: white;
  border: 1px solid #ced4da;
  border-radius: 0.25rem;
  margin-top: 4px;
  max-height: 300px;
  overflow-y: auto;
  z-index: 1000;
  box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
}

.marker-group-label {
  padding: 6px 12px;
  font-size: 0.75rem;
  font-weight: 600;
  color: #6c757d;
  text-transform: uppercase;
  background: #f8f9fa;
  border-bottom: 1px solid #dee2e6;
}

.marker-option {
  padding: 8px 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  transition: background-color 0.15s ease-in-out;
  font-size: 0.875rem;
}

.marker-option:hover {
  background-color: #f8f9fa;
}

.marker-option.selected {
  background-color: #e7f1ff;
  font-weight: 500;
}

.marker-icon-sm {
  width: 24px;
  height: 24px;
  margin-right: 10px;
  object-fit: contain;
}

/* PvE/PvP Trennlinie - horizontal durch die Mitte der E-Reihe */
.sector-cell.pve-border::after {
  content: '';
  position: absolute;
  top: 50%;
  left: -3px;
  right: -3px;
  bottom: -3px;
  background: linear-gradient(to bottom, transparent 0%, transparent 50%, rgba(40, 167, 69, 0.15) 50%, rgba(40, 167, 69, 0.15) 100%);
  border-top: 3px solid #28a745;
  z-index: 5;
  pointer-events: none;
}

/* Alternative: Einfache horizontale Linie in der Mitte */
.sector-cell.pve-border::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 3px;
  background: #28a745;
  z-index: 10;
  pointer-events: none;
  transform: translateY(-50%);
}

.sector-cell:hover .sector-label {
  opacity: 1 !important;
  font-weight: bold;
}
</style>

<!-- 
  DuneMap Admin Script wird automatisch via AssetManager geladen!
  Siehe Kommentar oben: "dunemap-admin.js (enqueued in /admin route)"
  NICHT manuell einbinden, sonst wird es doppelt geladen!
-->
