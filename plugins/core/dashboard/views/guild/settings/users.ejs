<!-- Core Plugin - Benutzer-Verwaltung -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fa-solid fa-users me-2"></i>
      <%= tr('core:USERS.TITLE') %>
    </h3>
  </div>
  <div class="card-body">
    
    <div class="alert alert-info">
      <i class="fa-solid fa-info-circle me-2"></i>
      <strong><%= tr('core:USERS.NOTICE_TITLE') %></strong> <%= tr('core:USERS.NOTICE_TEXT') %>
    </div>

    <!-- Benutzer-Tabelle (Platzhalter) -->
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><i class="fa-solid fa-user me-1"></i> <%= tr('core:USERS.TABLE_USER') %></th>
            <th><i class="fa-solid fa-shield me-1"></i> <%= tr('core:USERS.TABLE_ROLE') %></th>
            <th><i class="fa-solid fa-calendar me-1"></i> <%= tr('core:USERS.TABLE_JOINED') %></th>
            <th><i class="fa-solid fa-gear me-1"></i> <%= tr('core:USERS.TABLE_ACTIONS') %></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="4" class="text-center text-muted py-4">
              <i class="fa-solid fa-users fa-3x mb-3 d-block opacity-25"></i>
              <%= tr('core:USERS.TABLE_EMPTY') %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Platzhalter für zukünftige Features -->
    <div class="row mt-4">
      <div class="col-md-6">
        <div class="card bg-light">
          <div class="card-body">
            <h5 class="card-title">
              <i class="fa-solid fa-user-shield me-2"></i>
              <%= tr('core:USERS.ROLES_TITLE') %>
            </h5>
            <p class="card-text text-muted">
              <%= tr('core:USERS.ROLES_DESC') %>
            </p>
            <button class="btn btn-secondary btn-sm" disabled>
              <i class="fa-solid fa-lock me-1"></i>
              <%= tr('core:USERS.COMING_SOON') %>
            </button>
          </div>
        </div>
      </div>
      
      <div class="col-md-6">
        <div class="card bg-light">
          <div class="card-body">
            <h5 class="card-title">
              <i class="fa-solid fa-ban me-2"></i>
              <%= tr('core:USERS.BANNED_TITLE') %>
            </h5>
            <p class="card-text text-muted">
              <%= tr('core:USERS.BANNED_DESC') %>
            </p>
            <button class="btn btn-secondary btn-sm" disabled>
              <i class="fa-solid fa-lock me-1"></i>
              <%= tr('core:USERS.COMING_SOON') %>
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
