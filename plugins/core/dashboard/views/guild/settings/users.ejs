<!-- Core Plugin - Benutzer-Verwaltung -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fa-solid fa-users me-2"></i>
      <%= tr('core:USERS.TITLE') %>
    </h3>
    <div class="card-tools">
      <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addStaffModal">
        <i class="fa-solid fa-user-plus me-1"></i>
        Benutzer hinzufügen
      </button>
    </div>
  </div>
  <div class="card-body">
    
    <div class="alert alert-info">
      <i class="fa-solid fa-info-circle me-2"></i>
      <strong>Dashboard-Berechtigungen</strong><br>
      Hier kannst du Benutzern Zugriff auf diesen Server im Dashboard gewähren, auch ohne Discord-Administratorrechte.
    </div>

    <!-- Guild Staff Tabelle -->
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><i class="fa-solid fa-user me-1"></i> Benutzer</th>
            <th><i class="fa-solid fa-shield me-1"></i> Rolle</th>
            <th><i class="fa-solid fa-key me-1"></i> Berechtigungen</th>
            <th><i class="fa-solid fa-calendar me-1"></i> Hinzugefügt</th>
            <th><i class="fa-solid fa-clock me-1"></i> Läuft ab</th>
            <th><i class="fa-solid fa-gear me-1"></i> Aktionen</th>
          </tr>
        </thead>
        <tbody id="staffTable">
          <% if (staffMembers && staffMembers.length > 0) { %>
            <% staffMembers.forEach(member => { %>
              <tr data-user-id="<%= member.user_id %>">
                <td>
                  <div class="d-flex align-items-center">
                    <% if (member.avatarURL) { %>
                      <img src="<%= member.avatarURL %>" alt="<%= member.username %>" class="rounded-circle me-2" width="32" height="32">
                    <% } else { %>
                      <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                        <i class="fa-solid fa-user"></i>
                      </div>
                    <% } %>
                    <div>
                      <strong><%= member.username || member.user_id %></strong>
                      <% if (member.discriminator && member.discriminator !== '0') { %>
                        <span class="text-muted">#<%= member.discriminator %></span>
                      <% } %>
                      <br>
                      <small class="text-muted">ID: <%= member.user_id %></small>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (member.role === 'admin') { %>
                    <span class="badge bg-danger"><i class="fa-solid fa-crown me-1"></i> Admin</span>
                  <% } else if (member.role === 'manager') { %>
                    <span class="badge bg-warning"><i class="fa-solid fa-user-tie me-1"></i> Manager</span>
                  <% } else if (member.role === 'moderator') { %>
                    <span class="badge bg-info"><i class="fa-solid fa-gavel me-1"></i> Moderator</span>
                  <% } else { %>
                    <span class="badge bg-secondary"><i class="fa-solid fa-eye me-1"></i> Viewer</span>
                  <% } %>
                </td>
                <td>
                  <% if (member.can_manage_settings) { %>
                    <i class="fa-solid fa-cog text-success" title="Einstellungen verwalten"></i>
                  <% } %>
                  <% if (member.can_manage_plugins) { %>
                    <i class="fa-solid fa-puzzle-piece text-primary ms-1" title="Plugins verwalten"></i>
                  <% } %>
                  <% if (member.can_view_logs) { %>
                    <i class="fa-solid fa-file-lines text-info ms-1" title="Logs einsehen"></i>
                  <% } %>
                </td>
                <td>
                  <%= new Date(member.granted_at).toLocaleDateString('de-DE') %>
                  <small class="text-muted d-block">von <%= member.granted_by %></small>
                </td>
                <td>
                  <% if (member.expires_at) { %>
                    <%= new Date(member.expires_at).toLocaleDateString('de-DE') %>
                  <% } else { %>
                    <span class="text-muted">Nie</span>
                  <% } %>
                </td>
                <td>
                  <button type="button" class="btn btn-danger btn-sm remove-staff-btn" data-user-id="<%= member.user_id %>">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">
                <i class="fa-solid fa-users fa-3x mb-3 d-block opacity-25"></i>
                Keine Dashboard-Berechtigungen vergeben
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

  </div>
</div>

<!-- Add Staff Modal -->
<div class="modal fade" id="addStaffModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form class="guild-ajax-form" data-form-type="add-staff" data-method="POST" action="/guild/<%= guildId %>/plugins/core/settings/users/staff" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">
            <i class="fa-solid fa-user-plus me-2"></i>
            Benutzer hinzufügen
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          
          <!-- User ID -->
          <div class="mb-3">
            <label class="form-label">Discord User ID <span class="text-danger">*</span></label>
            <input type="text" name="user_id" class="form-control" placeholder="z.B. 123456789012345678" required pattern="[0-9]{17,19}">
            <small class="text-muted">Die 18-stellige Discord ID des Benutzers</small>
          </div>

          <!-- Rolle -->
          <div class="mb-3">
            <label class="form-label">Rolle <span class="text-danger">*</span></label>
            <select name="role" class="form-select" required>
              <option value="admin">Admin - Vollzugriff</option>
              <option value="manager" selected>Manager - Einstellungen & Plugins</option>
              <option value="moderator">Moderator - Nur Logs</option>
              <option value="viewer">Viewer - Nur Ansicht</option>
            </select>
          </div>

          <!-- Granulare Berechtigungen -->
          <div class="mb-3">
            <label class="form-label">Berechtigungen</label>
            <div class="form-check">
              <input type="checkbox" name="can_manage_settings" value="1" class="form-check-input" id="perm_settings" checked>
              <label class="form-check-label" for="perm_settings">
                <i class="fa-solid fa-cog me-1"></i> Einstellungen verwalten
              </label>
            </div>
            <div class="form-check">
              <input type="checkbox" name="can_manage_plugins" value="1" class="form-check-input" id="perm_plugins" checked>
              <label class="form-check-label" for="perm_plugins">
                <i class="fa-solid fa-puzzle-piece me-1"></i> Plugins verwalten
              </label>
            </div>
            <div class="form-check">
              <input type="checkbox" name="can_view_logs" value="1" class="form-check-input" id="perm_logs">
              <label class="form-check-label" for="perm_logs">
                <i class="fa-solid fa-file-lines me-1"></i> Logs einsehen
              </label>
            </div>
          </div>

          <!-- Ablaufdatum (optional) -->
          <div class="mb-3">
            <label class="form-label">Ablaufdatum (optional)</label>
            <input type="date" name="expires_at" class="form-control">
            <small class="text-muted">Leer lassen für unbegrenzten Zugriff</small>
          </div>

          <!-- Notizen (optional) -->
          <div class="mb-3">
            <label class="form-label">Notizen (optional)</label>
            <textarea name="notes" class="form-control" rows="2" placeholder="z.B. Grund für die Berechtigung"></textarea>
          </div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
          <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>
            Hinzufügen
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Remove Staff Button Handler
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.remove-staff-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
            const userId = this.dataset.userId;
            
            if (!confirm(`Berechtigung für User ${userId} wirklich entfernen?`)) {
                return;
            }
            
            try {
                const response = await fetch(`/guild/<%= guildId %>/plugins/core/settings/users/staff/${userId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Zeile aus Tabelle entfernen
                    document.querySelector(`tr[data-user-id="${userId}"]`).remove();
                    
                    // Toast anzeigen
                    if (typeof window.showToast === 'function') {
                        window.showToast('success', data.message || 'Benutzer entfernt');
                    }
                } else {
                    if (typeof window.showToast === 'function') {
                        window.showToast('error', data.message || 'Fehler beim Entfernen');
                    } else {
                        alert(data.message || 'Fehler beim Entfernen');
                    }
                }
            } catch (err) {
                console.error('Error removing staff:', err);
                if (typeof window.showToast === 'function') {
                    window.showToast('error', 'Serverfehler beim Entfernen');
                } else {
                    alert('Serverfehler beim Entfernen');
                }
            }
        });
    });
});
</script>
