<!-- Core Plugin - Allgemeine Einstellungen -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fa-solid fa-sliders me-2"></i>
      Allgemeine Einstellungen
    </h3>
  </div>
  <div class="card-body">
    <form id="general-settings-form">
      
      <!-- Bot-Präfix -->
      <div class="mb-4">
        <label for="botPrefix" class="form-label">
          <i class="fa-solid fa-terminal me-1"></i>
          Bot-Präfix
        </label>
        <input 
          type="text" 
          class="form-control" 
          id="botPrefix" 
          name="prefix" 
          value="!"
          maxlength="5"
          placeholder="!"
        >
        <div class="form-text">Das Präfix für Text-Befehle (z.B. !help)</div>
      </div>

      <!-- Standard-Sprache -->
      <div class="mb-4">
        <label for="defaultLocale" class="form-label">
          <i class="fa-solid fa-language me-1"></i>
          Standard-Sprache
        </label>
        <select class="form-select" id="defaultLocale" name="locale">
          <option value="de-DE" selected>Deutsch</option>
          <option value="en-GB">English (UK)</option>
          <option value="en-US">English (US)</option>
        </select>
        <div class="form-text">Die Standard-Sprache für Bot-Antworten</div>
      </div>

      <!-- Debug-Modus -->
      <div class="mb-4">
        <div class="form-check form-switch">
          <input 
            class="form-check-input" 
            type="checkbox" 
            id="debugMode" 
            name="debugMode"
          >
          <label class="form-check-label" for="debugMode">
            <i class="fa-solid fa-bug me-1"></i>
            Debug-Modus aktivieren
          </label>
          <div class="form-text">Zeigt erweiterte Fehlerinfos in der Konsole</div>
        </div>
      </div>

      <!-- Erweiterte Logs -->
      <div class="mb-4">
        <div class="form-check form-switch">
          <input 
            class="form-check-input" 
            type="checkbox" 
            id="verboseLogs" 
            name="verboseLogs"
          >
          <label class="form-check-label" for="verboseLogs">
            <i class="fa-solid fa-file-lines me-1"></i>
            Erweiterte Logs
          </label>
          <div class="form-text">Protokolliert alle Bot-Aktionen detailliert</div>
        </div>
      </div>

      <!-- Speichern Button -->
      <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-save me-1"></i>
          Einstellungen speichern
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// Form Submit Handler
document.getElementById('general-settings-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const formData = new FormData(e.target);
  const data = {
    prefix: formData.get('prefix'),
    locale: formData.get('locale'),
    debugMode: formData.get('debugMode') === 'on',
    verboseLogs: formData.get('verboseLogs') === 'on'
  };
  
  try {
    const response = await fetch('/api/core/settings/general', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    
    if (response.ok) {
      showAlert('success', 'Einstellungen erfolgreich gespeichert!');
    } else {
      throw new Error('Fehler beim Speichern');
    }
  } catch (err) {
    showAlert('danger', `Fehler: ${err.message}`);
  }
});

function showAlert(type, message) {
  const alertDiv = document.createElement('div');
  alertDiv.className = `alert alert-${type} alert-dismissible fade show mt-3`;
  alertDiv.innerHTML = `
    ${message}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  `;
  
  const form = document.getElementById('general-settings-form');
  form.parentNode.insertBefore(alertDiv, form);
  
  setTimeout(() => alertDiv.remove(), 5000);
}
</script>
