<!-- Core Plugin - Integrationen -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fa-solid fa-plug me-2"></i>
      Integrationen
    </h3>
  </div>
  <div class="card-body">
    
    <div class="alert alert-info mb-4">
      <i class="fa-solid fa-info-circle me-2"></i>
      <strong>Hinweis:</strong> Verbinde DuneBot mit externen Services und APIs.
    </div>

    <!-- Verfügbare Integrationen -->
    <div class="row g-3">
      
      <!-- Webhook Integration -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <div class="flex-shrink-0">
                <i class="fa-solid fa-webhook fa-2x text-primary"></i>
              </div>
              <div class="flex-grow-1 ms-3">
                <h5 class="card-title mb-0">Webhooks</h5>
                <small class="text-muted">Empfange externe Events</small>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="webhookEnabled" disabled>
              </div>
            </div>
            <p class="card-text text-muted small">
              Konfiguriere Webhooks um externe Events in deinem Server zu empfangen.
            </p>
            <button class="btn btn-sm btn-outline-secondary" disabled>
              <i class="fa-solid fa-gear me-1"></i>
              Konfigurieren
            </button>
          </div>
        </div>
      </div>

      <!-- Twitch Integration -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <div class="flex-shrink-0">
                <i class="fa-brands fa-twitch fa-2x" style="color: #9146FF;"></i>
              </div>
              <div class="flex-grow-1 ms-3">
                <h5 class="card-title mb-0">Twitch</h5>
                <small class="text-muted">Stream-Benachrichtigungen</small>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="twitchEnabled" disabled>
              </div>
            </div>
            <p class="card-text text-muted small">
              Erhalte Benachrichtigungen wenn deine Streamer live gehen.
            </p>
            <button class="btn btn-sm btn-outline-secondary" disabled>
              <i class="fa-solid fa-gear me-1"></i>
              Konfigurieren
            </button>
          </div>
        </div>
      </div>

      <!-- YouTube Integration -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <div class="flex-shrink-0">
                <i class="fa-brands fa-youtube fa-2x text-danger"></i>
              </div>
              <div class="flex-grow-1 ms-3">
                <h5 class="card-title mb-0">YouTube</h5>
                <small class="text-muted">Video-Benachrichtigungen</small>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="youtubeEnabled" disabled>
              </div>
            </div>
            <p class="card-text text-muted small">
              Benachrichtigungen bei neuen Videos deiner Lieblings-YouTuber.
            </p>
            <button class="btn btn-sm btn-outline-secondary" disabled>
              <i class="fa-solid fa-gear me-1"></i>
              Konfigurieren
            </button>
          </div>
        </div>
      </div>

      <!-- Custom API Integration -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <div class="flex-shrink-0">
                <i class="fa-solid fa-code fa-2x text-success"></i>
              </div>
              <div class="flex-grow-1 ms-3">
                <h5 class="card-title mb-0">Custom API</h5>
                <small class="text-muted">Eigene API-Integration</small>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="customApiEnabled" disabled>
              </div>
            </div>
            <p class="card-text text-muted small">
              Verbinde den Bot mit deiner eigenen API oder externen Services.
            </p>
            <button class="btn btn-sm btn-outline-secondary" disabled>
              <i class="fa-solid fa-gear me-1"></i>
              Konfigurieren
            </button>
          </div>
        </div>
      </div>

    </div>

    <!-- Info Box -->
    <div class="alert alert-warning mt-4">
      <i class="fa-solid fa-triangle-exclamation me-2"></i>
      <strong>In Entwicklung:</strong> Diese Features werden in zukünftigen Updates verfügbar sein.
    </div>

  </div>
</div>
