<!-- 
  Berechtigungsmatrix - Permission System
  Übersicht aller Berechtigungen für alle Gruppen (Matrix-Ansicht)
-->

<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h2 class="mb-1">
          <i class="fa-solid fa-table text-primary me-2"></i>
          Berechtigungsmatrix
        </h2>
        <p class="text-muted mb-0">
          Übersicht aller Berechtigungen für alle Gruppen
        </p>
      </div>
      
      <% if (userPermissions.permissions['PERMISSIONS.MATRIX.EDIT']) { %>
      <button type="button" class="btn btn-success" id="saveMatrixBtn">
        <i class="fa-solid fa-save me-2"></i>
        Änderungen speichern
      </button>
      <% } %>
    </div>
  </div>
</div>

<!-- Info Alert -->
<div class="row mb-4">
  <div class="col-12">
    <div class="alert alert-info">
      <i class="fa-solid fa-circle-info me-2"></i>
      <strong>Tipp:</strong> 
      Diese Matrix zeigt alle verfügbaren Berechtigungen und welche Gruppen sie besitzen. 
      Setze oder entferne Häkchen und klicke auf "Änderungen speichern".
    </div>
  </div>
</div>

<% if (groups.length === 0) { %>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-solid fa-table text-muted" style="font-size: 4rem;"></i>
        <h4 class="mt-3">Keine Gruppen vorhanden</h4>
        <p class="text-muted">Erstelle zuerst Gruppen, um die Matrix zu nutzen.</p>
        
        <a href="/guild/<%= guildId %>/plugins/core/permissions/groups" class="btn btn-primary mt-2">
          <i class="fa-solid fa-user-group me-2"></i>
          Zu den Gruppen
        </a>
      </div>
    </div>
  </div>
</div>
<% } else { %>

<!-- Matrix-Tabelle -->
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered table-hover mb-0" id="permissionMatrix">
            <thead class="table-light">
              <tr>
                <th style="width: 300px; position: sticky; left: 0; z-index: 10; background-color: #f8f9fa;">
                  <i class="fa-solid fa-key me-2"></i>
                  Berechtigung
                </th>
                <% groups.forEach(group => { %>
                <th class="text-center" style="min-width: 120px;">
                  <div class="d-flex flex-column align-items-center">
                    <span class="badge mb-1" style="background-color: <%= group.color %>;">
                      <%= group.name %>
                    </span>
                    <small class="text-muted">
                      <%= group.member_count || 0 %> User
                    </small>
                  </div>
                </th>
                <% }); %>
              </tr>
            </thead>
            <tbody>
              <% if (permissions && Object.keys(permissions).length > 0) {
                Object.keys(permissions).forEach(category => { %>
                
                <!-- Kategorie-Header -->
                <tr class="table-secondary">
                  <td colspan="<%= groups.length + 1 %>">
                    <strong class="text-uppercase">
                      <i class="fa-solid fa-folder-open me-2"></i>
                      <%= category %>
                    </strong>
                  </td>
                </tr>
                
                <!-- Permissions der Kategorie -->
                <% permissions[category].forEach(perm => { %>
                <tr data-permission="<%= perm.permission_key %>">
                  <td style="position: sticky; left: 0; z-index: 5; background-color: white;">
                    <div class="ps-3">
                      <strong><%= tr(perm.name_translation_key) %></strong>
                      <% if (perm.description_translation_key) { %>
                      <br><small class="text-muted"><%= tr(perm.description_translation_key) %></small>
                      <% } %>
                      <% if (perm.is_dangerous) { %>
                      <br><span class="badge bg-danger">Kritisch</span>
                      <% } %>
                    </div>
                  </td>
                  
                  <% groups.forEach(group => { 
                    const hasPermission = group.permissions && group.permissions[perm.permission_key] === true;
                    const isWildcard = group.permissions && (group.permissions['*'] === true || group.permissions[category + '.*'] === true);
                  %>
                  <td class="text-center align-middle">
                    <% if (group.is_protected && isWildcard) { %>
                      <!-- Geschützte Gruppen mit Wildcard (Owner) -->
                      <i class="fa-solid fa-check-circle text-success" 
                         data-bs-toggle="tooltip" 
                         title="Durch Wildcard-Berechtigung gewährt"></i>
                    <% } else if (userPermissions.permissions['PERMISSIONS.MATRIX.EDIT']) { %>
                      <!-- Bearbeitbare Checkbox -->
                      <div class="form-check d-flex justify-content-center">
                        <input class="form-check-input permission-checkbox" 
                               type="checkbox" 
                               data-group-id="<%= group.id %>"
                               data-permission-key="<%= perm.permission_key %>"
                               <%= hasPermission ? 'checked' : '' %>
                               <%= group.is_protected ? 'disabled' : '' %>>
                      </div>
                    <% } else { %>
                      <!-- Read-Only View -->
                      <% if (hasPermission) { %>
                      <i class="fa-solid fa-check-circle text-success"></i>
                      <% } else { %>
                      <i class="fa-solid fa-circle text-muted"></i>
                      <% } %>
                    <% } %>
                  </td>
                  <% }); %>
                </tr>
                <% }); %>
              <% }); 
              } else { %>
                <tr>
                  <td colspan="<%= groups.length + 1 %>" class="text-center text-muted py-4">
                    Keine Berechtigungen definiert
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      
      <% if (userPermissions.permissions['PERMISSIONS.MATRIX.EDIT']) { %>
      <div class="card-footer bg-light">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <span id="changeCounter" class="text-muted">
              <i class="fa-solid fa-info-circle me-1"></i>
              Keine ungespeicherten Änderungen
            </span>
          </div>
          <button type="button" class="btn btn-success" id="saveMatrixBtn2">
            <i class="fa-solid fa-save me-2"></i>
            Änderungen speichern
          </button>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Legende -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">
          <i class="fa-solid fa-question-circle me-2"></i>
          Legende
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <h6 class="text-muted mb-3">Status-Icons</h6>
            <ul class="list-unstyled">
              <li class="mb-2">
                <i class="fa-solid fa-check-circle text-success me-2"></i>
                <strong>Berechtigung gewährt</strong>
              </li>
              <li class="mb-2">
                <i class="fa-solid fa-circle text-muted me-2"></i>
                <strong>Berechtigung nicht gewährt</strong>
              </li>
              <li class="mb-2">
                <div class="form-check d-inline-flex align-items-center">
                  <input class="form-check-input" type="checkbox" disabled checked>
                  <label class="form-check-label ms-2">
                    <strong>Bearbeitbare Berechtigung</strong>
                  </label>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="col-md-6">
            <h6 class="text-muted mb-3">Besondere Kennzeichnungen</h6>
            <ul class="list-unstyled">
              <li class="mb-2">
                <span class="badge bg-danger me-2">Kritisch</span>
                <strong>Kritische Berechtigung</strong><br>
                <small class="text-muted">Mit Vorsicht vergeben</small>
              </li>
              <li class="mb-2">
                <i class="fa-solid fa-shield-halved text-warning me-2"></i>
                <strong>Geschützte Gruppe</strong><br>
                <small class="text-muted">Nur durch Guild-Owner bearbeitbar</small>
              </li>
              <li class="mb-2">
                <i class="fa-solid fa-star text-info me-2"></i>
                <strong>Wildcard-Berechtigung</strong><br>
                <small class="text-muted">Gilt für alle Unterkategorien</small>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% } %>

<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const guildId = '<%= guildId %>';
  const changedPermissions = new Map(); // groupId → { permission_key: true/false }
  const changeCounter = document.getElementById('changeCounter');
  
  // Track Changes
  document.querySelectorAll('.permission-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', (e) => {
      const groupId = e.target.dataset.groupId;
      const permKey = e.target.dataset.permissionKey;
      const isChecked = e.target.checked;
      
      if (!changedPermissions.has(groupId)) {
        changedPermissions.set(groupId, {});
      }
      
      changedPermissions.get(groupId)[permKey] = isChecked;
      
      updateChangeCounter();
    });
  });
  
  function updateChangeCounter() {
    let totalChanges = 0;
    changedPermissions.forEach(changes => {
      totalChanges += Object.keys(changes).length;
    });
    
    if (totalChanges > 0) {
      changeCounter.innerHTML = `
        <i class="fa-solid fa-exclamation-triangle me-1 text-warning"></i>
        <strong>${totalChanges}</strong> ungespeicherte Änderung(en)
      `;
    } else {
      changeCounter.innerHTML = `
        <i class="fa-solid fa-info-circle me-1"></i>
        Keine ungespeicherten Änderungen
      `;
    }
  }
  
  // Save Changes
  async function saveMatrix() {
    if (changedPermissions.size === 0) {
      showToast('info', 'Keine Änderungen zum Speichern');
      return;
    }
    
    try {
      // Konvertiere Map zu Object für JSON
      const updates = {};
      changedPermissions.forEach((changes, groupId) => {
        updates[groupId] = changes;
      });
      
      // AJAX-Request
      const response = await fetch(`/guild/${guildId}/plugins/core/permissions/matrix`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates })
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast('success', result.message || 'Änderungen gespeichert');
        changedPermissions.clear();
        updateChangeCounter();
        
        // Optional: Seite nach 1,5s neu laden
        setTimeout(() => window.location.reload(), 1500);
      } else {
        showToast('error', result.message || 'Fehler beim Speichern');
      }
    } catch (error) {
      console.error('Error saving matrix:', error);
      showToast('error', 'Fehler beim Speichern der Änderungen');
    }
  }
  
  // Save Buttons
  document.getElementById('saveMatrixBtn')?.addEventListener('click', saveMatrix);
  document.getElementById('saveMatrixBtn2')?.addEventListener('click', saveMatrix);
  
  // Toast Helper (nutzt das bestehende guild.js Toast-System)
  function showToast(type, message) {
    if (typeof GuildAjax !== 'undefined' && typeof GuildAjax.showToast === 'function') {
      GuildAjax.showToast(type, message);
    } else {
      console.log(`[${type.toUpperCase()}] ${message}`);
      alert(message); // Fallback
    }
  }
  
  // Initialize Bootstrap tooltips
  const tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
  tooltips.forEach(el => new bootstrap.Tooltip(el));
  
  // Sticky Header beim Scrollen
  const table = document.getElementById('permissionMatrix');
  if (table) {
    window.addEventListener('scroll', () => {
      const rect = table.getBoundingClientRect();
      const thead = table.querySelector('thead');
      
      if (rect.top < 0 && rect.bottom > 0) {
        thead.style.position = 'sticky';
        thead.style.top = '0';
        thead.style.zIndex = '100';
      }
    });
  }
});
</script>

<style>
#permissionMatrix thead th {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #f8f9fa;
}

#permissionMatrix tbody tr:hover {
  background-color: rgba(0, 0, 0, 0.02);
}

#permissionMatrix td:first-child {
  position: sticky;
  left: 0;
  background-color: white;
  box-shadow: 2px 0 5px rgba(0, 0, 0, 0.05);
}

#permissionMatrix tr.table-secondary td:first-child {
  background-color: #e2e3e5;
}

.permission-checkbox {
  /* Größere Variante - global in guild.css definiert */
  cursor: pointer;
}

.permission-checkbox:disabled {
  cursor: not-allowed;
  opacity: 0.5;
  background-color: #e9ecef;
}

.form-check {
  margin: 0;
  padding: 0;
}

.table-bordered th,
.table-bordered td {
  border: 1px solid #dee2e6;
}

.badge {
  font-size: 0.875rem;
}
</style>
