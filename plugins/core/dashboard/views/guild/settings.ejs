<!-- 
  Settings Hauptseite - Übersicht & Schnellzugriffe
  Zeigt alle verfügbaren Einstellungsbere        <ul class="list-unstyled small mb-3">
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.WEBHOOKS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.API_KEYS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.OAUTH') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.THIRD_PARTY') %></li>
        </ul>
        
        <a href="/guild/<%= guildId %>/plugins/core/settings/integrations" class="btn btn-warning btn-sm w-100 disabled">
          <i class="fa-solid fa-lock me-2"></i><%= tr('core:SETTINGS_OVERVIEW.COMING_SOON') %></a>visuellen Karten
-->

<div class="row mb-4">
  <div class="col-12">
    <div class="alert alert-info">
      <i class="fa-solid fa-circle-info me-2"></i>
      <strong><%= tr('DASHBOARD_COMMON.WELCOME_SETTINGS') %></strong> 
      <%= tr('DASHBOARD_COMMON.WELCOME_SETTINGS_DESC') %>
    </div>
  </div>
</div>

<!-- Schnellzugriff-Karten -->
<div class="row g-4 mb-4">
  <!-- Allgemeine Einstellungen -->
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 hover-shadow">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="icon-circle bg-primary bg-opacity-10 text-primary me-3">
            <i class="fa-solid fa-sliders fs-4"></i>
          </div>
          <div>
            <h5 class="card-title mb-0"><%= tr('core:SETTINGS_OVERVIEW.GENERAL_TITLE') %></h5>
            <small class="text-muted"><%= tr('core:SETTINGS_OVERVIEW.GENERAL_SUBTITLE') %></small>
          </div>
        </div>
        
        <p class="card-text text-muted mb-3">
          <%= tr('core:SETTINGS_OVERVIEW.GENERAL_DESCRIPTION') %>
        </p>
        
        <ul class="list-unstyled small mb-3">
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.GENERAL_FEATURES.PREFIX') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.GENERAL_FEATURES.LOCALE') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.GENERAL_FEATURES.THEME') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.GENERAL_FEATURES.SLASH') %></li>
        </ul>
        
        <a href="/guild/<%= guildId %>/plugins/core/settings/general" class="btn btn-primary btn-sm w-100">
          <i class="fa-solid fa-arrow-right me-2"></i><%= tr('core:SETTINGS_OVERVIEW.BTN_CONFIGURE') %>
        </a>
      </div>
    </div>
  </div>

  <!-- Benutzer-Verwaltung -->
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 hover-shadow">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="icon-circle bg-success bg-opacity-10 text-success me-3">
            <i class="fa-solid fa-users fs-4"></i>
          </div>
          <div>
            <h5 class="card-title mb-0"><%= tr('core:SETTINGS_OVERVIEW.USER_TITLE') %></h5>
            <small class="text-muted"><%= tr('core:SETTINGS_OVERVIEW.USER_SUBTITLE') %></small>
          </div>
        </div>
        
        <p class="card-text text-muted mb-3">
          <%= tr('core:SETTINGS_OVERVIEW.USER_DESCRIPTION') %>
        </p>
        
        <ul class="list-unstyled small mb-3">
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.USER_FEATURES.ROLES') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.USER_FEATURES.ADMIN') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.USER_FEATURES.COMMANDS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.USER_FEATURES.BLACKLIST') %></li>
        </ul>
        
        <a href="/guild/<%= guildId %>/plugins/core/settings/users" class="btn btn-success btn-sm w-100 disabled">
          <i class="fa-solid fa-lock me-2"></i><%= tr('core:SETTINGS_OVERVIEW.COMING_SOON') %>
        </a>
      </div>
    </div>
  </div>

  <!-- Integrationen -->
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 hover-shadow">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="icon-circle bg-warning bg-opacity-10 text-warning me-3">
            <i class="fa-solid fa-plug fs-4"></i>
          </div>
          <div>
            <h5 class="card-title mb-0"><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_TITLE') %></h5>
            <small class="text-muted"><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_SUBTITLE') %></small>
          </div>
        </div>
        
        <p class="card-text text-muted mb-3">
          <%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_DESCRIPTION') %>
        </p>
        
        <ul class="list-unstyled small mb-3">
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.WEBHOOKS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.API_KEYS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.DISCORD_LOGS') %></li>
          <li><i class="fa-solid fa-check text-success me-2"></i><%= tr('core:SETTINGS_OVERVIEW.INTEGRATIONS_FEATURES.EXTERNAL_SERVICES') %></li>
        </ul>
        
        <a href="/guild/<%= guildId %>/plugins/core/settings/integrations" class="btn btn-warning btn-sm w-100">
          <i class="fa-solid fa-arrow-right me-2"></i><%= tr('core:SETTINGS_OVERVIEW.BTN_OPEN') %>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Plugin-spezifische Einstellungen (dynamisch) -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-light">
        <h5 class="mb-0">
          <i class="fa-solid fa-puzzle-piece me-2"></i><%= tr('core:SETTINGS_OVERVIEW.PLUGIN_SETTINGS_TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        <p class="text-muted mb-3">
          <%= tr('core:SETTINGS_OVERVIEW.PLUGIN_SETTINGS_DESC') %>
        </p>
        
        <div class="alert alert-secondary mb-0">
          <i class="fa-solid fa-lightbulb me-2"></i>
          <strong><%= tr('core:SETTINGS_OVERVIEW.PLUGIN_SETTINGS_TIP') %>:</strong> <%= tr('core:SETTINGS_OVERVIEW.PLUGIN_SETTINGS_TIP_TEXT') %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- System-Status -->
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-light">
        <h5 class="mb-0">
          <i class="fa-solid fa-server me-2"></i><%= tr('core:SETTINGS_OVERVIEW.SYSTEM_STATUS_TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        <div class="row text-center">
          <div class="col-md-3">
            <div class="border-end">
              <i class="fa-solid fa-circle-check text-success fs-2 mb-2"></i>
              <h6 class="text-muted small mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_BOT') %></h6>
              <p class="fw-bold mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_BOT_ONLINE') %></p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border-end">
              <i class="fa-solid fa-database text-primary fs-2 mb-2"></i>
              <h6 class="text-muted small mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_DATABASE') %></h6>
              <p class="fw-bold mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_DATABASE_CONNECTED') %></p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border-end">
              <i class="fa-solid fa-puzzle-piece text-info fs-2 mb-2"></i>
              <h6 class="text-muted small mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_PLUGINS') %></h6>
              <p class="fw-bold mb-0"><%= enabledPlugins?.length || 0 %> <%= tr('core:SETTINGS_OVERVIEW.STATUS_PLUGINS_ACTIVE') %></p>
            </div>
          </div>
          <div class="col-md-3">
            <i class="fa-solid fa-bolt text-warning fs-2 mb-2"></i>
            <h6 class="text-muted small mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_PERFORMANCE') %></h6>
            <p class="fw-bold mb-0"><%= tr('core:SETTINGS_OVERVIEW.STATUS_PERFORMANCE_STABLE') %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.hover-shadow {
  transition: all 0.3s ease;
  cursor: pointer;
}

.hover-shadow:hover {
  transform: translateY(-5px);
  box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
}

.icon-circle {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.border-end:last-child {
  border-right: none !important;
}
</style>