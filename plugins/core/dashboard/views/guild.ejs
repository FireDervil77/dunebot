<section class="mb-6">
  <div class="border-border bg-bg-panel rounded-lg border p-4 shadow-sm sm:p-6 2xl:col-span-2">
    <!-- START: Card Header -->
    <div class="border-border mb-4 flex items-center justify-between border-b pb-4">
      <h3 class="text-text text-lg font-semibold"><%= tr("core:SERVER_DEFAULTS") %></h3>
    </div>
    <!-- END: Card Header -->

    <form class="guild-ajax-form" data-form-type="server-config" data-method="PUT" action="<%= `/guild/${guildId}/core` %>" method="POST">
      <!-- START: Card Body -->
      <div class="mb-3">
        <div class="grid gap-4 md:grid-cols-3 xl:grid-cols-3">
          <!-- START: Column 1 -->
          <div>
            <div class="mb-2">
              <label for="prefix" class="text-text text-sm font-semibold"><%= tr("core:PREFIX_TITLE") %></label>
              <div class="text-text-muted text-sm font-normal"><%= tr("core:PREFIX_DESC") %></div>
            </div>
            <input
              type="text"
              name="prefix"
              value="<%= config.PREFIX_COMMANDS.DEFAULT_PREFIX %>"
              minlength="1"
              maxlength="2"
              id="prefix"
              class="focus:border-primary focus:ring-primary border-border bg-bg-interactive text-text block w-full rounded-lg border p-2.5 shadow-sm sm:text-sm"
              required />
          </div>
          <!-- END: Column 1 -->

          <!-- START: Column 2 -->
          <div>
            <div class="mb-2">
              <label for="locale" class="text-text text-sm font-semibold"><%= tr("core:LOCALE_TITLE") %></label>
              <div class="text-text-muted text-sm font-normal"><%= tr("core:LOCALE_DESC") %></div>
            </div>
            <select
              name="locale"
              id="locale"
              class="focus:ring-primary focus:border-primary border-border bg-bg-interactive text-text block w-full rounded-lg border p-2.5 text-sm">
              <% languagesMeta.forEach((lang) => { %>
              <option value="<%= lang.name %>" <%= config.LOCALE.DEFAULT === lang.name ? 'selected' : '' %>><%= lang.name %></option>
              <% }) %>
            </select>
          </div>
          <!-- END: Column 2 -->

          <!-- START: Column 3 -->
          <div>
            <div class="mb-2">
              <label for="support_server" class="text-text text-sm font-semibold"><%= tr("core:SUPPORT") %></label>
              <div class="text-text-muted text-sm font-normal"><%= tr("core:SUPPORT_DESC") %></div>
            </div>
            <input
              type="url"
              name="support_server"
              value="<%= config.SUPPORT_SERVER %>"
              id="support_server"
              class="focus:border-primary focus:ring-primary border-border bg-bg-interactive text-text block w-full rounded-lg border p-2.5 shadow-sm sm:text-sm"
              required />
          </div>
          <!-- END: Column 3 -->

          <!-- START: Column 4 -->
          <div>
            <div class="mb-2">
              <label for="slash_commands" class="text-text text-sm font-semibold"><%= tr("core:SLASH") %></label>
              <div class="text-text-muted text-sm font-normal"><%= tr("core:SLASH_DESC") %></div>
            </div>
            <select
              name="slash_commands"
              id="slash_commands"
              class="focus:ring-primary focus:border-primary border-border bg-bg-interactive text-text block w-full rounded-lg border p-2.5 text-sm">
              <option value="on" <%= config.INTERACTIONS.SLASH ? 'selected' : '' %>><%=tr("core:ENABLED") %></option>
              <option value="off" <%= !config.INTERACTIONS.SLASH ? 'selected' : '' %>><%=tr("core:DISABLED") %></option>
            </select>
          </div>
          <!-- END: Column 4 -->

          <!-- START: Column 5 -->
          <div>
            <div class="mb-2">
              <label for="context_menus" class="text-text text-sm font-semibold"><%= tr("core:CONTEXT") %></label>
              <div class="text-text-muted text-sm font-normal"><%= tr("core:CONTEXT_DESC") %></div>
            </div>
            <select
              name="context_menus"
              id="context_menus"
              class="focus:ring-primary focus:border-primary border-border bg-bg-interactive text-text block w-full rounded-lg border p-2.5 text-sm">
              <option value="on" <%= config.INTERACTIONS.CONTEXT ? 'selected' : '' %>><%=tr("core:ENABLED") %></option>
              <option value="off" <%= !config.INTERACTIONS.CONTEXT ? 'selected' : '' %>><%=tr("core:DISABLED") %></option>
            </select>
          </div>
          <!-- END: Column 5 -->

          <!-- Hidden Field für Backend -->
          <input type="hidden" name="server_config" value="true" />
        </div>
      </div>
      <!-- END: Card Body -->

      <!-- START: Card Footer -->
      <div class="border-border mt-4 flex items-center justify-between border-t pt-3 sm:pt-6">
        <div></div>
        <div class="flex-shrink-0">
          <button
            type="submit"
            class="bg-primary hover:bg-primary-dark focus:ring-primary inline-flex items-center rounded-lg px-3 py-2 text-center text-sm font-medium text-white focus:outline-none focus:ring-4">
            <%= tr('BTN_SAVE') %>
          </button>
        </div>
      </div>
      <!-- END: Card Footer -->
    </form>
  </div>
</section>

