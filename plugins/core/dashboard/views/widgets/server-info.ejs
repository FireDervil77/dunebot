<!-- Server Info Card -->
<img src="<%= guild.icon ? guild.icon : (guild.iconURL ? guild.iconURL : '/themes/default/assets/images/DuneBot.png') %>" 
class="img-circle elevation-3" style="width: 45px; height: 45px;" alt="Server Icon">
  <h3 class="profile-username text-center"><%= guild.guild_name %></h3>
  <p class="text-muted text-center">ID: <%= guildId %></p>
  
<div class="col-md-6">
  <h5><%= tr('core:WIDGETS.SERVER_INFO.MEMORY_USAGE') %></h5>
  <p><%= Math.round(memory.heapUsed / 1024 / 1024) %> MB / <%= Math.round(memory.heapTotal / 1024 / 1024) %> MB</p>
</div>

<div class="progress mt-2">
  <div class="progress-bar bg-info" role="progressbar" style='width: <%- Math.round(memory.heapUsed / memory.heapTotal * 100) %>%'></div>
</div>
  
  <div class="mt-3">
    <a href="/guild/<%= guildId %>/plugins" class="btn btn-info btn-block">
      <i class="fas fa-puzzle-piece"></i> <%= tr('core:WIDGETS.SERVER_INFO.BTN_MANAGE_PLUGINS') %>
    </a>
  </div>