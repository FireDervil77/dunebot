<!-- 
  Task-Status-Widget (Wiederverwendbar)
  
  Usage:
  <%- include('../../masterserver/dashboard/views/partials/task-status-widget', { 
    taskId: 'abc-123',
    serverId: 'server-001',
    inline: false  // Optional: true für inline-Display
  }) %>
-->

<% 
  const taskId = typeof locals.taskId !== 'undefined' ? locals.taskId : null;
  const serverId = typeof locals.serverId !== 'undefined' ? locals.serverId : null;
  const inline = typeof locals.inline !== 'undefined' ? locals.inline : false;
  const widgetId = taskId || serverId || 'task-widget-' + Date.now();
%>

<div class="task-status-widget" data-widget-id="<%= widgetId %>" data-task-id="<%= taskId %>" data-server-id="<%= serverId %>">
  <% if (taskId) { %>
    <!-- Single Task Display -->
    <div class="card <%= inline ? 'card-outline' : '' %>">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-tasks me-2"></i>
          Task-Status
        </h3>
        <div class="card-tools">
          <button type="button" class="btn btn-tool" data-card-widget="collapse">
            <i class="fas fa-minus"></i>
          </button>
        </div>
      </div>
      <div class="card-body">
        <div class="task-info" data-task-id="<%= taskId %>">
          <!-- Initial Loading State -->
          <div class="text-center py-3">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Laden...</span>
            </div>
            <p class="text-muted mt-2">Task-Daten werden geladen...</p>
          </div>
        </div>
      </div>
    </div>
  <% } else if (serverId) { %>
    <!-- Server Task History -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-history me-2"></i>
          Task-Verlauf
        </h3>
        <div class="card-tools">
          <button type="button" class="btn btn-sm btn-primary task-refresh-btn" data-server-id="<%= serverId %>">
            <i class="fas fa-sync-alt"></i> Aktualisieren
          </button>
        </div>
      </div>
      <div class="card-body p-0">
        <div class="task-list" data-server-id="<%= serverId %>">
          <!-- Initial Loading State -->
          <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Laden...</span>
            </div>
            <p class="text-muted mt-2">Task-Historie wird geladen...</p>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Task Status Template (Hidden) -->
<template id="task-status-template">
  <div class="task-item mb-3">
    <div class="d-flex justify-content-between align-items-start">
      <div class="flex-grow-1">
        <div class="d-flex align-items-center mb-2">
          <span class="task-type-badge badge me-2"></span>
          <span class="task-status-badge badge"></span>
          <small class="text-muted ms-auto task-created-time"></small>
        </div>
        <div class="task-id text-muted small">
          <i class="fas fa-fingerprint me-1"></i>
          <code class="task-id-text"></code>
        </div>
        <div class="task-progress mt-2" style="display: none;">
          <div class="progress" style="height: 20px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated task-progress-bar" 
                 role="progressbar" style="width: 0%">
              <span class="task-progress-text">0%</span>
            </div>
          </div>
        </div>
        <div class="task-error alert alert-danger mt-2" style="display: none;">
          <i class="fas fa-exclamation-triangle me-2"></i>
          <span class="task-error-text"></span>
        </div>
      </div>
      <div class="task-actions ms-3">
        <button class="btn btn-sm btn-outline-danger task-cancel-btn" data-task-id="" style="display: none;">
          <i class="fas fa-times"></i> Abbrechen
        </button>
      </div>
    </div>
  </div>
</template>

<!-- Task List Item Template -->
<template id="task-list-item-template">
  <tr class="task-list-item">
    <td class="task-type-cell"></td>
    <td>
      <span class="task-status-badge badge"></span>
    </td>
    <td class="task-progress-cell">
      <div class="progress" style="height: 20px;">
        <div class="progress-bar task-progress-bar" role="progressbar" style="width: 0%">
          <span class="task-progress-text">0%</span>
        </div>
      </div>
    </td>
    <td class="task-created-cell"></td>
    <td class="text-end">
      <button class="btn btn-sm btn-info task-details-btn" data-task-id="">
        <i class="fas fa-eye"></i>
      </button>
      <button class="btn btn-sm btn-danger task-cancel-btn" data-task-id="" style="display: none;">
        <i class="fas fa-times"></i>
      </button>
    </td>
  </tr>
</template>

<style>
.task-status-widget .task-type-badge {
  font-size: 0.75rem;
  padding: 0.25rem 0.5rem;
}

.task-status-widget .task-status-badge {
  font-size: 0.75rem;
  padding: 0.25rem 0.5rem;
}

.task-status-widget .badge.status-pending { background-color: #6c757d; }
.task-status-widget .badge.status-running { background-color: #007bff; }
.task-status-widget .badge.status-completed { background-color: #28a745; }
.task-status-widget .badge.status-failed { background-color: #dc3545; }
.task-status-widget .badge.status-cancelled { background-color: #ffc107; color: #000; }

.task-status-widget .badge.type-server_start { background-color: #17a2b8; }
.task-status-widget .badge.type-server_stop { background-color: #ffc107; color: #000; }
.task-status-widget .badge.type-server_restart { background-color: #fd7e14; }
</style>

<script>
// Task Status Widget Controller
(function() {
  'use strict';

  class TaskStatusWidget {
    constructor(element) {
      this.element = element;
      this.taskId = element.dataset.taskId;
      this.serverId = element.dataset.serverId;
      this.guildId = '<%= guildId %>';
      this.pollInterval = null;
      
      this.init();
    }

    init() {
      if (this.taskId) {
        this.loadTaskStatus();
        this.startPolling();
      } else if (this.serverId) {
        this.loadTaskList();
        this.setupEventListeners();
      }
    }

    async loadTaskStatus() {
      try {
        const response = await fetch(`/guild/${this.guildId}/plugins/masterserver/api/tasks/${this.taskId}`);
        const data = await response.json();

        if (data.success) {
          this.renderTaskStatus(data.task);
          
          // Stop polling wenn Task abgeschlossen
          if (['completed', 'failed', 'cancelled'].includes(data.task.status)) {
            this.stopPolling();
          }
        }
      } catch (error) {
        console.error('Task-Status laden fehlgeschlagen:', error);
        this.showError('Fehler beim Laden des Task-Status');
      }
    }

    async loadTaskList() {
      try {
        const response = await fetch(`/guild/${this.guildId}/plugins/masterserver/api/tasks/server/${this.serverId}?limit=10`);
        const data = await response.json();

        if (data.success) {
          this.renderTaskList(data.tasks);
        }
      } catch (error) {
        console.error('Task-Liste laden fehlgeschlagen:', error);
        this.showError('Fehler beim Laden der Task-Liste');
      }
    }

    renderTaskStatus(task) {
      const container = this.element.querySelector('.task-info');
      const template = document.getElementById('task-status-template');
      const clone = template.content.cloneNode(true);

      // Type Badge
      const typeBadge = clone.querySelector('.task-type-badge');
      typeBadge.textContent = this.getTaskTypeLabel(task.task_type);
      typeBadge.classList.add(`type-${task.task_type.replace('_', '-')}`);

      // Status Badge
      const statusBadge = clone.querySelector('.task-status-badge');
      statusBadge.textContent = this.getStatusLabel(task.status);
      statusBadge.classList.add(`status-${task.status}`);

      // Task ID
      clone.querySelector('.task-id-text').textContent = task.id;

      // Created Time
      clone.querySelector('.task-created-time').textContent = this.formatDate(task.created_at);

      // Progress
      if (task.status === 'running' && task.progress > 0) {
        const progressContainer = clone.querySelector('.task-progress');
        progressContainer.style.display = 'block';
        const progressBar = clone.querySelector('.task-progress-bar');
        progressBar.style.width = `${task.progress}%`;
        clone.querySelector('.task-progress-text').textContent = `${task.progress}%`;
      }

      // Error
      if (task.error) {
        const errorContainer = clone.querySelector('.task-error');
        errorContainer.style.display = 'block';
        clone.querySelector('.task-error-text').textContent = task.error;
      }

      // Cancel Button
      if (['pending', 'running'].includes(task.status)) {
        const cancelBtn = clone.querySelector('.task-cancel-btn');
        cancelBtn.style.display = 'inline-block';
        cancelBtn.dataset.taskId = task.id;
        cancelBtn.addEventListener('click', () => this.cancelTask(task.id));
      }

      container.innerHTML = '';
      container.appendChild(clone);
    }

    renderTaskList(tasks) {
      const container = this.element.querySelector('.task-list');
      
      if (tasks.length === 0) {
        container.innerHTML = '<div class="text-center py-4 text-muted">Keine Tasks vorhanden</div>';
        return;
      }

      const table = document.createElement('table');
      table.className = 'table table-hover mb-0';
      table.innerHTML = `
        <thead>
          <tr>
            <th>Typ</th>
            <th>Status</th>
            <th>Fortschritt</th>
            <th>Erstellt</th>
            <th class="text-end">Aktionen</th>
          </tr>
        </thead>
        <tbody></tbody>
      `;

      const tbody = table.querySelector('tbody');
      const template = document.getElementById('task-list-item-template');

      tasks.forEach(task => {
        const clone = template.content.cloneNode(true);
        const row = clone.querySelector('.task-list-item');

        row.querySelector('.task-type-cell').textContent = this.getTaskTypeLabel(task.task_type);
        
        const statusBadge = row.querySelector('.task-status-badge');
        statusBadge.textContent = this.getStatusLabel(task.status);
        statusBadge.classList.add(`status-${task.status}`);

        const progressBar = row.querySelector('.task-progress-bar');
        progressBar.style.width = `${task.progress}%`;
        row.querySelector('.task-progress-text').textContent = `${task.progress}%`;

        row.querySelector('.task-created-cell').textContent = this.formatDate(task.created_at);

        const detailsBtn = row.querySelector('.task-details-btn');
        detailsBtn.dataset.taskId = task.id;
        detailsBtn.addEventListener('click', () => this.showTaskDetails(task.id));

        if (['pending', 'running'].includes(task.status)) {
          const cancelBtn = row.querySelector('.task-cancel-btn');
          cancelBtn.style.display = 'inline-block';
          cancelBtn.dataset.taskId = task.id;
          cancelBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            this.cancelTask(task.id);
          });
        }

        tbody.appendChild(clone);
      });

      container.innerHTML = '';
      container.appendChild(table);
    }

    async cancelTask(taskId) {
      if (!confirm('Möchten Sie diesen Task wirklich abbrechen?')) return;

      try {
        const response = await fetch(`/guild/${this.guildId}/plugins/masterserver/api/tasks/${taskId}/cancel`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });

        const data = await response.json();

        if (data.success) {
          this.showToast('success', 'Task wurde abgebrochen');
          this.taskId ? this.loadTaskStatus() : this.loadTaskList();
        } else {
          this.showToast('error', data.error || 'Task-Abbruch fehlgeschlagen');
        }
      } catch (error) {
        console.error('Task-Abbruch fehlgeschlagen:', error);
        this.showToast('error', 'Fehler beim Abbrechen des Tasks');
      }
    }

    showTaskDetails(taskId) {
      // TODO: Modal mit vollständigen Task-Details öffnen
      window.location.href = `/guild/${this.guildId}/plugins/masterserver/tasks/${taskId}`;
    }

    startPolling() {
      this.pollInterval = setInterval(() => this.loadTaskStatus(), 5000); // 5s
    }

    stopPolling() {
      if (this.pollInterval) {
        clearInterval(this.pollInterval);
        this.pollInterval = null;
      }
    }

    setupEventListeners() {
      const refreshBtn = this.element.querySelector('.task-refresh-btn');
      if (refreshBtn) {
        refreshBtn.addEventListener('click', () => this.loadTaskList());
      }
    }

    getTaskTypeLabel(type) {
      const labels = {
        'server_start': 'Start',
        'server_stop': 'Stop',
        'server_restart': 'Restart',
        'server_install': 'Installation',
        'server_update': 'Update'
      };
      return labels[type] || type;
    }

    getStatusLabel(status) {
      const labels = {
        'pending': 'Wartend',
        'running': 'Läuft',
        'completed': 'Abgeschlossen',
        'failed': 'Fehlgeschlagen',
        'cancelled': 'Abgebrochen'
      };
      return labels[status] || status;
    }

    formatDate(dateStr) {
      if (!dateStr) return '-';
      const date = new Date(dateStr);
      return date.toLocaleString('de-DE', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    showToast(type, message) {
      // AdminLTE Toast
      $(document).Toasts('create', {
        class: type === 'success' ? 'bg-success' : 'bg-danger',
        title: type === 'success' ? 'Erfolg' : 'Fehler',
        body: message,
        autohide: true,
        delay: 3000
      });
    }

    showError(message) {
      const container = this.element.querySelector('.task-info, .task-list');
      container.innerHTML = `
        <div class="alert alert-danger m-3">
          <i class="fas fa-exclamation-triangle me-2"></i>
          ${message}
        </div>
      `;
    }
  }

  // Auto-Initialize widgets on page load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.task-status-widget').forEach(element => {
      new TaskStatusWidget(element);
    });
  });

  // Export for manual initialization
  window.TaskStatusWidget = TaskStatusWidget;
})();
</script>
