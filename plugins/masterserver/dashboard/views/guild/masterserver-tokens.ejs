<!-- Masterserver Token Management -->
<div class="container-fluid">
  <div class="row">
    <!-- Page Header -->
    <div class="col-12 mb-3">
      <h2>
        <i class="fa-solid fa-key text-primary me-2"></i>
        <%= tr('masterserver:TOKENS.TITLE') %>
      </h2>
      <p class="text-muted">Verwalte Authentifizierungs-Tokens für deinen Daemon</p>
    </div>
  </div>

  <!-- Token Generation Card -->
  <div class="row">
    <div class="col-lg-4">
      <div class="card card-success">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fa-solid fa-plus-circle me-2"></i>
            <%= tr('masterserver:TOKENS.GENERATE') %>
          </h3>
        </div>
        <form class="guild-ajax-form" 
              data-form-type="token-generate" 
              data-method="POST"
              action="/guild/<%= guildId %>/plugins/masterserver/tokens/generate"
              method="POST">
          <div class="card-body">
            <div class="form-group">
              <label for="expiresInDays">
                Gültigkeit (Tage)
                <span class="text-danger">*</span>
              </label>
              <select class="form-control" id="expiresInDays" name="expiresInDays" required>
                <option value="30">30 Tage</option>
                <option value="90">90 Tage (3 Monate)</option>
                <option value="180">180 Tage (6 Monate)</option>
                <option value="365" selected>365 Tage (1 Jahr)</option>
                <option value="730">730 Tage (2 Jahre)</option>
              </select>
              <small class="form-text text-muted">
                Wähle wie lange der Token gültig sein soll.
              </small>
            </div>

            <div class="form-group">
              <label for="description">Beschreibung (optional)</label>
              <textarea
                class="form-control"
                id="description"
                name="description"
                rows="2"
                placeholder="z.B. Produktions-Server Token"
              ></textarea>
              <small class="form-text text-muted">
                Hilft dir den Token später zu identifizieren.
              </small>
            </div>

            <div class="alert alert-warning">
              <i class="fa-solid fa-exclamation-triangle me-2"></i>
              <strong>Wichtig:</strong> Der Token wird nur EINMAL angezeigt! 
              Speichere ihn sicher ab.
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" class="btn btn-success">
              <i class="fa-solid fa-key me-1"></i>
              Token generieren
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Active Tokens List -->
    <div class="col-lg-8">
      <div class="card card-primary">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fa-solid fa-check-circle me-2"></i>
            <%= tr('masterserver:TOKENS.ACTIVE') %> (<%= activeTokens.length %>)
          </h3>
        </div>
        <div class="card-body p-0">
          <% if (activeTokens.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0">
                <thead>
                  <tr>
                    <th width="10%">ID</th>
                    <th width="20%"><%= tr('masterserver:TOKENS.CREATED_AT') %></th>
                    <th width="20%"><%= tr('masterserver:TOKENS.EXPIRES_AT') %></th>
                    <th width="20%">Zuletzt benutzt</th>
                    <th width="20%">Beschreibung</th>
                    <th width="10%" class="text-center">Aktionen</th>
                  </tr>
                </thead>
                <tbody>
                  <% activeTokens.forEach(token => { 
                    const expiresIn = Math.floor((new Date(token.expires_at) - Date.now()) / (1000 * 60 * 60 * 24));
                    const isExpiringSoon = expiresIn <= 30;
                  %>
                    <tr>
                      <td>
                        <code>#<%= token.id %></code>
                      </td>
                      <td>
                        <small><%= new Date(token.created_at).toLocaleString('de-DE') %></small>
                      </td>
                      <td>
                        <small class="<%= isExpiringSoon ? 'text-warning' : '' %>">
                          <%= new Date(token.expires_at).toLocaleString('de-DE') %>
                          <% if (isExpiringSoon) { %>
                            <br><span class="badge badge-warning">Läuft bald ab!</span>
                          <% } %>
                        </small>
                      </td>
                      <td>
                        <small>
                          <% if (token.used_at) { %>
                            <%= new Date(token.used_at).toLocaleString('de-DE') %>
                          <% } else { %>
                            <span class="text-muted">Nie genutzt</span>
                          <% } %>
                        </small>
                      </td>
                      <td>
                        <small><%= token.description || '-' %></small>
                      </td>
                      <td class="text-center">
                        <button 
                          type="button" 
                          class="btn btn-sm btn-danger"
                          onclick="revokeToken('<%= token.id %>')"
                          title="<%= tr('masterserver:TOKENS.REVOKE') %>">
                          <i class="fa-solid fa-ban"></i>
                        </button>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="p-4 text-center text-muted">
              <i class="fa-solid fa-key fa-3x mb-3"></i>
              <p>Keine aktiven Tokens vorhanden.</p>
              <p class="small">Erstelle einen Token um deinen Daemon zu authentifizieren.</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Expired Tokens Card (Collapsed) -->
      <% if (expiredTokens.length > 0) { %>
        <div class="card card-danger collapsed-card">
          <div class="card-header">
            <h3 class="card-title">
              <i class="fa-solid fa-xmark-circle me-2"></i>
              <%= tr('masterserver:TOKENS.EXPIRED') %> (<%= expiredTokens.length %>)
            </h3>
            <div class="card-tools">
              <button type="button" class="btn btn-tool" data-card-widget="collapse">
                <i class="fas fa-plus"></i>
              </button>
            </div>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-sm table-striped mb-0">
                <thead>
                  <tr>
                    <th>Token-ID</th>
                    <th>Erstellt</th>
                    <th>Abgelaufen</th>
                    <th>Notiz</th>
                  </tr>
                </thead>
                <tbody>
                  <% expiredTokens.forEach(token => { %>
                    <tr class="text-muted">
                      <td><code><small>#<%= token.id %></small></code></td>
                      <td><small><%= new Date(token.created_at).toLocaleDateString('de-DE') %></small></td>
                      <td><small><%= new Date(token.expires_at).toLocaleDateString('de-DE') %></small></td>
                      <td><small><%= token.description || '-' %></small></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Token Display Modal (dynamisch erstellt) -->
  <div class="modal fade" id="tokenModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header bg-success">
          <h5 class="modal-title">
            <i class="fa-solid fa-check-circle me-2"></i>
            Token erfolgreich generiert!
          </h5>
          <button type="button" class="close" data-dismiss="modal">
            <span>&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <div class="alert alert-danger">
            <i class="fa-solid fa-exclamation-triangle me-2"></i>
            <strong>WICHTIG:</strong> Dieser Token wird nur EINMAL angezeigt! 
            Kopiere ihn jetzt und speichere ihn sicher.
          </div>

          <div class="form-group">
            <label>Token-ID:</label>
            <div class="input-group">
              <input type="text" class="form-control" id="modalTokenId" readonly>
              <div class="input-group-append">
                <button class="btn btn-outline-secondary" type="button" onclick="copyModalField('modalTokenId')">
                  <i class="fa-solid fa-copy"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>Token (geheim!):</label>
            <div class="input-group">
              <textarea class="form-control" id="modalToken" rows="3" readonly></textarea>
              <div class="input-group-append">
                <button class="btn btn-success" type="button" onclick="copyModalField('modalToken')">
                  <i class="fa-solid fa-copy me-1"></i> Kopieren
                </button>
              </div>
            </div>
          </div>

          <div class="callout callout-info">
            <h6><i class="fa-solid fa-info-circle me-2"></i>Nächste Schritte:</h6>
            <ol class="mb-0">
              <li>Kopiere den Token mit dem Button oben</li>
              <li>Speichere ihn sicher (z.B. in einem Passwort-Manager)</li>
              <li>Verwende ihn beim Starten deines Daemons: <code>--token YOUR_TOKEN</code></li>
            </ol>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Schließen</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script>
// Token widerrufen
function revokeToken(tokenId) {
  if (!confirm('Möchtest du diesen Token wirklich widerrufen? Der Daemon kann sich damit nicht mehr verbinden!')) {
    return;
  }

  fetch(`/guild/<%= guildId %>/plugins/masterserver/tokens/${tokenId}`, {
    method: 'DELETE',
    headers: {
      'Content-Type': 'application/json'
    }
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      GuildAjax.showToast('success', data.message || 'Token widerrufen');
      setTimeout(() => window.location.reload(), 1500);
    } else {
      GuildAjax.showToast('error', data.message || 'Fehler beim Widerrufen');
    }
  })
  .catch(err => {
    GuildAjax.showToast('error', 'Netzwerkfehler');
  });
}

// Modal-Feld kopieren
function copyModalField(fieldId) {
  const field = document.getElementById(fieldId);
  field.select();
  document.execCommand('copy');
  GuildAjax.showToast('success', 'In Zwischenablage kopiert!');
}
</script>
