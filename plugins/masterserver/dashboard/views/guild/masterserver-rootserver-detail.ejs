<!-- RootServer Detail-Seite -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fa-solid fa-server mr-2"></i>
                    <%= rootserver.name %>
                    <% if (isOnline) { %>
                        <span class="badge badge-success ml-2" style="font-size:0.6em;">
                            <i class="fa-solid fa-circle mr-1"></i>Online
                        </span>
                    <% } else { %>
                        <span class="badge badge-secondary ml-2" style="font-size:0.6em;">
                            <i class="fa-solid fa-circle mr-1"></i>Offline
                        </span>
                    <% } %>
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>/plugins/masterserver">Masterserver</a></li>
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>/plugins/masterserver/rootservers">RootServer</a></li>
                    <li class="breadcrumb-item active"><%= rootserver.name %></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <div class="row mb-3">
            <div class="col-12">
                <a href="/guild/<%= guildId %>/plugins/masterserver/rootservers" class="btn btn-secondary btn-sm">
                    <i class="fa-solid fa-arrow-left mr-1"></i>Zurück zur Übersicht
                </a>
            </div>
        </div>

        <!-- Live-Resource-Widgets -->
        <div class="row mb-3" id="resource-widgets">

            <!-- CPU Widget -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card card-outline <%= isOnline ? 'card-success' : 'card-secondary' %> h-100 mb-0">
                    <div class="card-header py-2 px-3">
                        <h3 class="card-title text-sm mb-0">
                            <i class="fa-solid fa-microchip mr-1"></i>CPU
                        </h3>
                        <div class="card-tools">
                            <% if (rootserver.cpu_model) { %>
                                <small class="text-muted" title="<%= rootserver.cpu_model %>" style="font-size:.7rem;">
                                    <%= rootserver.cpu_model.length > 22 ? rootserver.cpu_model.substring(0,22)+'…' : rootserver.cpu_model %>
                                </small>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-body text-center py-3">
                        <div class="position-relative d-inline-block mb-2" style="width:80px;height:80px;">
                            <svg viewBox="0 0 36 36" style="transform:rotate(-90deg);width:80px;height:80px;">
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e9ecef" stroke-width="3.2"/>
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#28a745" stroke-width="3.2"
                                        stroke-dasharray="0 100" id="cpu-ring"
                                        style="transition:stroke-dasharray .5s ease,stroke .3s ease;"/>
                            </svg>
                            <div class="position-absolute d-flex align-items-center justify-content-center"
                                 style="top:0;left:0;right:0;bottom:0;">
                                <span id="cpu-pct" class="font-weight-bold" style="font-size:1.1rem;">
                                    <%= rootserver.cpu_usage_percent != null ? Math.round(rootserver.cpu_usage_percent)+'%' : '–' %>
                                </span>
                            </div>
                        </div>
                        <div class="text-sm text-muted" style="font-size:.8rem;">
                            <%= rootserver.cpu_cores ? rootserver.cpu_cores + ' Kerne' : '' %><% if (rootserver.cpu_threads) { %> · <%= rootserver.cpu_threads %> Threads<% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RAM Widget -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card card-outline card-info h-100 mb-0">
                    <div class="card-header py-2 px-3">
                        <h3 class="card-title text-sm mb-0"><i class="fa-solid fa-memory mr-1"></i>RAM</h3>
                    </div>
                    <div class="card-body text-center py-3">
                        <div class="position-relative d-inline-block mb-2" style="width:80px;height:80px;">
                            <svg viewBox="0 0 36 36" style="transform:rotate(-90deg);width:80px;height:80px;">
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e9ecef" stroke-width="3.2"/>
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#17a2b8" stroke-width="3.2"
                                        stroke-dasharray="0 100" id="ram-ring"
                                        style="transition:stroke-dasharray .5s ease,stroke .3s ease;"/>
                            </svg>
                            <div class="position-absolute d-flex align-items-center justify-content-center"
                                 style="top:0;left:0;right:0;bottom:0;">
                                <span id="ram-pct" class="font-weight-bold" style="font-size:1.1rem;">–</span>
                            </div>
                        </div>
                        <div class="text-muted" id="ram-detail" style="font-size:.8rem;">
                            <%
                                const ramUsed = rootserver.ram_usage_gb != null ? parseFloat(rootserver.ram_usage_gb).toFixed(1) : null;
                                const ramTot  = rootserver.ram_total_gb != null ? parseFloat(rootserver.ram_total_gb).toFixed(1) : null;
                            %>
                            <% if (ramUsed && ramTot) { %><%= ramUsed %> / <%= ramTot %> GB<% } else if (ramTot) { %><%= ramTot %> GB<% } else { %>–<% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Disk Widget -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card card-outline card-warning h-100 mb-0">
                    <div class="card-header py-2 px-3">
                        <h3 class="card-title text-sm mb-0"><i class="fa-solid fa-hard-drive mr-1"></i>Disk</h3>
                    </div>
                    <div class="card-body text-center py-3">
                        <div class="position-relative d-inline-block mb-2" style="width:80px;height:80px;">
                            <svg viewBox="0 0 36 36" style="transform:rotate(-90deg);width:80px;height:80px;">
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e9ecef" stroke-width="3.2"/>
                                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#fd7e14" stroke-width="3.2"
                                        stroke-dasharray="0 100" id="disk-ring"
                                        style="transition:stroke-dasharray .5s ease,stroke .3s ease;"/>
                            </svg>
                            <div class="position-absolute d-flex align-items-center justify-content-center"
                                 style="top:0;left:0;right:0;bottom:0;">
                                <span id="disk-pct" class="font-weight-bold" style="font-size:1.1rem;">–</span>
                            </div>
                        </div>
                        <div class="text-muted" id="disk-detail" style="font-size:.8rem;">
                            <%
                                const diskUsed = rootserver.disk_usage_gb != null ? Math.round(rootserver.disk_usage_gb) : null;
                                const diskTot  = rootserver.disk_total_gb != null ? Math.round(rootserver.disk_total_gb) : null;
                            %>
                            <% if (diskUsed && diskTot) { %><%= diskUsed %> / <%= diskTot %> GB<% } else if (diskTot) { %><%= diskTot %> GB<% } else { %>–<% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Daemon/Gameserver-Widget -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card card-outline card-primary h-100 mb-0">
                    <div class="card-header py-2 px-3">
                        <h3 class="card-title text-sm mb-0"><i class="fa-solid fa-plug mr-1"></i>Daemon</h3>
                    </div>
                    <div class="card-body text-center py-3">
                        <div class="mb-2">
                            <span class="badge badge-<%= isOnline ? 'success' : 'secondary' %>" style="font-size:.9rem;padding:.4em .8em;">
                                <i class="fa-solid fa-circle mr-1" style="font-size:.6rem;"></i><%= isOnline ? 'Online' : 'Offline' %>
                            </span>
                            <% if (rootserver.daemon_version) { %>
                                <div class="text-muted mt-1" style="font-size:.8rem;">v<%= rootserver.daemon_version %></div>
                            <% } %>
                        </div>
                        <hr class="my-2">
                        <div>
                            <strong><%= gameserverStats.total || 0 %></strong>
                            <div class="text-muted" style="font-size:.75rem;">Gameserver</div>
                            <% if (gameserverStats.running > 0) { %>
                                <span class="badge badge-success mt-1" style="font-size:.7rem;"><i class="fa-solid fa-play mr-1"></i><%= gameserverStats.running %> laufend</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Tabs -->
        <div class="card card-primary card-outline">
            <div class="card-header p-0 pt-1">
                <ul class="nav nav-tabs" id="rootserverTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#tab-overview">
                            <i class="fa-solid fa-chart-line mr-1"></i>Übersicht
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-settings">
                            <i class="fa-solid fa-sliders mr-1"></i>Einstellungen
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-daemon">
                            <i class="fa-solid fa-terminal mr-1"></i>Daemon-Info
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-network" id="tab-network-link">
                            <i class="fa-solid fa-network-wired mr-1"></i>Netzwerk / IPs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-allocations" id="tab-allocations-link">
                            <i class="fa-solid fa-plug mr-1"></i>Allocations
                            <span class="badge badge-secondary ml-1" id="alloc-count-badge" style="font-size:.7rem;">0</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" data-toggle="tab" href="#tab-danger">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i>Gefahrenzone
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content">

                    <!-- Tab: Übersicht -->
                    <div class="tab-pane fade show active" id="tab-overview">
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table table-sm table-borderless">
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" width="40%">Name</td>
                                            <td><strong><%= rootserver.name %></strong></td>
                                        </tr>
                                        <% if (rootserver.description) { %>
                                        <tr>
                                            <td class="text-muted">Beschreibung</td>
                                            <td><%= rootserver.description %></td>
                                        </tr>
                                        <% } %>
                                        <tr>
                                            <td class="text-muted">Host / IP</td>
                                            <td><code><%= rootserver.host || '–' %></code></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Hostname</td>
                                            <td><%= rootserver.hostname || '–' %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Daemon-Port</td>
                                            <td><code><%= rootserver.daemon_port || 9340 %></code></td>
                                        </tr>

                                        <tr>
                                            <td class="text-muted">Standort</td>
                                            <td>
                                                <%= rootserver.datacenter || '–' %>
                                                <% if (rootserver.country_code) { %>
                                                    <span class="badge badge-light ml-1"><%= rootserver.country_code %></span>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Disk</td>
                                            <td><%= rootserver.disk_total_gb ? rootserver.disk_total_gb + ' GB' : '–' %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Erstellt</td>
                                            <td><%= rootserver.created_at ? new Date(rootserver.created_at).toLocaleString('de-DE') : '–' %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Zuletzt gesehen</td>
                                            <td><%= rootserver.last_seen ? new Date(rootserver.last_seen).toLocaleString('de-DE') : 'Noch nie verbunden' %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <% if (!isOnline) { %>
                                    <div class="callout callout-warning">
                                        <h6><i class="fa-solid fa-triangle-exclamation mr-1"></i>Daemon offline</h6>
                                        <p class="mb-2">Der Daemon ist nicht verbunden. Prüfe ob der Service auf dem Server läuft:</p>
                                        <pre class="bg-dark text-white p-2 rounded" style="font-size:0.8rem;"><code>sudo systemctl status firebot-daemon
sudo journalctl -u firebot-daemon -n 50</code></pre>
                                    </div>
                                <% } else { %>
                                    <div class="callout callout-success">
                                        <h6><i class="fa-solid fa-circle-check mr-1"></i>Daemon verbunden</h6>
                                        <p class="mb-0">Der Daemon ist online und bereit. Gameserver können erstellt werden.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Gameserver-Auslastung -->
                        <% if (typeof gameservers !== 'undefined' && gameservers.length > 0) { %>
                        <hr class="my-3">
                        <h5 class="mb-3"><i class="fa-solid fa-chart-bar mr-2"></i>Gameserver-Auslastung</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover" id="gs-metrics-table">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Server</th>
                                        <th>Status</th>
                                        <th style="width:25%">CPU</th>
                                        <th style="width:25%">RAM</th>
                                        <th>Spieler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for (const gs of gameservers) { 
                                        const gsStatusColors = { online: 'success', offline: 'secondary', starting: 'warning', stopping: 'warning', error: 'danger' };
                                        const gsColor = gsStatusColors[gs.status] || 'secondary';
                                        const cpuPct = gs.cpu_percent != null ? parseFloat(gs.cpu_percent) : null;
                                        const ramUsed = gs.ram_used_mb != null ? parseInt(gs.ram_used_mb) : null;
                                        const ramTotal = gs.ram_total_mb != null ? parseInt(gs.ram_total_mb) : null;
                                        const ramPct = (ramUsed && ramTotal && ramTotal > 0) ? Math.round(ramUsed / ramTotal * 100) : null;
                                        const players = gs.current_players != null ? gs.current_players : 0;
                                        const maxPlayers = gs.max_players || '?';
                                    %>
                                    <tr data-gs-id="<%= gs.server_id %>">
                                        <td>
                                            <strong><%= gs.display_name || gs.server_name %></strong>
                                            <% if (gs.game_name) { %>
                                                <br><small class="text-muted"><%= gs.game_name %></small>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= gsColor %>" data-gs-status>
                                                <%= gs.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1 mr-2" style="height:16px;">
                                                    <div class="progress-bar bg-<%= cpuPct != null && cpuPct >= 80 ? 'danger' : cpuPct != null && cpuPct >= 60 ? 'warning' : 'success' %>"
                                                         role="progressbar"
                                                         style="width: <%= cpuPct != null ? cpuPct : 0 %>%"
                                                         data-gs-cpu-bar></div>
                                                </div>
                                                <small class="text-nowrap" data-gs-cpu-text><%= cpuPct != null ? cpuPct.toFixed(1) + '%' : '–' %></small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1 mr-2" style="height:16px;">
                                                    <div class="progress-bar bg-<%= ramPct != null && ramPct >= 85 ? 'danger' : ramPct != null && ramPct >= 65 ? 'warning' : 'info' %>"
                                                         role="progressbar"
                                                         style="width: <%= ramPct != null ? ramPct : 0 %>%"
                                                         data-gs-ram-bar></div>
                                                </div>
                                                <small class="text-nowrap" data-gs-ram-text>
                                                    <% if (ramUsed != null && ramTotal != null) { %>
                                                        <%= (ramUsed / 1024).toFixed(1) %> / <%= (ramTotal / 1024).toFixed(1) %> GB
                                                    <% } else { %>
                                                        –
                                                    <% } %>
                                                </small>
                                            </div>
                                        </td>
                                        <td>
                                            <span data-gs-players><%= players %> / <%= maxPlayers %></span>
                                        </td>
                                    </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                        <hr class="my-3">
                        <div class="text-center text-muted py-3">
                            <i class="fa-solid fa-server fa-2x mb-2 d-block"></i>
                            Noch keine Gameserver auf diesem RootServer.
                        </div>
                        <% } %>
                    </div>

                    <!-- Tab: Einstellungen -->
                    <div class="tab-pane fade" id="tab-settings">
                        <form class="guild-ajax-form"
                              data-form-type="update-rootserver"
                              data-method="PUT"
                              action="/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>"
                              method="POST">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Name</label>
                                        <input type="text" class="form-control" name="name" value="<%= rootserver.name %>" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Hostname / FQDN</label>
                                        <input type="text" class="form-control" name="hostname" value="<%= rootserver.hostname || '' %>" placeholder="server01.example.com">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Host / IP</label>
                                        <input type="text" class="form-control" name="host" value="<%= rootserver.host || '' %>" placeholder="91.200.102.182">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Daemon-Port</label>
                                        <input type="number" class="form-control" name="daemon_port" value="<%= rootserver.daemon_port || 9340 %>">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Ländercode</label>
                                        <input type="text" class="form-control" name="country_code" value="<%= rootserver.country_code || '' %>" maxlength="2" placeholder="DE">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Rechenzentrum</label>
                                        <input type="text" class="form-control" name="datacenter" value="<%= rootserver.datacenter || '' %>" placeholder="Hetzner Falkenstein">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>RAM gesamt (GB)</label>
                                        <input type="number" class="form-control" name="ram_total_gb" value="<%= rootserver.ram_total_gb || '' %>" step="0.5">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Disk gesamt (GB)</label>
                                        <input type="number" class="form-control" name="disk_total_gb" value="<%= rootserver.disk_total_gb || '' %>" step="1">
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Beschreibung</label>
                                <textarea class="form-control" name="description" rows="2"><%= rootserver.description || '' %></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-save mr-1"></i>Speichern
                            </button>
                        </form>
                    </div>

                    <!-- Tab: Daemon-Info -->
                    <div class="tab-pane fade" id="tab-daemon">
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table table-sm table-borderless">
                                    <tbody>
                                        <tr>
                                            <td class="text-muted" width="40%">Daemon-ID</td>
                                            <td><code style="font-size:0.8rem;word-break:break-all;"><%= rootserver.daemon_id %></code></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Version</td>
                                            <td><%= rootserver.daemon_version || '–' %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Install-Status</td>
                                            <td>
                                                <span class="badge badge-<%= rootserver.install_status === 'completed' ? 'success' : rootserver.install_status === 'pending' ? 'warning' : 'danger' %>">
                                                    <%= rootserver.install_status || 'unknown' %>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Letzter Ping</td>
                                            <td id="rs-ping"><%= rootserver.last_ping_ms != null ? rootserver.last_ping_ms + ' ms' : '–' %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Verpasste Heartbeats</td>
                                            <td><%= rootserver.missed_heartbeats || 0 %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Basis-Verzeichnis</td>
                                            <td><code><%= rootserver.base_directory || '/opt/firebot-daemon' %></code></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted">Betriebssystem</td>
                                            <td><%= rootserver.os_info || '–' %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <div class="callout callout-info">
                                    <h6><i class="fa-solid fa-circle-info mr-1"></i>Service-Befehle</h6>
                                    <pre class="bg-dark text-white p-2 rounded mb-0" style="font-size:0.8rem;"><code>sudo systemctl status firebot-daemon
sudo systemctl restart firebot-daemon
sudo journalctl -u firebot-daemon -f</code></pre>
                                </div>
                                <a href="/guild/<%= guildId %>/plugins/masterserver/tokens" class="btn btn-sm btn-outline-primary mt-1">
                                    <i class="fa-solid fa-key mr-1"></i>Daemon-Token verwalten
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Tab: Netzwerk / IPs -->
                    <div class="tab-pane fade" id="tab-network">
                        <p class="text-muted mb-3">
                            <i class="fa-solid fa-circle-info mr-1"></i>
                            Alle IP-Adressen dieses Servers. Jede IP muss bereits auf dem Host konfiguriert sein (eth0, eth1, ...).
                            Bei der Gameserver-Erstellung kannst du dann wählen, auf welcher IP der Server lauscht.
                        </p>

                        <!-- Primäre IP (aus Host-Feld) -->
                        <table class="table table-sm table-hover" id="ip-table">
                            <thead class="thead-light">
                                <tr>
                                    <th>IP-Adresse</th>
                                    <th>Bezeichnung</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="ip-list-body">
                                <tr>
                                    <td><code><%= rootserver.host %></code></td>
                                    <td><span class="text-muted">Primäre IP (aus Host-Feld)</span></td>
                                    <td><span class="badge badge-primary"><i class="fa-solid fa-star mr-1"></i>Primär</span></td>
