</section>

<!-- Live-Widget Script -->
<script>
(function () {
    const RS_ID   = '<%= rootserver.id %>';
    const GUILD   = '<%= guildId %>';
    const ONLINE  = <%= isOnline ? 'true' : 'false' %>;
    const API_URL = '/guild/' + GUILD + '/plugins/masterserver/rootservers/' + RS_ID + '/status';

    // ── Ring-Gauge Helfer ────────────────────────────────────
    function setRing(id, pct, defaultColor) {
        const el = document.getElementById(id);
        if (!el || pct == null) return;
        const p = Math.min(Math.max(pct, 0), 100);
        el.setAttribute('stroke-dasharray', p + ' ' + (100 - p));
        el.setAttribute('stroke', pickColor(p, id) || defaultColor);
    }
    function pickColor(pct, ringId) {
        if (ringId === 'cpu-ring')  { if (pct >= 80) return '#dc3545'; if (pct >= 60) return '#ffc107'; return '#28a745'; }
        if (ringId === 'ram-ring')  { if (pct >= 85) return '#dc3545'; if (pct >= 65) return '#ffc107'; return '#17a2b8'; }
        if (ringId === 'disk-ring') { if (pct >= 90) return '#dc3545'; if (pct >= 70) return '#ffc107'; return '#fd7e14'; }
        return null;
    }

    // ── Initiale DB-Werte eintragen ──────────────────────────
    (function initFromDb() {
        <%
            const initCpu  = rootserver.cpu_usage_percent != null ? Math.round(rootserver.cpu_usage_percent) : null;
            const initRamU = rootserver.ram_usage_gb != null ? parseFloat(rootserver.ram_usage_gb) : null;
            const initRamT = rootserver.ram_total_gb != null ? parseFloat(rootserver.ram_total_gb) : null;
            const initDskU = rootserver.disk_usage_gb != null ? parseFloat(rootserver.disk_usage_gb) : null;
            const initDskT = rootserver.disk_total_gb != null ? parseFloat(rootserver.disk_total_gb) : null;
            const initRamP = (initRamU && initRamT && initRamT > 0) ? Math.round(initRamU / initRamT * 100) : null;
            const initDskP = (initDskU && initDskT && initDskT > 0) ? Math.round(initDskU / initDskT * 100) : null;
        %>
        <% if (initCpu !== null) { %>
            setRing('cpu-ring', <%= initCpu %>, '#28a745');
        <% } %>
        <% if (initRamP !== null) { %>
            setRing('ram-ring', <%= initRamP %>, '#17a2b8');
            document.getElementById('ram-pct').textContent = '<%= initRamP %>%';
        <% } %>
        <% if (initDskP !== null) { %>
            setRing('disk-ring', <%= initDskP %>, '#fd7e14');
            document.getElementById('disk-pct').textContent = '<%= initDskP %>%';
        <% } %>
    })();

    // ── Live-Updates via SSE (mit Polling-Fallback) ────────
    if (!ONLINE) return;

    const DAEMON_ID = '<%= rootserver.daemon_id %>';
    let sseConnected = false;
    let pollInterval = null;

    // Aktualisiert alle Gauges aus einem Hardware-Objekt
    function updateGauges(hw) {
        // CPU
        if (hw.cpu_percent != null) {
            const c = Math.round(hw.cpu_percent);
            document.getElementById('cpu-pct').textContent = c + '%';
            setRing('cpu-ring', c, '#28a745');
        }
        // RAM
        if (hw.ram_used_gb != null && hw.ram_total_gb != null && hw.ram_total_gb > 0) {
            const p = Math.round(hw.ram_used_gb / hw.ram_total_gb * 100);
            document.getElementById('ram-pct').textContent  = p + '%';
            document.getElementById('ram-detail').textContent =
                parseFloat(hw.ram_used_gb).toFixed(1) + ' / ' + parseFloat(hw.ram_total_gb).toFixed(1) + ' GB';
            setRing('ram-ring', p, '#17a2b8');
        }
        // Disk
        if (hw.disk_used_gb != null && hw.disk_total_gb != null && hw.disk_total_gb > 0) {
            const p = Math.round(hw.disk_used_gb / hw.disk_total_gb * 100);
            document.getElementById('disk-pct').textContent   = p + '%';
            document.getElementById('disk-detail').textContent =
                Math.round(hw.disk_used_gb) + ' / ' + Math.round(hw.disk_total_gb) + ' GB';
            setRing('disk-ring', p, '#fd7e14');
        }
        // Ping
        if (hw.ping_ms != null) {
            const el = document.getElementById('rs-ping');
            if (el) el.textContent = hw.ping_ms + ' ms';
        }
    }

    // Aktualisiert eine Gameserver-Zeile in der Auslastungs-Tabelle
    function updateGameserverRow(data) {
        const row = document.querySelector('[data-gs-id="' + data.server_id + '"]');
        if (!row) return;

        // Status
        if (data.status) {
            const statusEl = row.querySelector('[data-gs-status]');
            if (statusEl) {
                const colors = { online: 'success', offline: 'secondary', starting: 'warning', stopping: 'warning', error: 'danger' };
                statusEl.className = 'badge badge-' + (colors[data.status] || 'secondary');
                statusEl.textContent = data.status;
            }
        }

        // CPU
        if (data.cpu_percent != null) {
            const cpu = parseFloat(data.cpu_percent);
            const cpuBar = row.querySelector('[data-gs-cpu-bar]');
            const cpuText = row.querySelector('[data-gs-cpu-text]');
            if (cpuBar) {
                cpuBar.style.width = cpu + '%';
                cpuBar.className = 'progress-bar bg-' + (cpu >= 80 ? 'danger' : cpu >= 60 ? 'warning' : 'success');
            }
            if (cpuText) cpuText.textContent = cpu.toFixed(1) + '%';
        }

        // RAM
        if (data.ram_used_mb != null && data.ram_total_mb != null && data.ram_total_mb > 0) {
            const ramPct = Math.round(data.ram_used_mb / data.ram_total_mb * 100);
            const ramBar = row.querySelector('[data-gs-ram-bar]');
            const ramText = row.querySelector('[data-gs-ram-text]');
            if (ramBar) {
                ramBar.style.width = ramPct + '%';
                ramBar.className = 'progress-bar bg-' + (ramPct >= 85 ? 'danger' : ramPct >= 65 ? 'warning' : 'info');
            }
            if (ramText) ramText.textContent = (data.ram_used_mb / 1024).toFixed(1) + ' / ' + (data.ram_total_mb / 1024).toFixed(1) + ' GB';
        }

        // Spieler
        if (data.current_players != null) {
            const playersEl = row.querySelector('[data-gs-players]');
            if (playersEl) playersEl.textContent = data.current_players + ' / ' + (data.max_players || '?');
        }
    }

    // ── SSE-Verbindung ──────────────────────────────────────
    function connectSSE() {
        const sseUrl = '/guild/' + GUILD + '/plugins/masterserver/rootservers/events?daemon_id=' + DAEMON_ID;
        const evtSource = new EventSource(sseUrl);

        evtSource.addEventListener('connected', function() {
            sseConnected = true;
            // Polling stoppen wenn SSE aktiv
            if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
            console.log('[RootServer] SSE verbunden');
        });

        evtSource.addEventListener('metrics', function(e) {
            try {
                const data = JSON.parse(e.data);
                // Host-Stats für diesen Daemon → Ring-Gauges aktualisieren
                if (data.action === 'host_stats' && data.daemon_id === DAEMON_ID) {
                    updateGauges(data);
                }
                // Per-Gameserver Stats → Tabelle aktualisieren
                if (data.action === 'server_stats') {
                    updateGameserverRow(data);
                }
            } catch (_) {}
        });

        evtSource.onerror = function() {
            sseConnected = false;
            evtSource.close();
            console.warn('[RootServer] SSE getrennt, Fallback auf Polling');
            startPolling();
            // Reconnect nach 5s
            setTimeout(connectSSE, 5000);
        };

        return evtSource;
    }

    // ── Polling-Fallback ────────────────────────────────────
    async function poll() {
        try {
            const r = await fetch(API_URL);
            if (!r.ok) return;
            const { success, data } = await r.json();
            if (!success || !data || !data.systemResources) return;
            const hw = data.systemResources;
            updateGauges(hw);
            if (data.lastPingMs != null) {
                const el = document.getElementById('rs-ping');
                if (el) el.textContent = data.lastPingMs + ' ms';
            }
        } catch (_) {}
    }

    function startPolling() {
        if (pollInterval || sseConnected) return;
        poll();
        pollInterval = setInterval(poll, 8000);
    }

    // Initiales Laden + SSE starten
    poll();
    connectSSE();
})();

// ── RootServer löschen ───────────────────────────────────────
function confirmDeleteRootserver() {
    if (!confirm('RootServer wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden!')) return;
    fetch('/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
    }).then(r => r.json()).then(d => {
        if (d.success !== false) {
            window.location.href = d.redirectUrl || '/guild/<%= guildId %>/plugins/masterserver/rootservers';
        } else {
            alert('Fehler: ' + (d.message || 'Unbekannter Fehler'));
        }
    }).catch(() => alert('Netzwerkfehler'));
}

// ── IP-Verwaltung ────────────────────────────────────────────
const IP_API = '/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>/ips';
const HOST_IP_API = '/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>/host-ips';

async function loadHostIPSuggestions() {
    try {
        const r = await fetch(HOST_IP_API);
        const { success, data } = await r.json();
        if (!success || !data || data.length === 0) return;
        const container = document.getElementById('host-ip-suggestions');
        const badges = document.getElementById('host-ip-badges');
        // Bereits eingetragene IPs aus Tabelle lesen
        const existingIPs = new Set(
            Array.from(document.querySelectorAll('#ip-list-body td code')).map(el => el.textContent.trim())
        );
        const toShow = data.filter(d => !existingIPs.has(d.ip));
        if (toShow.length === 0) return;
        toShow.forEach(d => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn btn-sm btn-outline-secondary mr-1 mb-1';
            btn.innerHTML = `<i class="fa-solid fa-ethernet mr-1"></i><code>${d.ip}</code> <small class="text-muted">${d.interface}</small>`;
            btn.onclick = () => { document.getElementById('new-ip-address').value = d.ip; };
            badges.appendChild(btn);
        });
        container.style.display = '';
    } catch (_) {}
}

async function loadIPs() {
    try {
        const r = await fetch(IP_API);
        const { success, data } = await r.json();
        if (!success) return;
        const tbody = document.getElementById('ip-list-body');
        // Nur zusätzliche IPs (primäre bereits als erster Row)
        const extra = data.filter(ip => !ip.is_primary);
        extra.forEach(ip => {
            const tr = document.createElement('tr');
            tr.dataset.ipId = ip.id;
            tr.innerHTML = `
                <td><code>${ip.ip_address}</code></td>
                <td>${ip.label || '<span class="text-muted">–</span>'}</td>
                <td><span class="badge badge-secondary">Zusatz-IP</span></td>
                <td class="text-right">
                    <button class="btn btn-xs btn-outline-danger" onclick="removeIP(${ip.id})">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });
    } catch (_) {}
}

async function addIP() {
    const ip = document.getElementById('new-ip-address').value.trim();
    const label = document.getElementById('new-ip-label').value.trim();
    if (!ip) return alert('Bitte eine IP-Adresse eingeben.');
    try {
        const r = await fetch(IP_API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ip_address: ip, label: label || null, is_primary: 0 })
        });
        const d = await r.json();
        if (!d.success) return alert('Fehler: ' + d.message);
        // Zeile direkt einfügen
        const tbody = document.getElementById('ip-list-body');
        const tr = document.createElement('tr');
        tr.dataset.ipId = d.data.id;
        tr.innerHTML = `
            <td><code>${ip}</code></td>
            <td>${label || '<span class="text-muted">–</span>'}</td>
            <td><span class="badge badge-secondary">Zusatz-IP</span></td>
            <td class="text-right">
                <button class="btn btn-xs btn-outline-danger" onclick="removeIP(${d.data.id})">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </td>`;
        tbody.appendChild(tr);
        document.getElementById('new-ip-address').value = '';
        document.getElementById('new-ip-label').value = '';
    } catch (_) { alert('Netzwerkfehler'); }
}

async function removeIP(ipId) {
    if (!confirm('IP-Adresse entfernen?')) return;
    try {
        const r = await fetch(IP_API + '/' + ipId, { method: 'DELETE' });
        const d = await r.json();
        if (!d.success) return alert('Fehler: ' + d.message);
        const row = document.querySelector('tr[data-ip-id="' + ipId + '"]');
        if (row) row.remove();
    } catch (_) { alert('Netzwerkfehler'); }
}

// IPs laden wenn Tab aktiv wird (Bootstrap 4 = jQuery-Events!)
$('#tab-network-link').on('shown.bs.tab', function() {
    loadIPs();
    loadHostIPSuggestions();
});
// Auch direkt laden falls Tab schon aktiv
if (document.querySelector('#tab-network.active')) { loadIPs(); loadHostIPSuggestions(); }

// ── Port-Allocations (DuneDataTable) ────────────────────
const ALLOC_API = '/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>/allocations';

const allocTable = new DuneDataTable({
    containerId: 'alloc-table-container',
    apiUrl: ALLOC_API,
    rowKey: 'id',
    perPage: 25,
    selectable: true,
    searchable: true,
    columns: [
        { key: 'ip', label: 'IP-Adresse', sortable: true, render: (val, row) => 
            `<code>${val}</code>${row.ip_alias ? ' <small class="text-muted">(' + row.ip_alias + ')</small>' : ''}`
        },
        { key: 'port', label: 'Port', sortable: true, render: (val) => `<code>${val}</code>` },
        { key: 'server_name', label: 'Zugewiesen an', render: (val, row) => 
            row.server_id 
                ? '<span class="badge badge-warning"><i class="fa-solid fa-server mr-1"></i>' + (val || 'Server #' + row.server_id) + '</span>'
                : '<span class="badge badge-success"><i class="fa-solid fa-circle-check mr-1"></i>Frei</span>'
        },
        { key: 'notes', label: 'Notizen', render: (val) => val ? `<small class="text-muted">${val}</small>` : '' },
        { key: '_actions', label: '', render: (_, row) => 
            !row.server_id 
                ? `<button class="btn btn-xs btn-outline-danger" onclick="deleteAllocation(${row.id})"><i class="fa-solid fa-trash"></i></button>`
                : ''
        }
    ],
    filters: [
        { key: 'status', label: 'Status', options: [
            { value: 'all', text: 'Alle anzeigen' },
            { value: 'free', text: 'Nur freie' },
            { value: 'assigned', text: 'Nur zugewiesene' }
        ], match: (row, val) => val === 'free' ? row.server_id === null : val === 'assigned' ? row.server_id !== null : true }
    ],
    summaryMap: (summary) => [
        { label: 'Gesamt', value: summary.total, color: 'info', icon: 'fa-list' },
        { label: 'Frei', value: summary.free, color: 'success', icon: 'fa-circle-check' },
        { label: 'Zugewiesen', value: summary.assigned, color: 'warning', icon: 'fa-server' }
    ],
    rowClass: (row) => row.server_id ? '' : 'table-light',
    bulkActions: [
        { key: 'delete', label: 'Löschen', icon: 'fa-trash', class: 'btn-danger', confirm: '{count} freie Allocations wirklich löschen?' }
    ],
    onBulkAction: async (action, ids) => {
        if (action === 'delete') {
            let deleted = 0, skipped = 0;
            for (const id of ids) {
                const r = await fetch(ALLOC_API + '/' + id, { method: 'DELETE' });
                const d = await r.json();
                if (d.success) deleted++; else skipped++;
            }
            if (typeof toastr !== 'undefined') {
                toastr.success(`${deleted} Allocations gelöscht${skipped > 0 ? `, ${skipped} übersprungen (zugewiesen)` : ''}`);
            }
        }
    },
    onLoad: (data) => {
        // Badge im Tab-Header aktualisieren
        const badge = document.getElementById('alloc-count-badge');
        if (badge) badge.textContent = data.length;
        // IP-Dropdown aktualisieren
        updateAllocIPDropdown(data);
    },
    emptyText: 'Keine Allocations gefunden.',
    emptyIcon: 'fa-solid fa-inbox'
});

function updateAllocIPDropdown(allocations) {
    const select = document.getElementById('alloc-ip');
    if (!select) return;
    const primaryIp = '<%= rootserver.host %>';
    const ips = new Set([primaryIp]);
    allocations.forEach(a => ips.add(a.ip));
    ips.forEach(ip => {
        if (!Array.from(select.options).some(o => o.value === ip)) {
            const opt = document.createElement('option');
            opt.value = ip;
            opt.textContent = ip;
            select.appendChild(opt);
        }
    });
}

async function addAllocations() {
    const ip = document.getElementById('alloc-ip').value;
    const ports = document.getElementById('alloc-ports').value.trim();
    const alias = document.getElementById('alloc-alias').value.trim();

    if (!ports) return alert('Bitte Ports eingeben (z.B. 25565-25600)');

    try {
        const r = await fetch(ALLOC_API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ip, ports, ip_alias: alias || null })
        });
        const d = await r.json();
        if (!d.success) return alert('Fehler: ' + d.message);

        if (typeof toastr !== 'undefined') {
            toastr.success(d.message);
        }

        document.getElementById('alloc-ports').value = '';
        document.getElementById('alloc-alias').value = '';
        allocTable.load();
    } catch (_) { alert('Netzwerkfehler'); }
}

async function deleteAllocation(allocId) {
    if (!confirm('Port-Allocation wirklich löschen?')) return;
    try {
        const r = await fetch(ALLOC_API + '/' + allocId, { method: 'DELETE' });
        const d = await r.json();
        if (!d.success) return alert('Fehler: ' + d.message);
        allocTable.load();
    } catch (_) { alert('Netzwerkfehler'); }
}

// Allocations laden wenn Tab aktiv wird (Bootstrap 4 = jQuery-Events!)
$('#tab-allocations-link').on('shown.bs.tab', function() { allocTable.load(); });
// Auch direkt laden falls Tab schon aktiv
if (document.querySelector('#tab-allocations.active')) { allocTable.load(); }

// Zusatz-IPs in Allocation-Dropdown laden
async function loadAllocIPs() {
    try {
        const r = await fetch('/guild/<%= guildId %>/plugins/masterserver/rootservers/<%= rootserver.id %>/ips');
        const { success, data } = await r.json();
        if (!success) return;
        const select = document.getElementById('alloc-ip');
        data.forEach(ip => {
            if (!ip.is_primary && !Array.from(select.options).some(o => o.value === ip.ip_address)) {
                const opt = document.createElement('option');
                opt.value = ip.ip_address;
                opt.textContent = ip.ip_address + (ip.label ? ' (' + ip.label + ')' : '');
                select.appendChild(opt);
            }
        });
    } catch (_) {}
}
loadAllocIPs();
</script>
