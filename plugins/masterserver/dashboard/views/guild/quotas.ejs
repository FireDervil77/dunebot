<%
/**
 * Ressourcen-Management (Pterodactyl-Style)
 * Zeigt Ressourcen-Auslastung pro RootServer-Node mit Overallocation-Steuerung
 */
%>

<!-- Content Header -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-tachometer-alt mr-2"></i>Ressourcen-Management
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>/plugins/masterserver">Masterserver</a></li>
                    <li class="breadcrumb-item active">Ressourcen</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<section class="content">
    <div class="container-fluid">

        <% if (!nodes || nodes.length === 0) { %>
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            Kein RootServer konfiguriert. <a href="/guild/<%= guildId %>/plugins/masterserver/daemon">Daemon einrichten</a>.
        </div>
        <% } %>

        <% nodes.forEach(function(node) {
            const isOnline = node.daemon_status === 'online';
            const l = node.limits;
            const u = node.usage;
            const ramBarClass  = u.ramPct  >= 90 ? 'danger' : u.ramPct  >= 75 ? 'warning' : 'success';
            const diskBarClass = u.diskPct >= 90 ? 'danger' : u.diskPct >= 75 ? 'warning' : 'success';
            const cpuBarClass  = u.cpuPct  >= 90 ? 'danger' : u.cpuPct  >= 75 ? 'warning' : 'success';
        %>

        <div class="card card-outline <%= isOnline ? 'card-success' : 'card-secondary' %> mb-4">

            <!-- Card Header -->
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-server mr-2"></i>
                    <strong><%= node.name %></strong>
                    <% if (isOnline) { %>
                        <span class="badge badge-success ml-2">
                            <i class="fas fa-circle" style="font-size:.6em;"></i> Online
                        </span>
                    <% } else { %>
                        <span class="badge badge-secondary ml-2">
                            <i class="fas fa-circle" style="font-size:.6em;"></i> Offline
                        </span>
                    <% } %>
                </h3>
                <div class="card-tools">
                    <small class="text-muted">
                        <i class="fas fa-microchip mr-1"></i><%= node.cpu_cores || '?' %> Kerne &nbsp;·&nbsp;
                        <i class="fas fa-memory mr-1"></i><%= node.ram_total_gb ? parseFloat(node.ram_total_gb).toFixed(1) : '?' %> GB RAM &nbsp;·&nbsp;
                        <i class="fas fa-hdd mr-1"></i><%= node.disk_total_gb ? parseFloat(node.disk_total_gb).toFixed(1) : '?' %> GB Disk
                    </small>
                </div>
            </div>

            <div class="card-body">

                <!-- ── Ressourcen-Balken ── -->
                <div class="row mb-3">

                    <!-- RAM -->
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-sm font-weight-bold">
                                <i class="fas fa-memory mr-1 text-muted"></i>Arbeitsspeicher
                            </span>
                            <span class="text-sm text-muted">
                                <%= Math.round(node.allocated.allocated_ram_mb || 0).toLocaleString() %> MB
                                / <%= l.usableRamMB.toLocaleString() %> MB
                            </span>
                        </div>
                        <div class="progress" style="height:14px;">
                            <div class="progress-bar bg-<%= ramBarClass %>"
                                 style="width:<%= u.ramPct %>%"
                                 title="<%= u.ramPct %>%">
                                <% if (u.ramPct >= 15) { %><%= u.ramPct %>%<% } %>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">Reserviert: <%= l.reservedRamMB %> MB</small>
                            <small class="text-muted">Gesamt: <%= l.totalRamMB.toLocaleString() %> MB</small>
                        </div>
                    </div>

                    <!-- Disk -->
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-sm font-weight-bold">
                                <i class="fas fa-hdd mr-1 text-muted"></i>Festplatte
                            </span>
                            <span class="text-sm text-muted">
                                <%= Math.round(node.allocated.allocated_disk_gb || 0) %> GB
                                / <%= l.usableDiskGB %> GB
                            </span>
                        </div>
                        <div class="progress" style="height:14px;">
                            <div class="progress-bar bg-<%= diskBarClass %>"
                                 style="width:<%= u.diskPct %>%"
                                 title="<%= u.diskPct %>%">
                                <% if (u.diskPct >= 15) { %><%= u.diskPct %>%<% } %>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">Reserviert: <%= l.reservedDiskGB %> GB</small>
                            <small class="text-muted">Gesamt: <%= l.totalDiskGB %> GB</small>
                        </div>
                    </div>

                    <!-- CPU -->
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-sm font-weight-bold">
                                <i class="fas fa-microchip mr-1 text-muted"></i>CPU-Kerne
                            </span>
                            <span class="text-sm text-muted">
                                <%= node.allocated.allocated_cpu_cores || 0 %> / <%= l.totalCpuCores %>
                            </span>
                        </div>
                        <div class="progress" style="height:14px;">
                            <div class="progress-bar bg-<%= cpuBarClass %>"
                                 style="width:<%= u.cpuPct %>%"
                                 title="<%= u.cpuPct %>%">
                                <% if (u.cpuPct >= 15) { %><%= u.cpuPct %>%<% } %>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">Server: <%= node.allocated.server_count || 0 %></small>
                            <small class="text-muted">Kerne: <%= l.totalCpuCores %></small>
                        </div>
                    </div>

                </div>

                <hr class="mt-2 mb-3">

                <!-- ── Verwaltungszeilen ── -->
                <div class="row">

                    <!-- Überallokation -->
                    <div class="col-md-6 mb-3 mb-md-0">
                        <h6 class="text-sm font-weight-bold mb-2">
                            <i class="fas fa-expand-arrows-alt mr-1 text-muted"></i>Überallokation
                            <small class="text-muted font-weight-normal ml-1">(0 – 300 %)</small>
                        </h6>
                        <form class="form-overallocation" data-rs-id="<%= node.id %>">
                            <div class="input-group input-group-sm mb-2">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" style="min-width:80px;">RAM %</span>
                                </div>
                                <input type="number" class="form-control" name="overallocateRam"
                                       min="0" max="300" value="<%= l.overRam %>"
                                       placeholder="0">
                                <div class="input-group-append">
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="input-group input-group-sm mb-2">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" style="min-width:80px;">Disk %</span>
                                </div>
                                <input type="number" class="form-control" name="overallocateDisk"
                                       min="0" max="300" value="<%= l.overDisk %>"
                                       placeholder="0">
                                <div class="input-group-append">
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="fas fa-save mr-1"></i>Speichern
                            </button>
                        </form>
                    </div>

                    <!-- OS-Reservierung -->
                    <div class="col-md-6">
                        <h6 class="text-sm font-weight-bold mb-2">
                            <i class="fas fa-lock mr-1 text-muted"></i>OS-Reservierung
                            <small class="text-muted font-weight-normal ml-1">(Betriebssystem)</small>
                        </h6>
                        <form class="form-reserved" data-rs-id="<%= node.id %>">
                            <div class="input-group input-group-sm mb-2">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" style="min-width:80px;">RAM</span>
                                </div>
                                <input type="number" class="form-control" name="reservedRamMB"
                                       min="0" value="<%= l.reservedRamMB %>"
                                       placeholder="1024">
                                <div class="input-group-append">
                                    <span class="input-group-text">MB</span>
                                </div>
                            </div>
                            <div class="input-group input-group-sm mb-2">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" style="min-width:80px;">Disk</span>
                                </div>
                                <input type="number" class="form-control" name="reservedDiskGB"
                                       min="0" value="<%= l.reservedDiskGB %>"
                                       placeholder="10">
                                <div class="input-group-append">
                                    <span class="input-group-text">GB</span>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="fas fa-save mr-1"></i>Speichern
                            </button>
                        </form>
                    </div>

                </div>

                <!-- ── Gameserver-Tabelle ── -->
                <% if (node.gameservers && node.gameservers.length > 0) { %>
                <hr class="mt-3 mb-3">
                <h6 class="text-sm font-weight-bold mb-2">
                    <i class="fas fa-th-list mr-1 text-muted"></i>
                    Gameserver (<%= node.gameservers.length %>)
                </h6>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr class="text-muted" style="font-size:.8rem;">
                                <th>Name</th>
                                <th>Typ</th>
                                <th class="text-right">RAM</th>
                                <th class="text-right">CPU</th>
                                <th class="text-right">Disk</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                        <% node.gameservers.forEach(function(gs) { %>
                            <tr>
                                <td>
                                    <a href="/guild/<%= guildId %>/plugins/masterserver/servers/<%= gs.server_id %>"
                                       class="text-dark">
                                        <%= gs.server_name || gs.server_id %>
                                    </a>
                                </td>
                                <td><small class="text-muted"><%= gs.server_type || '–' %></small></td>
                                <td class="text-right">
                                    <span class="<%= (gs.allocated_ram_mb || 0) > 0 ? '' : 'text-muted' %>">
                                        <%= gs.allocated_ram_mb ? gs.allocated_ram_mb.toLocaleString() + ' MB' : '–' %>
                                    </span>
                                </td>
                                <td class="text-right">
                                    <span class="<%= (gs.allocated_cpu_cores || 0) > 0 ? '' : 'text-muted' %>">
                                        <%= gs.allocated_cpu_cores || '–' %>
                                    </span>
                                </td>
                                <td class="text-right">
                                    <span class="<%= (gs.allocated_disk_gb || 0) > 0 ? '' : 'text-muted' %>">
                                        <%= gs.allocated_disk_gb ? gs.allocated_disk_gb + ' GB' : '–' %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <% if (gs.status === 'running') { %>
                                        <span class="badge badge-success">running</span>
                                    <% } else if (gs.status === 'stopped') { %>
                                        <span class="badge badge-secondary">stopped</span>
                                    <% } else if (gs.status === 'starting') { %>
                                        <span class="badge badge-warning">starting</span>
                                    <% } else { %>
                                        <span class="badge badge-light"><%= gs.status || 'unknown' %></span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <hr class="mt-3 mb-2">
                <p class="text-muted text-sm mb-0">
                    <i class="fas fa-info-circle mr-1"></i>
                    Keine Gameserver auf diesem Node.
                </p>
                <% } %>

            </div><!-- /.card-body -->
        </div><!-- /.card -->

        <% }); %>

    </div><!-- /.container-fluid -->
</section>

<!-- ── JavaScript ── -->
<script>
(function () {
    'use strict';

    const guildId = '<%= guildId %>';

    // ── Überallokation speichern ──────────────────────────────────────────────
    document.querySelectorAll('.form-overallocation').forEach(function (form) {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const rsId = form.dataset.rsId;
            const data = Object.fromEntries(new FormData(form));
            try {
                const r = await fetch(`/guild/${guildId}/plugins/masterserver/quotas/rootserver/${rsId}/overallocation`, {
                    method:  'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ overallocateRam: data.overallocateRam, overallocateDisk: data.overallocateDisk })
                });
                const json = await r.json();
                if (json.success) {
                    showToast('Überallokation gespeichert.', 'success');
                    setTimeout(function () { location.reload(); }, 800);
                } else {
                    showToast('Fehler: ' + (json.message || 'Unbekannt'), 'error');
                }
            } catch (err) {
                showToast('Netzwerk-Fehler', 'error');
            }
        });
    });

    // ── OS-Reservierung speichern ─────────────────────────────────────────────
    document.querySelectorAll('.form-reserved').forEach(function (form) {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const rsId = form.dataset.rsId;
            const data = Object.fromEntries(new FormData(form));
            try {
                const r = await fetch(`/guild/${guildId}/plugins/masterserver/quotas/rootserver/${rsId}/reserved`, {
                    method:  'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ reservedRamMB: data.reservedRamMB, reservedDiskGB: data.reservedDiskGB })
                });
                const json = await r.json();
                if (json.success) {
                    showToast('Reservierung gespeichert.', 'success');
                    setTimeout(function () { location.reload(); }, 800);
                } else {
                    showToast('Fehler: ' + (json.message || 'Unbekannt'), 'error');
                }
            } catch (err) {
                showToast('Netzwerk-Fehler', 'error');
            }
        });
    });

    // ── Toast Helper ──────────────────────────────────────────────────────────
    function showToast(msg, type) {
        if (window.toastr) {
            if (type === 'success') toastr.success(msg);
            else toastr.error(msg);
        } else {
            alert(msg);
        }
    }
})();
</script>
