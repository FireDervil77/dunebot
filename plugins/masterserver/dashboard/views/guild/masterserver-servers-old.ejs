<!-- Masterserver Server-Verwaltung (Physische Server) -->
<div class="container-fluid">
  <div class="row">
    <!-- Page Header -->
    <div class="col-12 mb-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h2>
            <i class="fa-solid fa-server text-primary me-2"></i>
            <%= tr('masterserver:SERVERS.TITLE') || 'Server-Verwaltung' %>
          </h2>
          <p class="text-muted">Physische/virtuelle Server die vom Daemon verwaltet werden</p>
        </div>
        <button type="button" class="btn btn-primary" onclick="showCreateServerModal()">
          <i class="fa-solid fa-plus me-2"></i>
          Neuer Server
        </button>
      </div>
    </div>
  </div>

  <!-- Status Info Bar -->
  <div class="row mb-3">
    <div class="col-12">
      <div class="alert <%= daemonOnline ? 'alert-success' : 'alert-warning' %>">
        <i class="fa-solid <%= daemonOnline ? 'fa-circle-check' : 'fa-circle-exclamation' %> me-2"></i>
        <strong>Daemon-Status:</strong> 
        <%= daemonOnline ? 'Online - Hardware-Stats werden live aktualisiert' : 'Offline - Letzte bekannte Daten werden angezeigt' %>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="row mb-3">
    <div class="col-md-3">
      <div class="info-box">
        <span class="info-box-icon bg-primary"><i class="fa-solid fa-server"></i></span>
        <div class="info-box-content">
          <span class="info-box-text">Gesamt</span>
          <span class="info-box-number"><%= serverStats.total %></span>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="info-box">
        <span class="info-box-icon bg-success"><i class="fa-solid fa-circle-check"></i></span>
        <div class="info-box-content">
          <span class="info-box-text">Aktiv</span>
          <span class="info-box-number"><%= serverStats.active %></span>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="info-box">
        <span class="info-box-icon bg-warning"><i class="fa-solid fa-wrench"></i></span>
        <div class="info-box-content">
          <span class="info-box-text">Wartung</span>
          <span class="info-box-number"><%= serverStats.maintenance %></span>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="info-box">
        <span class="info-box-icon bg-info"><i class="fa-solid fa-gamepad"></i></span>
        <div class="info-box-content">
          <span class="info-box-text">Gameserver</span>
          <span class="info-box-number"><%= serverStats.totalGameservers %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Servers Table Card -->
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fa-solid fa-server me-2"></i>
            Registrierte Server (<%= servers.length %>)
          </h3>
          <div class="card-tools">
            <button type="button" class="btn btn-sm btn-primary" onclick="window.location.reload()">
              <i class="fa-solid fa-refresh me-1"></i> Aktualisieren
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <% if (servers.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0">
                <thead>
                  <tr>
                    <th width="5%">Status</th>
                    <th width="15%"><%= tr('masterserver:SERVERS.SERVER_NAME') %></th>
                    <th width="10%"><%= tr('masterserver:SERVERS.SERVER_TYPE') %></th>
                    <th width="15%"><%= tr('masterserver:SERVERS.SERVER_ID') %></th>
                    <th width="10%" class="text-center"><%= tr('masterserver:SERVERS.PLAYERS') %></th>
                    <th width="15%"><%= tr('masterserver:SERVERS.LAST_HEARTBEAT') %></th>
                    <th width="15%">Erstellt</th>
                    <th width="15%" class="text-center">Aktionen</th>
                  </tr>
                </thead>
                <tbody>
                  <% servers.forEach(server => { 
                    const statusColors = {
                      'online': 'success',
                      'offline': 'secondary',
                      'starting': 'info',
                      'stopping': 'warning',
                      'error': 'danger'
                    };
                    const statusColor = statusColors[server.status] || 'secondary';
                    const lastHeartbeat = new Date(server.last_heartbeat);
                    const heartbeatAge = Math.floor((Date.now() - lastHeartbeat) / 60000); // Minuten
                  %>
                    <tr>
                      <td>
                        <span class="badge badge-<%= statusColor %>">
                          <i class="fa-solid fa-circle"></i>
                        </span>
                      </td>
                      <td>
                        <strong><%= server.server_name %></strong>
                        <% if (server.plugin_name) { %>
                          <br><small class="text-muted">Plugin: <%= server.plugin_name %></small>
                        <% } %>
                      </td>
                      <td>
                        <span class="badge badge-info"><%= server.server_type %></span>
                      </td>
                      <td>
                        <code style="font-size: 11px;"><%= server.server_id %></code>
                      </td>
                      <td class="text-center">
                        <% if (server.status === 'online') { %>
                          <strong><%= server.current_players %></strong> / <%= server.max_players %>
                          <div class="progress mt-1" style="height: 5px;">
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: <%= (server.current_players / server.max_players * 100) %>%">
                            </div>
                          </div>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td>
                        <small>
                          <%= lastHeartbeat.toLocaleString('de-DE') %>
                          <br>
                          <span class="<%= heartbeatAge > 5 ? 'text-danger' : 'text-success' %>">
                            (vor <%= heartbeatAge %> Min.)
                          </span>
                        </small>
                      </td>
                      <td>
                        <small><%= new Date(server.created_at).toLocaleString('de-DE') %></small>
                      </td>
                      <td class="text-center">
                        <div class="btn-group btn-group-sm">
                          <button type="button" class="btn btn-info btn-sm" onclick="showServerDetails('<%= server.server_id %>')" title="Details">
                            <i class="fa-solid fa-info-circle"></i>
                          </button>
                          <button type="button" class="btn btn-warning btn-sm" onclick="showServerConfig('<%= server.server_id %>')" title="Konfiguration">
                            <i class="fa-solid fa-cog"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="p-5 text-center text-muted">
              <i class="fa-solid fa-server fa-4x mb-3"></i>
              <h5><%= tr('masterserver:SERVERS.NO_SERVERS') %></h5>
              <p>Keine Server registriert. Server werden automatisch vom Daemon registriert wenn sie gestartet werden.</p>
              <hr class="my-4">
              <div class="alert alert-info">
                <h6><i class="fa-solid fa-lightbulb me-2"></i>Wie registriere ich Server?</h6>
                <ol class="text-left mb-0">
                  <li>Stelle sicher dass dein Daemon online ist</li>
                  <li>Installiere ein Server-Plugin (z.B. Gameserver-Plugin)</li>
                  <li>Konfiguriere den Server im Plugin</li>
                  <li>Der Daemon registriert den Server automatisch</li>
                </ol>
              </div>
            </div>
          <% } %>
        </div>
        <% if (servers.length > 0) { %>
          <div class="card-footer">
            <div class="row text-center">
              <div class="col-3">
                <strong><%= servers.filter(s => s.status === 'online').length %></strong>
                <br><small class="text-muted">Online</small>
              </div>
              <div class="col-3">
                <strong><%= servers.filter(s => s.status === 'offline').length %></strong>
                <br><small class="text-muted">Offline</small>
              </div>
              <div class="col-3">
                <strong><%= servers.reduce((sum, s) => sum + (s.current_players || 0), 0) %></strong>
                <br><small class="text-muted">Spieler gesamt</small>
              </div>
              <div class="col-3">
                <strong><%= servers.reduce((sum, s) => sum + (s.max_players || 0), 0) %></strong>
                <br><small class="text-muted">Maximale Kapazität</small>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Server Details Modal -->
<div class="modal fade" id="serverDetailsModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header bg-info">
        <h5 class="modal-title">
          <i class="fa-solid fa-info-circle me-2"></i>
          Server-Details
        </h5>
        <button type="button" class="close" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>
      <div class="modal-body" id="serverDetailsContent">
        <p class="text-center"><i class="fa-solid fa-spinner fa-spin"></i> Lädt...</p>
      </div>
    </div>
  </div>
</div>

<!-- Server Config Modal -->
<div class="modal fade" id="serverConfigModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header bg-warning">
        <h5 class="modal-title">
          <i class="fa-solid fa-cog me-2"></i>
          Server-Konfiguration
        </h5>
        <button type="button" class="close" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>
      <div class="modal-body" id="serverConfigContent">
        <p class="text-center"><i class="fa-solid fa-spinner fa-spin"></i> Lädt...</p>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script>
function showServerDetails(serverId) {
  // Finde Server in der Tabelle
  const servers = <%- JSON.stringify(servers) %>;
  const server = servers.find(s => s.server_id === serverId);
  
  if (!server) {
    GuildAjax.showToast('error', 'Server nicht gefunden');
    return;
  }
  
  // Modal-Content erstellen
  const content = `
    <table class="table table-sm">
      <tbody>
        <tr><th width="30%">Server-ID:</th><td><code>${server.server_id}</code></td></tr>
        <tr><th>Name:</th><td>${server.server_name}</td></tr>
        <tr><th>Typ:</th><td>${server.server_type}</td></tr>
        <tr><th>Plugin:</th><td>${server.plugin_name || '-'}</td></tr>
        <tr><th>Status:</th><td><span class="badge badge-${server.status === 'online' ? 'success' : 'secondary'}">${server.status}</span></td></tr>
        <tr><th>Spieler:</th><td>${server.current_players || 0} / ${server.max_players || 0}</td></tr>
        <tr><th>Erstellt am:</th><td>${new Date(server.created_at).toLocaleString('de-DE')}</td></tr>
        <tr><th>Letzter Heartbeat:</th><td>${new Date(server.last_heartbeat).toLocaleString('de-DE')}</td></tr>
        ${server.last_start ? `<tr><th>Letzter Start:</th><td>${new Date(server.last_start).toLocaleString('de-DE')}</td></tr>` : ''}
        ${server.last_stop ? `<tr><th>Letzter Stop:</th><td>${new Date(server.last_stop).toLocaleString('de-DE')}</td></tr>` : ''}
      </tbody>
    </table>
  `;
  
  document.getElementById('serverDetailsContent').innerHTML = content;
  $('#serverDetailsModal').modal('show');
}

function showServerConfig(serverId) {
  const servers = <%- JSON.stringify(servers) %>;
  const server = servers.find(s => s.server_id === serverId);
  
  if (!server) {
    GuildAjax.showToast('error', 'Server nicht gefunden');
    return;
  }
  
  const config = server.config || {};
  const content = `
    <pre class="bg-dark text-white p-3 rounded"><code>${JSON.stringify(config, null, 2)}</code></pre>
    ${server.start_command ? `<h6 class="mt-3">Start-Befehl:</h6><pre class="bg-light p-2"><code>${server.start_command}</code></pre>` : ''}
    ${server.stop_command ? `<h6 class="mt-3">Stop-Befehl:</h6><pre class="bg-light p-2"><code>${server.stop_command}</code></pre>` : ''}
    ${server.status_command ? `<h6 class="mt-3">Status-Befehl:</h6><pre class="bg-light p-2"><code>${server.status_command}</code></pre>` : ''}
  `;
  
  document.getElementById('serverConfigContent').innerHTML = content;
  $('#serverConfigModal').modal('show');
}

// Auto-Reload bei Online-Daemon (alle 30s)
<% if (daemonOnline) { %>
  setTimeout(() => {
    console.log('[Masterserver] Auto-Refresh Server-Registry');
    window.location.reload();
  }, 30000);
<% } %>
</script>
