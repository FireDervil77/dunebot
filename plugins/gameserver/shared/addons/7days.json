{
  "meta": {
    "version": "FIREBOT_v2",
    "author": "FireBot Official",
    "update_url": null
  },
  "exported_at": "2025-10-19T00:00:00+00:00",
  "name": "7 Days to Die",
  "slug": "7days",
  "description": "7 Days to Die Dedicated Server - Zombie-Survival mit Crafting, Base-Building und Horden-Angriffen. Umfangreiche XML-Konfiguration möglich.",
  "category": "survival",
  "tags": [
    "steam",
    "survival",
    "zombies",
    "crafting",
    "pve",
    "pvp"
  ],
  "visibility": "official",
  "trust_level": "official",
  "status": "approved",
  "features": [
    "mods",
    "xml_config"
  ],
  "steam": {
    "app_id": 251570,
    "server_app_id": 294420,
    "install_dir": "7dtd"
  },
  "installation": {
    "method": "steamcmd",
    "app_id": "294420",
    "validate": true,
    "script": "#!/bin/bash\ncd \"${INSTALL_DIR}\"\n\"${STEAMCMD}\" +force_install_dir \"${INSTALL_DIR}\" +login anonymous +app_update 294420 validate +quit"
  },
  "startup": {
    "command": "./7DaysToDieServer.x86_64 -configfile=serverconfig.xml -logfile /mnt/server/logs/output.log -quit -batchmode -nographics -dedicated",
    "done": "GameServer.Init successful",
    "stop": "shutdown"
  },
  "config": {
    "files": {
      "serverconfig.xml": {
        "parser": "xml",
        "find": {
          "ServerSettings": {
            "ServerName": "<property name=\"ServerName\" value=\"{{SERVER_NAME}}\"/>",
            "ServerDescription": "<property name=\"ServerDescription\" value=\"{{SERVER_DESCRIPTION}}\"/>",
            "ServerWebsiteURL": "<property name=\"ServerWebsiteURL\" value=\"{{SERVER_URL}}\"/>",
            "ServerPassword": "<property name=\"ServerPassword\" value=\"{{SERVER_PASSWORD}}\"/>",
            "ServerPort": "<property name=\"ServerPort\" value=\"{{SERVER_PORT}}\"/>",
            "ServerMaxPlayerCount": "<property name=\"ServerMaxPlayerCount\" value=\"{{MAX_PLAYERS}}\"/>",
            "ServerVisibility": "<property name=\"ServerVisibility\" value=\"{{VISIBILITY}}\"/>",
            "GameWorld": "<property name=\"GameWorld\" value=\"{{GAME_WORLD}}\"/>",
            "WorldGenSeed": "<property name=\"WorldGenSeed\" value=\"{{WORLD_SEED}}\"/>",
            "WorldGenSize": "<property name=\"WorldGenSize\" value=\"{{WORLD_SIZE}}\"/>",
            "GameMode": "<property name=\"GameMode\" value=\"{{GAME_MODE}}\"/>",
            "GameDifficulty": "<property name=\"GameDifficulty\" value=\"{{DIFFICULTY}}\"/>",
            "DayNightLength": "<property name=\"DayNightLength\" value=\"{{DAY_LENGTH}}\"/>",
            "ZombiesRun": "<property name=\"ZombiesRun\" value=\"{{ZOMBIE_RUN}}\"/>",
            "BloodMoonEnemyCount": "<property name=\"BloodMoonEnemyCount\" value=\"{{BLOOD_MOON_COUNT}}\"/>",
            "LootAbundance": "<property name=\"LootAbundance\" value=\"{{LOOT_ABUNDANCE}}\"/>",
            "LootRespawnDays": "<property name=\"LootRespawnDays\" value=\"{{LOOT_RESPAWN}}\"/>",
            "XPMultiplier": "<property name=\"XPMultiplier\" value=\"{{XP_MULTI}}\"/>",
            "PlayerKillingMode": "<property name=\"PlayerKillingMode\" value=\"{{PK_MODE}}\"/>"
          }
        }
      }
    },
    "startup": {
      "done": "GameServer.Init successful"
    },
    "logs": {},
    "stop": "shutdown"
  },
  "variables": [
    {
      "name": "Server Name",
      "description": "Name deines 7 Days to Die Servers",
      "env_variable": "SERVER_NAME",
      "default_value": "My 7DTD Server",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:100",
      "field_type": "text"
    },
    {
      "name": "Server Description",
      "description": "Beschreibung für die Serverliste",
      "env_variable": "SERVER_DESCRIPTION",
      "default_value": "A 7 Days to Die Server",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string|max:500",
      "field_type": "textarea"
    },
    {
      "name": "Server Website URL",
      "description": "Website oder Discord-Link",
      "env_variable": "SERVER_URL",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|url",
      "field_type": "text"
    },
    {
      "name": "Server Password",
      "description": "Passwort (leer = kein Passwort)",
      "env_variable": "SERVER_PASSWORD",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string|max:50",
      "field_type": "text"
    },
    {
      "name": "Max Players",
      "description": "Maximale Spieleranzahl",
      "env_variable": "MAX_PLAYERS",
      "default_value": "8",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:1|max:32",
      "field_type": "number"
    },
    {
      "name": "Server Port",
      "description": "Hauptport des Servers",
      "env_variable": "SERVER_PORT",
      "default_value": "26900",
      "user_viewable": true,
      "user_editable": false,
      "rules": "required|integer",
      "field_type": "text"
    },
    {
      "name": "Server Visibility",
      "description": "Sichtbarkeit in der Serverliste",
      "env_variable": "VISIBILITY",
      "default_value": "2",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|in:0,1,2",
      "field_type": "select",
      "select_options": {
        "2": "Public (Öffentlich)",
        "1": "Friends Only",
        "0": "Hidden (Unsichtbar)"
      }
    },
    {
      "name": "Game World",
      "description": "Welche Welt soll geladen werden?",
      "env_variable": "GAME_WORLD",
      "default_value": "Navezgane",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "select",
      "select_options": {
        "Navezgane": "Navezgane (Standard)",
        "RWG": "Random Gen (Prozedural)"
      }
    },
    {
      "name": "World Seed",
      "description": "Map-Seed für Random Gen (beliebiger Text)",
      "env_variable": "WORLD_SEED",
      "default_value": "FireBot",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string|max:50",
      "field_type": "text"
    },
    {
      "name": "World Size",
      "description": "Weltgröße (nur für Random Gen)",
      "env_variable": "WORLD_SIZE",
      "default_value": "6144",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|in:4096,6144,8192,10240",
      "field_type": "select",
      "select_options": {
        "4096": "Small (4K)",
        "6144": "Medium (6K)",
        "8192": "Large (8K)",
        "10240": "XL (10K)"
      }
    },
    {
      "name": "Game Mode",
      "description": "Spiel-Modus",
      "env_variable": "GAME_MODE",
      "default_value": "GameModeSurvival",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "select",
      "select_options": {
        "GameModeSurvival": "Survival"
      }
    },
    {
      "name": "Difficulty",
      "description": "Schwierigkeitsgrad",
      "env_variable": "DIFFICULTY",
      "default_value": "2",
      "user_viewable": true,
      "user_editable": true,
