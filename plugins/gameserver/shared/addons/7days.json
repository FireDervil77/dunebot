      "field_type": "select",
      "select_options": {
        "0": "Scavenger (Sehr leicht)",
        "1": "Adventurer (Leicht)",
        "2": "Nomad (Normal)",
        "3": "Warrior (Schwer)",
        "4": "Survivalist (Sehr schwer)",
        "5": "Insane (Albtraum)"
      }
    },
    {
      "name": "Day Length",
      "description": "Tag/Nacht-Zyklus in Minuten (Echtzeit)",
      "env_variable": "DAY_LENGTH",
      "default_value": "60",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:10|max:240",
      "field_type": "number"
    },
    {
      "name": "Zombies Run",
      "description": "Zombie-Verhalten",
      "env_variable": "ZOMBIE_RUN",
      "default_value": "0",
      "user_viewable": true,
      "user_editable": true,
