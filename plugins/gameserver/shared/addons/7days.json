    },
    {
      "name": "XP Multiplier",
      "description": "Erfahrungs-Multiplikator (Prozent)",
      "env_variable": "XP_MULTI",
      "default_value": "100",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:50|max:500",
      "field_type": "number"
    },
    {
      "name": "Player Killing Mode",
      "description": "PvP-Modus",
      "env_variable": "PK_MODE",
      "default_value": "3",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|in:0,1,2,3",
      "field_type": "select",
      "select_options": {
        "0": "No Killing",
        "1": "Kill Allies Only",
        "2": "Kill Strangers Only",
        "3": "Kill Everyone"
      }
    }
  ],
