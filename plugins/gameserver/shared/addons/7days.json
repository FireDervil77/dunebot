      "field_type": "select",
      "select_options": {
        "0": "Walk (Tag), Sprint (Nacht)",
        "1": "Always Walk",
        "2": "Always Sprint"
      }
    },
    {
      "name": "Blood Moon Enemy Count",
      "description": "Zombie-Anzahl bei Blood Moon (0-64)",
      "env_variable": "BLOOD_MOON_COUNT",
      "default_value": "8",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:0|max:64",
      "field_type": "number"
    },
    {
      "name": "Loot Abundance",
      "description": "Loot-Häufigkeit (Prozent)",
      "env_variable": "LOOT_ABUNDANCE",
      "default_value": "100",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:25|max:300",
      "field_type": "number"
    },
    {
      "name": "Loot Respawn Days",
      "description": "Tage bis Loot-Respawn",
      "env_variable": "LOOT_RESPAWN",
      "default_value": "7",
      "user_viewable": true,
      "user_editable": true,
