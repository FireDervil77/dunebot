      "env_variable": "ALLOW_THIRD_PERSON",
      "default_value": "True",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|in:True,False",
      "field_type": "select",
      "select_options": {
        "True": "Ja",
        "False": "Nein"
      }
    },
    {
      "name": "Crosshair",
