      "default_value": "1.0",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|numeric|min:0.1|max:10",
      "field_type": "number"
    },
    {
      "name": "Taming Speed",
      "description": "Zähm-Geschwindigkeit Multiplikator",
      "env_variable": "TAMING_SPEED",
      "default_value": "1.0",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|numeric|min:0.1|max:50",
      "field_type": "number"
    },
    {
      "name": "Harvest Multiplier",
      "description": "Ressourcen-Multiplikator beim Abbauen",
      "env_variable": "HARVEST_MULTI",
      "default_value": "1.0",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|numeric|min:0.1|max:50",
      "field_type": "number"
    },
    {
      "name": "XP Multiplier",
      "description": "Erfahrungs-Multiplikator",
      "env_variable": "XP_MULTI",
      "default_value": "1.0",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|numeric|min:0.1|max:50",
      "field_type": "number"
    },
    {
      "name": "Show Player on Map",
      "description": "Spieler-Position auf der Karte anzeigen?",
      "env_variable": "SHOW_PLAYER_MAP",
      "default_value": "False",
      "user_viewable": true,
