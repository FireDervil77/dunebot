{
  "meta": {
    "version": "PTDL_v2",
    "author": "DuneBot Official",
    "update_url": null
  },
  "exported_at": "2025-10-19T00:00:00+00:00",
  "name": "ARK: Survival Evolved",
  "slug": "ark",
  "description": "ARK: Survival Evolved Dedicated Server mit umfangreichen Konfigurationsmöglichkeiten. Unterstützt alle Maps und Mods via Steam Workshop.",
  "category": "survival",
  "tags": [
    "steam",
    "survival",
    "dinosaurs",
    "pvp",
    "pve",
    "mods"
  ],
  "visibility": "official",
  "trust_level": "official",
  "status": "approved",
  "features": [
    "steam_workshop",
    "mods",
    "crossplay"
  ],
  "steam": {
    "app_id": 346110,
    "server_app_id": 376030,
    "install_dir": "ark"
  },
  "installation": {
    "method": "steamcmd",
    "app_id": "376030",
    "validate": true,
    "script": "#!/bin/bash\ncd \"${INSTALL_DIR}\"\n\"${STEAMCMD}\" +force_install_dir \"${INSTALL_DIR}\" +login anonymous +app_update 376030 validate +quit\nmkdir -p ${INSTALL_DIR}/ShooterGame/Saved/Config/LinuxServer"
  },
  "startup": {
    "command": "./ShooterGame/Binaries/Linux/ShooterGameServer {{MAP}}?listen?SessionName=\"{{SERVER_NAME}}\"?ServerPassword={{SERVER_PASSWORD}}?ServerAdminPassword={{ADMIN_PASSWORD}}?Port={{SERVER_PORT}}?QueryPort={{QUERY_PORT}}?MaxPlayers={{MAX_PLAYERS}} -server -log",
    "done": "Setting breakpad minidump AppID",
    "stop": "^C"
  },
  "config": {
    "files": {
      "ShooterGame/Saved/Config/LinuxServer/GameUserSettings.ini": {
        "parser": "ini",
        "find": {
          "ServerSettings": {
            "DifficultyOffset": "DifficultyOffset={{DIFFICULTY}}",
            "TamingSpeedMultiplier": "TamingSpeedMultiplier={{TAMING_SPEED}}",
            "HarvestAmountMultiplier": "HarvestAmountMultiplier={{HARVEST_MULTI}}",
            "XPMultiplier": "XPMultiplier={{XP_MULTI}}",
            "ShowMapPlayerLocation": "ShowMapPlayerLocation={{SHOW_PLAYER_MAP}}",
            "AllowThirdPersonPlayer": "AllowThirdPersonPlayer={{ALLOW_THIRD_PERSON}}",
            "ServerCrosshair": "ServerCrosshair={{CROSSHAIR}}",
            "AllowFlyerCarryPvE": "AllowFlyerCarryPvE={{FLYER_CARRY_PVE}}"
          }
        }
      }
    },
    "startup": {
      "done": "Setting breakpad minidump AppID"
    },
    "logs": {},
    "stop": "^C",
    "rcon": {
      "protocol": "srcds",
      "port_var": "rcon",
      "password_var": "ADMIN_PASSWORD"
    }
  },
  "variables": [
    {
      "name": "Server Name",
      "description": "Name deines ARK-Servers",
      "env_variable": "SERVER_NAME",
      "default_value": "My ARK Server",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:100",
      "field_type": "text"
    },
    {
      "name": "Map",
      "description": "Welche Map soll geladen werden?",
      "env_variable": "MAP",
      "default_value": "TheIsland",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string",
      "field_type": "select",
      "select_options": {
        "TheIsland": "The Island (Standard)",
        "TheCenter": "The Center",
        "ScorchedEarth_P": "Scorched Earth (DLC)",
        "Aberration_P": "Aberration (DLC)",
        "Extinction": "Extinction (DLC)",
        "Genesis": "Genesis Part 1 (DLC)",
        "Gen2": "Genesis Part 2 (DLC)",
        "Ragnarok": "Ragnarok (Free)",
        "Valguero_P": "Valguero (Free)",
        "CrystalIsles": "Crystal Isles (Free)",
        "LostIsland": "Lost Island (Free)",
        "Fjordur": "Fjordur (Free)"
      }
    },
    {
      "name": "Server Password",
      "description": "Passwort zum Betreten (leer = kein Passwort)",
      "env_variable": "SERVER_PASSWORD",
      "default_value": "",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string|max:50",
      "field_type": "text"
    },
    {
      "name": "Admin Password",
      "description": "Admin-Passwort für In-Game Commands",
      "env_variable": "ADMIN_PASSWORD",
      "default_value": "AUTOGENERATE",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|min:6",
      "field_type": "password"
    },
    {
      "name": "Max Players",
      "description": "Maximale Spieleranzahl",
      "env_variable": "MAX_PLAYERS",
      "default_value": "20",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:1|max:100",
      "field_type": "number"
    },
    {
      "name": "Server Port",
      "description": "Hauptport des Servers",
      "env_variable": "SERVER_PORT",
      "default_value": "7777",
      "user_viewable": true,
      "user_editable": false,
      "rules": "required|integer",
      "field_type": "text"
    },
    {
      "name": "Query Port",
      "description": "Query Port (normalerweise Server Port + 1)",
      "env_variable": "QUERY_PORT",
      "default_value": "27015",
      "user_viewable": true,
      "user_editable": false,
      "rules": "required|integer",
      "field_type": "text"
    },
    {
