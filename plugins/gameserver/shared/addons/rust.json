{
  "meta": {
    "version": "PTDL_v2",
    "author": "DuneBot Official",
    "update_url": null
  },
  "exported_at": "2025-10-19T00:00:00+00:00",
  "name": "Rust",
  "slug": "rust",
  "description": "Rust Dedicated Server mit Oxide/uMod-Support für Plugins. Hardcore-Survival-PvP mit umfangreichen Konfigurationsmöglichkeiten.",
  "category": "survival",
  "tags": [
    "steam",
    "survival",
    "pvp",
    "hardcore",
    "oxide",
    "plugins"
  ],
  "visibility": "official",
  "trust_level": "official",
  "status": "approved",
  "features": [
    "oxide",
    "plugins",
    "rcon"
  ],
  "steam": {
    "app_id": 252490,
    "server_app_id": 258550,
    "install_dir": "rust"
  },
  "installation": {
    "method": "steamcmd",
    "app_id": "258550",
    "validate": true,
    "script": "#!/bin/bash\ncd \"${INSTALL_DIR}\"\n\"${STEAMCMD}\" +force_install_dir \"${INSTALL_DIR}\" +login anonymous +app_update 258550 validate +quit\n\n# Oxide Installation (optional)\nif [ \"{{INSTALL_OXIDE}}\" == \"1\" ]; then\n  wget -O oxide.zip https://umod.org/games/rust/download\n  unzip -o oxide.zip -d /mnt/server\n  rm oxide.zip\nfi"
  },
  "startup": {
    "command": "./RustDedicated -batchmode +server.hostname \"{{SERVER_NAME}}\" +server.port {{SERVER_PORT}} +server.maxplayers {{MAX_PLAYERS}} +server.worldsize {{WORLD_SIZE}} +server.seed {{WORLD_SEED}} +rcon.port {{RCON_PORT}} +rcon.password {{RCON_PASSWORD}} +rcon.web 1 +server.headerimage {{HEADER_IMAGE}} +server.url {{SERVER_URL}} +server.description \"{{SERVER_DESCRIPTION}}\" +server.saveinterval {{SAVE_INTERVAL}}",
    "done": "Server startup complete",
    "stop": "quit"
  },
  "config": {
    "files": {
      "server/{{SERVER_IDENTITY}}/cfg/server.cfg": {
        "parser": "file",
        "find": {
          "server.hostname": "server.hostname \"{{SERVER_NAME}}\"",
          "server.maxplayers": "server.maxplayers {{MAX_PLAYERS}}",
          "server.worldsize": "server.worldsize {{WORLD_SIZE}}",
          "server.seed": "server.seed {{WORLD_SEED}}",
          "server.pve": "server.pve {{PVE_MODE}}",
          "decay.scale": "decay.scale {{DECAY_SCALE}}"
        }
      }
    },
    "startup": {
      "done": "Server startup complete"
    },
    "logs": {},
    "stop": "quit",
    "rcon": {
      "protocol": "srcds",
      "port_var": "RCON_PORT",
      "password_var": "RCON_PASSWORD"
    }
  },
  "variables": [
    {
      "name": "Server Name",
      "description": "Name deines Rust-Servers",
      "env_variable": "SERVER_NAME",
      "default_value": "My Rust Server",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:100",
      "field_type": "text"
    },
    {
      "name": "Server Description",
      "description": "Beschreibung für die Serverliste",
      "env_variable": "SERVER_DESCRIPTION",
      "default_value": "Welcome to my Rust server!",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string|max:500",
      "field_type": "textarea"
    },
    {
      "name": "Server Identity",
      "description": "Eindeutiger Identifier für Savegame (nur a-z, 0-9, -)",
      "env_variable": "SERVER_IDENTITY",
      "default_value": "rustserver",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|alpha_dash|max:30",
      "field_type": "text"
    },
    {
      "name": "Max Players",
      "description": "Maximale Spieleranzahl",
      "env_variable": "MAX_PLAYERS",
      "default_value": "50",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:1|max:500",
      "field_type": "number"
