/**
 * Addon Marketplace Route
 * Zeigt verfügbare Game-Addons (wie Pterodactyl Eggs)
 * @module routes/addons
 * @author FireBot Team
 */

const express = require('express');
const router = express.Router();
const { ServiceManager } = require('dunebot-core');

/**
 * GET /guild/:guildId/plugins/gameserver/addons
 * Addon Marketplace - Übersicht aller verfügbaren Game-Addons
 */
router.get('/', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId; // ← Aus res.locals!
        const user = res.locals.user; // ← User aus res.locals!
        const { category, search, sort } = req.query;

        Logger.debug(`[Gameserver] Addon Marketplace aufgerufen für Guild ${guildId}`);

        // Query Builder für Filter
        let query = `
            SELECT 
                id,
                slug,
                name,
                description,
                category,
                tags,
                steam_app_id,
                author_user_id,
                trust_level,
                visibility,
                status,
                rating_avg,
                rating_count,
                install_count,
                icon_url,
                banner_url,
                created_at,
                updated_at
            FROM addon_marketplace
            WHERE status = 'approved'
            AND (visibility = 'official' OR visibility = 'public')
        `;
        const params = [];

        // Filter: Kategorie
        if (category && category !== 'all') {
            query += ' AND category = ?';
            params.push(category);
        }

        // Filter: Suche
        if (search) {
            query += ' AND (name LIKE ? OR description LIKE ? OR tags LIKE ?)';
            const searchTerm = `%${search}%`;
            params.push(searchTerm, searchTerm, searchTerm);
        }

        // Sortierung
        let orderBy = 'ORDER BY trust_level DESC, rating_avg DESC, install_count DESC';
        if (sort === 'newest') {
            orderBy = 'ORDER BY created_at DESC';
        } else if (sort === 'popular') {
            orderBy = 'ORDER BY install_count DESC';
        } else if (sort === 'rating') {
            orderBy = 'ORDER BY rating_avg DESC, rating_count DESC';
        }
        query += ` ${orderBy}`;

        // Addons abrufen
        const addons = await dbService.query(query, params);

        // Kategorien für Filter
        const categories = await dbService.query(`
            SELECT DISTINCT category, COUNT(*) as count
            FROM addon_marketplace
            WHERE status = 'approved'
            AND (visibility = 'official' OR visibility = 'public')
            GROUP BY category
            ORDER BY count DESC
        `);

        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-marketplace', {
            title: 'Addon Marketplace',
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons`,
            addons: addons || [],
            categories: categories || [],
            filters: { category: category || 'all', search: search || '', sort: sort || 'default' },
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden des Addon Marketplace:', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden des Addon Marketplace',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/addons/my-eggs
 * Meine Addons - Liste eigener Eggs (private + public pending)
 * WICHTIG: MUSS VOR /:slug stehen!
 */
router.get('/my-eggs', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        
        Logger.debug(`[Gameserver] Meine Addons aufgerufen für Guild ${guildId}`);
        
        // Eigene Eggs laden (guild_id = current guild ODER author_user_id = current user)
        const myEggs = await dbService.query(`
            SELECT 
                id,
                slug,
                name,
                description,
                category,
                visibility,
                status,
                trust_level,
                version,
                install_count,
                icon_url,
                created_at,
                updated_at
            FROM addon_marketplace
            WHERE (guild_id = ? OR author_user_id = ?)
            AND status != 'rejected'
            ORDER BY updated_at DESC
        `, [guildId, user.id]);
        
        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-my-eggs', {
            title: 'Meine Addons',
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`,
            myEggs: myEggs || [],
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden von Meine Addons:', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden deiner Addons',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/addons/create
 * Egg Editor - Neues Egg erstellen (mit Template-Support)
 * WICHTIG: MUSS VOR /:slug stehen!
 */
router.get('/create', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        const templateSource = req.query.template; // 'blank', 'pterodactyl-cs2', 'clone:123'
        
        Logger.debug(`[Gameserver] Egg Editor (Create) aufgerufen für Guild ${guildId}, Template: ${templateSource || 'blank'}`);
        
        let template = null;
        let gameData = null;
        
        // Template laden falls angegeben
        if (templateSource && templateSource !== 'blank') {
            // Clone eigenes Egg
            if (templateSource.startsWith('clone:')) {
                const cloneId = templateSource.split(':')[1];
                const [egg] = await dbService.query(
                    'SELECT * FROM addon_marketplace WHERE id = ? AND (guild_id = ? OR author_user_id = ?)',
                    [cloneId, guildId, user.id]
                );
                
                if (egg) {
                    template = egg;
                    gameData = typeof egg.game_data === 'string' ? JSON.parse(egg.game_data) : egg.game_data;
                }
            }
            // TODO: Pterodactyl-Template-Import (später)
        }
        
        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-egg-editor', {
            title: 'Neues Egg erstellen',
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`,
            mode: 'create',
            template: template || null,
            gameData: gameData || {},
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden des Egg Editors (Create):', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden des Egg Editors',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/addons/edit/:id
 * Egg Editor - Bestehendes Egg bearbeiten
 * WICHTIG: MUSS VOR /:slug stehen!
 */
router.get('/edit/:id', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        const eggId = req.params.id;
        
        Logger.debug(`[Gameserver] Egg Editor (Edit) aufgerufen für Egg ${eggId}`);
        
        // Egg laden mit Permission-Check
        const [egg] = await dbService.query(
            'SELECT * FROM addon_marketplace WHERE id = ? AND (guild_id = ? OR author_user_id = ?)',
            [eggId, guildId, user.id]
        );
        
        if (!egg) {
            return res.status(404).render('error', {
                message: 'Egg nicht gefunden oder keine Berechtigung',
                error: {}
            });
        }
        
        // game_data parsen
        let gameData = {};
        try {
            gameData = typeof egg.game_data === 'string' ? JSON.parse(egg.game_data) : egg.game_data;
        } catch (error) {
            Logger.error('[Gameserver] Fehler beim Parsen von game_data:', error);
            gameData = {};
        }
        
        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-egg-editor', {
            title: `Egg bearbeiten: ${egg.name}`,
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`,
            mode: 'edit',
            egg,
            gameData,
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden des Egg Editors (Edit):', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden des Egg Editors',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/addons/:slug
 * Addon Detail-Seite mit Templates, Ratings, Comments
 * WICHTIG: MUSS NACH /my-eggs, /create, /edit/:id stehen!
 */
router.get('/:slug', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId; // ← Aus res.locals!
        const { slug } = req.params;
        const user = res.locals.user; // ← User aus res.locals!

        Logger.debug(`[Gameserver] Addon Detail aufgerufen: ${slug} für Guild ${guildId}`);

        // Addon abrufen (mit vollem game_data JSON)
        const addonResult = await dbService.query(`
            SELECT 
                id,
                slug,
                name,
                description,
                category,
                tags,
                steam_app_id,
                steam_server_app_id,
                author_user_id,
                game_data,
                trust_level,
                visibility,
                status,
                rating_avg,
                rating_count,
                install_count,
                icon_url,
                banner_url,
                screenshots,
                created_at,
                updated_at
            FROM addon_marketplace
            WHERE slug = ?
            AND status = 'approved'
        `, [slug]);
        
        const addon = addonResult && addonResult[0] ? addonResult[0] : null;

        if (!addon) {
            return res.status(404).render('error', {
                message: 'Addon nicht gefunden',
                error: {}
            });
        }

        // game_data JSON parsen
        let gameData = {};
        try {
            gameData = typeof addon.game_data === 'string' 
                ? JSON.parse(addon.game_data) 
                : addon.game_data;
        } catch (error) {
            Logger.error(`[Gameserver] Fehler beim Parsen von game_data für ${slug}:`, error);
            gameData = { templates: [], variables: [] };
        }

        // Ratings abrufen (Top 5)
        const ratings = await dbService.query(`
            SELECT 
                ar.rating,
                ar.review,
                ar.usage_hours,
                ar.helpful_count,
                ar.created_at,
                ar.user_id
            FROM addon_ratings ar
            WHERE ar.addon_id = ?
            ORDER BY ar.helpful_count DESC, ar.created_at DESC
            LIMIT 5
        `, [addon.id]);

        // Kommentare abrufen (nur Top-Level, ohne Replies)
        const comments = await dbService.query(`
            SELECT 
                ac.id,
                ac.comment,
                ac.created_at,
                ac.user_id,
                ac.is_deleted
            FROM addon_comments ac
            WHERE ac.addon_id = ?
            AND ac.parent_id IS NULL
            AND ac.is_deleted = 0
            ORDER BY ac.created_at DESC
            LIMIT 10
        `, [addon.id]);

        // Daemon Servers abrufen (für Server-Creation)
        // TODO: Später über IPC vom Bot abrufen
        const daemonServers = []; // Placeholder

        // Install Count incrementieren (statt downloads)
        await dbService.query(
            'UPDATE addon_marketplace SET install_count = install_count + 1 WHERE id = ?',
            [addon.id]
        );

        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-addon-detail', {
            title: `${addon.name} - Addon Details`,
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons`,
            addon,
            gameData,
            ratings: ratings || [],
            comments: comments || [],
            daemonServers: daemonServers || [],
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden des Addon Details:', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden der Addon-Details',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

