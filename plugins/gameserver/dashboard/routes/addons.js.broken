/**
 * GET /guild/:guildId/plugins/gameserver/addons/edit/:id
 * Egg Editor - Bestehendes Egg bearbeiten
 */
router.get('/edit/:id', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        const eggId = req.params.id;
        
        Logger.debug(`[Gameserver] Egg Editor (Edit) aufgerufen für Egg ${eggId}`);
        
        // Egg laden
        const [egg] = await dbService.query(
            'SELECT * FROM addon_marketplace WHERE id = ?',
            [eggId]
        );
        
        if (!egg) {
            return res.status(404).render('error', {
                message: 'Egg nicht gefunden',
                error: {}
            });
        }
        
        // Permission-Check: Nur eigene Eggs bearbeiten
        if (egg.guild_id !== guildId && egg.author_user_id !== user.id) {
            return res.status(403).render('error', {
                message: 'Keine Berechtigung zum Bearbeiten dieses Eggs',
                error: {}
            });
        }
        
        // game_data parsen
        const gameData = egg.game_data ? JSON.parse(egg.game_data) : null;
        
        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-egg-editor', {
            title: `Egg bearbeiten: ${egg.name}`,
            activeMenu: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`,
            mode: 'edit',
            egg,
            gameData,
            myEggs: [], // Für Edit nicht benötigt
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Laden des Egg Editors (Edit):', error);
        res.status(500).render('error', {
            message: 'Fehler beim Laden des Egg Editors',
            error: process.env.NODE_ENV === 'development' ? error : {}
        });
    }
});

/**
 * POST /addons - Create new Egg
 */
router.post('/', async (req, res) => {
    const guildId = res.locals.guildId;
    const user = res.locals.user;

    try {
        const { 
            name, slug, description, category, tags, icon_url,
            meta_author, install_method, 
            steam_app_id, steam_validate,
            git_repo, wget_url,
            startup_command, startup_done, startup_stop,
            ports_json, requirements_json, variables_json, templates_json,
            visibility 
        } = req.body;

        // Validierung
        if (!name || !slug || !description || !category) {
            return res.status(400).json({
                success: false,
                message: 'Name, Slug, Beschreibung und Kategorie sind Pflichtfelder'
            });
        }

        // Prüfe ob Slug bereits existiert
        const existingSlug = await dbService.query(
            'SELECT id FROM addon_marketplace WHERE slug = ?',
            [slug]
        );

        if (existingSlug.length > 0) {
            return res.status(400).json({
                success: false,
                message: 'Ein Egg mit diesem Slug existiert bereits. Bitte wähle einen anderen Namen.'
            });
        }

        // PTDL_v2 game_data bauen
        const gameData = {
            meta: {
                version: 'PTDL_v2',
                author: meta_author || user.username
            },
            install: {},
            startup: {
                command: startup_command || '',
                done: startup_done || 'Server is ready',
                stop: startup_stop || 'quit'
            },
            ports: JSON.parse(ports_json || '{}'),
            requirements: JSON.parse(requirements_json || '{}'),
            variables: JSON.parse(variables_json || '[]'),
            templates: JSON.parse(templates_json || '[]')
        };

        // Install-Methode
        if (install_method === 'steamcmd') {
            gameData.install.steamcmd = {
                app_id: parseInt(steam_app_id) || 0,
                validate: steam_validate === '1'
            };
        } else if (install_method === 'git') {
            gameData.install.git = {
                repo: git_repo || ''
            };
        } else if (install_method === 'wget') {
            gameData.install.wget = {
                url: wget_url || ''
            };
        }

        // Visibility-Handling
        let status = 'draft';
        let guildIdValue = null;
        let trustLevel = 'unverified';

        if (visibility === 'private') {
            status = 'approved'; // Private Eggs auto-approved für Guild
            guildIdValue = guildId;
        } else if (visibility === 'public') {
            status = 'pending_review'; // Public Eggs brauchen Moderation
            trustLevel = 'unverified';
        }

        // INSERT in DB
        const result = await dbService.query(`
            INSERT INTO addon_marketplace (
                name, slug, description, category, tags, icon_url,
                visibility, status, trust_level,
                guild_id, author_user_id,
                game_data,
                created_at, updated_at
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW(), NOW())
        `, [
            name, slug, description, category, 
            tags || null, icon_url || null,
            visibility, status, trustLevel,
            guildIdValue, user.id,
            JSON.stringify(gameData)
        ]);

        Logger.info(`[Gameserver] Neues Egg erstellt: ${name} (ID: ${result.insertId}) von User ${user.id}`);

        res.json({
            success: true,
            message: visibility === 'private' 
                ? 'Egg erfolgreich erstellt und für deine Guild freigegeben!' 
                : 'Egg erstellt! Es wird nun von Moderatoren geprüft.',
            egg_id: result.insertId,
            redirect: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`
        });

    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Erstellen des Eggs:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Erstellen des Eggs'
        });
    }
});

/**
 * PUT /addons/:id - Update existing Egg
 */
router.put('/:id', async (req, res) => {
    const guildId = res.locals.guildId;
    const user = res.locals.user;
    const eggId = req.params.id;

    try {
        // Permission Check
        const egg = await dbService.query(
            'SELECT * FROM addon_marketplace WHERE id = ?',
            [eggId]
        );

        if (egg.length === 0) {
            return res.status(404).json({
                success: false,
                message: 'Egg nicht gefunden'
            });
        }

        const eggData = egg[0];
        const hasPermission = eggData.guild_id === guildId || eggData.author_user_id === user.id;

        if (!hasPermission) {
            return res.status(403).json({
                success: false,
                message: 'Keine Berechtigung dieses Egg zu bearbeiten'
            });
        }

        const { 
            name, description, category, tags, icon_url,
            meta_author, install_method, 
            steam_app_id, steam_validate,
            git_repo, wget_url,
            startup_command, startup_done, startup_stop,
            ports_json, requirements_json, variables_json, templates_json,
            visibility 
        } = req.body;

        // PTDL_v2 game_data bauen (wie bei POST)
        const gameData = {
            meta: {
                version: 'PTDL_v2',
                author: meta_author || user.username
            },
            install: {},
            startup: {
                command: startup_command || '',
                done: startup_done || 'Server is ready',
                stop: startup_stop || 'quit'
            },
            ports: JSON.parse(ports_json || '{}'),
            requirements: JSON.parse(requirements_json || '{}'),
            variables: JSON.parse(variables_json || '[]'),
            templates: JSON.parse(templates_json || '[]')
        };

        if (install_method === 'steamcmd') {
            gameData.install.steamcmd = {
                app_id: parseInt(steam_app_id) || 0,
                validate: steam_validate === '1'
            };
        } else if (install_method === 'git') {
            gameData.install.git = { repo: git_repo || '' };
        } else if (install_method === 'wget') {
            gameData.install.wget = { url: wget_url || '' };
        }

        // Visibility-Update
        let status = eggData.status;
        let guildIdValue = eggData.guild_id;

        // Wenn visibility geändert wird
        if (visibility !== eggData.visibility) {
            if (visibility === 'private') {
                status = 'approved';
                guildIdValue = guildId;
            } else if (visibility === 'public') {
                status = 'pending_review'; // Erneute Prüfung
                guildIdValue = null;
            }
        }

        // UPDATE in DB
        await dbService.query(`
            UPDATE addon_marketplace SET
                name = ?, description = ?, category = ?, tags = ?, icon_url = ?,
                visibility = ?, status = ?, guild_id = ?,
                game_data = ?,
                updated_at = NOW()
            WHERE id = ?
        `, [
            name, description, category, tags || null, icon_url || null,
            visibility, status, guildIdValue,
            JSON.stringify(gameData),
            eggId
        ]);

        Logger.info(`[Gameserver] Egg aktualisiert: ${name} (ID: ${eggId}) von User ${user.id}`);

        res.json({
            success: true,
            message: 'Egg erfolgreich aktualisiert!',
            redirect: `/guild/${guildId}/plugins/gameserver/addons/my-eggs`
        });

    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Aktualisieren des Eggs:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Aktualisieren des Eggs'
        });
    }
});

/**
 * DELETE /addons/:id - Delete Egg
 */
router.delete('/:id', async (req, res) => {
    const guildId = res.locals.guildId;
    const user = res.locals.user;
    const eggId = req.params.id;

    try {
        // Permission Check
        const egg = await dbService.query(
            'SELECT * FROM addon_marketplace WHERE id = ?',
            [eggId]
        );

        if (egg.length === 0) {
            return res.status(404).json({
                success: false,
                message: 'Egg nicht gefunden'
            });
        }

        const eggData = egg[0];
        const hasPermission = eggData.guild_id === guildId || eggData.author_user_id === user.id;

        if (!hasPermission) {
            return res.status(403).json({
                success: false,
                message: 'Keine Berechtigung dieses Egg zu löschen'
            });
        }

        // Prüfe ob Egg von Gameservern genutzt wird
        const usedByServers = await dbService.query(
            'SELECT COUNT(*) as count FROM gameservers WHERE addon_marketplace_id = ?',
            [eggId]
        );

        if (usedByServers[0].count > 0) {
            return res.status(400).json({
                success: false,
                message: `Dieses Egg kann nicht gelöscht werden, da es von ${usedByServers[0].count} Server(n) verwendet wird.`
            });
        }

        // DELETE
        await dbService.query(
            'DELETE FROM addon_marketplace WHERE id = ?',
            [eggId]
        );

        Logger.info(`[Gameserver] Egg gelöscht: ${eggData.name} (ID: ${eggId}) von User ${user.id}`);

        res.json({
            success: true,
            message: 'Egg erfolgreich gelöscht!'
        });

    } catch (error) {
        Logger.error('[Gameserver] Fehler beim Löschen des Eggs:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Löschen des Eggs'
        });
    }
});

module.exports = router;
