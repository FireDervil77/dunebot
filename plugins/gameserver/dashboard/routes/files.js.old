/**
 * Gameserver File Management Routes (WebFTP)
 * Dateisystem-Zugriff für Gameserver via IPM
 * 
 * @module routes/files
 * @author FireBot Team
 */

const express = require('express');
const router = express.Router();
const { ServiceManager } = require('dunebot-core');
const multer = require('multer');
const path = require('path');

// File-Upload konfigurieren (Max 100MB, Memory-Storage)
const upload = multer({
    storage: multer.memoryStorage(),
    limits: { 
        fileSize: 100 * 1024 * 1024,  // 100MB
        files: 1  // Max 1 File pro Upload
    },
    fileFilter: (req, file, cb) => {
        // Verbotene Dateiendungen (Sicherheit)
        const forbiddenExtensions = ['.exe', '.bat', '.cmd', '.sh', '.bash'];
        const ext = path.extname(file.originalname).toLowerCase();
        
        if (forbiddenExtensions.includes(ext)) {
            return cb(new Error(`Dateiendung ${ext} ist nicht erlaubt`));
        }
        
        cb(null, true);
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/servers/:serverId/files
 * File-Browser anzeigen (WebFTP-Interface)
 */
router.get('/:serverId/files', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        const { serverId } = req.params;
        const { path: requestedPath = '/' } = req.query;

        Logger.debug(`[Gameserver Files] File-Browser aufgerufen für Server ${serverId}, Path: ${requestedPath}`);

        // Server-Daten laden mit Daemon-Verbindung
        const [server] = await dbService.query(`
            SELECT 
                gs.id,
                gs.name,
                gs.status,
                gs.rootserver_id,
                gs.install_path,
                r.daemon_id,
                r.name as daemon_name,
                r.system_user
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).send('Server nicht gefunden');
        }

        // SFTP-Credentials vorbereiten
        const sftpCredentials = {
            username: server.system_user || 'N/A',
            hasPassword: true, // TODO: Aus DB oder Daemon prüfen
            path: server.install_path || '/'
        };

        // Daemon offline?
        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return await themeManager.renderView(res, 'guild/gameserver-files', {
                title: `Files - ${server.name}`,
                activeMenu: `/guild/${guildId}/plugins/gameserver/servers`,
                server,
                sftpCredentials,
                files: [],
                currentPath: requestedPath,
                parentPath: null,
                error: 'Daemon ist offline - Dateizugriff nicht möglich',
                guildId,
                user
            });
        }

        // File-Liste vom Daemon abrufen
        Logger.debug(`[Gameserver Files] Sende filesystem.list an Daemon ${server.daemon_id}`, {
            serverId,
            path: requestedPath
        });

        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.list', {
            server_id: serverId.toString(),
            path: requestedPath
        }, 10000);

        if (!response.success) {
            Logger.warn(`[Gameserver Files] filesystem.list fehlgeschlagen: ${response.message}`);
            return await themeManager.renderView(res, 'guild/gameserver-files', {
                title: `Files - ${server.name}`,
                activeMenu: `/guild/${guildId}/plugins/gameserver/servers`,
                server,
                sftpCredentials,
                files: [],
                currentPath: requestedPath,
                parentPath: null,
                error: response.message || 'Fehler beim Laden der Dateien',
                guildId,
                user
            });
        }

        // Parent-Path berechnen (für ".." Navigation)
        const parentPath = requestedPath === '/' 
            ? null 
            : '/' + requestedPath.split('/').filter(p => p).slice(0, -1).join('/');

        Logger.success(`[Gameserver Files] ${response.data.files?.length || 0} Dateien geladen`);

        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-files', {
            title: `Files - ${server.name}`,
            activeMenu: `/guild/${guildId}/plugins/gameserver/servers`,
            server,
            sftpCredentials,
            files: response.data.files || [],
            currentPath: requestedPath,
            parentPath,
            error: null,
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Laden der Dateien:', error);
        res.status(500).send('Serverfehler beim Laden der Dateien');
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/servers/:serverId/files/download
 * Datei vom Gameserver herunterladen
 */
router.get('/:serverId/files/download', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { path: filePath } = req.query;

        if (!filePath || filePath === '/') {
            return res.status(400).send('Kein gültiger Dateipfad angegeben');
        }

        Logger.info(`[Gameserver Files] File-Editor aufgerufen: ${filePath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).send('Server nicht gefunden');
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).send('Daemon ist offline');
        }

        // Datei vom Daemon abrufen
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.read', {
            server_id: serverId.toString(),
            path: filePath
        }, 30000);  // 30s Timeout für große Dateien

        if (!response.success) {
            Logger.error(`[Gameserver Files] Download fehlgeschlagen: ${response.message}`);
            return res.status(500).send(response.message || 'Fehler beim Laden der Datei');
        }

        // Datei-Download vorbereiten
        const filename = filePath.split('/').pop();
        res.setHeader('Content-Disposition', `attachment; filename="${filename}"`);
        res.setHeader('Content-Type', 'application/octet-stream');
        
        // Base64-decoded Content (Daemon sendet Base64)
        if (response.data.encoding === 'base64') {
            const buffer = Buffer.from(response.data.content, 'base64');
            Logger.success(`[Gameserver Files] Download gestartet: ${filename} (${buffer.length} bytes)`);
            res.send(buffer);
        } else {
            // Plain-Text Content
            Logger.success(`[Gameserver Files] Download gestartet: ${filename}`);
            res.send(response.data.content);
        }
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Download:', error);
        res.status(500).send('Serverfehler beim Herunterladen der Datei');
    }
});

/**
 * POST /guild/:guildId/plugins/gameserver/servers/:serverId/files/upload
 * Datei auf Gameserver hochladen
 */
router.post('/:serverId/files/upload', upload.single('file'), async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { path: targetPath = '/' } = req.body;
        const file = req.file;

        if (!file) {
            return res.status(400).json({
                success: false,
                message: 'Keine Datei hochgeladen'
            });
        }

        Logger.info(`[Gameserver Files] Upload gestartet: ${file.originalname} (${file.size} bytes) → ${targetPath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).json({
                success: false,
                message: 'Daemon ist offline'
            });
        }

        // Datei zum Daemon senden (Base64-encoded)
        const base64Content = file.buffer.toString('base64');
        const fullPath = targetPath.endsWith('/') 
            ? `${targetPath}${file.originalname}` 
            : `${targetPath}/${file.originalname}`;
        
        Logger.debug(`[Gameserver Files] Sende filesystem.write an Daemon`, {
            fullPath,
            size: file.size,
            encoding: 'base64'
        });

        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.write', {
            server_id: serverId.toString(),
            path: fullPath,
            content: base64Content,
            encoding: 'base64'
        }, 60000);  // 60s Timeout für große Dateien

        if (!response.success) {
            Logger.error(`[Gameserver Files] Upload fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Hochladen der Datei'
            });
        }

        Logger.success(`[Gameserver Files] Upload erfolgreich: ${file.originalname}`);

        res.json({
            success: true,
            message: `Datei "${file.originalname}" erfolgreich hochgeladen`
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Upload:', error);
        res.status(500).json({
            success: false,
            message: error.message || 'Serverfehler beim Hochladen der Datei'
        });
    }
});

/**
 * DELETE /guild/:guildId/plugins/gameserver/servers/:serverId/files
 * Datei oder Ordner vom Gameserver löschen
 */
router.delete('/:serverId/files', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { path: deletePath } = req.body;

        if (!deletePath || deletePath === '/') {
            return res.status(400).json({
                success: false,
                message: 'Root-Verzeichnis kann nicht gelöscht werden'
            });
        }

        Logger.info(`[Gameserver Files] Umbenennen: ${oldPath} → ${newPath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).json({
                success: false,
                message: 'Daemon ist offline'
            });
        }

        // Löschen via Daemon
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.delete', {
            server_id: serverId.toString(),
            path: deletePath
        }, 10000);

        if (!response.success) {
            Logger.error(`[Gameserver Files] Löschung fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Löschen'
            });
        }

        Logger.success(`[Gameserver Files] Erfolgreich gelöscht: ${deletePath}`);

        res.json({
            success: true,
            message: 'Erfolgreich gelöscht'
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Löschen:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Löschen'
        });
    }
});

/**
 * POST /guild/:guildId/plugins/gameserver/servers/:serverId/files/mkdir
 * Neues Verzeichnis auf Gameserver erstellen
 */
router.post('/:serverId/files/mkdir', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { path: parentPath, name } = req.body;

        // Validierung
        if (!name || name.includes('/') || name.includes('..') || name.trim() === '') {
            return res.status(400).json({
                success: false,
                message: 'Ungültiger Verzeichnisname (darf keine /, .. oder Leerzeichen enthalten)'
            });
        }

        const fullPath = parentPath.endsWith('/') 
            ? `${parentPath}${name}` 
            : `${parentPath}/${name}`;

        Logger.info(`[Gameserver Files] Verzeichnis erstellen: ${fullPath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).json({
                success: false,
                message: 'Daemon ist offline'
            });
        }

        // Verzeichnis erstellen via Daemon
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.mkdir', {
            server_id: serverId.toString(),
            path: fullPath
        }, 10000);

        if (!response.success) {
            Logger.error(`[Gameserver Files] Mkdir fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Erstellen des Verzeichnisses'
            });
        }

        Logger.success(`[Gameserver Files] Verzeichnis erstellt: ${fullPath}`);

        res.json({
            success: true,
            message: `Verzeichnis "${name}" erfolgreich erstellt`
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Erstellen des Verzeichnisses:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Erstellen des Verzeichnisses'
        });
    }
});

/**
 * PUT /guild/:guildId/plugins/gameserver/servers/:serverId/files/rename
 * Datei oder Ordner umbenennen
 */
router.put('/:serverId/files/rename', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { oldPath, newName } = req.body;

        // Validierung
        if (!oldPath || !newName || newName.includes('/') || newName.includes('..')) {
            return res.status(400).json({
                success: false,
                message: 'Ungültiger Pfad oder Name'
            });
        }

        // Neuen Pfad berechnen
        const parentDir = oldPath.substring(0, oldPath.lastIndexOf('/'));
        const newPath = parentDir ? `${parentDir}/${newName}` : `/${newName}`;

        Logger.info(`[Gameserver Files] Ordner erstellen: ${folderPath}/${folderName}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).json({
                success: false,
                message: 'Daemon ist offline'
            });
        }

        // Umbenennen via Daemon
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.rename', {
            server_id: serverId.toString(),
            old_path: oldPath,
            new_path: newPath
        }, 10000);

        if (!response.success) {
            Logger.error(`[Gameserver Files] Rename fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Umbenennen'
            });
        }

        Logger.success(`[Gameserver Files] Erfolgreich umbenannt: ${oldPath} → ${newPath}`);

        res.json({
            success: true,
            message: 'Erfolgreich umbenannt'
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Umbenennen:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Umbenennen'
        });
    }
});

/**
 * GET /guild/:guildId/plugins/gameserver/servers/:serverId/files/edit
 * Datei-Editor anzeigen (für Text-Dateien)
 */
router.get('/:serverId/files/edit', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    const themeManager = ServiceManager.get('themeManager');
    
    try {
        const guildId = res.locals.guildId;
        const user = res.locals.user;
        const { serverId } = req.params;
        const { path: filePath } = req.query;

        if (!filePath) {
            return res.status(400).send('Kein Dateipfad angegeben');
        }

        Logger.debug(`[Gameserver Files] Editor aufgerufen für: ${filePath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT 
                gs.id,
                gs.name,
                r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).send('Server nicht gefunden');
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).send('Daemon ist offline - Editor nicht verfügbar');
        }

        // Datei-Inhalt vom Daemon abrufen
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.read', {
            server_id: serverId.toString(),
            path: filePath
        }, 30000);

        if (!response.success) {
            return res.status(500).send(response.message || 'Fehler beim Laden der Datei');
        }

        // Base64-Decode falls nötig
        let content = response.data.content;
        if (response.data.encoding === 'base64') {
            content = Buffer.from(content, 'base64').toString('utf-8');
        }

        // View rendern
        await themeManager.renderView(res, 'guild/gameserver-file-editor', {
            title: `Editor - ${filePath.split('/').pop()}`,
            activeMenu: `/guild/${guildId}/plugins/gameserver/servers`,
            server,
            filePath,
            content,
            guildId,
            user
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Laden des Editors:', error);
        res.status(500).send('Serverfehler beim Laden des Editors');
    }
});

/**
 * PUT /guild/:guildId/plugins/gameserver/servers/:serverId/files/edit
 * Datei-Inhalt speichern (Editor)
 */
router.put('/:serverId/files/edit', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { path: filePath, content } = req.body;

        if (!filePath || content === undefined) {
            return res.status(400).json({
                success: false,
                message: 'Pfad oder Inhalt fehlt'
            });
        }

        Logger.info(`[Gameserver Files] File-Save aufgerufen: ${filePath}`);

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT r.daemon_id
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!ipmServer || !ipmServer.isDaemonOnline(server.daemon_id)) {
            return res.status(503).json({
                success: false,
                message: 'Daemon ist offline'
            });
        }

        // Content Base64-encoden für sichere Übertragung
        const base64Content = Buffer.from(content, 'utf-8').toString('base64');

        // Datei speichern via Daemon
        const response = await ipmServer.sendCommand(server.daemon_id, 'filesystem.write', {
            server_id: serverId.toString(),
            path: filePath,
            content: base64Content,
            encoding: 'base64'
        }, 30000);

        if (!response.success) {
            Logger.error(`[Gameserver Files] Speichern fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Speichern der Datei'
            });
        }

        Logger.success(`[Gameserver Files] Datei gespeichert: ${filePath}`);

        res.json({
            success: true,
            message: 'Datei erfolgreich gespeichert'
        });
    } catch (error) {
        Logger.error('[Gameserver Files] Fehler beim Speichern:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Speichern der Datei'
        });
    }
});

/**
 * POST /guild/:guildId/plugins/gameserver/servers/:serverId/sftp/password
 * SFTP-Passwort setzen (erstmalig)
 */
router.post('/:serverId/sftp/password', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { password, password_confirm } = req.body;

        // Validierung
        if (!password || password.length < 8) {
            return res.status(400).json({
                success: false,
                message: 'Passwort muss mindestens 8 Zeichen lang sein'
            });
        }

        if (password !== password_confirm) {
            return res.status(400).json({
                success: false,
                message: 'Passwörter stimmen nicht überein'
            });
        }

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT gs.id, gs.name, r.daemon_id, r.system_user
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        if (!server.daemon_id || !server.system_user) {
            return res.status(400).json({
                success: false,
                message: 'Kein Daemon oder System-User zugeordnet'
            });
        }

        // Passwort über IPM an Daemon senden
        Logger.info(`[SFTP] Setze Passwort für User ${server.system_user}`);

        const response = await ipmServer.sendCommand(server.daemon_id, 'sftp.set_password', {
            username: server.system_user,
            password: password
        }, 10000);

        if (!response.success) {
            Logger.error(`[SFTP] Passwort-Setzung fehlgeschlagen: ${response.message}`);
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Setzen des Passworts'
            });
        }

        Logger.success(`[SFTP] Passwort erfolgreich gesetzt für ${server.system_user}`);

        res.json({
            success: true,
            message: 'SFTP-Passwort erfolgreich gesetzt'
        });
    } catch (error) {
        Logger.error('[SFTP] Fehler beim Setzen des Passworts:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Setzen des Passworts'
        });
    }
});

/**
 * PUT /guild/:guildId/plugins/gameserver/servers/:serverId/sftp/password
 * SFTP-Passwort zurücksetzen
 */
router.put('/:serverId/sftp/password', async (req, res) => {
    const Logger = ServiceManager.get('Logger');
    const dbService = ServiceManager.get('dbService');
    const ipmServer = ServiceManager.get('ipmServer');
    
    try {
        const guildId = res.locals.guildId;
        const { serverId } = req.params;
        const { password, password_confirm } = req.body;

        // Validierung
        if (!password || password.length < 8) {
            return res.status(400).json({
                success: false,
                message: 'Passwort muss mindestens 8 Zeichen lang sein'
            });
        }

        if (password !== password_confirm) {
            return res.status(400).json({
                success: false,
                message: 'Passwörter stimmen nicht überein'
            });
        }

        // Server-Daten laden
        const [server] = await dbService.query(`
            SELECT gs.id, gs.name, r.daemon_id, r.system_user
            FROM gameservers gs
            LEFT JOIN rootserver r ON gs.rootserver_id = r.id
            WHERE gs.id = ? AND gs.guild_id = ?
        `, [serverId, guildId]);

        if (!server) {
            return res.status(404).json({
                success: false,
                message: 'Server nicht gefunden'
            });
        }

        // Passwort über IPM zurücksetzen
        Logger.info(`[SFTP] Setze neues Passwort für User ${server.system_user}`);

        const response = await ipmServer.sendCommand(server.daemon_id, 'sftp.set_password', {
            username: server.system_user,
            password: password
        }, 10000);

        if (!response.success) {
            return res.status(500).json({
                success: false,
                message: response.message || 'Fehler beim Zurücksetzen des Passworts'
            });
        }

        Logger.success(`[SFTP] Passwort erfolgreich zurückgesetzt`);

        res.json({
            success: true,
            message: 'SFTP-Passwort erfolgreich zurückgesetzt'
        });
    } catch (error) {
        Logger.error('[SFTP] Fehler beim Zurücksetzen:', error);
        res.status(500).json({
            success: false,
            message: 'Serverfehler beim Zurücksetzen'
        });
    }
});

module.exports = router;

