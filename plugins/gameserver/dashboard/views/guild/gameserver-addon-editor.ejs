document.getElementById('add-variable-btn').addEventListener('click', () => {
    const row = createVariableRow();
    document.getElementById('variables-container').appendChild(row);
    row.querySelector('.toggle-variable-details').click();
    updateNoVariablesMessage();
    updateJSONPreview();
});

function serializeVariables() {
    const variables = [];
    document.querySelectorAll('.variable-row').forEach(row => {
        variables.push({
            name:          row.querySelector('.var-name').value,
            description:   row.querySelector('.var-description').value,
            env_variable:  row.querySelector('.var-env').value,
            default_value: row.querySelector('.var-default').value,
            user_viewable: row.querySelector('.var-user-viewable').checked,
            user_editable: row.querySelector('.var-user-editable').checked,
            rules:         row.querySelector('.var-rules').value,
            field_type:    row.querySelector('.var-field-type').value
        });
    });
    return variables;
}

function loadVariablesIntoBuilder(variables) {
    if (!Array.isArray(variables)) return;
    const container = document.getElementById('variables-container');
    container.innerHTML = '';
    variables.forEach((v, i) => container.appendChild(createVariableRow(v, i)));
    updateNoVariablesMessage();
}

function updateNoVariablesMessage() {
    const count = document.querySelectorAll('.variable-row').length;
    document.getElementById('no-variables-message').style.display = count === 0 ? 'block' : 'none';
}

