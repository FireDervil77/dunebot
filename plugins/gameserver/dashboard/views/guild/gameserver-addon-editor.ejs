// DOCKER IMAGES BUILDER
// ──────────────────────────────────────────────────────────────────────────────
let dockerImageCounter = 0;

function createDockerImageRow(imageKey, imageLabel) {
    imageKey   = imageKey   || '';
    imageLabel = imageLabel || '';
    const row  = document.createElement('div');
    row.className = 'docker-image-row input-group mb-2';
    row.innerHTML = `
