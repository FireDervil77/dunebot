    const id  = index !== undefined ? index : variableCounter++;
    const row = document.createElement('div');
    row.className          = 'variable-row card mb-3';
    row.dataset.variableId = id;
    row.innerHTML = `
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <strong class="variable-name-display">${escHtml(varData.name) || 'Neue Variable'}</strong>
                    <code class="ml-2 text-muted">{{${escHtml(varData.env_variable) || 'VAR_NAME'}}}</code>
                </div>
                <div class="col-md-6 text-right">
                    <button type="button" class="btn btn-sm btn-danger remove-variable-btn">
                        <i class="fa-solid fa-trash"></i> Entfernen
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary toggle-variable-details">
                        <i class="fa-solid fa-chevron-down"></i> Details
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body variable-details" style="display: none;">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control var-name"
                               value="${escHtml(varData.name)}" placeholder="Server Name" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Umgebungsvariable <span class="text-danger">*</span></label>
                        <input type="text" class="form-control var-env"
                               value="${escHtml(varData.env_variable)}" placeholder="SERVER_NAME" required>
                        <small class="text-muted">Großbuchstaben + Unterstriche</small>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>Beschreibung</label>
                <textarea class="form-control var-description" rows="2"
                          placeholder="Name des Servers im Server-Browser">${escHtml(varData.description)}</textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Standard-Wert</label>
                        <input type="text" class="form-control var-default"
                               value="${escHtml(varData.default_value)}" placeholder="My Server">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Feld-Typ</label>
                        <select class="form-control var-field-type">
                            <option value="text"    ${!varData.field_type || varData.field_type === 'text'    ? 'selected' : ''}>Text</option>
                            <option value="boolean" ${varData.field_type === 'boolean' ? 'selected' : ''}>Boolean (0/1)</option>
                            <option value="integer" ${varData.field_type === 'integer' ? 'selected' : ''}>Zahl (Integer)</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>Validierungs-Regeln</label>
                <input type="text" class="form-control var-rules"
                       value="${escHtml(varData.rules)}" placeholder="required|string|max:60">
                <small class="text-muted">Laravel-Syntax (z.B. "required|string|max:60")</small>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input var-user-viewable"
                               ${varData.user_viewable !== false ? 'checked' : ''}>
                        <label class="form-check-label">Sichtbar für Benutzer</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input var-user-editable"
                               ${varData.user_editable !== false ? 'checked' : ''}>
                        <label class="form-check-label">Bearbeitbar für Benutzer</label>
                    </div>
                </div>
            </div>
        </div>
    `;

    row.querySelector('.remove-variable-btn').addEventListener('click', () => {
        if (confirm('Variable wirklich entfernen?')) {
            row.remove();
            updateNoVariablesMessage();
            updateJSONPreview();
        }
    });

    row.querySelector('.toggle-variable-details').addEventListener('click', function () {
        const details = row.querySelector('.variable-details');
        const open    = details.style.display === 'none';
        details.style.display             = open ? 'block' : 'none';
        this.querySelector('i').className = open ? 'fa-solid fa-chevron-up' : 'fa-solid fa-chevron-down';
    });

    row.querySelector('.var-name').addEventListener('input', function () {
        row.querySelector('.variable-name-display').textContent = this.value || 'Neue Variable';
        updateJSONPreview();
    });

    row.querySelector('.var-env').addEventListener('input', function () {
        row.querySelector('code').textContent = '{{' + (this.value || 'VAR_NAME') + '}}';
        updateJSONPreview();
    });

    row.querySelectorAll('input, textarea, select').forEach(inp => {
