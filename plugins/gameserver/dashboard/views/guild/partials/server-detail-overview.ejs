<%# 
  * Server-Detail Overview-Tab
  * Zeigt allgemeine Informationen, Stats, Konfiguration
  %>

<div class="row">
    <!-- ========================================
         SERVER INFORMATION
         ======================================== -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-info-circle me-2"></i>
                    Server-Informationen
                </h3>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <th style="width: 40%">Server-ID:</th>
                            <td><code><%= server.id %></code></td>
                        </tr>
                        <tr>
                            <th>Name:</th>
                            <td><%= server.name %></td>
                        </tr>
                        <tr>
                            <th>Spiel:</th>
                            <td>
                                <%= server.game_name || 'Unbekannt' %>
                                <% if (server.addon_version) { %>
                                    <span class="badge bg-secondary ms-2">v<%= server.addon_version %></span>
                                <% } %>
                            </td>
                        </tr>
                        <tr>
                            <th>Template:</th>
                            <td><%= server.template_name || 'Standard' %></td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                <% 
                                const statusColors = {
                                    online: 'success',
                                    offline: 'secondary',
                                    starting: 'warning',
                                    stopping: 'warning',
                                    error: 'danger',
                                    installing: 'info',
                                    installed: 'success'
                                };
                                const color = statusColors[server.status] || 'secondary';
                                %>
                                <span class="badge bg-<%= color %>" data-server-status>
                                    <span data-status-text><%= server.status %></span>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>RootServer:</th>
                            <td>
                                <%= server.rootserver_name || 'N/A' %>
                                <% if (server.rootserver_hostname) { %>
                                    <small class="text-muted">(<%= server.rootserver_hostname %>)</small>
                                <% } %>
                            </td>
                        </tr>
                        <tr>
                            <th>Erstellt am:</th>
                            <td><%= new Date(server.created_at).toLocaleString('de-DE') %></td>
                        </tr>
                        <tr>
                            <th>Letzte Änderung:</th>
                            <td><%= new Date(server.updated_at).toLocaleString('de-DE') %></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

<!-- ========================================
     CONNECTION & PORTS
     ======================================== -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-plug me-2"></i>
                    Verbindung & Ports
                </h3>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <th style="width: 40%">IP-Adresse:</th>
                            <td>
                                <code><%= server.ip_address || 'N/A' %></code>
                                <% if (server.ip_address) { %>
                                    <button class="btn btn-sm btn-outline-secondary ms-2" 
                                            onclick="copyToClipboard('<%= server.ip_address %>')"
                                            title="Kopieren">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                        <tr>
                            <th>Game-Port:</th>
                            <td>
                                <code><%= server.port_game || 'N/A' %></code>
                                <% if (server.ip_address && server.port_game) { %>
                                    <button class="btn btn-sm btn-outline-secondary ms-2" 
                                            onclick="copyToClipboard('<%= server.ip_address %>:<%= server.port_game %>')"
                                            title="Verbindungsstring kopieren">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                        <tr>
                            <th>Query-Port:</th>
                            <td>
                                <% if (server.port_query) { %>
                                    <code><%= server.port_query %></code>
                                    <button class="btn btn-sm btn-outline-secondary ms-2" 
                                            onclick="copyToClipboard('<%= server.port_query %>')"
                                            title="Port kopieren">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                <% } else { %>
                                    <span class="text-muted">Nicht konfiguriert</span>
                                    <small class="text-muted d-block">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Query-Port ermöglicht Server-Status-Abfragen (z.B. für Discord-Bots)
                                    </small>
                                <% } %>
                            </td>
                        </tr>
                        <tr>
                            <th>RCON-Port:</th>
                            <td>
                                <% if (server.port_rcon) { %>
                                    <code><%= server.port_rcon %></code>
                                    <button class="btn btn-sm btn-outline-secondary ms-2" 
                                            onclick="copyToClipboard('<%= server.port_rcon %>')"
                                            title="Port kopieren">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                <% } else { %>
                                    <span class="text-muted">Nicht konfiguriert</span>
                                    <small class="text-muted d-block">
                                        <i class="fas fa-info-circle me-1"></i>
                                        RCON ermöglicht Remote-Administration des Servers
                                    </small>
                                <% } %>
                            </td>
                        </tr>
                        <%
                            // Dynamisch alle zusätzlichen Ports anzeigen (beacon, etc.)
                            const knownPorts = ['game', 'query', 'rcon', 'main'];
                            const extraPortEntries = server.ports_parsed
                                ? Object.entries(server.ports_parsed).filter(([k]) => !knownPorts.includes(k))
                                : [];
                        %>
                        <% extraPortEntries.forEach(([portType, portData]) => { %>
                            <tr>
                                <th><%= portType.charAt(0).toUpperCase() + portType.slice(1) %>-Port:</th>
                                <td>
                                    <% const epVal = portData.external || portData.internal; %>
                                    <% if (epVal) { %>
                                        <code><%= epVal %></code>
                                        <button class="btn btn-sm btn-outline-secondary ms-2" 
                                                onclick="copyToClipboard('<%= epVal %>')"
                                                title="Port kopieren">
                                            <i class="fas fa-copy"></i>
                                        </button>
                                    <% } else { %>
                                        <span class="text-muted">Nicht konfiguriert</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                        <tr>
                            <th>Installationspfad:</th>
                            <td>
                                <small><code><%= server.install_path || 'N/A' %></code></small>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <% if (userPermissions.permissions['GAMESERVER.EDIT']) { %>
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#portsEditModal">
                        <i class="fas fa-edit me-1"></i>Ports bearbeiten
                    </button>
                </div>
                <% } %>
            </div>
        </div>

<!-- Port-Edit-Modal -->
<div class="modal fade" id="portsEditModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-plug me-2"></i>Ports bearbeiten</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning alert-sm">
                    <i class="fas fa-exclamation-triangle me-1"></i>
                    Ports können nur geändert werden wenn der Server <strong>offline</strong> ist.
                    Stelle sicher, dass kein anderer Server diese Ports belegt.
                </div>
                <div id="ports-form">
                <%
                const portsObj = server.ports_parsed || {};
                const portTypeLabels = { game: 'Game-Port', query: 'Query-Port', rcon: 'RCON-Port' };
                const allPortKeys = Object.keys(portsObj).length ? Object.keys(portsObj) : ['game'];
                for (const pKey of allPortKeys) {
                    const pEntry = portsObj[pKey] || {};
                    const label = portTypeLabels[pKey] || pKey;
                    const extVal = pEntry.external || pEntry.internal || '';
                %>
                    <div class="form-group">
                        <label><strong><%= label %></strong> <code class="text-muted small"><%= pKey %></code></label>
                        <input type="number" class="form-control port-input" data-port-key="<%= pKey %>"
                               value="<%= extVal %>" min="1024" max="65535" placeholder="z.B. 27015">
                    </div>
                <% } %>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" id="ports-save-btn" onclick="savePorts()">
                    <i class="fas fa-save me-1"></i>Speichern
                </button>
            </div>
        </div>
    </div>
</div>

<script>
async function savePorts() {
    const btn = document.getElementById('ports-save-btn');
    const inputs = document.querySelectorAll('.port-input');
    const ports = {};
    inputs.forEach(inp => {
        const key = inp.dataset.portKey;
        const val = parseInt(inp.value, 10);
        if (key && val >= 1024 && val <= 65535) ports[key] = val;
        else if (key) { toastr.error(`Ungültiger Port für ${key}: ${inp.value} (muss zwischen 1024 und 65535 liegen)`); return; }
    });
    if (!Object.keys(ports).length) return;
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Speichern...';
    try {
        const resp = await fetch(`/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/ports`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify(ports)
        });
        const r = await resp.json();
        if (r.success) {
            toastr.success('Ports gespeichert – wird beim nächsten Start wirksam.');
            $('#portsEditModal').modal('hide');
            // Port-Anzeige aktualisieren ohne Reload
            Object.entries(ports).forEach(([k, v]) => {
                if (k === 'game') document.querySelector('[data-port-game]') && (document.querySelector('[data-port-game]').textContent = v);
            });
        } else { toastr.error(r.message || 'Fehler beim Speichern'); }
    } catch(e) { toastr.error('Netzwerkfehler'); }
    finally { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save me-1"></i>Speichern'; }
}
</script>
            <!-- ========================================
             PLAYER STATS (nur bei online)
             ======================================== -->
        <% if (server.status === 'online') { %>
            <div class="card mt-3">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-users me-2"></i>
                        Spieler
                    </h3>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Aktuelle Spieler:</span>
                        <strong class="text-primary" data-current-players>
                            <%= server.current_players || 0 %> / <%= server.max_players || '?' %>
                        </strong>
                    </div>
                    <div class="progress">
                        <% 
                        const playerPercent = server.max_players > 0 
                            ? (server.current_players / server.max_players) * 100 
                            : 0;
                        %>
                        <div class="progress-bar bg-primary" 
                             role="progressbar" 
                             style="width: <%= playerPercent %>%"
                             data-players-bar>
                            <%= playerPercent.toFixed(0) %>%
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- ========================================
             LIVE-QUERY (GameDig – nur wenn Addon Query unterstützt)
             ======================================== -->
        <% if (server.status === 'online' && server.gamedig_type) { %>
            <div class="card mt-3" id="live-query-card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-satellite-dish me-2"></i>
                        Live-Status
                        <span class="badge bg-secondary ms-2" id="query-ping-badge" style="display:none"></span>
                    </h3>
                    <button class="btn btn-sm btn-outline-primary" id="btn-refresh-query" onclick="refreshLiveQuery()">
                        <i class="fas fa-sync-alt me-1"></i>Aktualisieren
                    </button>
                </div>
                <div class="card-body">
                    <div id="live-query-loading" class="text-center text-muted py-3">
                        <i class="fas fa-spinner fa-spin me-2"></i>Lade Live-Status…
                    </div>
                    <div id="live-query-content" style="display:none">
                        <div class="row g-3 mb-3">
                            <div class="col-6 col-md-3 text-center">
                                <div class="fw-bold text-primary fs-4" id="qry-players">–</div>
                                <div class="small text-muted">Spieler</div>
                            </div>
                            <div class="col-6 col-md-3 text-center">
                                <div class="fw-bold fs-4" id="qry-map">–</div>
                                <div class="small text-muted">Map</div>
                            </div>
                            <div class="col-6 col-md-3 text-center">
                                <div class="fw-bold fs-4" id="qry-ping">–</div>
                                <div class="small text-muted">Ping (ms)</div>
                            </div>
                            <div class="col-6 col-md-3 text-center">
                                <div id="qry-password" class="fw-bold fs-4">–</div>
                                <div class="small text-muted">Passwort</div>
                            </div>
                            <div class="col-6 col-md-3 text-center" id="qry-version-col" style="display:none">
                                <div class="fw-bold fs-4" id="qry-version">–</div>
                                <div class="small text-muted">Spielversion</div>
                            </div>
                        </div>
                        <div id="qry-player-list" class="mt-2" style="display:none">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>Spielername</th>
                                        <th class="text-end">Score</th>
                                        <th class="text-end">Spielzeit</th>
                                    </tr>
                                </thead>
                                <tbody id="qry-player-tbody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div id="live-query-error" class="alert alert-warning mb-0" style="display:none">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span id="live-query-error-msg"></span>
                    </div>
                </div>
            </div>

            <script>
            (function () {
                const QUERY_URL = '/guild/<%= server.guild_id %>/plugins/gameserver/servers/<%= server.id %>/query';

                function secondsToHMS(s) {
                    if (!s && s !== 0) return '–';
                    const h = Math.floor(s / 3600);
                    const m = Math.floor((s % 3600) / 60);
                    const sec = Math.floor(s % 60);
                    return [h>0?h+'h':null, m+'m', sec+'s'].filter(Boolean).join(' ');
                }

                window.refreshLiveQuery = async function () {
                    document.getElementById('live-query-loading').style.display = '';
                    document.getElementById('live-query-content').style.display = 'none';
                    document.getElementById('live-query-error').style.display = 'none';
                    document.getElementById('btn-refresh-query').disabled = true;

                    try {
                        const res  = await fetch(QUERY_URL, { credentials: 'same-origin' });
                        const data = await res.json();

                        if (!data.success) {
                            document.getElementById('live-query-error-msg').textContent = data.error || 'Abfrage fehlgeschlagen';
                            document.getElementById('live-query-error').style.display = '';
                            document.getElementById('live-query-loading').style.display = 'none';
                            return;
                        }

                        // Felder füllen
                        const currentPlayersCount = data.players?.length ?? 0;
                        const maxPlayersCount     = data.maxPlayers ?? 0;
                        document.getElementById('qry-players').textContent =
                            currentPlayersCount + ' / ' + (data.maxPlayers ?? '?');

                        // Spieler-Card oben live aktualisieren
                        const cpEl = document.querySelector('[data-current-players]');
                        if (cpEl) cpEl.textContent = currentPlayersCount + ' / ' + (data.maxPlayers ?? '?');
                        const barEl = document.querySelector('[data-players-bar]');
                        if (barEl && maxPlayersCount > 0) {
                            const pct = Math.round((currentPlayersCount / maxPlayersCount) * 100);
                            barEl.style.width = pct + '%';
                            barEl.textContent = pct + '%';
                        }

                        document.getElementById('qry-map').textContent  = data.map  || '–';
                        document.getElementById('qry-ping').textContent = data.ping != null ? data.ping + ' ms' : '–';
                        document.getElementById('qry-password').innerHTML = data.password
                            ? '<i class="fas fa-lock text-warning"></i>' : '<i class="fas fa-lock-open text-success"></i>';

                        // Spielversion aus tags (z.B. ["g=0.221.12", ...])
                        const versionTag = (data.tags || []).find(t => t.startsWith('g='));
                        const gameVersion = versionTag ? versionTag.slice(2) : null;
                        const verCol = document.getElementById('qry-version-col');
                        if (gameVersion) {
                            document.getElementById('qry-version').textContent = gameVersion;
                            verCol.style.display = '';
                        } else {
                            verCol.style.display = 'none';
                        }

                        // Ping-Badge
                        const badge = document.getElementById('query-ping-badge');
                        badge.textContent = data.ping != null ? data.ping + ' ms' : '';
                        badge.style.display = data.ping != null ? '' : 'none';

                        // Spielerliste
                        const players = data.players || [];
                        if (players.length > 0) {
                            const tbody = document.getElementById('qry-player-tbody');
                            tbody.innerHTML = players.map((p, i) => `
                                <tr>
                                    <td>${p.name || ('Spieler ' + (i + 1))}</td>
                                    <td class="text-end">${p.score ?? '–'}</td>
                                    <td class="text-end">${secondsToHMS(p.time)}</td>
                                </tr>`).join('');
                            document.getElementById('qry-player-list').style.display = '';
                        } else {
                            document.getElementById('qry-player-list').style.display = 'none';
                        }

                        document.getElementById('live-query-content').style.display = '';
                        document.getElementById('live-query-loading').style.display = 'none';

                    } catch (e) {
                        document.getElementById('live-query-error-msg').textContent = 'Netzwerkfehler: ' + e.message;
                        document.getElementById('live-query-error').style.display = '';
                        document.getElementById('live-query-loading').style.display = 'none';
                    } finally {
                        document.getElementById('btn-refresh-query').disabled = false;
                    }
                };

                // Automatisch beim Laden ausführen
                refreshLiveQuery();
            })();
            </script>
        <% } %>
    </div>
</div>

<!-- ========================================
     CONFIGURATION (wenn vorhanden)
     ======================================== -->
<% if (server.launch_params || server.auto_restart !== null || server.auto_update !== null) { %>
    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-cogs me-2"></i>
                        Konfiguration
                    </h3>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tbody>
                            <% if (server.launch_params) { %>
                                <tr>
                                    <th style="width: 30%">Start-Parameter:</th>
                                    <td>
                                        <!-- View-Mode -->
                                        <div id="launch-params-view">
                                            <div class="mb-2 d-flex align-items-start">
                                                <code class="d-block p-2 bg-light border rounded flex-grow-1" id="launch-params-display"><%= server.launch_params %></code>
                                                <% if (userPermissions.permissions['GAMESERVER.EDIT']) { %>
                                                    <button class="btn btn-sm btn-primary ms-2" onclick="toggleLaunchParamsEdit(true)" title="Bearbeiten">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                <% } %>
                                            </div>
                                            <small class="text-muted">
                                                <i class="fas fa-lightbulb me-1"></i>
                                                <strong>Verfügbare Variablen:</strong><br>
                                                <code>{{PORT}}</code> - Game-Port,
                                                <code>{{QUERY_PORT}}</code> - Query-Port,
                                                <code>{{RCON_PORT}}</code> - RCON-Port,
                                                <code>{{MAX_PLAYERS}}</code> - Max. Spieler,
                                                <code>{{SERVER_NAME}}</code> - Server-Name
                                            </small>
                                        </div>
                                        
                                        <!-- Edit-Mode -->
                                        <div id="launch-params-edit" style="display: none;">
                                            <form class="guild-ajax-form" 
                                                  data-form-type="launch-params"
                                                  data-method="PUT"
                                                  action="/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/launch-params"
                                                  method="POST">
                                                
                                                <textarea class="form-control font-monospace mb-2" 
                                                          name="launch_params" 
                                                          id="launch-params-input"
                                                          rows="3"
                                                          required
                                                          placeholder="z.B. -port {{PORT}} -maxplayers {{MAX_PLAYERS}}"
                                                          style="font-size: 0.9rem;"><%= server.launch_params %></textarea>
                                                
                                                <div class="d-flex gap-2">
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-save me-1"></i> Speichern
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-secondary" onclick="toggleLaunchParamsEdit(false)">
                                                        <i class="fas fa-times me-1"></i> Abbrechen
                                                    </button>
                                                </div>
                                                
                                                <small class="text-muted d-block mt-2">
                                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                                    <strong>Wichtig:</strong> Änderungen werden erst nach Neustart des Servers aktiv!
                                                </small>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                            <% if (server.auto_restart !== null) { %>
                                <tr>
                                    <th>Auto-Restart:</th>
                                    <td>
                                        <% if (server.auto_restart) { %>
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i> Aktiviert
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-times me-1"></i> Deaktiviert
                                            </span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% } %>
                            <% if (server.auto_update !== null) { %>
                                <tr>
                                    <th>Auto-Update:</th>
                                    <td>
                                        <% if (server.auto_update) { %>
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i> Aktiviert
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-times me-1"></i> Deaktiviert
                                            </span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
<% } %>

<!-- ========================================
     SFTP-ZUGANGSDATEN
     ======================================== -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-folder-open mr-2"></i>
                    SFTP-Zugang
                </h3>
                <div class="card-tools">
                    <% if (userPermissions && userPermissions.permissions && userPermissions.permissions['GAMESERVER.EDIT']) { %>
                    <button type="button"
                            class="btn btn-sm btn-warning"
                            id="sftp-reset-btn"
                            onclick="sftpResetPassword()">
                        <i class="fas fa-sync-alt mr-1"></i>
                        Passwort zurücksetzen
                    </button>
                    <% } %>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 col-sm-6 mb-2">
                        <label class="text-muted small mb-1 d-block">HOST</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" id="sftp-host" value="<%= server.sftp_host %>" readonly>
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" onclick="copyToClipboard('<%= server.sftp_host %>')" title="Kopieren">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-1 col-sm-6 mb-2">
                        <label class="text-muted small mb-1 d-block">PORT</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" value="<%= server.sftp_port %>" readonly>
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" onclick="copyToClipboard('<%= server.sftp_port %>')" title="Kopieren">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 col-sm-6 mb-2">
                        <label class="text-muted small mb-1 d-block">BENUTZERNAME</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control font-italic" id="sftp-user" value="<%= server.sftp_username || '' %>" readonly>
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" onclick="copyToClipboard('<%= server.sftp_username %>')" title="Kopieren">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 col-sm-6 mb-2">
                        <label class="text-muted small mb-1 d-block">PASSWORT</label>
                        <div class="input-group input-group-sm">
                            <input type="password" class="form-control font-italic" id="sftp-pass" value="<%= server.sftp_password || '' %>" readonly>
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" id="sftp-pass-toggle" onclick="toggleSftpPassword()" title="Anzeigen/Verbergen">
                                    <i class="fas fa-eye" id="sftp-pass-icon"></i>
                                </button>
                                <button class="btn btn-outline-secondary" onclick="copyToClipboard(document.getElementById('sftp-pass').value)" title="Kopieren">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <small class="text-muted">
                    <i class="fas fa-info-circle mr-1"></i>
                    Verbindung: <code>sftp://<%= server.sftp_username %>@<%= server.sftp_host %>:<%= server.sftp_port %></code>
                    &nbsp;|&nbsp;
                    Client-Empfehlung: FileZilla, WinSCP
                </small>
            </div>
        </div>
    </div>
</div>

<script>
function toggleSftpPassword() {
    const input = document.getElementById('sftp-pass');
    const icon  = document.getElementById('sftp-pass-icon');
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}

async function sftpResetPassword() {
    const btn = document.getElementById('sftp-reset-btn');
    if (!confirm('Passwort zurücksetzen? Das alte Passwort wird sofort ungültig.')) return;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Wird gesetzt...';
    try {
        const resp = await fetch(
            `/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/sftp/reset-password`,
            { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } }
        );
        const data = await resp.json();
        if (data.success) {
            document.getElementById('sftp-user').value = data.sftp_username;
            document.getElementById('sftp-pass').value = data.sftp_password;
            document.getElementById('sftp-pass').type  = 'text';
            document.getElementById('sftp-pass-icon').classList.replace('fa-eye', 'fa-eye-slash');
            toastr.success('SFTP-Passwort erfolgreich zurückgesetzt!');
        } else {
            toastr.error(data.message || 'Passwort-Reset fehlgeschlagen.');
        }
    } catch (e) {
        toastr.error('Netzwerkfehler beim SFTP-Passwort-Reset.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt mr-1"></i> Passwort zurücksetzen';
    }
}
</script>

<script>
/**
 * Toggle Launch-Params Edit-Mode
 */
function toggleLaunchParamsEdit(edit) {
    const viewMode = document.getElementById('launch-params-view');
    const editMode = document.getElementById('launch-params-edit');
    
    if (edit) {
        viewMode.style.display = 'none';
        editMode.style.display = 'block';
        document.getElementById('launch-params-input').focus();
    } else {
        viewMode.style.display = 'block';
        editMode.style.display = 'none';
    }
}
</script>
