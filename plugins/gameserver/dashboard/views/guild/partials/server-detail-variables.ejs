<%#
 * Server-Detail Variablen-Tab
 * Zeigt alle game_data.variables mit aktuellen Werten aus env_variables
 * und erlaubt das Bearbeiten.
 %>

<%
// Variablen-Array normalisieren (Array oder Object möglich)
let variablesArray = [];
if (gameData.variables) {
    if (Array.isArray(gameData.variables)) {
        variablesArray = gameData.variables;
    } else if (typeof gameData.variables === 'object') {
        variablesArray = Object.entries(gameData.variables).map(([key, value]) => ({
            name: key,
            display_name: key.replace(/_/g, ' '),
            default_value: typeof value === 'object' ? (value.default || '') : value,
            description: typeof value === 'object' ? (value.description || '') : '',
            type: typeof value === 'object' ? (value.type || 'text') : 'text',
            options: typeof value === 'object' ? (value.options || []) : [],
            required: typeof value === 'object' ? (value.required || false) : false
        }));
    }
}
const envVars = server.env_variables_parsed || {};

// Startup-Command aus game_data.startup.command (Template mit {{VAR}} Platzhaltern)
const startupTemplate = (gameData.startup && gameData.startup.command) || server.launch_params || '';

// Platzhalter durch aktuelle Werte ersetzen
let resolvedStartup = startupTemplate;
if (startupTemplate) {
    // Alle {{VAR}} Platzhalter substituieren
    resolvedStartup = startupTemplate.replace(/\{\{(\w+)\}\}/g, (match, varName) => {
        // Prüfe env_variables zuerst, dann variable defaults
        if (envVars[varName] !== undefined && envVars[varName] !== '') {
            return envVars[varName];
        }
        // Fallback: Default-Wert aus Variable-Definition suchen
        const varDef = variablesArray.find(v => (v.env_variable || v.name) === varName);
        if (varDef && varDef.default_value !== undefined && varDef.default_value !== '') {
            return varDef.default_value;
        }
        return match; // Platzhalter beibehalten wenn kein Wert gefunden
    });
}
%>

<%# ═══════ Startup Command Anzeige ═══════ %>
<% if (startupTemplate) { %>
<div class="card card-outline card-dark mb-3">
    <div class="card-header py-2">
        <h3 class="card-title">
            <i class="fas fa-terminal me-2"></i>
            Startup Command
        </h3>
    </div>
    <div class="card-body p-2">
        <pre id="startup-command-preview" class="bg-dark text-success p-3 rounded mb-0" style="font-size: 13px; white-space: pre-wrap; word-break: break-all;"><%= resolvedStartup %></pre>
    </div>
</div>
<% } %>

<% if (variablesArray.length === 0) { %>
    <div class="alert alert-info">
        <i class="fas fa-info-circle mr-2"></i>
        Dieses Addon hat keine konfigurierbaren Variablen.
    </div>
<% } else { %>

<form id="variables-form">
    <div class="row">
        <% variablesArray.forEach(variable => {
            // env_variable = technischer ENV-Key (SERVER_NAME), name = Anzeigename ("Server Name")
            // IPC-Pfad speichert mit env_variable-Key, Dashboard-Pfad (alt) mit name-Key
            const envKey         = variable.env_variable || variable.name || '';
            const varName        = envKey; // Primärschlüssel für Formulare = ENV-Key
            const varDisplayName = variable.display_name || variable.name || envKey;
            const varDescription = variable.description || '';
            const varType        = variable.type || (variable.field_type) || 'text';
            const varOptions     = variable.options || [];
            const isRequired     = variable.required === true || (typeof variable.rules === 'string' && variable.rules.includes('required') && !variable.rules.includes('nullable'));
            // Wert-Lookup: env_variable-Key zuerst, dann name-Key (Legacy-Compat), dann default
            const currentValue   = envVars[envKey] !== undefined
                                    ? envVars[envKey]
                                    : (envVars[variable.name] !== undefined
                                        ? envVars[variable.name]
                                        : (variable.default_value ?? ''));
        %>
        <div class="col-md-6 col-lg-4">
            <div class="form-group">
                <label for="env_<%= varName %>">
                    <strong><%= varDisplayName %></strong>
                    <% if (isRequired) { %><span class="text-danger">*</span><% } %>
                    <code class="ml-1 text-muted small">{{<%= varName %>}}</code>
                </label>

                <% if (varType === 'select' && varOptions.length > 0) { %>
                    <select class="form-control form-control-sm"
                            id="env_<%= varName %>"
                            name="<%= varName %>"
                            <%= isRequired ? 'required' : '' %>>
                        <% varOptions.forEach(opt => {
                            const optVal   = typeof opt === 'object' ? opt.value : opt;
                            const optLabel = typeof opt === 'object' ? opt.label  : opt;
                        %>
                            <option value="<%= optVal %>" <%= optVal == currentValue ? 'selected' : '' %>><%= optLabel %></option>
                        <% }); %>
                    </select>

                <% } else if (varType === 'boolean') { %>
                    <select class="form-control form-control-sm"
                            id="env_<%= varName %>"
                            name="<%= varName %>"
                            <%= isRequired ? 'required' : '' %>>
                        <option value="true"  <%= currentValue === 'true'  || currentValue === true  ? 'selected' : '' %>>Ja</option>
                        <option value="false" <%= currentValue === 'false' || currentValue === false ? 'selected' : '' %>>Nein</option>
                    </select>

                <% } else if (varType === 'number') { %>
                    <input type="number"
                           class="form-control form-control-sm"
                           id="env_<%= varName %>"
                           name="<%= varName %>"
                           value="<%= currentValue %>"
                           placeholder="<%= variable.default_value || '' %>"
                           <%= isRequired ? 'required' : '' %>>

                <% } else { %>
                    <input type="text"
                           class="form-control form-control-sm"
                           id="env_<%= varName %>"
                           name="<%= varName %>"
                           value="<%= currentValue %>"
                           placeholder="<%= variable.default_value || 'Optional' %>"
                           <%= isRequired ? 'required' : '' %>>
                <% } %>

                <% if (varDescription) { %>
                    <small class="form-text text-muted"><%= varDescription %></small>
                <% } %>
            </div>
        </div>
        <% }); %>
    </div><!-- /.row -->

    <div class="row mt-2">
        <div class="col-12">
            <button type="button" class="btn btn-primary" id="variables-save-btn" onclick="saveVariables()">
                <i class="fas fa-save mr-1"></i>
                Variablen speichern
            </button>
            <% if (gameData.config && gameData.config.files && Object.keys(gameData.config.files).length > 0) { %>
            <button type="button" class="btn btn-outline-info ml-2" id="apply-config-btn" onclick="applyConfig()" title="Config-Dateien auf dem Server patchen (ohne Neustart)">
                <i class="fas fa-cogs mr-1"></i>
                Config anwenden
            </button>
            <% } %>
            <small class="text-muted ml-3">
                <i class="fas fa-info-circle mr-1"></i>
                Änderungen werden beim nächsten Server-Start wirksam.
            </small>
        </div>
    </div>
</form>

<% } %>

<script>
// ═══════ Startup-Command Live-Vorschau ═══════
(function() {
    const startupTemplate = `<%= startupTemplate.replace(/`/g, '\\`').replace(/\\/g, '\\\\') %>`;
    const preview = document.getElementById('startup-command-preview');
    const form = document.getElementById('variables-form');
    if (!preview || !form || !startupTemplate) return;

    function updateStartupPreview() {
        let resolved = startupTemplate;
        form.querySelectorAll('[name]').forEach(el => {
            const val = el.value || '';
            // Ersetze {{VAR_NAME}} mit dem aktuellen Wert
            resolved = resolved.replace(new RegExp('\\{\\{' + el.name + '\\}\\}', 'g'), val || '{{' + el.name + '}}');
        });
        preview.textContent = resolved;
    }

    // Bei jeder Eingabe-Änderung aktualisieren
    form.addEventListener('input', updateStartupPreview);
    form.addEventListener('change', updateStartupPreview);
})();

async function saveVariables() {
    const form = document.getElementById('variables-form');
    const btn  = document.getElementById('variables-save-btn');
    if (!form) return;

    const data = {};
    form.querySelectorAll('[name]').forEach(el => {
        data[el.name] = el.value;
    });

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Speichern...';

    try {
        const resp = await fetch(
            `/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/variables`,
            {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(data)
            }
        );
        const result = await resp.json();
        if (result.success) {
            toastr.success('Variablen erfolgreich gespeichert!');
        } else {
            toastr.error(result.message || 'Fehler beim Speichern.');
        }
    } catch (e) {
        toastr.error('Netzwerkfehler beim Speichern der Variablen.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save mr-1"></i> Variablen speichern';
    }
}

// ═══════ Config-Apply (Configs auf Disk patchen) ═══════
async function applyConfig() {
    const btn = document.getElementById('apply-config-btn');
    if (!btn) return;

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Patche Configs...';

    try {
        const resp = await fetch(
            `/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/apply-config`,
            {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }
        );
        const result = await resp.json();
        if (result.success) {
            toastr.success(result.message || 'Config-Dateien gepatcht!');
        } else {
            toastr.error(result.message || 'Fehler beim Config-Apply.');
        }
    } catch (e) {
        toastr.error('Netzwerkfehler beim Config-Apply.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-cogs mr-1"></i> Config anwenden';
    }
}
</script>
