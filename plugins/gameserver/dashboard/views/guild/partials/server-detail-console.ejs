<%# 
  * Server-Detail Console-Tab
  * Live-Console mit xterm.js
  * @author FireBot Team
  %>

<!-- Console-Container -->
<div id="console-container" class="position-relative">
    <!-- Installation-Hinweis (nur bei Status 'installing') -->
    <% if (server.status === 'installing') { %>
        <div class="alert alert-info mb-3">
            <i class="fas fa-download me-2"></i>
            <strong>Installation läuft:</strong> 
            Verbinde die Console, um die Live-Installation-Logs zu sehen (SteamCMD-Output, Progress, etc.)
        </div>
    <% } %>
    
    <!-- Status Bar -->
    <div class="alert alert-secondary mb-3 d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-terminal me-2"></i>
            <strong>Live-Console:</strong> 
            <span id="console-status" class="badge bg-secondary">Nicht verbunden</span>
        </div>
        <div>
            <!-- Clear-Button (immer verfügbar) -->
            <button id="console-clear-btn" class="btn btn-sm btn-secondary" onclick="gameserverConsole.clear()">
                <i class="fas fa-eraser me-1"></i> Löschen
            </button>
        </div>
    </div>

    <!-- Terminal (xterm.js) -->
    <div id="xterm-terminal" class="border rounded" style="background-color: #000; padding: 10px; height: 500px; width: 100%; overflow: hidden;"></div>

    <!-- Command Input -->
    <% if (userPermissions.permissions['GAMESERVER.CONSOLE.EXECUTE']) { %>
        <div class="mt-3">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="fas fa-chevron-right"></i>
                </span>
                <input type="text" 
                       id="console-input" 
                       class="form-control" 
                       placeholder="Command eingeben... (z.B. 'say Hello World')"
                       autocomplete="off">
                <button class="btn btn-primary" onclick="gameserverConsole.sendCommand()">
                    <i class="fas fa-paper-plane me-1"></i> Senden
                </button>
            </div>
            <small class="text-muted">
                <i class="fas fa-info-circle me-1"></i>
                Tipp: Drücke <kbd>↑</kbd> / <kbd>↓</kbd> für Command-History
            </small>
        </div>
    <% } else { %>
        <div class="alert alert-warning mt-3">
            <i class="fas fa-lock me-2"></i>
            Du hast keine Berechtigung, Commands zu senden (benötigt: <code>GAMESERVER.CONSOLE.EXECUTE</code>)
        </div>
    <% } %>
</div>

<!-- xterm.js Assets via AssetManager (lokal gehostet) -->
<% if (locals.assetManager) { %>
    <% assetManager.enqueueStyle('xterm-style'); %>
    <% assetManager.enqueueScript('xterm-core'); %>
    <% assetManager.enqueueScript('xterm-addon-fit'); %>
<% } else { %>
    <!-- Fallback für Entwicklung ohne AssetManager -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js"></script>
<% } %>

<!-- Console-Client Script via AssetManager -->
<% if (locals.assetManager) { %>
    <% assetManager.enqueueScript('gameserver-console'); %>
<% } else { %>
    <!-- Fallback für Entwicklung ohne AssetManager -->
    <script src="/assets/plugins/gameserver/js/console-client.js"></script>
<% } %>

<script>
// Globale Console-Config für console-client.js
window.CONSOLE_CONFIG = {
    serverId: '<%= server.id %>',
    guildId: '<%= guildId %>',
    canExecute: <%= userPermissions.permissions['GAMESERVER.CONSOLE.EXECUTE'] ? 'true' : 'false' %>,
    apiBase: '/guild/<%= guildId %>/plugins/gameserver/console/<%= server.id %>'
};

// Inline-Fallback: Script bereits geladen (kein AssetManager)?
// Mit Guard: nie doppelt instanziieren
if (typeof gameserverConsole === 'undefined' && typeof GameserverConsoleClient !== 'undefined') {
    window.gameserverConsole = new GameserverConsoleClient(CONSOLE_CONFIG);
    console.log('[Console] Console-Client initialisiert (inline)');
}

// ════════════════════════════════════════════════════════════════════════════
// ✨ PERSISTENT AUTO-CONNECT – Console bleibt dauerhaft verbunden
// Kein Tab-basiertes Disconnect: SSE-Stream läuft immer, auch wenn Tab
// nicht aktiv ist (Install-Output geht so nie verloren).
// ════════════════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', function() {
    // AssetManager-Fallback: Script im Footer geladen → jetzt instanziieren
    if (typeof gameserverConsole === 'undefined' && typeof GameserverConsoleClient !== 'undefined') {
        window.gameserverConsole = new GameserverConsoleClient(CONSOLE_CONFIG);
        console.log('[Console] Console-Client initialisiert (DOMContentLoaded/AssetManager)');
    }

    // ── Einmalig verbinden beim Page-Load ───────────────────────────────────
    function tryConnect() {
        if (typeof gameserverConsole === 'undefined') {
            setTimeout(tryConnect, 100);
            return;
        }
        if (!gameserverConsole.connected) {
            console.log('[Console] Starte persistente Verbindung...');
            gameserverConsole.connect();
        }
    }
    setTimeout(tryConnect, 100);

    // ── Tab-shown: nur fitAddon neu berechnen (kein Re-Connect!) ───────────
    const consoleTab = document.getElementById('console-tab');
    if (consoleTab) {
        consoleTab.addEventListener('shown.bs.tab', function() {
            setTimeout(function() {
                try {
                    if (gameserverConsole?.fitAddon) gameserverConsole.fitAddon.fit();
                    if (gameserverConsole?.terminal) {
                        gameserverConsole.terminal.refresh(0, gameserverConsole.terminal.rows - 1);
                        gameserverConsole.terminal.scrollToBottom();
                    }
                } catch(e) {}
            }, 50);
        });
    }

    // ── Page Unload: sauber trennen ────────────────────────────────────────
    window.addEventListener('beforeunload', function() {
        if (gameserverConsole?.connected) {
            gameserverConsole.disconnect();
        }
    });
});
</script>

