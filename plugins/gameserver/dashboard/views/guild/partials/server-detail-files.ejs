<%# 
  * Server-Detail Files-Tab
  * File-Manager mit Multi-Select, Monaco Editor, Upload
  * @author FireBot Team
  %>

<!-- File-Manager Container -->
<div id="file-manager-container">
    <!-- Permissions-Check -->
    <% const canView = userPermissions.permissions['GAMESERVER.FILES.VIEW']; %>
    <% const canManage = userPermissions.permissions['GAMESERVER.FILES.MANAGE']; %>
    
    <% if (!canView) { %>
        <!-- Keine Berechtigung -->
        <div class="alert alert-danger">
            <i class="fas fa-lock me-2"></i>
            <strong>Keine Berechtigung:</strong> Du benötigst <code>GAMESERVER.FILES.VIEW</code> um Dateien anzusehen.
        </div>
    <% } else { %>
        
        <!-- Toolbar -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <!-- Breadcrumbs -->
                    <div class="col-md-6">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0" id="file-breadcrumbs">
                                <li class="breadcrumb-item">
                                    <a href="#" data-path="/" onclick="fileManager.navigateTo('/'); return false;">
                                        <i class="fas fa-home"></i> Root
                                    </a>
                                </li>
                                <!-- Dynamisch gefüllt via JS -->
                            </ol>
                        </nav>
                    </div>
                    
                    <!-- Actions -->
                    <div class="col-md-6 text-end">
                        <% if (canManage) { %>
                            <button class="btn btn-sm btn-primary" onclick="fileManager.showNewFolderModal()">
                                <i class="fas fa-folder-plus me-1"></i> Neuer Ordner
                            </button>
                            <button class="btn btn-sm btn-success" onclick="fileManager.showUploadModal()">
                                <i class="fas fa-upload me-1"></i> Hochladen
                            </button>
                        <% } %>
                        <button class="btn btn-sm btn-secondary" onclick="fileManager.reload()">
                            <i class="fas fa-sync-alt me-1"></i> Aktualisieren
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Multi-Select Toolbar (hidden by default) -->
        <div id="bulk-actions-toolbar" class="alert alert-info mb-3" style="display: none;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-check-square me-2"></i>
                    <strong><span id="selected-count">0</span> ausgewählt</strong>
                </div>
                <div>
                    <% if (canManage) { %>
                        <button class="btn btn-sm btn-warning me-2" onclick="fileManager.showBulkMoveModal()">
                            <i class="fas fa-arrows-alt me-1"></i> Verschieben
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="fileManager.confirmBulkDelete()">
                            <i class="fas fa-trash me-1"></i> Löschen
                        </button>
                    <% } %>
                    <button class="btn btn-sm btn-secondary" onclick="fileManager.clearSelection()">
                        <i class="fas fa-times me-1"></i> Abbrechen
                    </button>
                </div>
            </div>
        </div>
        
        <!-- File-Liste -->
        <div class="card">
            <div class="card-body">
                <!-- Loading Spinner -->
                <div id="files-loading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Laden...</span>
                    </div>
                    <p class="mt-2 text-muted">Dateien werden geladen...</p>
                </div>
                
                <!-- Datei-Tabelle -->
                <div id="files-table-container" style="display: none;">
                    <table class="table table-hover table-sm">
                        <thead>
                            <tr>
                                <th style="width: 40px;">
                                    <% if (canManage) { %>
                                        <input type="checkbox" 
                                               id="select-all-checkbox" 
                                               class="form-check-input"
                                               onchange="fileManager.toggleSelectAll(this.checked)">
                                    <% } %>
                                </th>
                                <th>Name</th>
                                <th style="width: 120px;">Größe</th>
                                <th style="width: 200px;">Geändert</th>
                                <th style="width: 150px;" class="text-end">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="files-tbody">
                            <!-- Dynamisch gefüllt via JS -->
                        </tbody>
                    </table>
                </div>
                
                <!-- Empty State -->
                <div id="files-empty" class="text-center py-5" style="display: none;">
                    <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Dieser Ordner ist leer</p>
                </div>
                
                <!-- Error State -->
                <div id="files-error" class="alert alert-danger" style="display: none;">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Fehler:</strong> <span id="files-error-message"></span>
                </div>
            </div>
        </div>
        
    <% } %>
</div>

<!-- ════════════════════════════════════════════════════════════════════════════ -->
<!-- MODALS -->
<!-- ════════════════════════════════════════════════════════════════════════════ -->

<!-- Monaco Editor Modal -->
<div class="modal fade" id="editor-modal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-fullscreen-lg-down">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit me-2"></i>
                    <span id="editor-file-name">Datei bearbeiten</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <!-- Monaco Editor Container -->
                <div id="monaco-editor" style="height: 60vh; min-height: 400px;"></div>
            </div>
            <div class="modal-footer">
                <div class="me-auto text-muted small">
                    <i class="fas fa-keyboard me-1"></i>
                    Tipp: <kbd>Ctrl+S</kbd> zum Speichern
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Abbrechen
                </button>
                <% if (canManage) { %>
                    <button type="button" class="btn btn-primary" onclick="fileManager.saveFile()">
                        <i class="fas fa-save me-1"></i> Speichern
                    </button>
                <% } else { %>
                    <button type="button" class="btn btn-secondary" disabled>
                        <i class="fas fa-lock me-1"></i> Nur-Lesen
                    </button>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- New Folder Modal -->
<% if (canManage) { %>
<div class="modal fade" id="new-folder-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-folder-plus me-2"></i>
                    Neuer Ordner
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="new-folder-form" onsubmit="fileManager.createFolder(); return false;">
                    <div class="mb-3">
                        <label for="new-folder-name" class="form-label">Ordnername</label>
                        <input type="text" 
                               class="form-control" 
                               id="new-folder-name" 
                               placeholder="z.B. configs"
                               pattern="[a-zA-Z0-9_\-]+"
                               required>
                        <div class="form-text">
                            Nur Buchstaben, Zahlen, Unterstrich und Bindestrich erlaubt
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" onclick="fileManager.createFolder()">
                    <i class="fas fa-check me-1"></i> Erstellen
                </button>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Upload Modal -->
<% if (canManage) { %>
<div class="modal fade" id="upload-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-upload me-2"></i>
                    Dateien hochladen
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Limit:</strong> Max. 500 MB pro Datei
                </div>
                
                <!-- Drag & Drop Zone -->
                <div id="upload-dropzone" class="border border-2 border-dashed rounded text-center p-5 mb-3"
                     ondrop="fileManager.handleDrop(event)" 
                     ondragover="fileManager.handleDragOver(event)"
                     ondragleave="fileManager.handleDragLeave(event)">
                    <i class="fas fa-cloud-upload-alt fa-3x text-muted mb-3"></i>
                    <p class="mb-2">Dateien hierher ziehen</p>
                    <p class="text-muted small">oder</p>
                    <input type="file" id="file-input" multiple style="display: none;" onchange="fileManager.handleFileSelect(event)">
                    <button type="button" class="btn btn-primary" onclick="document.getElementById('file-input').click()">
                        <i class="fas fa-folder-open me-1"></i> Dateien auswählen
                    </button>
                </div>
                
                <!-- Upload-Queue -->
                <div id="upload-queue" style="display: none;">
                    <h6>Upload-Queue:</h6>
                    <ul class="list-group" id="upload-queue-list">
                        <!-- Dynamisch gefüllt -->
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" id="start-upload-btn" onclick="fileManager.startUpload()" disabled>
                    <i class="fas fa-upload me-1"></i> Hochladen
                </button>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Rename Modal -->
<% if (canManage) { %>
<div class="modal fade" id="rename-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit me-2"></i>
                    Umbenennen
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="rename-form" onsubmit="fileManager.renameFile(); return false;">
                    <div class="mb-3">
                        <label for="rename-new-name" class="form-label">Neuer Name</label>
                        <input type="text" 
                               class="form-control" 
                               id="rename-new-name"
                               required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" onclick="fileManager.renameFile()">
                    <i class="fas fa-check me-1"></i> Umbenennen
                </button>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Bulk Move Modal -->
<% if (canManage) { %>
<div class="modal fade" id="bulk-move-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-arrows-alt me-2"></i>
                    Dateien verschieben
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Ziel-Ordner auswählen:</p>
                <select class="form-select" id="bulk-move-target" size="8">
                    <option value="/">/</option>
                    <!-- Dynamisch gefüllt mit Ordnern -->
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" onclick="fileManager.bulkMove()">
                    <i class="fas fa-check me-1"></i> Verschieben
                </button>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Confirmation Modal (für Delete) -->
<div class="modal fade" id="confirm-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <span id="confirm-title">Bestätigung erforderlich</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirm-message">Bist du sicher?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong>Warnung:</strong> Diese Aktion kann nicht rückgängig gemacht werden!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-danger" id="confirm-action-btn">
                    <i class="fas fa-check me-1"></i> Bestätigen
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════════════════════════ -->
<!-- CONTEXT MENU -->
<!-- ════════════════════════════════════════════════════════════════════════════ -->

<div id="context-menu" class="dropdown-menu" style="display: none; position: absolute; z-index: 9999;">
    <% if (canManage) { %>
        <a class="dropdown-item" href="#" onclick="fileManager.contextMenuAction('edit'); return false;">
            <i class="fas fa-edit me-2"></i> Bearbeiten
        </a>
        <a class="dropdown-item" href="#" onclick="fileManager.contextMenuAction('rename'); return false;">
            <i class="fas fa-i-cursor me-2"></i> Umbenennen
        </a>
        <div class="dropdown-divider"></div>
    <% } %>
    <a class="dropdown-item" href="#" onclick="fileManager.contextMenuAction('download'); return false;">
        <i class="fas fa-download me-2"></i> Herunterladen
    </a>
    <% if (canManage) { %>
        <div class="dropdown-divider"></div>
        <a class="dropdown-item text-danger" href="#" onclick="fileManager.contextMenuAction('delete'); return false;">
            <i class="fas fa-trash me-2"></i> Löschen
        </a>
    <% } %>
</div>

<!-- ════════════════════════════════════════════════════════════════════════════ -->
<!-- ASSETS & INITIALIZATION -->
<!-- ════════════════════════════════════════════════════════════════════════════ -->

<!-- Monaco Editor Assets -->
<% if (locals.assetManager) { %>
    <% assetManager.enqueueScript('monaco-loader'); %>
    <% assetManager.enqueueScript('gameserver-file-manager'); %>
<% } %>

<script>
// Globale Config für file-manager.js
window.FILE_MANAGER_CONFIG = {
    serverId: '<%= server.id %>',
    guildId: '<%= guildId %>',
    serverName: '<%= server.name %>',
    baseUrl: '/guild/<%= guildId %>/plugins/gameserver',
    permissions: {
        canView: <%= canView ? 'true' : 'false' %>,
        canManage: <%= canManage ? 'true' : 'false' %>
    }
};
</script>
