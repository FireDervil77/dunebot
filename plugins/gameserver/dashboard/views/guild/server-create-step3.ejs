<!-- Gameserver Server-Erstellungs-Wizard - Step 3: Resources & Finalization -->
<div class="app-content">
  <div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>"><i class="fa-solid fa-home"></i> <%= tr('core:NAV.DASHBOARD') %></a>
        </li>
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>/plugins/gameserver"><%= tr('gameserver:NAV.GAMESERVER') %></a>
        </li>
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>/plugins/gameserver/servers"><%= tr('gameserver:NAV.SERVERS') %></a>
        </li>
        <li class="breadcrumb-item active" aria-current="page"><%= tr('gameserver:SERVER.CREATE') %></li>
      </ol>
    </nav>

    <!-- Wizard Progress -->
    <div class="row text-center mb-4">
      <div class="col-md-4">
        <div class="progress-step completed">
          <div class="progress-circle bg-success text-white">
            <i class="fa-solid fa-check"></i>
          </div>
          <div class="text-muted">1. Information</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="progress-step completed">
          <div class="progress-circle bg-success text-white">
            <i class="fa-solid fa-check"></i>
          </div>
          <div class="text-muted">2. Egg Configuration</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="progress-step active">
          <div class="progress-circle bg-primary text-white">
            <strong>3</strong>
          </div>
          <div><strong>3. Resources & Finalization</strong></div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="row">
      <div class="col-lg-8">
        <!-- Form Start -->
        <form id="serverCreateForm" method="POST" action="/guild/<%= guildId %>/plugins/gameserver/servers">
          
          <!-- ✅ Hidden Fields für Step 1 & 2 Daten -->
          <input type="hidden" id="hiddenServerName" name="server_name" value="">
          <input type="hidden" id="hiddenRootserverId" name="rootserver_id" value="">
          <input type="hidden" id="hiddenRunInstall" name="run_install" value="">
          <input type="hidden" id="hiddenStartAfter" name="start_after" value="">
          <input type="hidden" name="addon_slug" value="<%= addon.slug %>">
          
          <!-- Resource Limits -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fa-solid fa-gauge-high mr-2"></i>
                <%= tr('gameserver:SERVER.RESOURCE_LIMITS') || 'Resource Limits' %>
              </h5>
            </div>
            <div class="card-body">
              <!-- Memory Limit -->
              <div class="form-group mb-4">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-memory mr-2 text-info"></i>Memory</span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="ram" data-value="unlimited">Unlimited</button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="ram" data-value="limited">Limited</button>
                  </div>
                </label>
                <div id="ramLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_ram_mb" id="allocated_ram_mb" min="512" step="512" placeholder="2048">
                    <div class="input-group-append">
                      <span class="input-group-text">MiB</span>
                    </div>
                  </div>
                  <small class="form-text text-muted">Minimum: 512 MiB | Empfohlen: 2048 MiB+</small>
                </div>
              </div>

              <!-- CPU Limit -->
              <div class="form-group mb-4">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-microchip mr-2 text-primary"></i>CPU</span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="cpu" data-value="unlimited">Unlimited</button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="cpu" data-value="limited">Limited</button>
                  </div>
                </label>
                <div id="cpuLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_cpu_percent" id="allocated_cpu_percent" min="10" max="100" step="5" placeholder="100">
                    <div class="input-group-append">
                      <span class="input-group-text">%</span>
                    </div>
                  </div>
                  <small class="form-text text-muted">10% = 0.1 Core | 100% = 1 Core | 200% = 2 Cores</small>
                </div>
              </div>

              <!-- Disk Limit -->
              <div class="form-group mb-0">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-hdd mr-2 text-warning"></i>Disk Space</span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="disk" data-value="unlimited">Unlimited</button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="disk" data-value="limited">Limited</button>
                  </div>
                </label>
                <div id="diskLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_disk_gb" id="allocated_disk_gb" min="5" step="5" placeholder="50">
                    <div class="input-group-append">
                      <span class="input-group-text">GiB</span>
                    </div>
                  </div>
                  <small class="form-text text-muted">Minimum: 5 GiB | Empfohlen: 50+ GiB (je nach Spiel)</small>
                </div>
              </div>
            </div>
          </div>

          <!-- SFTP Access (Vorbereitet für später) -->
          <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="mb-0">
                <i class="fa-solid fa-folder-tree mr-2"></i>
                <%= tr('gameserver:SERVER.SFTP_ACCESS') || 'SFTP File Access' %>
              </h5>
              <span class="badge badge-warning">Coming Soon</span>
            </div>
            <div class="card-body">
              <div class="alert alert-info mb-0">
                <i class="fa-solid fa-info-circle mr-2"></i>
                <strong>SFTP-Zugriff wird nach der Server-Erstellung automatisch eingerichtet.</strong><br>
                <small>Du erhältst Username, Passwort und Port nach der Installation.</small>
              </div>
              <!-- 
              SPÄTER: 
              - SFTP Username (auto-generated)
              - SFTP Password (auto-generated mit option to customize)
              - SFTP Port (auto-assigned oder manual)
              -->
            </div>
          </div>

          <!-- Advanced Settings -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fa-solid fa-sliders mr-2"></i>
                <%= tr('gameserver:SERVER.ADVANCED_SETTINGS') || 'Advanced Settings' %>
              </h5>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="auto_restart">
                    <i class="fa-solid fa-rotate mr-2 text-success"></i>
                    <%= tr('gameserver:SERVER.AUTO_RESTART') || 'Auto-Restart on Crash' %>
                  </label>
                  <select class="form-control" id="auto_restart" name="auto_restart">
                    <option value="1" selected>Enabled</option>
                    <option value="0">Disabled</option>
                  </select>
                  <small class="form-text text-muted">
                    <%= tr('gameserver:SERVER.AUTO_RESTART_HELP') || 'Server startet automatisch neu bei Absturz' %>
                  </small>
                </div>
                <div class="col-md-6 mb-3">
                  <label for="auto_update">
                    <i class="fa-solid fa-download mr-2 text-info"></i>
                    <%= tr('gameserver:SERVER.AUTO_UPDATE') || 'Auto-Update' %>
                  </label>
                  <select class="form-control" id="auto_update" name="auto_update">
                    <option value="0" selected>Disabled</option>
                    <option value="1">Enabled</option>
                  </select>
                  <small class="form-text text-muted">
                    <%= tr('gameserver:SERVER.AUTO_UPDATE_HELP') || 'Server-Dateien automatisch aktualisieren' %>
                  </small>
                </div>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <button type="button" id="btnBack" class="btn btn-secondary">
                  <i class="fa-solid fa-arrow-left mr-2"></i>
                  <%= tr('gameserver:SERVER.BACK') || 'Zurück' %>
                </button>
                <button type="submit" id="btnCreate" class="btn btn-success btn-lg">
                  <i class="fa-solid fa-rocket mr-2"></i>
                  <%= tr('gameserver:SERVER.CREATE_SERVER') || 'Server erstellen' %>
                </button>
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Right Sidebar: Summary -->
      <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
          <div class="card-header bg-success text-white">
            <h6 class="mb-0">
              <i class="fa-solid fa-clipboard-check mr-2"></i>
              <%= tr('gameserver:SERVER.SUMMARY') || 'Configuration Summary' %>
            </h6>
          </div>
          <div class="card-body">
            <!-- From Step 1 -->
            <h6 class="text-muted mb-2">Step 1: Information</h6>
            <ul class="list-unstyled mb-3">
              <li><strong>Server Name:</strong> <span id="summaryServerName">-</span></li>
              <li><strong>Addon:</strong> <%= addon.name %></li>
              <li><strong>Rootserver:</strong> <span id="summaryRootserver">-</span></li>
              <li><strong>Install Script:</strong> <span id="summaryInstall">-</span></li>
              <li><strong>Auto-Start:</strong> <span id="summaryAutoStart">-</span></li>
            </ul>
            <hr>
            
            <!-- From Step 2 -->
            <h6 class="text-muted mb-2">Step 2: Variables</h6>
            <ul class="list-unstyled mb-3" id="summaryVariables">
              <li class="text-muted"><em>Keine Variablen konfiguriert</em></li>
            </ul>
            <hr>
            
            <!-- From Step 3 -->
            <h6 class="text-muted mb-2">Step 3: Resources</h6>
            <ul class="list-unstyled mb-0">
              <li><strong>RAM:</strong> <span id="summaryRam">Unlimited</span></li>
              <li><strong>CPU:</strong> <span id="summaryCpu">Unlimited</span></li>
              <li><strong>Disk:</strong> <span id="summaryDisk">Unlimited</span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
.progress-step {
    padding: 20px 0;
}

.progress-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 10px;
}

.progress-step.active .progress-circle {
    box-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
}

.progress-step.completed .progress-circle {
    box-shadow: 0 0 10px rgba(40, 167, 69, 0.5);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const guildId = '<%= guildId %>';
    const urlParams = new URLSearchParams(window.location.search);
    
    // ========================================
    // RESOURCE LIMIT TOGGLES
    // ========================================
    document.querySelectorAll('[data-toggle-limit]').forEach(button => {
        button.addEventListener('click', function() {
            const limitType = this.dataset.toggleLimit; // ram, cpu, disk
            const value = this.dataset.value; // unlimited, limited
            
            // Toggle active state
            this.parentElement.querySelectorAll('button').forEach(btn => {
                btn.classList.remove('active');
            });
            this.classList.add('active');
            
            // Show/Hide input
            const inputDiv = document.getElementById(`${limitType}LimitInput`);
            const inputField = document.getElementById(`allocated_${limitType === 'cpu' ? 'cpu_percent' : limitType === 'ram' ? 'ram_mb' : 'disk_gb'}`);
            
            if (value === 'limited') {
                inputDiv.style.display = 'block';
                inputField.required = true;
            } else {
                inputDiv.style.display = 'none';
                inputField.required = false;
                inputField.value = '';
            }
            
            updateSummary();
        });
    });
    
    // Live-Update Summary
    function updateSummary() {
        // RAM
        const ramInput = document.getElementById('allocated_ram_mb');
        const ramValue = ramInput.value ? `${ramInput.value} MiB` : 'Unlimited';
        document.getElementById('summaryRam').textContent = ramValue;
        
        // CPU
        const cpuInput = document.getElementById('allocated_cpu_percent');
        const cpuValue = cpuInput.value ? `${cpuInput.value}%` : 'Unlimited';
        document.getElementById('summaryCpu').textContent = cpuValue;
        
        // Disk
        const diskInput = document.getElementById('allocated_disk_gb');
        const diskValue = diskInput.value ? `${diskInput.value} GiB` : 'Unlimited';
        document.getElementById('summaryDisk').textContent = diskValue;
    }
    
    // Input-Änderungen → Summary aktualisieren
    ['allocated_ram_mb', 'allocated_cpu_percent', 'allocated_disk_gb'].forEach(id => {
        const input = document.getElementById(id);
        if (input) {
            input.addEventListener('input', updateSummary);
        }
    });
    
    // ========================================
    // SUMMARY FROM URL PARAMS (Step 1 + 2)
    // ========================================
    
    // Step 1 Data aus URL-Params extrahieren
    const serverName = urlParams.get('server_name') || '-';
    const rootserverId = urlParams.get('rootserver') || '-';
    const runInstall = urlParams.get('run_install') === 'true';
    const startAfter = urlParams.get('start_after') === 'true';
    
    // ✅ Hidden Fields füllen (für Form-Submit)
    document.getElementById('hiddenRunInstall').value = runInstall ? 'true' : 'false';
    document.getElementById('hiddenStartAfter').value = startAfter ? 'true' : 'false';
    document.getElementById('hiddenRootserverId').value = rootserverId;
    document.getElementById('hiddenServerName').value = serverName;
    
    // Summary anzeigen
    document.getElementById('summaryServerName').textContent = serverName;
    document.getElementById('summaryRootserver').textContent = `ID: ${rootserverId}`;
    document.getElementById('summaryInstall').textContent = runInstall ? 'Yes' : 'Skip';
    document.getElementById('summaryAutoStart').textContent = startAfter ? 'Yes' : 'No';
    
    // Step 2 Variables
    const variablesList = document.getElementById('summaryVariables');
    variablesList.innerHTML = ''; // Clear
    
    let hasVariables = false;
    urlParams.forEach((value, key) => {
        if (key.startsWith('variable_')) {
            hasVariables = true;
            const varName = key.replace('variable_', '');
            const li = document.createElement('li');
            li.innerHTML = `<strong>${varName}:</strong> ${value}`;
            variablesList.appendChild(li);
        }
    });
    
    if (!hasVariables) {
        variablesList.innerHTML = '<li class="text-muted"><em>Keine Variablen</em></li>';
    }
    
    // ========================================
    // BACK BUTTON
    // ========================================
    document.getElementById('btnBack').addEventListener('click', function() {
        const params = new URLSearchParams(window.location.search);
        params.set('step', '2');
        window.location.href = `/guild/${guildId}/plugins/gameserver/servers/create?${params.toString()}`;
    });
    
    // ========================================
    // FORM SUBMIT (via AJAX mit Toast + Redirect)
    // ========================================
    document.getElementById('serverCreateForm').addEventListener('submit', async function(e) {
        e.preventDefault(); // ← Verhindere normalen Form-Submit!
        
        const form = this;
        const submitBtn = form.querySelector('button[type="submit"]');
        
        // Button disablen + Spinner
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Erstelle Server...';
        
        try {
            // ✅ JSON-Payload aus Form-Daten + URL-Params
            const formData = new FormData(form);
            const payload = {};
            
            // Form-Felder (Hidden + Visible)
            formData.forEach((value, key) => {
                payload[key] = value;
            });
            
            // Step 2 Variables aus URL-Params hinzufügen
            urlParams.forEach((value, key) => {
                if (key.startsWith('variable_')) {
                    payload[key] = value;
                }
            });
            
            console.log('[Step3] Submitting via AJAX...', payload);
            
            // AJAX Request mit JSON
            const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.success) {
                // ✅ Success Toast
                toastr.success(result.message || 'Server wird erstellt...');
                
                // Redirect nach 1,5s
                setTimeout(() => {
                    if (result.redirectUrl) {
                        window.location.href = result.redirectUrl;
                    } else {
                        window.location.href = '/guild/<%= guildId %>/plugins/gameserver/servers';
                    }
                }, 1500);
            } else {
                // ❌ Error Toast
                toastr.error(result.message || 'Fehler beim Erstellen des Servers');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
            
        } catch (error) {
            console.error('[Step3] Submit error:', error);
            toastr.error('Netzwerkfehler beim Erstellen des Servers');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
    
    // Initial Summary
    updateSummary();
});
</script>