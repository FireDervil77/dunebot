<!-- Gameserver Server-Erstellungs-Wizard - Step 3: Resources & Finalization -->
<div class="app-content">
  <div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>"><i class="fa-solid fa-home"></i> <%= tr('core:NAV.DASHBOARD') %></a>
        </li>
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>/plugins/gameserver"><%= tr('gameserver:NAV.GAMESERVER') %></a>
        </li>
        <li class="breadcrumb-item">
          <a href="/guild/<%= guildId %>/plugins/gameserver/servers"><%= tr('gameserver:NAV.SERVERS') %></a>
        </li>
        <li class="breadcrumb-item active" aria-current="page"><%= tr('gameserver:SERVER.CREATE') %></li>
      </ol>
    </nav>

    <!-- Wizard Progress -->
    <div class="row text-center mb-4">
      <div class="col-md-4">
        <div class="progress-step completed">
          <div class="progress-circle bg-success text-white">
            <i class="fa-solid fa-check"></i>
          </div>
          <div class="text-muted"><%= tr('gameserver:SERVER.STEP1_LABEL') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="progress-step completed">
          <div class="progress-circle bg-success text-white">
            <i class="fa-solid fa-check"></i>
          </div>
          <div class="text-muted"><%= tr('gameserver:SERVER.STEP2_LABEL_EGG') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="progress-step active">
          <div class="progress-circle bg-primary text-white">
            <strong>3</strong>
          </div>
          <div><strong><%= tr('gameserver:SERVER.STEP3_LABEL_FINAL') %></strong></div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="row">
      <div class="col-lg-8">
        <!-- Form Start -->
        <form id="serverCreateForm" method="POST" action="/guild/<%= guildId %>/plugins/gameserver/servers">
          
          <!-- ✅ Hidden Fields für Step 1 & 2 Daten -->
          <input type="hidden" id="hiddenServerName" name="server_name" value="">
          <input type="hidden" id="hiddenRootserverId" name="rootserver_id" value="">
          <input type="hidden" id="hiddenRunInstall" name="run_install" value="">
          <input type="hidden" id="hiddenStartAfter" name="start_after" value="">
          <input type="hidden" name="addon_slug" value="<%= addon.slug %>">
          
          <!-- Port-Auswahl -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fa-solid fa-network-wired mr-2"></i>
                <%= tr('gameserver:SERVER.PORT_CONFIG') %>
              </h5>
            </div>
            <div class="card-body">
              <div class="form-group mb-0">
                <label for="game_port">
                  <i class="fa-solid fa-plug mr-1 text-primary"></i><%= tr('gameserver:SERVER.GAME_PORT') %>
                </label>
                <div class="input-group">
                  <select class="form-control" id="game_port" name="game_port">
                    <option value="auto"><%= tr('gameserver:SERVER.PORT_AUTO') %></option>
                  </select>
                  <div class="input-group-append">
                    <button type="button" class="btn btn-outline-secondary" id="toggleManualPort" title="<%= tr('gameserver:SERVER.PORT_MANUAL_TITLE') %>">
                      <i class="fa-solid fa-keyboard"></i>
                    </button>
                  </div>
                </div>
                <div id="manualPortInput" style="display:none;" class="mt-2">
                  <div class="input-group">
                    <input type="number" class="form-control" id="game_port_manual" min="1024" max="65535" placeholder="<%= tr('gameserver:SERVER.PORT_MANUAL_PLACEHOLDER') %>">
                    <div class="input-group-append">
                        <button type="button" class="btn btn-outline-primary" id="useManualPort"><%= tr('gameserver:SERVER.PORT_MANUAL_APPLY') %></button>
                    </div>
                  </div>
                  <small class="form-text text-muted"><%= tr('gameserver:SERVER.PORT_POOL_HELP') %></small>
                </div>
                <small class="form-text text-muted" id="portPoolInfo"><i class="fa-solid fa-spinner fa-spin mr-1"></i><%= tr('gameserver:SERVER.PORT_LOADING') %></small>
              </div>
            </div>
          </div>

          <!-- Resource Limits -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fa-solid fa-gauge-high mr-2"></i>
                <%= tr('gameserver:SERVER.RESOURCE_LIMITS') %>
              </h5>
            </div>
            <div class="card-body">
              <!-- Memory Limit -->
              <div class="form-group mb-4">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-memory mr-2 text-info"></i><%= tr('gameserver:SERVER.MEMORY') %></span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="ram" data-value="unlimited"><%= tr('gameserver:SERVER.UNLIMITED') %></button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="ram" data-value="limited"><%= tr('gameserver:SERVER.LIMITED') %></button>
                  </div>
                </label>
                <div id="ramLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_ram_mb" id="allocated_ram_mb" min="512" step="512" placeholder="2048">
                    <div class="input-group-append">
                      <span class="input-group-text">MiB</span>
                    </div>
                  </div>
                  <small class="form-text text-muted"><%= tr('gameserver:SERVER.RAM_HELP') %></small>
                </div>
              </div>

              <!-- CPU Limit -->
              <div class="form-group mb-4">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-microchip mr-2 text-primary"></i><%= tr('gameserver:SERVER.CPU_LABEL') %></span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="cpu" data-value="unlimited"><%= tr('gameserver:SERVER.UNLIMITED') %></button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="cpu" data-value="limited"><%= tr('gameserver:SERVER.LIMITED') %></button>
                  </div>
                </label>
                <div id="cpuLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_cpu_percent" id="allocated_cpu_percent" min="10" max="100" step="5" placeholder="100">
                    <div class="input-group-append">
                      <span class="input-group-text">%</span>
                    </div>
                  </div>
                  <small class="form-text text-muted"><%= tr('gameserver:SERVER.CPU_HELP') %></small>
                </div>
              </div>

              <!-- Disk Limit -->
              <div class="form-group mb-0">
                <label class="d-flex justify-content-between align-items-center">
                  <span><i class="fa-solid fa-hdd mr-2 text-warning"></i><%= tr('gameserver:SERVER.DISK_SPACE') %></span>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-toggle-limit="disk" data-value="unlimited"><%= tr('gameserver:SERVER.UNLIMITED') %></button>
                    <button type="button" class="btn btn-outline-secondary" data-toggle-limit="disk" data-value="limited"><%= tr('gameserver:SERVER.LIMITED') %></button>
                  </div>
                </label>
                <div id="diskLimitInput" style="display: none;">
                  <div class="input-group">
                    <input type="number" class="form-control" name="allocated_disk_gb" id="allocated_disk_gb" min="5" step="5" placeholder="50">
                    <div class="input-group-append">
                      <span class="input-group-text">GiB</span>
                    </div>
                  </div>
                  <small class="form-text text-muted"><%= tr('gameserver:SERVER.DISK_HELP') %></small>
                </div>
              </div>
            </div>
          </div>

          <!-- SFTP Access (Vorbereitet für später) -->
          <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="mb-0">
                <i class="fa-solid fa-folder-tree mr-2"></i>
                <%= tr('gameserver:SERVER.SFTP_ACCESS') %>
              </h5>
              <span class="badge badge-warning"><%= tr('gameserver:SERVER.COMING_SOON') %></span>
            </div>
            <div class="card-body">
              <div class="alert alert-info mb-0">
                <i class="fa-solid fa-info-circle mr-2"></i>
                <strong><%= tr('gameserver:SERVER.SFTP_INFO') %></strong><br>
                <small><%= tr('gameserver:SERVER.SFTP_INFO_DETAIL') %></small>
              </div>
              <!-- 
              SPÄTER: 
              - SFTP Username (auto-generated)
              - SFTP Password (auto-generated mit option to customize)
              - SFTP Port (auto-assigned oder manual)
              -->
            </div>
          </div>

          <!-- Advanced Settings -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fa-solid fa-sliders mr-2"></i>
                <%= tr('gameserver:SERVER.ADVANCED_SETTINGS') %>
              </h5>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="auto_restart">
                    <i class="fa-solid fa-rotate mr-2 text-success"></i>
                    <%= tr('gameserver:SERVER.AUTO_RESTART') %>
                  </label>
                  <select class="form-control" id="auto_restart" name="auto_restart">
                    <option value="1" selected><%= tr('gameserver:SERVER.ENABLED') %></option>
                    <option value="0"><%= tr('gameserver:SERVER.DISABLED') %></option>
                  </select>
                  <small class="form-text text-muted">
                    <%= tr('gameserver:SERVER.AUTO_RESTART_HELP') %>
                  </small>
                </div>
                <div class="col-md-6 mb-3">
                  <label for="auto_update">
                    <i class="fa-solid fa-download mr-2 text-info"></i>
                    <%= tr('gameserver:SERVER.AUTO_UPDATE') %>
                  </label>
                  <select class="form-control" id="auto_update" name="auto_update">
                    <option value="0" selected><%= tr('gameserver:SERVER.DISABLED') %></option>
                    <option value="1"><%= tr('gameserver:SERVER.ENABLED') %></option>
                  </select>
                  <small class="form-text text-muted">
                    <%= tr('gameserver:SERVER.AUTO_UPDATE_HELP') %>
                  </small>
                </div>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <button type="button" id="btnBack" class="btn btn-secondary">
                  <i class="fa-solid fa-arrow-left mr-2"></i>
                  <%= tr('gameserver:SERVER.BACK') %>
                </button>
                <button type="submit" id="btnCreate" class="btn btn-success btn-lg">
                  <i class="fa-solid fa-rocket mr-2"></i>
                  <%= tr('gameserver:SERVER.CREATE_SERVER') %>
                </button>
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Right Sidebar: Summary -->
      <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
          <div class="card-header bg-success text-white">
            <h6 class="mb-0">
              <i class="fa-solid fa-clipboard-check mr-2"></i>
              <%= tr('gameserver:SERVER.SUMMARY') %>
            </h6>
          </div>
          <div class="card-body">
            <!-- From Step 1 -->
            <h6 class="text-muted mb-2"><%= tr('gameserver:SERVER.SUMMARY_STEP1') %></h6>
            <ul class="list-unstyled mb-3">
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_SERVER_NAME') %></strong> <span id="summaryServerName">-</span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_ADDON') %></strong> <%= addon.name %></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_ROOTSERVER') %></strong> <span id="summaryRootserver">-</span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_INSTALL_SCRIPT') %></strong> <span id="summaryInstall">-</span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_AUTO_START') %></strong> <span id="summaryAutoStart">-</span></li>
            </ul>
            <hr>
            
            <!-- From Step 2 -->
            <h6 class="text-muted mb-2"><%= tr('gameserver:SERVER.SUMMARY_STEP2') %></h6>
            <ul class="list-unstyled mb-3" id="summaryVariables">
              <li class="text-muted"><em><%= tr('gameserver:SERVER.SUMMARY_NO_VARIABLES') %></em></li>
            </ul>
            <hr>
            
            <!-- From Step 3 -->
            <h6 class="text-muted mb-2"><%= tr('gameserver:SERVER.SUMMARY_STEP3') %></h6>
            <ul class="list-unstyled mb-0">
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_PORT') %></strong> <span id="summaryPort">Auto</span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_RAM') %></strong> <span id="summaryRam"><%= tr('gameserver:SERVER.UNLIMITED') %></span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_CPU') %></strong> <span id="summaryCpu"><%= tr('gameserver:SERVER.UNLIMITED') %></span></li>
              <li><strong><%= tr('gameserver:SERVER.SUMMARY_DISK') %></strong> <span id="summaryDisk"><%= tr('gameserver:SERVER.UNLIMITED') %></span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
.progress-step {
    padding: 20px 0;
}

.progress-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 10px;
}

.progress-step.active .progress-circle {
    box-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
}

.progress-step.completed .progress-circle {
    box-shadow: 0 0 10px rgba(40, 167, 69, 0.5);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const guildId = '<%= guildId %>';
    const urlParams = new URLSearchParams(window.location.search);
    
    // ========================================
    // I18N TRANSLATIONS FOR JS
    // ========================================
    const i18n = {
        unlimited: '<%= tr("gameserver:SERVER.UNLIMITED") %>',
        creatingServer: '<%= tr("gameserver:SERVER.CREATING_SERVER") %>',
        serverCreatedMsg: '<%= tr("gameserver:SERVER.SERVER_CREATED_MSG") %>',
        errorCreatingServer: '<%= tr("gameserver:SERVER.ERROR_CREATING_SERVER") %>',
        networkError: '<%= tr("gameserver:SERVER.NETWORK_ERROR") %>',
        noRootserverSelected: '<%= tr("gameserver:SERVER.NO_ROOTSERVER_SELECTED") %>',
        errorLoadingPorts: '<%= tr("gameserver:SERVER.ERROR_LOADING_PORTS") %>',
        noFreePorts: '<%= tr("gameserver:SERVER.NO_FREE_PORTS") %>',
        moreFreePorts: '<%= tr("gameserver:SERVER.MORE_FREE_PORTS") %>',
        freePortsAvailable: '<%= tr("gameserver:SERVER.FREE_PORTS_AVAILABLE") %>',
        portsAssigned: '<%= tr("gameserver:SERVER.PORTS_ASSIGNED") %>',
        invalidPort: '<%= tr("gameserver:SERVER.INVALID_PORT") %>',
        portManualSuffix: '<%= tr("gameserver:SERVER.PORT_MANUAL_SUFFIX") %>',
        portAutoLabel: '<%= tr("gameserver:SERVER.PORT_AUTO_LABEL") %>',
        yes: '<%= tr("gameserver:SERVER.YES") %>',
        no: '<%= tr("gameserver:SERVER.NO") %>',
        skip: '<%= tr("gameserver:SERVER.SKIP") %>',
        noVariables: '<%= tr("gameserver:SERVER.NO_VARIABLES_SUMMARY") %>'
    };
    
    // ========================================
    // RESOURCE LIMIT TOGGLES
    // ========================================
    document.querySelectorAll('[data-toggle-limit]').forEach(button => {
        button.addEventListener('click', function() {
            const limitType = this.dataset.toggleLimit; // ram, cpu, disk
            const value = this.dataset.value; // unlimited, limited
            
            // Toggle active state
            this.parentElement.querySelectorAll('button').forEach(btn => {
                btn.classList.remove('active');
            });
            this.classList.add('active');
            
            // Show/Hide input
            const inputDiv = document.getElementById(`${limitType}LimitInput`);
            const inputField = document.getElementById(`allocated_${limitType === 'cpu' ? 'cpu_percent' : limitType === 'ram' ? 'ram_mb' : 'disk_gb'}`);
            
            if (value === 'limited') {
                inputDiv.style.display = 'block';
                inputField.required = true;
            } else {
                inputDiv.style.display = 'none';
                inputField.required = false;
                inputField.value = '';
            }
            
            updateSummary();
        });
    });
    
    // Live-Update Summary
    function updateSummary() {
        // RAM
        const ramInput = document.getElementById('allocated_ram_mb');
        const ramValue = ramInput.value ? `${ramInput.value} MiB` : i18n.unlimited;
        document.getElementById('summaryRam').textContent = ramValue;
        
        // CPU
        const cpuInput = document.getElementById('allocated_cpu_percent');
        const cpuValue = cpuInput.value ? `${cpuInput.value}%` : i18n.unlimited;
        document.getElementById('summaryCpu').textContent = cpuValue;
        
        // Disk
        const diskInput = document.getElementById('allocated_disk_gb');
        const diskValue = diskInput.value ? `${diskInput.value} GiB` : i18n.unlimited;
        document.getElementById('summaryDisk').textContent = diskValue;
    }
    
    // Input-Änderungen → Summary aktualisieren
    ['allocated_ram_mb', 'allocated_cpu_percent', 'allocated_disk_gb'].forEach(id => {
        const input = document.getElementById(id);
        if (input) {
            input.addEventListener('input', updateSummary);
        }
    });
    
    // ========================================
    // SUMMARY FROM URL PARAMS (Step 1 + 2)
    // ========================================
    
    // Step 1 Data aus URL-Params extrahieren
    const serverName = urlParams.get('server_name') || '-';
    const rootserverId = urlParams.get('rootserver') || '-';
    const runInstall = urlParams.get('run_install') === 'true';
    const startAfter = urlParams.get('start_after') === 'true';
    
    // ✅ Hidden Fields füllen (für Form-Submit)
    document.getElementById('hiddenRunInstall').value = runInstall ? 'true' : 'false';
    document.getElementById('hiddenStartAfter').value = startAfter ? 'true' : 'false';
    document.getElementById('hiddenRootserverId').value = rootserverId;
    document.getElementById('hiddenServerName').value = serverName;
    
    // Summary anzeigen
    document.getElementById('summaryServerName').textContent = serverName;
    document.getElementById('summaryRootserver').textContent = `ID: ${rootserverId}`;
    document.getElementById('summaryInstall').textContent = runInstall ? i18n.yes : i18n.skip;
    document.getElementById('summaryAutoStart').textContent = startAfter ? i18n.yes : i18n.no;
    
    // Step 2 Variables
    const variablesList = document.getElementById('summaryVariables');
    variablesList.innerHTML = ''; // Clear
    
    let hasVariables = false;
    urlParams.forEach((value, key) => {
        if (key.startsWith('variable_')) {
            hasVariables = true;
            const varName = key.replace('variable_', '');
            const li = document.createElement('li');
            li.innerHTML = `<strong>${varName}:</strong> ${value}`;
            variablesList.appendChild(li);
        }
    });
    
    if (!hasVariables) {
        variablesList.innerHTML = `<li class="text-muted"><em>${i18n.noVariables}</em></li>`;
    }
    
    // ========================================
    // BACK BUTTON
    // ========================================
    document.getElementById('btnBack').addEventListener('click', function() {
        const params = new URLSearchParams(window.location.search);
        params.set('step', '2');
        window.location.href = `/guild/${guildId}/plugins/gameserver/servers/create?${params.toString()}`;
    });
    
    // ========================================
    // FORM SUBMIT (via AJAX mit Toast + Redirect)
    // ========================================
    document.getElementById('serverCreateForm').addEventListener('submit', async function(e) {
        e.preventDefault(); // ← Verhindere normalen Form-Submit!
        
        const form = this;
        const submitBtn = form.querySelector('button[type="submit"]');
        
        // Button disablen + Spinner
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i> ${i18n.creatingServer}`;
        
        try {
            // ✅ JSON-Payload aus Form-Daten + URL-Params
            const formData = new FormData(form);
            const payload = {};
            
            // Form-Felder (Hidden + Visible)
            formData.forEach((value, key) => {
                payload[key] = value;
            });
            
            // Step 2 Variables aus URL-Params hinzufügen
            urlParams.forEach((value, key) => {
                if (key.startsWith('variable_')) {
                    payload[key] = value;
                }
            });
            
            console.log('[Step3] Submitting via AJAX...', payload);
            
            // AJAX Request mit JSON
            const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.success) {
                // ✅ Success Toast
                toastr.success(result.message || i18n.serverCreatedMsg);
                
                // Redirect nach 1,5s
                setTimeout(() => {
                    if (result.redirectUrl) {
                        window.location.href = result.redirectUrl;
                    } else {
                        window.location.href = '/guild/<%= guildId %>/plugins/gameserver/servers';
                    }
                }, 1500);
            } else {
                // ❌ Error Toast
                toastr.error(result.message || i18n.errorCreatingServer);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
            
        } catch (error) {
            console.error('[Step3] Submit error:', error);
            toastr.error(i18n.networkError);
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
    
    // ========================================
    // PORT-AUSWAHL
    // ========================================
    const portSelect = document.getElementById('game_port');
    const portInfo = document.getElementById('portPoolInfo');
    const manualPortDiv = document.getElementById('manualPortInput');
    const toggleManualBtn = document.getElementById('toggleManualPort');
    const manualPortInput = document.getElementById('game_port_manual');
    const useManualBtn = document.getElementById('useManualPort');

    // Freie Ports vom Rootserver laden
    async function loadFreePorts() {
        const rsId = urlParams.get('rootserver');
        if (!rsId) {
            portInfo.innerHTML = `<span class="text-warning"><i class="fa-solid fa-triangle-exclamation mr-1"></i>${i18n.noRootserverSelected}</span>`;
            return;
        }
        try {
            const r = await fetch(`/guild/${guildId}/plugins/masterserver/rootservers/${rsId}/allocations`);
            const { success, data, summary } = await r.json();
            if (!success) {
                portInfo.innerHTML = `<span class="text-danger">${i18n.errorLoadingPorts}</span>`;
                return;
            }
            const freePorts = data.filter(a => a.server_id === null).sort((a, b) => a.port - b.port);
            if (freePorts.length === 0) {
                portInfo.innerHTML = `<span class="text-danger"><i class="fa-solid fa-circle-xmark mr-1"></i>${i18n.noFreePorts}</span>`;
                return;
            }
            // Dropdown befüllen (max 200 einzeln anzeigen, danach gruppiert)
            const showMax = 200;
            const toShow = freePorts.slice(0, showMax);
            toShow.forEach(a => {
                const opt = document.createElement('option');
                opt.value = a.port;
                opt.textContent = a.ip + ':' + a.port;
                portSelect.appendChild(opt);
            });
            if (freePorts.length > showMax) {
                const opt = document.createElement('option');
                opt.disabled = true;
                opt.textContent = `... ${freePorts.length - showMax} ${i18n.moreFreePorts}`;
                portSelect.appendChild(opt);
            }
            portInfo.innerHTML = `<span class="text-success"><i class="fa-solid fa-circle-check mr-1"></i>${freePorts.length} ${i18n.freePortsAvailable} (${summary.assigned} ${i18n.portsAssigned})</span>`;
        } catch (_) {
            portInfo.innerHTML = `<span class="text-danger">${i18n.networkError}</span>`;
        }
    }
    loadFreePorts();

    // Toggle: Dropdown ↔ Manuelle Eingabe
    toggleManualBtn.addEventListener('click', () => {
        const show = manualPortDiv.style.display === 'none';
        manualPortDiv.style.display = show ? '' : 'none';
        toggleManualBtn.classList.toggle('btn-outline-secondary', !show);
        toggleManualBtn.classList.toggle('btn-secondary', show);
    });

    // Manuell eingegebenen Port als Custom-Option einfügen
    useManualBtn.addEventListener('click', () => {
        const port = parseInt(manualPortInput.value);
        if (!port || port < 1024 || port > 65535) {
            toastr.warning(i18n.invalidPort);
            return;
        }
        // Prüfe ob Option schon existiert
        const exists = Array.from(portSelect.options).some(o => o.value === String(port));
        if (!exists) {
            const opt = document.createElement('option');
            opt.value = port;
            opt.textContent = port + ' ' + i18n.portManualSuffix;
            portSelect.insertBefore(opt, portSelect.options[1]); // Nach "Auto"
        }
        portSelect.value = String(port);
        manualPortDiv.style.display = 'none';
        updateSummary();
    });

    portSelect.addEventListener('change', updateSummary);

    // Summary Port-Info
    const origUpdateSummary = updateSummary;
    updateSummary = function() {
        origUpdateSummary();
        const sel = portSelect.value;
        document.getElementById('summaryPort').textContent = sel === 'auto' ? i18n.portAutoLabel : sel;
    };

    // Initial Summary
    updateSummary();
});
</script>