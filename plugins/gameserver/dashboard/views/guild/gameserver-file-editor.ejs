<%# 
  * Gameserver File-Editor (Text-Editor für Config-Files)
  * Ermöglicht Bearbeitung von Text-Dateien mit Syntax-Highlighting
  * @author FireBot Team
  %>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-edit me-2"></i>
                        Editor - <%= fileName %>
                    </h3>
                    <div class="card-tools">
                        <% if (!error) { %>
                            <!-- Speichern-Button -->
                            <button class="btn btn-sm btn-success" id="saveBtn">
                                <i class="fas fa-save me-1"></i> Speichern (Strg+S)
                            </button>
                            <!-- Fullscreen-Toggle -->
                            <button class="btn btn-sm btn-secondary" id="fullscreenBtn">
                                <i class="fas fa-expand"></i>
                            </button>
                        <% } %>
                        <!-- Zurück zum File-Browser -->
                        <a href="/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/files?path=<%= encodeURIComponent(parentPath) %>" class="btn btn-sm btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Zurück
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Error-Meldung -->
                    <% if (error) { %>
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <%= error %>
                        </div>
                    <% } else { %>
                        <!-- File-Info -->
                        <div class="alert alert-info mb-3">
                            <div class="row">
                                <div class="col-md-6">
                                    <i class="bi bi-file-earmark-text me-2"></i>
                                    <strong>Datei:</strong> <%= filePath %>
                                </div>
                                <div class="col-md-3">
                                    <i class="bi bi-hdd me-2"></i>
                                    <strong>Größe:</strong> <%= (fileContent.length / 1024).toFixed(2) %> KB
                                </div>
                                <div class="col-md-3">
                                    <i class="bi bi-code-square me-2"></i>
                                    <strong>Zeilen:</strong> <%= fileContent.split('\n').length %>
                                </div>
                            </div>
                        </div>

                        <!-- Unsaved-Changes-Warnung -->
                        <div id="unsavedAlert" class="alert alert-warning" style="display: none;">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Ungespeicherte Änderungen!</strong> Bitte speichern Sie Ihre Änderungen.
                        </div>

                        <!-- Textarea-Editor (Fallback, falls Monaco nicht lädt) -->
                        <textarea id="codeEditor" class="form-control" style="font-family: 'Courier New', monospace; min-height: 500px;"><%= fileContent %></textarea>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (!error) { %>
<script>
// ============================
// Code-Editor (Einfache Textarea mit Features)
// ============================
const editorElement = document.getElementById('codeEditor');
const saveBtn = document.getElementById('saveBtn');
const fullscreenBtn = document.getElementById('fullscreenBtn');
const unsavedAlert = document.getElementById('unsavedAlert');
let isDirty = false;
let isFullscreen = false;

// Original-Content speichern
const originalContent = editorElement.value;

// Dirty-State überwachen
editorElement.addEventListener('input', () => {
    if (editorElement.value !== originalContent) {
        if (!isDirty) {
            isDirty = true;
            unsavedAlert.style.display = 'block';
            saveBtn.classList.add('btn-warning');
            saveBtn.classList.remove('btn-success');
        }
    } else {
        isDirty = false;
        unsavedAlert.style.display = 'none';
        saveBtn.classList.add('btn-success');
        saveBtn.classList.remove('btn-warning');
    }
});

// Fullscreen-Toggle
fullscreenBtn.addEventListener('click', () => {
    const card = document.querySelector('.card');
    if (!isFullscreen) {
        // Enter Fullscreen
        if (card.requestFullscreen) {
            card.requestFullscreen();
        } else if (card.webkitRequestFullscreen) {
            card.webkitRequestFullscreen();
        } else if (card.msRequestFullscreen) {
            card.msRequestFullscreen();
        }
        fullscreenBtn.innerHTML = '<i class="fas fa-compress"></i>';
        isFullscreen = true;
        editorElement.style.minHeight = 'calc(100vh - 200px)';
    } else {
        // Exit Fullscreen
        if (document.exitFullscreen) {
            document.exitFullscreen();
        } else if (document.webkitExitFullscreen) {
            document.webkitExitFullscreen();
        } else if (document.msExitFullscreen) {
            document.msExitFullscreen();
        }
        fullscreenBtn.innerHTML = '<i class="fas fa-expand"></i>';
        isFullscreen = false;
        editorElement.style.minHeight = '500px';
    }
});

// Fullscreen-Change Event
document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) {
        isFullscreen = false;
        fullscreenBtn.innerHTML = '<i class="fas fa-expand"></i>';
        editorElement.style.minHeight = '500px';
    }
});

// Speichern-Funktion
async function saveFile() {
    if (!isDirty) {
        showToast('info', 'Keine Änderungen zum Speichern');
        return;
    }
    
    const content = editorElement.value;
    
    try {
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Speichere...';
        
        const response = await fetch(`/guild/<%= guildId %>/plugins/gameserver/servers/<%= server.id %>/files/edit`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                path: '<%= filePath %>',
                content: content
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            showToast('success', result.message || 'Erfolgreich gespeichert');
            isDirty = false;
            unsavedAlert.style.display = 'none';
            saveBtn.classList.add('btn-success');
            saveBtn.classList.remove('btn-warning');
            
            // Original-Content aktualisieren
            editorElement.defaultValue = content;
        } else {
            showToast('error', result.message || 'Fehler beim Speichern');
        }
    } catch (error) {
        console.error('Save-Fehler:', error);
        showToast('error', 'Netzwerkfehler beim Speichern');
    } finally {
        saveBtn.disabled = false;
        saveBtn.innerHTML = '<i class="fas fa-save me-1"></i> Speichern (Strg+S)';
    }
}

// Speichern-Button Click
saveBtn.addEventListener('click', saveFile);

// Keyboard-Shortcut (Strg+S)
editorElement.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        saveFile();
    }
});

// Tab-Support (Einfügen von Tabs mit Tab-Taste)
editorElement.addEventListener('keydown', function(e) {
    if (e.key === 'Tab') {
        e.preventDefault();
        const start = this.selectionStart;
        const end = this.selectionEnd;
        const value = this.value;
        
        // Tab einfügen
        this.value = value.substring(0, start) + '\t' + value.substring(end);
        
        // Cursor nach dem Tab positionieren
        this.selectionStart = this.selectionEnd = start + 1;
    }
});

// Before-Unload-Warning (Ungespeicherte Änderungen)
window.addEventListener('beforeunload', (e) => {
    if (isDirty) {
        e.preventDefault();
        e.returnValue = 'Sie haben ungespeicherte Änderungen. Wirklich schließen?';
        return e.returnValue;
    }
});

// Toast-Helper
function showToast(type, message) {
    if (typeof window.showToast === 'function') {
        window.showToast(type, message);
    } else {
        alert(message);
    }
}

// Zeilennummern (optional) - funktioniert mit CSS
function addLineNumbers() {
    const lines = editorElement.value.split('\n').length;
    let lineNumbers = '';
    for (let i = 1; i <= lines; i++) {
        lineNumbers += i + '\n';
    }
    
    // Falls ein Line-Number-Div existiert
    const lineNumberDiv = document.getElementById('lineNumbers');
    if (lineNumberDiv) {
        lineNumberDiv.textContent = lineNumbers;
    }
}

// Initial Line-Numbers
editorElement.addEventListener('input', addLineNumbers);
editorElement.addEventListener('scroll', function() {
    const lineNumberDiv = document.getElementById('lineNumbers');
    if (lineNumberDiv) {
        lineNumberDiv.scrollTop = this.scrollTop;
    }
});
addLineNumbers();
</script>

<!-- CSS für Editor-Styling -->
<style>
#codeEditor {
    font-family: 'Courier New', 'Consolas', monospace;
    font-size: 14px;
    line-height: 1.5;
    tab-size: 4;
    white-space: pre;
    overflow-wrap: normal;
    overflow-x: auto;
}

/* Fullscreen-Mode Anpassungen */
.card:-webkit-full-screen {
    width: 100%;
    height: 100%;
}

.card:-moz-full-screen {
    width: 100%;
    height: 100%;
}

.card:fullscreen {
    width: 100%;
    height: 100%;
}

.card:fullscreen .card-body {
    height: calc(100vh - 100px);
    overflow-y: auto;
}
</style>
<% } %>
