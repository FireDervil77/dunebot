<!-- Giveaway Plugin - Dashboard View -->
<div class="container-fluid">
  <div class="row">
    <div class="col-lg-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <div>
            <h3 class="card-title">
              <i class="fa-solid fa-gift me-2"></i>
              <%= tr('giveaway:TITLE') %>
            </h3>
            <p class="text-muted mb-0 mt-2"><%= tr('giveaway:DESCRIPTION') %></p>
          </div>
          <button class="btn btn-primary" data-toggle="modal" data-target="#createGiveawayModal">
            <i class="fa-solid fa-plus me-1"></i> <%= tr('giveaway:CREATE_NEW_BTN') %>
          </button>
        </div>

        <div class="card-body">
          <!-- Nav Tabs -->
          <ul class="nav nav-tabs" id="giveawayTabs" role="tablist">
            <li class="nav-item">
              <a class="nav-link active" id="active-tab" data-toggle="tab" href="#tab-active" role="tab">
                <i class="fa-solid fa-bolt me-1"></i> <%= tr('giveaway:LIST_TITLE') %>
                <% if (active.length > 0) { %>
                  <span class="badge bg-success ml-1"><%= active.length %></span>
                <% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="scheduled-tab" data-toggle="tab" href="#tab-scheduled" role="tab">
                <i class="fa-solid fa-clock me-1"></i> <%= tr('giveaway:SCHEDULED_TITLE') || 'Geplant' %>
                <% if (scheduled && scheduled.length > 0) { %>
                  <span class="badge bg-info ml-1"><%= scheduled.length %></span>
                <% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="recent-tab" data-toggle="tab" href="#tab-recent" role="tab">
                <i class="fa-solid fa-history me-1"></i> <%= tr('giveaway:RECENT_TITLE') || 'Beendet' %>
                <% if (recent.length > 0) { %>
                  <span class="badge bg-secondary ml-1"><%= recent.length %></span>
                <% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="templates-tab" data-toggle="tab" href="#tab-templates" role="tab">
                <i class="fa-solid fa-copy me-1"></i> <%= tr('giveaway:TEMPLATES_TITLE') || 'Vorlagen' %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="blacklist-tab" data-toggle="tab" href="#tab-blacklist" role="tab">
                <i class="fa-solid fa-ban me-1"></i> <%= tr('giveaway:BLACKLIST_TITLE') || 'Blacklist' %>
                <% if (blacklist && blacklist.length > 0) { %>
                  <span class="badge bg-danger ml-1"><%= blacklist.length %></span>
                <% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" id="analytics-tab" data-toggle="tab" href="#tab-analytics" role="tab">
                <i class="fa-solid fa-chart-bar me-1"></i> <%= tr('giveaway:ANALYTICS_TITLE') || 'Statistiken' %>
              </a>
            </li>
          </ul>

          <div class="tab-content mt-4" id="giveawayTabContent">
            <!-- ═══════ TAB 1: Active Giveaways ═══════ -->
            <div class="tab-pane fade show active" id="tab-active" role="tabpanel">
              <% if (active.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-gift fa-3x mb-3"></i>
                  <p><%= tr('giveaway:LIST_EMPTY') || 'Keine aktiven Giveaways.' %></p>
                </div>
              <% } else { %>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th><%= tr('giveaway:LIST_PRIZE') %></th>
                        <th><%= tr('giveaway:LIST_CHANNEL') %></th>
                        <th><%= tr('giveaway:LIST_WINNERS') %></th>
                        <th><%= tr('giveaway:LIST_ENDS_AT') %></th>
                        <th>Status</th>
                        <th><%= tr('giveaway:LIST_ENTRIES') || 'Teilnehmer' %></th>
                        <th><%= tr('giveaway:LIST_ACTION') %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% active.forEach(g => { %>
                        <tr>
                          <td><strong><%= g.prize %></strong></td>
                          <td>
                            <% const ch = channels.find(c => c.id === g.channel_id); %>
                            #<%= ch ? ch.name : g.channel_id %>
                          </td>
                          <td><%= g.winner_count %></td>
                          <td>
                            <% if (g.ends_at) { %>
                              <span data-countdown="<%= new Date(g.ends_at).toISOString() %>">
                                <%= new Date(g.ends_at).toLocaleString() %>
                              </span>
                            <% } else { %>
                              -
                            <% } %>
                          </td>
                          <td>
                            <% if (g.status === 'active') { %>
                              <span class="badge bg-success">Aktiv</span>
                            <% } else if (g.status === 'paused') { %>
                              <span class="badge bg-warning">Pausiert</span>
                            <% } %>
                          </td>
                          <td><%= g.entry_count || 0 %></td>
                          <td>
                            <div class="btn-group btn-group-sm">
                              <% if (g.status === 'active') { %>
                                <button class="btn btn-warning btn-sm" onclick="giveawayAction(<%= g.id %>, 'pause')" title="Pause">
                                  <i class="fa-solid fa-pause"></i>
                                </button>
                              <% } else if (g.status === 'paused') { %>
                                <button class="btn btn-success btn-sm" onclick="giveawayAction(<%= g.id %>, 'resume')" title="Resume">
                                  <i class="fa-solid fa-play"></i>
                                </button>
                              <% } %>
                              <button class="btn btn-danger btn-sm" onclick="giveawayAction(<%= g.id %>, 'end')" title="End">
                                <i class="fa-solid fa-stop"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

            <!-- ═══════ TAB 2: Scheduled Giveaways ═══════ -->
            <div class="tab-pane fade" id="tab-scheduled" role="tabpanel">
              <% if (!scheduled || scheduled.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-clock fa-3x mb-3"></i>
                  <p><%= tr('giveaway:SCHEDULED_EMPTY') || 'Keine geplanten Giveaways.' %></p>
                </div>
              <% } else { %>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th><%= tr('giveaway:LIST_PRIZE') %></th>
                        <th><%= tr('giveaway:LIST_CHANNEL') %></th>
                        <th><%= tr('giveaway:LIST_WINNERS') %></th>
                        <th><%= tr('giveaway:SCHEDULED_START') || 'Start' %></th>
                        <th><%= tr('giveaway:LIST_ACTION') %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% scheduled.forEach(g => { %>
                        <tr>
                          <td><strong><%= g.prize %></strong></td>
                          <td>
                            <% const sch = channels.find(c => c.id === g.channel_id); %>
                            #<%= sch ? sch.name : g.channel_id %>
                          </td>
                          <td><%= g.winner_count %></td>
                          <td><%= g.scheduled_start ? new Date(g.scheduled_start).toLocaleString() : '-' %></td>
                          <td>
                            <button class="btn btn-danger btn-sm" onclick="giveawayDelete(<%= g.id %>)" title="Löschen">
                              <i class="fa-solid fa-trash"></i>
                            </button>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

            <!-- ═══════ TAB 3: Recent Giveaways ═══════ -->
            <div class="tab-pane fade" id="tab-recent" role="tabpanel">
              <% if (recent.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-clock-rotate-left fa-3x mb-3"></i>
                  <p><%= tr('giveaway:RECENT_EMPTY') || 'Keine beendeten Giveaways.' %></p>
                </div>
              <% } else { %>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th><%= tr('giveaway:LIST_PRIZE') %></th>
                        <th><%= tr('giveaway:LIST_CHANNEL') %></th>
                        <th><%= tr('giveaway:LIST_WINNERS') %></th>
                        <th><%= tr('giveaway:RECENT_WINNER_LIST') || 'Gewinner' %></th>
                        <th><%= tr('giveaway:RECENT_ENDED') || 'Beendet' %></th>
                        <th><%= tr('giveaway:LIST_ACTION') %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% recent.forEach(g => { %>
                        <tr>
                          <td><strong><%= g.prize %></strong></td>
                          <td>
                            <% const rch = channels.find(c => c.id === g.channel_id); %>
                            #<%= rch ? rch.name : g.channel_id %>
                          </td>
                          <td><%= g.winner_count %></td>
                          <td>
                            <% if (g.winner_details && g.winner_details.length > 0) { %>
                              <% g.winner_details.forEach(w => { %>
                                <span class="badge <%= w.claim_status === 'claimed' ? 'bg-success' : w.claim_status === 'expired' ? 'bg-danger' : 'bg-warning' %> mr-1">
                                  &lt;@<%= w.user_id %>&gt;
                                  <% if (w.claim_status && w.claim_status !== 'pending') { %>
                                    (<%= w.claim_status %>)
                                  <% } %>
                                </span>
                              <% }); %>
                            <% } else if (g.winners && g.winners.length > 0) { %>
                              <%= g.winners.map(id => '<@' + id + '>').join(', ') %>
                            <% } else { %>
                              <span class="text-muted"><%= tr('giveaway:RECENT_NO_WINNERS') || 'Keine Gewinner' %></span>
                            <% } %>
                          </td>
                          <td><%= g.ended_at ? new Date(g.ended_at).toLocaleString() : '-' %></td>
                          <td>
                            <div class="btn-group btn-group-sm">
                              <button class="btn btn-info btn-sm" onclick="giveawayAction(<%= g.id %>, 'reroll')" title="Reroll">
                                <i class="fa-solid fa-arrows-rotate"></i>
                              </button>
                              <button class="btn btn-danger btn-sm" onclick="giveawayDelete(<%= g.id %>)" title="Löschen">
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

            <!-- ═══════ TAB 4: Templates ═══════ -->
            <div class="tab-pane fade" id="tab-templates" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0"><%= tr('giveaway:TEMPLATES_TITLE') || 'Vorlagen' %></h5>
                <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#createTemplateModal">
                  <i class="fa-solid fa-plus me-1"></i> <%= tr('giveaway:TEMPLATE_CREATE_BTN') || 'Vorlage erstellen' %>
                </button>
              </div>

              <% if (!templates || templates.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-copy fa-3x mb-3"></i>
                  <p><%= tr('giveaway:TEMPLATES_EMPTY') || 'Keine Vorlagen vorhanden.' %></p>
                </div>
              <% } else { %>
                <div class="row">
                  <% templates.forEach(t => { %>
                    <div class="col-md-4 mb-3">
                      <div class="card card-outline card-info">
                        <div class="card-header">
                          <h3 class="card-title"><i class="fa-solid fa-copy me-1"></i> <%= t.name %></h3>
                        </div>
                        <div class="card-body p-3">
                          <% if (t.config) { %>
                            <% if (t.config.prize) { %><p class="mb-1"><strong>Preis:</strong> <%= t.config.prize %></p><% } %>
                            <% if (t.config.duration) { %><p class="mb-1"><strong>Dauer:</strong> <%= Math.round(t.config.duration / 60000) %> Min</p><% } %>
                            <% if (t.config.winner_count) { %><p class="mb-1"><strong>Gewinner:</strong> <%= t.config.winner_count %></p><% } %>
                            <% if (t.config.claim_duration_ms) { %><p class="mb-1"><strong>Claim-Zeit:</strong> <%= Math.round(t.config.claim_duration_ms / 60000) %> Min</p><% } %>
                          <% } %>
                        </div>
                        <div class="card-footer text-right">
                          <button class="btn btn-sm btn-danger" onclick="deleteTemplate(<%= t.id %>)">
                            <i class="fa-solid fa-trash"></i> Löschen
                          </button>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } %>
            </div>

            <!-- ═══════ TAB 5: Blacklist ═══════ -->
            <div class="tab-pane fade" id="tab-blacklist" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0"><%= tr('giveaway:BLACKLIST_TITLE') || 'Blacklist' %></h5>
                <button class="btn btn-sm btn-danger" data-toggle="modal" data-target="#addBlacklistModal">
                  <i class="fa-solid fa-plus me-1"></i> <%= tr('giveaway:BLACKLIST_ADD_BTN') || 'Zur Blacklist hinzufügen' %>
                </button>
              </div>

              <% if (!blacklist || blacklist.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-ban fa-3x mb-3"></i>
                  <p><%= tr('giveaway:BLACKLIST_EMPTY') || 'Keine Einträge auf der Blacklist.' %></p>
                </div>
              <% } else { %>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>User ID</th>
                        <th><%= tr('giveaway:BLACKLIST_REASON') || 'Grund' %></th>
                        <th><%= tr('giveaway:BLACKLIST_ADDED_BY') || 'Hinzugefügt von' %></th>
                        <th><%= tr('giveaway:BLACKLIST_DATE') || 'Datum' %></th>
                        <th><%= tr('giveaway:LIST_ACTION') %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% blacklist.forEach(b => { %>
                        <tr>
                          <td><code><%= b.user_id %></code></td>
                          <td><%= b.reason || '-' %></td>
                          <td><%= b.added_by || '-' %></td>
                          <td><%= b.created_at ? new Date(b.created_at).toLocaleString() : '-' %></td>
                          <td>
                            <button class="btn btn-sm btn-warning" onclick="removeBlacklist('<%= b.user_id %>')">
                              <i class="fa-solid fa-user-check"></i> Entfernen
                            </button>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

            <!-- ═══════ TAB 6: Analytics ═══════ -->
            <div class="tab-pane fade" id="tab-analytics" role="tabpanel">
              <% if (!analytics) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-chart-bar fa-3x mb-3"></i>
                  <p><%= tr('giveaway:ANALYTICS_EMPTY') || 'Keine Statistiken verfügbar.' %></p>
                </div>
              <% } else { %>
                <div class="row">
                  <div class="col-md-3">
                    <div class="small-box bg-info">
                      <div class="inner">
                        <h3><%= analytics.total_giveaways || 0 %></h3>
                        <p><%= tr('giveaway:ANALYTICS_TOTAL') || 'Giveaways gesamt' %></p>
                      </div>
                      <div class="icon"><i class="fa-solid fa-gift"></i></div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="small-box bg-success">
                      <div class="inner">
                        <h3><%= analytics.active_giveaways || 0 %></h3>
                        <p><%= tr('giveaway:ANALYTICS_ACTIVE') || 'Aktive Giveaways' %></p>
                      </div>
                      <div class="icon"><i class="fa-solid fa-bolt"></i></div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="small-box bg-warning">
                      <div class="inner">
                        <h3><%= analytics.total_participants || 0 %></h3>
                        <p><%= tr('giveaway:ANALYTICS_PARTICIPANTS') || 'Teilnehmer gesamt' %></p>
                      </div>
                      <div class="icon"><i class="fa-solid fa-users"></i></div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="small-box bg-danger">
                      <div class="inner">
                        <h3><%= analytics.total_winners || 0 %></h3>
                        <p><%= tr('giveaway:ANALYTICS_WINNERS') || 'Gewinner gesamt' %></p>
                      </div>
                      <div class="icon"><i class="fa-solid fa-trophy"></i></div>
                    </div>
                  </div>
                </div>

                <% if (analytics.top_entrants && analytics.top_entrants.length > 0) { %>
                  <div class="card mt-3">
                    <div class="card-header">
                      <h3 class="card-title"><i class="fa-solid fa-ranking-star me-1"></i> <%= tr('giveaway:ANALYTICS_TOP_ENTRANTS') || 'Top Teilnehmer' %></h3>
                    </div>
                    <div class="card-body p-0">
                      <table class="table table-sm mb-0">
                        <thead>
                          <tr>
                            <th>#</th>
                            <th>User ID</th>
                            <th><%= tr('giveaway:ANALYTICS_ENTRIES') || 'Teilnahmen' %></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% analytics.top_entrants.forEach((e, i) => { %>
                            <tr>
                              <td><%= i + 1 %></td>
                              <td><code><%= e.user_id %></code></td>
                              <td><%= e.entry_count %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                <% } %>
              <% } %>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════ Create Giveaway Modal ═══════ -->
<div class="modal fade" id="createGiveawayModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-gift me-2"></i> <%= tr('giveaway:CREATE_TITLE') %></h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <form id="createGiveawayForm">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <!-- Channel -->
              <div class="form-group">
                <label><%= tr('giveaway:CREATE_CHANNEL') %></label>
                <select name="channel_id" class="form-control" required>
                  <option value=""><%= tr('giveaway:CREATE_CHANNEL_PLACEHOLDER') %></option>
                  <% channels.filter(c => c.type === 0).forEach(ch => { %>
                    <option value="<%= ch.id %>">#<%= ch.name %></option>
                  <% }); %>
                </select>
              </div>

              <!-- Prize -->
              <div class="form-group">
                <label><%= tr('giveaway:CREATE_PRIZE') %></label>
                <input type="text" name="prize" class="form-control" placeholder="Nitro, Game Key, ..." required maxlength="256">
              </div>

              <!-- Duration -->
              <div class="form-group">
                <label><%= tr('giveaway:CREATE_DURATION') %></label>
                <select name="duration" class="form-control" required>
                  <option value="900000">15 Minuten</option>
                  <option value="1800000">30 Minuten</option>
                  <option value="3600000" selected>1 Stunde</option>
                  <option value="7200000">2 Stunden</option>
                  <option value="21600000">6 Stunden</option>
                  <option value="43200000">12 Stunden</option>
                  <option value="86400000">1 Tag</option>
                  <option value="259200000">3 Tage</option>
                  <option value="604800000">1 Woche</option>
                </select>
              </div>

              <!-- Winners -->
              <div class="form-group">
                <label><%= tr('giveaway:CREATE_WINNERS') %></label>
                <input type="number" name="winner_count" class="form-control" value="1" min="1" max="20">
              </div>
            </div>

            <div class="col-md-6">
              <!-- Allowed Roles -->
              <div class="form-group">
                <label><%= tr('giveaway:CREATE_MEM_ROLE') %></label>
                <select name="allowed_roles" class="form-control" multiple>
                  <% roles.filter(r => r.name !== '@everyone').forEach(role => { %>
                    <option value="<%= role.id %>"><%= role.name %></option>
                  <% }); %>
                </select>
                <small class="text-muted"><%= tr('giveaway:CREATE_MEM_ROLE_DESC') %></small>
              </div>

              <!-- Scheduled Start -->
              <div class="form-group">
                <label><i class="fa-solid fa-clock me-1"></i> <%= tr('giveaway:CREATE_SCHEDULED') || 'Geplanter Start' %></label>
                <input type="datetime-local" name="scheduled_start" class="form-control">
                <small class="text-muted"><%= tr('giveaway:CREATE_SCHEDULED_DESC') || 'Leer lassen für sofortigen Start' %></small>
              </div>

              <!-- Claim Duration -->
              <div class="form-group">
                <label><i class="fa-solid fa-hand me-1"></i> <%= tr('giveaway:CREATE_CLAIM_DURATION') || 'Claim-Zeitlimit' %></label>
                <select name="claim_duration" class="form-control">
                  <option value=""><%= tr('giveaway:CREATE_CLAIM_NONE') || 'Kein Claim erforderlich' %></option>
                  <option value="300000">5 Minuten</option>
                  <option value="900000">15 Minuten</option>
                  <option value="1800000">30 Minuten</option>
                  <option value="3600000">1 Stunde</option>
                  <option value="7200000">2 Stunden</option>
                  <option value="43200000">12 Stunden</option>
                  <option value="86400000">24 Stunden</option>
                </select>
                <small class="text-muted"><%= tr('giveaway:CREATE_CLAIM_DESC') || 'Gewinner müssen ihren Preis innerhalb dieser Zeit beanspruchen' %></small>
              </div>

              <!-- Requirements -->
              <div class="form-group">
                <label><i class="fa-solid fa-shield-halved me-1"></i> <%= tr('giveaway:CREATE_REQUIREMENTS') || 'Anforderungen' %></label>
                <div id="requirementsContainer">
                  <!-- Dynamic requirement rows will be added here -->
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="addRequirement()">
                  <i class="fa-solid fa-plus me-1"></i> <%= tr('giveaway:CREATE_ADD_REQUIREMENT') || 'Anforderung hinzufügen' %>
                </button>
              </div>
            </div>
          </div>

          <!-- Template Quick-Fill -->
          <% if (templates && templates.length > 0) { %>
            <hr>
            <div class="form-group">
              <label><i class="fa-solid fa-copy me-1"></i> <%= tr('giveaway:CREATE_FROM_TEMPLATE') || 'Aus Vorlage laden' %></label>
              <select class="form-control" id="templateSelect" onchange="fillFromTemplate(this.value)">
                <option value="">-- Vorlage wählen --</option>
                <% templates.forEach(t => { %>
                  <option value='<%= JSON.stringify(t.config) %>'><%= t.name %></option>
                <% }); %>
              </select>
            </div>
          <% } %>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= tr('giveaway:CREATE_CLOSE_BTN') %></button>
          <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-rocket me-1"></i> <%= tr('giveaway:CREATE_BTN') %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ═══════ Create Template Modal ═══════ -->
<div class="modal fade" id="createTemplateModal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-copy me-2"></i> <%= tr('giveaway:TEMPLATE_CREATE_TITLE') || 'Vorlage erstellen' %></h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <form id="createTemplateForm">
        <div class="modal-body">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="template_name" class="form-control" required maxlength="100" placeholder="z.B. Nitro Standard">
          </div>
          <div class="form-group">
            <label>Preis</label>
            <input type="text" name="template_prize" class="form-control" maxlength="256" placeholder="Nitro, Game Key, ...">
          </div>
          <div class="form-group">
            <label>Dauer (ms)</label>
            <select name="template_duration" class="form-control">
              <option value="3600000">1 Stunde</option>
              <option value="86400000">1 Tag</option>
              <option value="259200000">3 Tage</option>
              <option value="604800000">1 Woche</option>
            </select>
          </div>
          <div class="form-group">
            <label>Gewinner-Anzahl</label>
            <input type="number" name="template_winners" class="form-control" value="1" min="1" max="20">
          </div>
          <div class="form-group">
            <label>Claim-Zeitlimit</label>
            <select name="template_claim" class="form-control">
              <option value="">Kein Claim</option>
              <option value="1800000">30 Minuten</option>
              <option value="3600000">1 Stunde</option>
              <option value="86400000">24 Stunden</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Speichern</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ═══════ Add Blacklist Modal ═══════ -->
<div class="modal fade" id="addBlacklistModal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-ban me-2"></i> <%= tr('giveaway:BLACKLIST_ADD_TITLE') || 'Zur Blacklist hinzufügen' %></h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <form id="addBlacklistForm">
        <div class="modal-body">
          <div class="form-group">
            <label>User ID</label>
            <input type="text" name="user_id" class="form-control" required placeholder="Discord User ID">
          </div>
          <div class="form-group">
            <label><%= tr('giveaway:BLACKLIST_REASON') || 'Grund' %></label>
            <input type="text" name="reason" class="form-control" maxlength="256" placeholder="Optional">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
          <button type="submit" class="btn btn-danger"><i class="fa-solid fa-ban me-1"></i> Hinzufügen</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ═══════ Scripts ═══════ -->
<script>
// ── Create Giveaway ──
document.getElementById('createGiveawayForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = new FormData(this);

    // Collect requirements
    const requirements = [];
    document.querySelectorAll('.requirement-row').forEach(row => {
        const type = row.querySelector('[name="req_type"]').value;
        const value = row.querySelector('[name="req_value"]').value;
        if (type && value) {
            requirements.push({ type, value });
        }
    });

    const data = {
        channel_id: form.get('channel_id'),
        prize: form.get('prize'),
        duration: form.get('duration'),
        winner_count: form.get('winner_count'),
        allowed_roles: form.getAll('allowed_roles'),
        scheduled_start: form.get('scheduled_start') || null,
        claim_duration: form.get('claim_duration') || null,
        requirements,
    };

    try {
        const resp = await fetch(window.location.pathname + '/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Giveaway erstellt!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Fehler beim Erstellen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
});

// ── Giveaway Actions ──
async function giveawayAction(id, action) {
    if (!confirm('Bist du sicher, dass du dieses Giveaway ' + action + ' möchtest?')) return;

    try {
        const resp = await fetch(window.location.pathname + '/' + id + '/' + action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Giveaway ' + action + ' erfolgreich!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Aktion fehlgeschlagen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
}

async function giveawayDelete(id) {
    if (!confirm('Bist du sicher, dass du dieses Giveaway LÖSCHEN möchtest? Dies kann nicht rückgängig gemacht werden.')) return;

    try {
        const resp = await fetch(window.location.pathname + '/' + id, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Giveaway gelöscht!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Löschen fehlgeschlagen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
}

// ── Templates ──
document.getElementById('createTemplateForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = new FormData(this);
    const data = {
        name: form.get('template_name'),
        config: {
            prize: form.get('template_prize') || null,
            duration: parseInt(form.get('template_duration')) || 3600000,
            winner_count: parseInt(form.get('template_winners')) || 1,
            claim_duration_ms: form.get('template_claim') ? parseInt(form.get('template_claim')) : null,
        },
    };

    try {
        const resp = await fetch(window.location.pathname + '/templates', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Vorlage erstellt!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Fehler beim Erstellen der Vorlage');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
});

async function deleteTemplate(id) {
    if (!confirm('Vorlage wirklich löschen?')) return;

    try {
        const resp = await fetch(window.location.pathname + '/templates/' + id, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Vorlage gelöscht!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Fehler beim Löschen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
}

function fillFromTemplate(configJson) {
    if (!configJson) return;
    try {
        const config = JSON.parse(configJson);
        const form = document.getElementById('createGiveawayForm');
        if (config.prize) form.querySelector('[name="prize"]').value = config.prize;
        if (config.duration) form.querySelector('[name="duration"]').value = config.duration;
        if (config.winner_count) form.querySelector('[name="winner_count"]').value = config.winner_count;
        if (config.claim_duration_ms) form.querySelector('[name="claim_duration"]').value = config.claim_duration_ms;
    } catch (e) { /* ignore parse errors */ }
}

// ── Blacklist ──
document.getElementById('addBlacklistForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = new FormData(this);
    const data = {
        user_id: form.get('user_id'),
        reason: form.get('reason') || null,
    };

    try {
        const resp = await fetch(window.location.pathname + '/blacklist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Benutzer zur Blacklist hinzugefügt!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Fehler beim Hinzufügen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
});

async function removeBlacklist(userId) {
    if (!confirm('Benutzer wirklich von der Blacklist entfernen?')) return;

    try {
        const resp = await fetch(window.location.pathname + '/blacklist/' + userId, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
        });
        const result = await resp.json();
        if (result.success) {
            showToast('success', 'Benutzer von Blacklist entfernt!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', result.error || 'Fehler beim Entfernen');
        }
    } catch (err) {
        showToast('error', 'Ein Fehler ist aufgetreten');
    }
}

// ── Requirements ──
function addRequirement() {
    const container = document.getElementById('requirementsContainer');
    const row = document.createElement('div');
    row.className = 'requirement-row d-flex mb-2';
    row.innerHTML = `
        <select name="req_type" class="form-control mr-2" style="width: 40%;">
            <option value="role">Rolle benötigt</option>
            <option value="account_age">Account-Alter (Tage)</option>
            <option value="server_age">Server-Mitgliedschaft (Tage)</option>
        </select>
        <input type="text" name="req_value" class="form-control mr-2" placeholder="Rolle-ID oder Tage" style="width: 45%;">
        <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.parentElement.remove()">
            <i class="fa-solid fa-times"></i>
        </button>
    `;
    container.appendChild(row);
}

// ── Toast ──
function showToast(type, message) {
    if (typeof toastr !== 'undefined') {
        toastr[type](message);
    } else {
        alert(message);
    }
}
</script>
