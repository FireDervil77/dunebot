{
  "name": "ticket",
  "displayName": "Ticket",
  "version": "1.1.0",
  "previousVersion": null,
  "author": "FireDervil",
  "description": "Comprehensive ticketing system for managing user support requests",
  "minSystemVersion": "0.1.0",

"changelog": {
    "1.1.0": [
      "🎟️ Initial release of the Ticket plugin",
      "📩 Create and manage support tickets with ease",
      "🔒 Configurable permissions for ticket access",
      "📝 Customizable ticket categories and forms",
      "📊 Ticket status tracking and reporting"
    ]
  },

  "compatibility": {
    "bot": true,
    "dashboard": true
  },

   "dependencies": {
    "core": ">=0.1.0"
  },

    "permissions": {
        "bot": ["ManageChannels", "ManageMessages", "ReadMessageHistory"],
        "dashboard": ["ManageGuild"]
    }
}