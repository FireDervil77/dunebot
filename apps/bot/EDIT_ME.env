# Shared
# IPC_SERVER_HOST mit localhost für ipv4 oder "::1" für ipv6
IPC_SERVER_HOST=
IPC_SERVER_PORT=3000


# Redis verbdinungs URL
REDIS_URL=redis://localhost:6379


# Owner IDS
OWNER_IDS=


# Path settings
REGISTRY_PATH=../../plugins/registry.json
PLUGINS_DIR=../../plugins


# Debug Settings
LOG_LEVEL=debug
NODE_ENV=development
DEBUG_HOOKS=true
VEZA_DEBUG=true


# BOT & Shard Settings
BOT_TOKEN=
SHARDS=auto
AUTO_RESPAWN=false
SPAWN_TIMEOUT=30000
SHARD_MODE=process
SHUTDOWN_GRACEFUL=false

# DATABASE SETTINGS
# DB_TYPE kann nun nur noch mysql
DB_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=


# VERSIONS
DASHBOARD_VERSION=0.1.5.1545
BOT_VERSION=0.1.5.1545