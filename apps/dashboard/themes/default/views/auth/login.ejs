<div class="login-box">
    <div class="card">
        <div class="card-body login-card-body">
            <div class="login-logo">
                <img src="/themes/default/assets/images/firebot.png" width="125px" height="125px" alt="FireBot"><b>FireBot</b> 
            </div>
            
            <h1 class="h3 mb-4 fw-normal">Mit Discord anmelden</h1>

            <div class="mt-4">
                <a href="<%= discordAuthURL %>" id="discord-login-btn" class="w-100 btn btn-lg btn-primary">
                    <i class="fab fa-discord me-2"></i> Mit Discord fortfahren
                </a>
                <p class="mt-3 text-body-secondary">
                    Du wirst zur Discord OAuth2-Seite weitergeleitet, um dich mit Discord anzumelden
                </p>
                <div id="login-loader" class="d-none text-center mt-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Bitte warten...</p>
                </div>
            </div>
    </div>
</div>

<script>
document.getElementById('discord-login-btn').addEventListener('click', function() {
    // Button ausblenden und Ladeindikator anzeigen
    this.classList.add('d-none');
    document.getElementById('login-loader').classList.remove('d-none');
    
    // Wenn nach 15 Sekunden noch keine Weiterleitung erfolgt ist
    setTimeout(() => {
        if (document.getElementById('login-loader').classList.contains('d-none') === false) {
            document.getElementById('login-loader').innerHTML = 
                '<div class="alert alert-warning">Die Anmeldung dauert länger als erwartet. ' +
                '<a href="<%= discordAuthURL %>" class="alert-link">Erneut versuchen</a></div>';
        }
    }, 15000);
});
</script>