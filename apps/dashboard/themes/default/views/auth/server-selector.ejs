<% 
// Session-Fehlermeldungen aus locals auslesen
const errorMessage = locals.errorMessage || null;
%>

<% if (errorMessage === 'BOT_OFFLINE' || (typeof botOnline !== 'undefined' && botOnline === false)) { %>
  <div class="container py-5">
    <div class="alert alert-warning shadow-sm">
      <h4 class="alert-heading">
        <i class="fas fa-power-off me-2"></i><%= tr('SELECTOR.BOT_OFFLINE_TITLE') %>
      </h4>
      <p class="mb-2">
        <strong><%= tr('SELECTOR.BOT_OFFLINE_DESC') %></strong><br>
        <%= tr('SELECTOR.BOT_OFFLINE_REASON') %>
      </p>
      <ul class="mb-3 small">
        <li><%= tr('SELECTOR.BOT_OFFLINE_WAIT') %></li>
        <li><%= tr('SELECTOR.BOT_OFFLINE_NO_DATA') %></li>
        <li><%= tr('SELECTOR.BOT_OFFLINE_SESSION') %></li>
      </ul>
      <div class="d-flex gap-2">
        <a href="/auth/server-selector" class="btn btn-outline-secondary">
          <i class="fas fa-sync-alt me-1"></i> <%= tr('SELECTOR.BOT_OFFLINE_BTN_RETRY') %>
        </a>
        <button id="autoReloadBtn" class="btn btn-outline-primary">
          <i class="fas fa-redo-alt me-1"></i> <%= tr('SELECTOR.BOT_OFFLINE_BTN_AUTO_ENABLE') %>
        </button>
      </div>
      <hr>
      <p class="mb-0 text-muted small">
        <%= tr('SELECTOR.BOT_OFFLINE_CONTACT') %>
      </p>
    </div>
    <div class="text-center text-muted small">
      <span id="nextReloadInfo"></span>
    </div>
  </div>
  <script>
    (function(){
      let auto = false;
      let countdown = 15;
      const btn = document.getElementById('autoReloadBtn');
      const info = document.getElementById('nextReloadInfo');
      const enableText = '<i class="fas fa-redo-alt me-1"></i> <%= tr("SELECTOR.BOT_OFFLINE_BTN_AUTO_ENABLE") %>';
      const stopText = '<i class="fas fa-stop-circle me-1"></i> <%= tr("SELECTOR.BOT_OFFLINE_BTN_AUTO_STOP") %>';
      const reloadTemplate = '<%= tr("SELECTOR.BOT_OFFLINE_RELOAD_IN") %>';
      
      function updateInfo() {
        if (!auto) { info.textContent = ''; return; }
        info.textContent = reloadTemplate.replace('{seconds}', countdown);
      }
      let interval = null;
      btn.addEventListener('click', () => {
        auto = !auto;
        if (auto) {
          btn.classList.remove('btn-outline-primary');
          btn.classList.add('btn-primary');
          btn.innerHTML = stopText;
          countdown = 15;
          updateInfo();
          interval = setInterval(() => {
            if (!auto) return;
            countdown--;
            if (countdown <= 0) location.reload();
            updateInfo();
          }, 1000);
        } else {
          btn.classList.remove('btn-primary');
          btn.classList.add('btn-outline-primary');
          btn.innerHTML = enableText;
          if (interval) clearInterval(interval);
          info.textContent = '';
        }
      });
    })();
  </script>
<% } else if (errorMessage === 'GUILD_UNAVAILABLE') { %>
  <div class="container py-5">
    <div class="alert alert-danger shadow-sm">
      <h4 class="alert-heading">
        <i class="fas fa-ban me-2"></i><%= tr('SELECTOR.GUILD_UNAVAILABLE_TITLE') %>
      </h4>
      <p class="mb-2">
        <strong><%= tr('SELECTOR.GUILD_UNAVAILABLE_DESC') %></strong><br>
        <%= tr('SELECTOR.GUILD_UNAVAILABLE_REASON') %>
      </p>
      <ul class="mb-3 small">
        <li><%= tr('SELECTOR.GUILD_UNAVAILABLE_KICKED') %></li>
        <li><%= tr('SELECTOR.GUILD_UNAVAILABLE_LEFT') %></li>
        <li><%= tr('SELECTOR.GUILD_UNAVAILABLE_DELETED') %></li>
      </ul>
      <div class="d-flex gap-2">
        <a href="/auth/server-selector" class="btn btn-primary">
          <i class="fas fa-arrow-left me-1"></i> <%= tr('SELECTOR.GUILD_UNAVAILABLE_BTN_BACK') %>
        </a>
        <% if (locals.supportUrl && locals.supportUrl !== '#') { %>
        <a href="<%= locals.supportUrl %>" target="_blank" class="btn btn-outline-secondary">
          <i class="fab fa-discord me-1"></i> <%= tr('SELECTOR.GUILD_UNAVAILABLE_BTN_SUPPORT') %>
        </a>
        <% } %>
      </div>
      <hr>
      <p class="mb-0 text-muted small">
        <%= tr('SELECTOR.GUILD_UNAVAILABLE_HINT') %>
      </p>
    </div>
  </div>
<% } else { %>

  <div class="login-box server-selector">
    <div class="login-logo">
      <img src="/themes/default/assets/images/DuneBot.png" width="125" height="125" alt="DuneBot">
      <b>DuneBot</b>
      <p><span><%= tr('SELECTOR.PAGE_TITLE') %></span></p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
      <% (guilds || []).forEach(guild => { %>
        <div class="col">
          <div class="card h-100">
            <div class="card-body login-card-body text-center">
              <img src="<%= guild.iconURL %>" alt="<%= guild.name %>" class="guild-icon mb-2" width="100" height="100">
              <h5 class="card-title"><%= guild.name %></h5>
              <% if (guild.botInGuild) { %>
                <div class="guild-status text-success mb-3">
                  <i class="fas fa-check-circle me-1"></i> <%= tr('SELECTOR.BOT_IN_GUILD') %>
                </div>
                <a href="<%= guild.settingsUrl %>" class="btn btn-primary w-100"><%= tr('SELECTOR.BTN_MANAGE') %></a>
              <% } else { %>
                <div class="guild-status text-danger mb-3">
                  <i class="fas fa-exclamation-circle me-1"></i> <%= tr('SELECTOR.BOT_NOT_IN_GUILD') %>
                </div>
                <a href="<%= guild.settingsUrl %>" id="invite-btn-<%= guild.id %>" target="_blank" class="btn btn-outline-primary w-100">
                  <i class="fas fa-plus-circle me-2"></i> <%= tr('SELECTOR.BTN_INVITE') %>
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <% if (!guilds || guilds.length === 0) { %>
      <div class="alert alert-info text-center mt-5">
        <i class="fas fa-info-circle me-2"></i> Du hast keine Server, in denen du Besitzer (Owner) bist.
      </div>
      <div class="text-center">
        <a href="https://discord.com/new" target="_blank" class="btn btn-primary mt-3">
          <i class="fas a-plus-circle me-2"></i> Neuen Discord Server erstellen
        </a>
      </div>
    <% } %>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[id^="invite-btn-"]').forEach(button => {
        button.addEventListener('click', function() {
          const guildId = this.id.replace('invite-btn-','');
          localStorage.setItem('pendingBotInvite', guildId);
          localStorage.setItem('inviteTimestamp', Date.now());
          startPolling(guildId);
        });
      });
      const pendingInvite = localStorage.getItem('pendingBotInvite');
      const inviteTimestamp = localStorage.getItem('inviteTimestamp');
      if (pendingInvite && inviteTimestamp && (Date.now() - parseInt(inviteTimestamp)) < 5*60*1000) {
        startPolling(pendingInvite);
      } else {
        localStorage.removeItem('pendingBotInvite');
        localStorage.removeItem('inviteTimestamp');
      }
      function startPolling(guildId) {
        const statusDiv = document.createElement('div');
        statusDiv.className='alert alert-info position-fixed top-0 start-50 translate-middle-x mt-3';
        statusDiv.style.zIndex='1050';
        statusDiv.innerHTML='<i class="fas fa-spinner fa-spin me-2"></i> Prüfe Bot-Status...';
        document.body.appendChild(statusDiv);
        const pollInterval = setInterval(async () => {
          try {
            const r = await fetch(`/api/bot-status/${guildId}`);
            const data = await r.json();
            if (data.success && data.botInGuild) {
              statusDiv.className='alert alert-success position-fixed top-0 start-50 translate-middle-x mt-3';
              statusDiv.innerHTML='<i class="fas fa-check-circle me-2"></i> Bot erfolgreich hinzugefügt!';
              clearInterval(pollInterval);
              updateGuildCard(guildId);
              localStorage.removeItem('pendingBotInvite');
              localStorage.removeItem('inviteTimestamp');
              setTimeout(()=>statusDiv.remove(),3000);
            }
          } catch(e){
            console.error('Bot-Status Fehler:', e);
            statusDiv.className='alert alert-danger position-fixed top-0 start-50 translate-middle-x mt-3';
            statusDiv.innerHTML='<i class="fas fa-times-circle me-2"></i> Fehler beim Prüfen';
            clearInterval(pollInterval);
          }
        },3000);
        setTimeout(()=>{ clearInterval(pollInterval); if (document.body.contains(statusDiv)) statusDiv.remove(); },5*60*1000);
      }
      function updateGuildCard(guildId) {
        const btn = document.querySelector(`#invite-btn-${guildId}`);
        if (!btn) return;
        const card = btn.closest('.card');
        const statusDiv = card.querySelector('.guild-status');
        if (statusDiv) {
          statusDiv.className='guild-status text-success mb-3';
          statusDiv.innerHTML='<i class="fas fa-check-circle me-1"></i> Bot in Guild';
        }
        btn.remove();
        const manageBtn = document.createElement('a');
        manageBtn.href=`/guild/${guildId}`;
        manageBtn.className='btn btn-primary w-100';
        manageBtn.textContent='Verwalten';
        card.querySelector('.card-body').appendChild(manageBtn);
      }
    });
  </script>
<% } %>