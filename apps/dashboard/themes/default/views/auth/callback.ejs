<h1 class="h3 mb-4 fw-normal">Anmeldung erfolgreich</h1>

<div class="d-flex justify-content-center my-4">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Lädt...</span>
    </div>
</div>

<p class="text-body-secondary">Du wirst weitergeleitet...</p>

<script>
    // Weiterleitung nach kurzer Verzögerung
    setTimeout(() => {
        window.location.href = "<%= locals.redirectURL || '/auth/server-selector' %>";
    }, 1500);
</script>