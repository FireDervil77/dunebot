<!-- filepath: /home/firedervil/dunebot_new/apps/dashboard/themes/default/views/auth/error.ejs -->
<h1 class="h3 mb-4 fw-normal">Anmeldung fehlgeschlagen</h1>

<div class="alert alert-danger" role="alert">
    <%= error %>
</div>

<div class="mt-4">
    <% if (locals.retry_url) { %>
        <a href="<%= retry_url %>" class="btn btn-primary">
            <i class="fas fa-redo me-2"></i> Erneut versuchen
        </a>
    <% } else { %>
        <a href="/auth/login" class="btn btn-primary">
            <i class="fas fa-redo me-2"></i> Erneut versuchen
        </a>
    <% } %>
    
    <a href="/" class="btn btn-outline-secondary ms-2">
        <i class="fas fa-home me-2"></i> Zurück zur Startseite
    </a>
</div>

<div class="mt-4 small">
    <p class="text-muted">
        Falls das Problem weiterhin besteht, versuche:
    </p>
    <ul class="text-muted">
        <li>Deinen Browser-Cache zu leeren</li>
        <li>Dich von Discord abzumelden und erneut anzumelden</li>
        <li>Den Bot-Administrator zu kontaktieren</li>
    </ul>
</div>