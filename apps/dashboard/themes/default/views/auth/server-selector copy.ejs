<div class="container-xl py-4">
  <div class="text-center mb-4">
    <h1 class="h3 fw-normal">Server auswählen</h1>
    <p class="text-body-secondary mb-0">
      Wähle einen deiner Discord-Server aus, um den Bot zu verwalten. Oder auf deinen Server einzuladen!
    </p>
  </div>

      <!-- Bootstrap Grid -->
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-3">
    <% guilds.forEach(guild => { %>
      <div class="col">
        <div class="card h-100 auth-guild-card">
          <div class="card-body d-flex flex-column align-items-center text-center">
            <img src="<%= guild.iconURL %>" alt="<%= guild.name %>" class="guild-icon mb-2" width="100" height="100">
            <h5 class="guild-title mb-1"><%= guild.name %></h5>

            <% if (guild.botInGuild) { %>
              <div class="guild-status text-success mb-3">
                <i class="fas fa-check-circle me-1"></i> Bot bereits drin
              </div>
            <% } else { %>
              <div class="guild-status text-danger mb-3">
                <i class="fas fa-exclamation-circle me-1"></i> Bot nicht eingeladen
              </div>
              <a href="<%= guild.settingsUrl %>" id="invite-btn-<%= guild.id %>" target="_blank" class="btn btn-outline-primary w-100">
                <i class="fas fa-plus-circle me-2"></i> Bot hinzufügen
              </a>
            <% } %>
          </div>
          <div class="card-footer bg-white text-center">
            <a href="<%= guild.settingsUrl %>" class="btn btn-primary btn-sm">Verwalten</a>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <% if (!guilds || guilds.length === 0) { %>
    <div class="alert alert-info text-center mt-5">
      <i class="fas fa-info-circle me-2"></i> Du hast keine Server, in denen du Besitzer (Owner) bist.
    </div>
    <div class="text-center">
      <a href="https://discord.com/new" target="_blank" class="btn btn-primary mt-3">
        <i class="fas fa-plus-circle me-2"></i> Neuen Discord Server erstellen
      </a>
    </div>
  <% } %>
</div>

<!-- Bot-Einladungsprozess mit automatischem Redirect -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Event-Listener für Bot-Einladung hinzufügen
  document.querySelectorAll('[id^="invite-btn-"]').forEach(button => {
    button.addEventListener('click', function(e) {
      const guildId = this.id.replace('invite-btn-', '');
      localStorage.setItem('pendingBotInvite', guildId);
      localStorage.setItem('inviteTimestamp', Date.now());
    });
  });
  
  // Prüfen, ob eine Bot-Einladung abgeschlossen wurde
  const pendingInvite = localStorage.getItem('pendingBotInvite');
  const inviteTimestamp = localStorage.getItem('inviteTimestamp');
  
  if (pendingInvite && inviteTimestamp) {
    // Nur prüfen, wenn die Einladung in den letzten 5 Minuten erfolgte
    const now = Date.now();
    if (now - parseInt(inviteTimestamp) < 5 * 60 * 1000) {
      checkBotStatus(pendingInvite);
    } else {
      // Alten Einladungsstatus löschen
      localStorage.removeItem('pendingBotInvite');
      localStorage.removeItem('inviteTimestamp');
    }
  }
  
  // Funktion zum Prüfen des Bot-Status
  function checkBotStatus(guildId) {
    // Status-Nachricht anzeigen
    const statusDiv = document.createElement('div');
    statusDiv.className = 'alert alert-info position-fixed top-0 start-50 translate-middle-x mt-3';
    statusDiv.style.zIndex = '1050';
    statusDiv.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Prüfe Bot-Status...';
    document.body.appendChild(statusDiv);
    
    // Verzögerung für den Fall, dass die Datenbank noch aktualisiert wird
    setTimeout(() => {
      fetch(`/api/bot-status/${guildId}`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.botInGuild) {
            // Bot ist in der Guild - Redirect zur Admin-Seite
            statusDiv.className = 'alert alert-success position-fixed top-0 start-50 translate-middle-x mt-3';
            statusDiv.innerHTML = '<i class="fas fa-check-circle me-2"></i> Bot erfolgreich hinzugefügt! Weiterleitung...';
            
            setTimeout(() => {
              // Einladungsstatus löschen und weiterleiten
              localStorage.removeItem('pendingBotInvite');
              localStorage.removeItem('inviteTimestamp');
              window.location.href = `/guild/${guildId}`;
            }, 1500);
          } else {
            // Bot ist nicht in der Guild - Status aktualisieren
            statusDiv.className = 'alert alert-warning position-fixed top-0 start-50 translate-middle-x mt-3';
            statusDiv.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i> Bot wurde noch nicht hinzugefügt. <button class="btn btn-sm btn-light ms-2" id="dismiss-status">Schließen</button>';
            
            document.getElementById('dismiss-status').addEventListener('click', function() {
              statusDiv.remove();
            });
            
            // Nach 30 Sekunden automatisch ausblenden
            setTimeout(() => {
              if (document.body.contains(statusDiv)) {
                statusDiv.remove();
              }
            }, 30000);
          }
        })
        .catch(error => {
          console.error('Fehler beim Prüfen des Bot-Status:', error);
          statusDiv.className = 'alert alert-danger position-fixed top-0 start-50 translate-middle-x mt-3';
          statusDiv.innerHTML = '<i class="fas fa-times-circle me-2"></i> Fehler beim Prüfen des Bot-Status. <button class="btn btn-sm btn-light ms-2" id="dismiss-status">Schließen</button>';
          
          document.getElementById('dismiss-status').addEventListener('click', function() {
            statusDiv.remove();
          });
        });
    }, 3000); // 3 Sekunden Verzögerung, um der Datenbank Zeit zu geben
  }
});
</script>
