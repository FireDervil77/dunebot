<!-- News Detail Section -->
<main id="main">
  <section class="news-detail section">
    <div class="container" data-aos="fade-up">
      <article class="news-article">
        <div class="meta d-flex align-items-center mb-4">
          <div class="d-flex align-items-center me-4">
            <i class="bi bi-calendar me-2"></i>
            <span><%= news.date %></span>
          </div>
          <% if (news.author) { %>
            <div class="d-flex align-items-center">
              <i class="bi bi-person me-2"></i>
              <span><%= news.author %></span>
            </div>
          <% } %>
        </div>

        <% if (news.image_url) { %>
          <div class="featured-image mb-4">
            <img src="<%= theme.asset(news.image_url) %>" class="img-fluid rounded" alt="<%= news.title %>">
          </div>
        <% } %>
        <div class="title"><h1><%= news.title %></h1></div>
        <div class="content">
          <%- news.content %>
        </div>

        <div class="mt-4">
          <a href="/#news" class="btn btn-primary">
            <i class="bi bi-arrow-left me-2"></i>
            <%= tr('NEWS.BACK_TO_NEWS') %>
          </a>
        </div>
      </article>
    </div>
  </section>
</main>

<style>
/* TinyMCE Content-Styling für News */
.news-article .content {
  line-height: 1.8;
  color: #333;
}

.news-article .content h2,
.news-article .content h3,
.news-article .content h4 {
  margin-top: 2rem;
  margin-bottom: 1rem;
  font-weight: 600;
  line-height: 1.3;
  color: #2c3e50;
}

.news-article .content h2 {
  font-size: 2rem;
  border-bottom: 2px solid var(--accent-color);
  padding-bottom: 0.5rem;
}

.news-article .content h3 {
  font-size: 1.5rem;
}

.news-article .content h4 {
  font-size: 1.25rem;
}

.news-article .content p {
  margin-bottom: 1.25rem;
  line-height: 1.8;
}

.news-article .content ul,
.news-article .content ol {
  margin-left: 2rem;
  margin-bottom: 1.25rem;
}

.news-article .content ul li,
.news-article .content ol li {
  margin-bottom: 0.5rem;
  line-height: 1.7;
}

.news-article .content strong {
  font-weight: 600;
  color: #2c3e50;
}

.news-article .content em {
  font-style: italic;
}

.news-article .content code {
  background: #f8f9fa;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  font-family: 'Courier New', monospace;
  font-size: 0.9em;
  color: #e83e8c;
}

.news-article .content pre {
  background: #f8f9fa;
  padding: 1.5rem;
  border-radius: 8px;
  overflow-x: auto;
  margin: 1.5rem 0;
  border-left: 4px solid var(--accent-color);
}

.news-article .content pre code {
  background: none;
  padding: 0;
  color: #333;
}

.news-article .content a {
  color: var(--accent-color);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s;
}

.news-article .content a:hover {
  border-bottom-color: var(--accent-color);
}

.news-article .content blockquote {
  border-left: 4px solid var(--accent-color);
  padding-left: 1.5rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: #6c757d;
  background: #f8f9fa;
  padding: 1rem 1rem 1rem 1.5rem;
  border-radius: 4px;
}

.news-article .content img {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1.5rem 0;
  box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.news-article .content table {
  width: 100%;
  margin: 1.5rem 0;
  border-collapse: collapse;
}

.news-article .content table th,
.news-article .content table td {
  padding: 0.75rem;
  border: 1px solid #dee2e6;
}

.news-article .content table th {
  background: #f8f9fa;
  font-weight: 600;
  text-align: left;
}

.news-article .content table tr:hover {
  background: #f8f9fa;
}

/* Responsive */
@media (max-width: 768px) {
  .news-article .content h2 {
    font-size: 1.5rem;
  }
  
  .news-article .content h3 {
    font-size: 1.25rem;
  }
  
  .news-article .content h4 {
    font-size: 1.1rem;
  }
}
</style>
  </section>
</main>