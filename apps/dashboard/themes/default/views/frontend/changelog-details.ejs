<!-- Changelog Detail Section -->
<main id="main">
  <section class="changelog-detail section">
    <div class="container" data-aos="fade-up">
      <article class="changelog-article">
        <!-- Header -->
        <div class="changelog-header mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <% 
            const typeColors = {
              major: 'danger',
              minor: 'warning',
              patch: 'info'
            };
            const badgeColor = typeColors[changelog.type] || 'secondary';
            %>
            <span class="badge bg-<%= badgeColor %> fs-3">
              v<%= changelog.version %>
            </span>
            <small class="text-muted">
              <i class="bi bi-calendar me-2"></i>
              <%= new Date(changelog.release_date).toLocaleDateString(currentLocale) %>
            </small>
          </div>
          
          <div class="title"><h1><%= changelog.title %></h1></div>
          
          <% if (changelog.description) { %>
            <p class="lead text-muted"><%= changelog.description %></p>
          <% } %>
          
          <div class="changelog-meta d-flex align-items-center gap-3 mt-3">
            <% 
            const typeIcons = {
              major: 'rocket',
              minor: 'star',
              patch: 'wrench'
            };
            const icon = typeIcons[changelog.type] || 'code-branch';
            %>
            <div class="d-flex align-items-center">
              <i class="bi bi-<%= icon %> me-2"></i>
              <span class="text-capitalize"><%= changelog.type %> Release</span>
            </div>
          </div>
        </div>

        <!-- Changes List -->
        <div class="content">
          <% if (hierarchicalData && hierarchicalData.length > 0) { %>
            <div class="changelog-hierarchical">
              <% hierarchicalData.forEach((group, groupIndex) => { %>
                <% if (group.type === 'group') { %>
                  <!-- Hauptgruppe (# Header) -->
                  <div class="change-group mb-5">
                    <h2 class="group-title mb-4">
                      <i class="bi bi-folder2-open me-2 text-primary"></i>
                      <%= group.title %>
                    </h2>
                    
                    <% (group.children || []).forEach((subgroup, subIndex) => { %>
                      <% if (subgroup.type === 'subgroup') { %>
                        <!-- Untergruppe (## Sub-Header) -->
                        <div class="change-subgroup mb-4">
                          <h3 class="subgroup-title mb-3">
                            <i class="bi bi-box me-2"></i>
                            <%= subgroup.title %>
                          </h3>
                          
                          <!-- ✅ NEU: Description anzeigen (falls vorhanden) -->
                          <% if (subgroup.description) { %>
                            <div class="subgroup-description mb-3">
                              <%- subgroup.description %>
                            </div>
                          <% } %>
                          
                          <% if (subgroup.items && subgroup.items.length > 0) { %>
                            <%
                            // Gruppiere Items nach Kategorie
                            const itemsByCategory = {};
                            subgroup.items.forEach(item => {
                              const category = item.category || 'Other';
                              if (!itemsByCategory[category]) {
                                itemsByCategory[category] = [];
                              }
                              itemsByCategory[category].push(item);
                            });
                            
                            // Kategorie-Reihenfolge
                            const categoryOrder = ['Features', 'Fixes', 'Changes', 'Removed', 'Other'];
                            const sortedCategories = Object.keys(itemsByCategory).sort((a, b) => {
                              const indexA = categoryOrder.indexOf(a);
                              const indexB = categoryOrder.indexOf(b);
                              return (indexA === -1 ? 999 : indexA) - (indexB === -1 ? 999 : indexB);
                            });
                            
                            // Icons und Übersetzungen für Kategorien
                            const categoryIcons = {
                              'Features': 'plus-circle text-success',
                              'Fixes': 'wrench text-warning',
                              'Changes': 'arrow-up-circle text-primary',
                              'Removed': 'dash-circle text-danger',
                              'Other': 'info-circle text-secondary'
                            };
                            
                            const categoryLabels = {
                              'Features': tr('CHANGELOGS.CHANGES.ADDED'),
                              'Fixes': tr('CHANGELOGS.CHANGES.FIXED'),
                              'Changes': tr('CHANGELOGS.CHANGES.IMPROVED'),
                              'Removed': tr('CHANGELOGS.CHANGES.REMOVED'),
                              'Other': tr('CHANGELOGS.CHANGES.OTHER')
                            };
                            %>
                            
                            <% sortedCategories.forEach(category => { %>
                              <div class="change-section mb-3">
                                <h4 class="change-title">
                                  <i class="bi bi-<%= categoryIcons[category] %> me-2"></i>
                                  <%= categoryLabels[category] %>
                                </h4>
                                <ul class="change-list">
                                  <% itemsByCategory[category].forEach(item => { %>
                                    <li><%- item.text %></li>
                                  <% }); %>
                                </ul>
                              </div>
                            <% }); %>
                          <% } %>
                        </div>
                      <% } %>
                    <% }); %>
                  </div>
                <% } %>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-muted"><em><%= tr('CHANGELOGS.NO_CHANGES') %></em></p>
          <% } %>
        </div>

        <div class="mt-5">
          <a href="/changelogs" class="btn btn-primary">
            <i class="bi bi-arrow-left me-2"></i>
            <%= tr('CHANGELOGS.BACK_TO_CHANGELOGS') %>
          </a>
        </div>
      </article>
    </div>
  </section>
</main>

<style>
.changelog-header {
  border-bottom: 2px solid #e9ecef;
  padding-bottom: 1.5rem;
}

.changelog-meta {
  color: #6c757d;
  font-size: 0.95rem;
}

/* Hierarchische Struktur */
.changelog-hierarchical {
  margin-top: 2rem;
}

.change-group {
  border-left: 4px solid var(--accent-color);
  padding-left: 1.5rem;
}

.group-title {
  font-size: 1.75rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 1.5rem;
}

.change-subgroup {
  background: #f8f9fa;
  padding: 1.5rem;
  border-radius: 8px;
  margin-left: 0.5rem;
}

.subgroup-title {
  font-size: 1.35rem;
  font-weight: 500;
  color: #495057;
  margin-bottom: 1rem;
}

/* ✅ NEU: Description-Styling */
.subgroup-description {
  background: #fff;
  padding: 1rem;
  border-left: 3px solid var(--accent-color);
  border-radius: 4px;
  color: #555;
  font-size: 0.95rem;
  line-height: 1.6;
  font-style: italic;
}

.subgroup-description strong {
  font-weight: 600;
  color: #333;
}

.subgroup-description em {
  font-style: italic;
}

.subgroup-description code {
  background: #f1f3f5;
  padding: 0.2rem 0.4rem;
  border-radius: 3px;
  font-family: 'Courier New', monospace;
  font-size: 0.9rem;
}

.change-section {
  margin-bottom: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid #dee2e6;
}

.change-section:last-child {
  border-bottom: none;
}

.change-title {
  font-size: 1.1rem;
  margin-bottom: 0.75rem;
  display: flex;
  align-items: center;
  font-weight: 500;
}

.change-list {
  list-style: none;
  padding-left: 0;
  margin-bottom: 0;
}

.change-list li {
  padding: 0.4rem 0;
  padding-left: 2rem;
  position: relative;
  line-height: 1.6;
}

.change-list li:before {
  content: "•";
  position: absolute;
  left: 0.75rem;
  color: var(--accent-color);
  font-weight: bold;
  font-size: 1.2rem;
}

/* TinyMCE Content-Styling */
.change-list li h2,
.change-list li h3,
.change-list li h4 {
  margin-top: 1rem;
  margin-bottom: 0.5rem;
  font-weight: 600;
  line-height: 1.3;
}

.change-list li h2 {
  font-size: 1.5rem;
}

.change-list li h3 {
  font-size: 1.25rem;
}

.change-list li h4 {
  font-size: 1.1rem;
}

.change-list li p {
  margin-bottom: 0.75rem;
  line-height: 1.6;
}

.change-list li ul,
.change-list li ol {
  margin-left: 1.5rem;
  margin-bottom: 0.75rem;
}

.change-list li ul li,
.change-list li ol li {
  padding-left: 0;
  margin-bottom: 0.25rem;
}

.change-list li ul li:before {
  content: "◦";
  font-size: 1rem;
}

.change-list li strong {
  font-weight: 600;
}

.change-list li em {
  font-style: italic;
}

.change-list li code {
  background: #f8f9fa;
  padding: 0.2rem 0.4rem;
  border-radius: 3px;
  font-family: 'Courier New', monospace;
  font-size: 0.9em;
}

.change-list li pre {
  background: #f8f9fa;
  padding: 1rem;
  border-radius: 5px;
  overflow-x: auto;
  margin: 0.5rem 0;
}

.change-list li a {
  color: var(--accent-color);
  text-decoration: none;
}

.change-list li a:hover {
  text-decoration: underline;
}

.change-list li blockquote {
  border-left: 4px solid var(--accent-color);
  padding-left: 1rem;
  margin: 0.75rem 0;
  font-style: italic;
  color: #6c757d;
}

/* Responsive */
@media (max-width: 768px) {
  .group-title {
    font-size: 1.5rem;
  }
  
  .subgroup-title {
    font-size: 1.2rem;
  }
  
  .change-subgroup {
    padding: 1rem;
    margin-left: 0;
  }
  
  .change-group {
    padding-left: 1rem;
  }
}
</style>
