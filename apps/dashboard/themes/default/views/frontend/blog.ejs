<!-- Blog Overview -->
<main id="main">
  <section class="blog-overview section">
    <div class="container" data-aos="fade-up">

      <div class="section-header text-center mb-5">
        <h2>Blog</h2>
        <p>Neuigkeiten rund um Gaming, Tutorials und mehr</p>
      </div>

      <% if (blogPosts && blogPosts.length > 0) { %>

        <%# Category Filter %>
        <% const allCategories = [...new Set(blogPosts.map(p => p.category).filter(Boolean))]; %>
        <% if (allCategories.length > 1) { %>
        <div class="text-center mb-4">
          <a href="/blog" class="btn btn-sm <%= !currentCategory ? 'btn-primary' : 'btn-outline-primary' %> me-1 mb-1">Alle</a>
          <% allCategories.forEach(cat => { %>
            <a href="/blog?category=<%= cat %>" 
               class="btn btn-sm <%= currentCategory === cat ? 'btn-primary' : 'btn-outline-primary' %> me-1 mb-1">
              <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
            </a>
          <% }); %>
        </div>
        <% } %>

        <div class="row gy-4">
          <% blogPosts.forEach(post => { %>
          <div class="col-lg-4 col-md-6">
            <article class="blog-card card h-100 shadow-sm border-0">
              <% if (post.image_url) { %>
                <a href="/blog/<%= post.slug %>">
                  <img src="<%= theme.asset(post.image_url) %>" class="card-img-top" alt="<%= post.title %>" 
                       style="height: 200px; object-fit: cover;">
                </a>
              <% } else { %>
                <a href="/blog/<%= post.slug %>">
                  <div class="card-img-top d-flex align-items-center justify-content-center" 
                       style="height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <i class="bi bi-controller" style="font-size: 3rem; color: rgba(255,255,255,0.7);"></i>
                  </div>
                </a>
              <% } %>
              <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center mb-2">
                  <span class="badge bg-primary bg-opacity-10 text-primary me-2">
                    <%= (post.category || 'gaming').charAt(0).toUpperCase() + (post.category || 'gaming').slice(1) %>
                  </span>
                  <small class="text-muted">
                    <i class="bi bi-calendar me-1"></i><%= post.formattedDate %>
                  </small>
                </div>
                <h5 class="card-title">
                  <a href="/blog/<%= post.slug %>" class="text-decoration-none text-dark">
                    <%= post.title %>
                  </a>
                </h5>
                <% if (post.excerpt) { %>
                  <p class="card-text text-muted flex-grow-1"><%= post.excerpt.replace(/<[^>]+>/g, '').substring(0, 150) %><%= post.excerpt.replace(/<[^>]+>/g, '').length > 150 ? '...' : '' %></p>
                <% } %>
                <div class="mt-auto pt-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                      <i class="bi bi-person me-1"></i><%= post.author || 'Admin' %>
                    </small>
                    <a href="/blog/<%= post.slug %>" class="btn btn-sm btn-outline-primary">
                      Weiterlesen <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                  </div>
                </div>
              </div>
            </article>
          </div>
          <% }); %>
        </div>

      <% } else { %>
        <div class="text-center py-5">
          <i class="bi bi-journal-text" style="font-size: 4rem; color: #ccc;"></i>
          <p class="mt-3 text-muted">Noch keine Blog-Posts vorhanden.</p>
        </div>
      <% } %>

    </div>
  </section>
</main>

<style>
.blog-overview .blog-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border-radius: 12px;
  overflow: hidden;
}
.blog-overview .blog-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.12) !important;
}
.blog-overview .card-title a:hover {
  color: var(--accent-color) !important;
}
</style>
