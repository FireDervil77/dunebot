<%# 
 * Frontend: Dokumentation (öffentlich)
 * Rendert Markdown-Dokumentation mit Sidebar-Navigation.
 *
 * @context {String} docTitle    - Seitentitel
 * @context {String} htmlContent - Gerendertes HTML aus Markdown
 * @context {Array}  nav         - Dateibaum [{name, path, type, children?}]
 * @context {String} currentPath - Aktuell angezeigte Seite (relativer Pfad ohne .md)
%>

<main id="main">
  <section class="docs-page section">
    <div class="container" data-aos="fade-up">

      <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3 col-md-4 mb-4">
          <div class="docs-sidebar">
            <h5 class="docs-sidebar-title">
              <i class="bi bi-book me-2"></i>Dokumentation
            </h5>
            <nav class="docs-nav">
              <a href="/docs" class="docs-nav-link <%= !currentPath ? 'active' : '' %>">
                <i class="bi bi-house me-1"></i> Übersicht
              </a>
              <% function renderNav(items, depth) { %>
                <% items.forEach(item => { %>
                  <% if (item.type === 'folder') { %>
                    <div class="docs-nav-group" style="padding-left: <%= depth * 12 %>px;">
                      <span class="docs-nav-folder">
                        <i class="bi bi-folder me-1"></i><%= item.name %>
                      </span>
                      <% if (item.children) { renderNav(item.children, depth + 1); } %>
                    </div>
                  <% } else { %>
                    <a href="/docs/<%= item.path %>" 
                       class="docs-nav-link <%= currentPath === item.path ? 'active' : '' %>"
                       style="padding-left: <%= (depth * 12) + 8 %>px;">
                      <%= item.name %>
                    </a>
                  <% } %>
                <% }); %>
              <% } %>
              <% if (nav && nav.length > 0) { renderNav(nav, 0); } %>
            </nav>
          </div>
        </div>

        <!-- Content -->
        <div class="col-lg-9 col-md-8">
          <article class="docs-content">
            <div class="docs-article">
              <%- htmlContent %>
            </div>

            <!-- Navigation unten -->
            <div class="docs-footer-nav mt-5 pt-4 border-top">
              <a href="/docs" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Zurück zur Übersicht
              </a>
            </div>
          </article>
        </div>
      </div>

    </div>
  </section>
</main>

<style>
  .docs-page {
    padding: 80px 0 60px;
    min-height: 70vh;
  }
  .docs-sidebar {
    position: sticky;
    top: 100px;
  }
  .docs-sidebar-title {
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--accent-color, #4154f1);
  }
  .docs-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .docs-nav-link {
    display: block;
    padding: 6px 12px;
    color: var(--default-color, #444);
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .docs-nav-link:hover {
    background: rgba(65, 84, 241, 0.08);
    color: var(--accent-color, #4154f1);
  }
  .docs-nav-link.active {
    background: var(--accent-color, #4154f1);
    color: #fff;
    font-weight: 600;
  }
  .docs-nav-folder {
    display: block;
    padding: 8px 12px 4px;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--heading-color, #2a2c39);
    margin-top: 8px;
  }
  .docs-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .docs-article h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem; }
  .docs-article h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #eee; }
  .docs-article h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; }
  .docs-article code {
    background: #f4f5f7;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
    color: #d63384;
  }
  .docs-article pre {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .docs-article pre code {
    background: none;
    color: inherit;
    padding: 0;
  }
  .docs-article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  .docs-article th, .docs-article td {
    border: 1px solid #dee2e6;
    padding: 8px 12px;
    text-align: left;
  }
  .docs-article th {
    background: #f8f9fa;
    font-weight: 600;
  }
  .docs-article img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
  .docs-article blockquote {
    border-left: 4px solid var(--accent-color, #4154f1);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    background: rgba(65, 84, 241, 0.05);
    border-radius: 0 4px 4px 0;
  }
  .docs-article blockquote p:last-child { margin-bottom: 0; }

  @media (max-width: 768px) {
    .docs-sidebar {
      position: static;
      margin-bottom: 2rem;
    }
  }
</style>
