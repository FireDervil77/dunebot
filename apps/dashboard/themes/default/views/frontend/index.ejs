<main class="main">

<%#
 * Frontend Landing Page — Dynamisches Sektions-Rendering
 * Sektionen werden aus `frontpage_sections` DB-Tabelle geladen.
 * Reihenfolge und Sichtbarkeit sind über /admin/themes/frontpage steuerbar.
 * Divider werden manuell (divider_before) oder automatisch gesteuert.
 *
 * @context {Array} sections      - Sichtbare Sektionen sortiert nach Position
 * @context {Array} newsList      - Lokalisierte News
 * @context {Array} carouselNews  - Letzte 3 News für Hero-Carousel
 * @context {Array} changelogsList - Lokalisierte Changelogs
 * @context {Array} pluginsList   - Plugins aus Filesystem
%>

<%
  // Divider-Logik: dark→light oder light→dark zwischen Sektionen
  const darkTypes = new Set(['hero', 'features', 'changelogs', 'documentation']);
  const lightTypes = new Set(['news']);

  function isDark(section) {
    if (section.css_class === 'dark-background') return true;
    if (section.css_class === 'light-background') return false;
    return darkTypes.has(section.section_type);
  }

  // Partial-Map: section_type → Partial-Pfad
  const partialMap = {
    hero: 'frontend/sections/hero',
    features: 'frontend/sections/features',
    news: 'frontend/sections/news',
    changelogs: 'frontend/sections/changelogs',
    plugins: 'frontend/sections/plugins',
    documentation: 'frontend/sections/documentation',
    stats: 'frontend/sections/stats',
    skills: 'frontend/sections/skills',
    custom: 'frontend/sections/custom'
  };
%>

<% sections.forEach(function(section, index) { %>
  <%
    // Divider vor dieser Sektion (außer bei der ersten)
    if (index > 0) {
      const dividerSetting = section.divider_before || 'auto';

      if (dividerSetting === 'none') {
        // Kein Divider
      } else if (dividerSetting === 'light-to-dark') {
  %>
    <div class="section-divider divider-light-to-dark"></div>
  <%  } else if (dividerSetting === 'dark-to-light') { %>
    <div class="section-divider divider-dark-to-light"></div>
  <%  } else {
        // auto: berechne basierend auf vorheriger/aktueller Sektion
        const prevDark = isDark(sections[index - 1]);
        const currDark = isDark(section);
        if (prevDark && !currDark) {
  %>
    <div class="section-divider divider-dark-to-light"></div>
  <%    } else if (!prevDark && currDark) { %>
    <div class="section-divider divider-light-to-dark"></div>
  <%    }
      }
    }
  %>

  <%
    const partialPath = partialMap[section.section_type];
    if (partialPath) {
      // Custom-Sektionen brauchen auch die section-Row selbst
      const partialData = { sectionConfig: section.config || {} };
      if (section.section_type === 'custom') {
        partialData.sectionConfig.custom_html = section.custom_html || '';
      }
  %>
    <%- include('../../partials/' + partialPath, partialData) %>
  <% } %>

<% }); %>

</main>
