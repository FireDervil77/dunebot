<section id="tos" class="tos-page section dark-background">
  <div class="tos-container">
    <h1 class="text-center">📜 <%= tr('TOS.PAGE_TITLE') %></h1>
    <p class="text-center"><strong><%= tr('TOS.LAST_UPDATED') %></strong> <em><%= tr('TOS.LAST_UPDATED_DATE') %></em></p>
    <p class="text-center"><strong><%= tr('TOS.SCOPE') %></strong> <%= tr('TOS.SCOPE_TEXT') %></p>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION1_TITLE') %></div>
      <p>
        <%= tr('TOS.SECTION1_TEXT') %>
      </p>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION2_TITLE') %></div>
      <ul class="tos-list">
        <li><%= tr('TOS.SECTION2_ITEM1') %></li>
        <li><%= tr('TOS.SECTION2_ITEM2') %></li>
        <li><%= tr('TOS.SECTION2_ITEM3') %></li>
      </ul>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION3_TITLE') %></div>
      <ul class="tos-list">
        <li><%= tr('TOS.SECTION3_ITEM1') %></li>
        <li><%= tr('TOS.SECTION3_ITEM2') %></li>
      </ul>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION4_TITLE') %></div>
      <p>
        <%= tr('TOS.SECTION4_P1') %><br>
        <%= tr('TOS.SECTION4_P2') %>
      </p>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION5_TITLE') %></div>
      <p>
        <%= tr('TOS.SECTION5_INTRO') %>
      </p>
      <ul class="tos-list">
        <li><%= tr('TOS.SECTION5_ITEM1') %></li>
        <li><%= tr('TOS.SECTION5_ITEM2') %></li>
      </ul>
      <p>
        <%= tr('TOS.SECTION5_P1') %><br>
        <%= tr('TOS.SECTION5_P2') %> <a href="/privacy"><%= tr('TOS.SECTION5_PRIVACY_LINK') %></a>.
      </p>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION6_TITLE') %></div>
      <p>
        <%= tr('TOS.SECTION6_TEXT') %>
      </p>
    </div>

    <div class="tos-section">
      <div class="section-title text-center"><%= tr('TOS.SECTION7_TITLE') %></div>
      <p>
        <%= tr('TOS.SECTION7_TEXT') %>
        <a href="mailto:<%= tr('TOS.SECTION7_EMAIL') %>" class="text-primary"><%= tr('TOS.SECTION7_EMAIL') %></a>
        <%= tr('TOS.SECTION7_OR') %>
        <a href="https://discord.gg/AKZv8rqg9X" class="text-primary" target="_blank"><%= tr('TOS.SECTION7_DISCORD') %></a>.
      </p>
      <p class="text-center">
        <a href="/" class="back-link text-primary"><i class="fas fa-arrow-left"></i> <%= tr('TOS.BACK_TO_HOME') %></a>
      </p>
    </div>
  </div>
</section>