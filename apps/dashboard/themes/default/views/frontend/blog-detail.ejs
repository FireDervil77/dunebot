<!-- Blog Post Detail -->
<main id="main">
  <section class="blog-detail section">
    <div class="container" data-aos="fade-up">
      <article class="blog-article">
        <div class="meta d-flex align-items-center mb-4">
          <div class="d-flex align-items-center me-3">
            <i class="bi bi-calendar me-2"></i>
            <span><%= post.formattedDate %></span>
          </div>
          <% if (post.author) { %>
            <div class="d-flex align-items-center me-3">
              <i class="bi bi-person me-2"></i>
              <span><%= post.author %></span>
            </div>
          <% } %>
          <% if (post.category) { %>
            <span class="badge bg-primary bg-opacity-10 text-primary">
              <%= post.category.charAt(0).toUpperCase() + post.category.slice(1) %>
            </span>
          <% } %>
        </div>

        <% if (post.image_url) { %>
          <div class="featured-image mb-4">
            <img src="<%= theme.asset(post.image_url) %>" class="img-fluid rounded" alt="<%= post.title %>">
          </div>
        <% } %>

        <div class="title"><h1><%= post.title %></h1></div>

        <% if (post.tags) { %>
          <div class="tags mb-4">
            <% post.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
              <span class="badge bg-secondary bg-opacity-10 text-secondary me-1">
                <i class="bi bi-tag me-1"></i><%= tag %>
              </span>
            <% }); %>
          </div>
        <% } %>

        <div class="content">
          <%- post.content %>
        </div>

        <div class="mt-5 pt-3 border-top">
          <a href="/blog" class="btn btn-primary">
            <i class="bi bi-arrow-left me-2"></i>
            Zurück zum Blog
          </a>
        </div>
      </article>
    </div>
  </section>
</main>

<style>
.blog-article .content {
  line-height: 1.8;
  color: #333;
}
.blog-article .content h2,
.blog-article .content h3,
.blog-article .content h4 {
  margin-top: 2rem;
  margin-bottom: 1rem;
  font-weight: 600;
  line-height: 1.3;
  color: #2c3e50;
}
.blog-article .content h2 {
  font-size: 2rem;
  border-bottom: 2px solid var(--accent-color);
  padding-bottom: 0.5rem;
}
.blog-article .content h3 { font-size: 1.5rem; }
.blog-article .content h4 { font-size: 1.25rem; }
.blog-article .content p {
  margin-bottom: 1.25rem;
  line-height: 1.8;
}
.blog-article .content ul,
.blog-article .content ol {
  margin-left: 2rem;
  margin-bottom: 1.25rem;
}
.blog-article .content ul li,
.blog-article .content ol li {
  margin-bottom: 0.5rem;
  line-height: 1.7;
}
.blog-article .content strong {
  font-weight: 600;
  color: #2c3e50;
}
.blog-article .content code {
  background: #f8f9fa;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  font-size: 0.9em;
}
.blog-article .content blockquote {
  border-left: 4px solid var(--accent-color);
  padding: 1rem 1.5rem;
  margin: 1.5rem 0;
  background: #f8f9fa;
  border-radius: 0 8px 8px 0;
}
.blog-article .content img {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1rem 0;
}
</style>
