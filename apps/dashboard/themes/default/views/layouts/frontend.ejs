<!-- filepath: /home/firedervil/dunebot_new/apps/dashboard/themes/default/layouts/frontend.ejs -->
<!doctype html>
<html lang="<%= locals.lang || 'de' %>" class="<%= locals.theme?.info?.darkMode ? 'dark' : '' %>">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title ? `${title} - ${locals.dashboardLogo?.name || 'DuneBot'}` : `${locals.dashboardLogo?.name || 'DuneBot'} - Der Discord-Bot für deine Community` %></title>
    
    <!-- Dashboard Logo Config -->
    <script>
      window.DASHBOARD_CONFIG = {
        logoName: '<%= locals.dashboardLogo?.name || "DuneBot" %>',
        logoUrl: '<%= locals.dashboardLogo?.url || "/images/logo.png" %>'
      };
    </script>
    
    <!-- Meta & SEO -->
    <%- includePartial('frontend/header', locals) %>
    
    <!-- Stylesheets (Fonts, Icons, Vendor CSS, Theme CSS) -->
    <%- includePartial('frontend/stylesheets', locals) %>
    
    <!-- Hook: frontend_head -->
    <% if (locals.hooks && hooks.getViewHooks) { %>
      <% const headHooks = hooks.getViewHooks('frontend_head'); %>
      <% if (headHooks && headHooks.length > 0) { %>
        <% headHooks.forEach(hook => { %>
          <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
      <% } %>
    <% } %>
  </head>

  <body class="landing-page">
    <!-- Navigation -->
    <%- includePartial('frontend/header_nav', { locals }) %>
    
    <!-- Hook: before_frontend_content -->
    <% if (locals.hooks && hooks.getViewHooks) { %>
      <% const beforeContentHooks = hooks.getViewHooks('before_frontend_content'); %>
      <% if (beforeContentHooks && beforeContentHooks.length > 0) { %>
        <% beforeContentHooks.forEach(hook => { %>
          <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
      <% } %>
    <% } %>
    
    <!-- Main Content -->
    <%- body %>
    
    <!-- Hook: after_frontend_content -->
    <% if (locals.hooks && hooks.getViewHooks) { %>
      <% const afterContentHooks = hooks.getViewHooks('after_frontend_content'); %>
      <% if (afterContentHooks && afterContentHooks.length > 0) { %>
        <% afterContentHooks.forEach(hook => { %>
          <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
      <% } %>
    <% } %>

    <!-- Footer -->
    <%- includePartial('frontend/footer', locals) %>
    
    <!-- Scripts (jQuery + Bootstrap + Vendor) -->
    <%- includePartial('frontend/scripts', locals) %>
    
    <!-- Hook: frontend_footer_scripts -->
    <% if (locals.hooks && hooks.getViewHooks) { %>
      <% const footerScriptHooks = hooks.getViewHooks('frontend_footer_scripts'); %>
      <% if (footerScriptHooks && footerScriptHooks.length > 0) { %>
        <% footerScriptHooks.forEach(hook => { %>
          <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
      <% } %>
    <% } %>
  </body>
</html>