<!DOCTYPE html>
<html lang="<%= locals.lang || 'de' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title ? `${title} - FireBot` : 'FireBot - Authentifizierung' %></title>
    
    <!-- Favicon -->
    <link rel="icon" href="<%= theme.asset('images/favicon.ico') %>" type="image/x-icon">
    
    <!-- Theme CSS -->
    <link rel="stylesheet" href="<%= theme.asset('css/adminlte.min.css') %>">
    <link rel="stylesheet" href="<%= theme.asset('css/auth.css') %>">

    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="/public/vendor/bootstrap/css/bootstrap.min.css?v=<%= cacheBuster %>" type="text/css">

    <!-- Hook: auth_head -->
    <% if (locals.hooks && hooks.getViewHooks) { %>
        <% const headHooks = hooks.getViewHooks('auth_head'); %>
        <% if (headHooks && headHooks.length > 0) { %>
            <% headHooks.forEach(hook => { %>
                <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
            <% }); %>
        <% } %>
    <% } %>
</head>
<body class="login-page bg-body-secondary">
                              
<!-- Hook: before_auth_content -->
<% if (locals.hooks && hooks.getViewHooks) { %>
    <% const beforeContentHooks = hooks.getViewHooks('auth_before_content'); %>
    <% if (beforeContentHooks && beforeContentHooks.length > 0) { %>
        <% beforeContentHooks.forEach(hook => { %>
            <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
    <% } %>
<% } %>

<!-- Main Content -->
<%- body %>

<!-- Hook: after_auth_content -->
<% if (locals.hooks && hooks.getViewHooks) { %>
    <% const afterContentHooks = hooks.getViewHooks('auth_after_content'); %>
    <% if (afterContentHooks && afterContentHooks.length > 0) { %>
        <% afterContentHooks.forEach(hook => { %>
            <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
    <% } %>
<% } %>

<!-- Footer -->
<p class="mt-3 mb-3 text-body-secondary">
    &copy; <%= new Date().getFullYear() %> FireBot
</p>

</main>

<!-- jQuery (von CDN mit CSP-konformer Quelle) -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  
<!-- Bootstrap JS (optional lokal) -->
<script src="/public/vendor/bootstrap/js/bootstrap.bundle.min.js?v=<%= cacheBuster %>"></script>

<!-- Theme JS -->
<script src="<%= theme.asset('js/adminlte.min.js') %>"></script>
<script src="<%= theme.asset('js/auth.js') %>"></script>

<!-- Hook: auth_footer_scripts -->
<% if (locals.hooks && hooks.getViewHooks) { %>
    <% const footerScriptHooks = hooks.getViewHooks('auth_footer_scripts'); %>
    <% if (footerScriptHooks && footerScriptHooks.length > 0) { %>
        <% footerScriptHooks.forEach(hook => { %>
            <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
        <% }); %>
    <% } %>
<% } %>
</body>
</html>