<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <%= notification && notification.id ? tr('NOTIFICATIONS.EDIT_NOTIFICATION') : tr('NOTIFICATIONS.NEW_NOTIFICATION') %>
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/admin">SuperAdmin</a></li>
                    <li class="breadcrumb-item"><a href="/admin/notifications"><%= tr('NOTIFICATIONS.TITLE') %></a></li>
                    <li class="breadcrumb-item active"><%= notification && notification.id ? tr('NOTIFICATIONS.EDIT') : tr('NOTIFICATIONS.NEW') %></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<%
    // Parse delivery_methods (backwards compat: string → array)
    let deliveryMethods = [];
    if (notification?.delivery_method) {
        try {
            const parsed = JSON.parse(notification.delivery_method);
            deliveryMethods = Array.isArray(parsed) ? parsed : [notification.delivery_method];
        } catch(e) {
            deliveryMethods = [notification.delivery_method];
        }
    }
    if (deliveryMethods.length === 0) deliveryMethods = ['dashboard'];
    // Expand legacy 'all' value
    if (deliveryMethods.includes('all')) {
        deliveryMethods = ['dashboard', 'system_channel', 'discord_channel', 'discord_dm'];
    }
    // Migrate old 'discord_channel' (was system channel) if no system_channel present
    // Keep as-is for new multi-select
%>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    const targetGuildsSelect = document.getElementById('target_guild_ids');
    const channelPickerGroup = document.getElementById('channel-picker-group');
    const channelSelect = document.getElementById('discord_channel_id');
    const discordSections = document.getElementById('discord-options-section');

    // Toggle Discord-Optionen basierend auf Checkboxes
    function toggleDiscordOptions() {
        const needsChannel = document.getElementById('dm_discord_channel')?.checked;
        const needsDiscord = document.getElementById('dm_system_channel')?.checked || 
                             needsChannel || 
                             document.getElementById('dm_discord_dm')?.checked;

        if (channelPickerGroup) {
            channelPickerGroup.style.display = needsChannel ? 'block' : 'none';
        }
        if (discordSections) {
            discordSections.style.display = needsDiscord ? 'block' : 'none';
        }
    }

    document.querySelectorAll('.delivery-method-cb').forEach(function(cb) {
        cb.addEventListener('change', toggleDiscordOptions);
    });
    toggleDiscordOptions(); // Initial

    // Lade Bot-Guilds
    try {
        const response = await fetch('/api/bot-guilds');
        const data = await response.json();

        if (data.success && data.guilds) {
            targetGuildsSelect.innerHTML = '';
            const sortedGuilds = data.guilds.sort((a, b) => a.name.localeCompare(b.name));

            sortedGuilds.forEach(function(guild) {
                const option = document.createElement('option');
                option.value = guild.id;
                option.textContent = guild.name + ' (' + guild.memberCount + ' Members)';

                <% if (notification?.target_guild_ids) { %>
                try {
                    const raw = '<%= notification.target_guild_ids %>';
                    const targetIds = JSON.parse(raw);
                    if (Array.isArray(targetIds) && targetIds.includes(guild.id)) {
                        option.selected = true;
                    }
                } catch (e) {}
                <% } %>

                targetGuildsSelect.appendChild(option);
            });

            // Channel-Picker: Lade Channels wenn nur EINE Guild gewählt
            targetGuildsSelect.addEventListener('change', loadChannelsForSelectedGuild);
            loadChannelsForSelectedGuild();
        } else {
            targetGuildsSelect.innerHTML = '<option value="" disabled>Fehler beim Laden</option>';
        }
    } catch (error) {
        targetGuildsSelect.innerHTML = '<option value="" disabled>Fehler beim Laden</option>';
        console.error('Fehler beim Laden der Bot-Guilds:', error);
    }

    // Channel-Picker: Channels einer Guild laden
    async function loadChannelsForSelectedGuild() {
        const selected = Array.from(targetGuildsSelect.selectedOptions).map(o => o.value);
        if (selected.length !== 1) {
            channelSelect.innerHTML = '<option value="">Zuerst genau einen Server wählen</option>';
            channelSelect.disabled = true;
            return;
        }
        channelSelect.innerHTML = '<option value="">Lade Channels...</option>';
        channelSelect.disabled = true;
        try {
            const resp = await fetch('/api/guild-channels/' + selected[0]);
            const data = await resp.json();
            if (data.success && data.channels) {
                channelSelect.innerHTML = '<option value="">(System-Channel verwenden)</option>';
                let currentCategory = '';
                data.channels.forEach(function(ch) {
                    if (ch.parentName && ch.parentName !== currentCategory) {
                        currentCategory = ch.parentName;
                        const optGroup = document.createElement('optgroup');
                        optGroup.label = ch.parentName;
                        // Sammle alle Channels dieser Category
                        data.channels.filter(c => c.parentName === ch.parentName).forEach(function(c) {
                            const opt = document.createElement('option');
                            opt.value = c.id;
                            opt.textContent = '#' + c.name;
                            <% if (notification?.discord_channel_id) { %>
                            if (c.id === '<%= notification.discord_channel_id %>') opt.selected = true;
                            <% } %>
                            optGroup.appendChild(opt);
                        });
                        channelSelect.appendChild(optGroup);
                    }
                });
                // Channels ohne Category
                data.channels.filter(c => !c.parentName).forEach(function(ch) {
                    const opt = document.createElement('option');
                    opt.value = ch.id;
                    opt.textContent = '#' + ch.name;
                    <% if (notification?.discord_channel_id) { %>
                    if (ch.id === '<%= notification.discord_channel_id %>') opt.selected = true;
                    <% } %>
                    channelSelect.appendChild(opt);
                });
                channelSelect.disabled = false;
            }
        } catch (err) {
            channelSelect.innerHTML = '<option value="">Fehler beim Laden</option>';
            console.error('Channel-Laden fehlgeschlagen:', err);
        }
    }

    // Form-Submit: Konvertiere Daten
    document.querySelector('form').addEventListener('submit', function() {
        // Target Guild IDs
        const selectedGuilds = Array.from(targetGuildsSelect.selectedOptions).map(o => o.value);
        var hiddenGuilds = document.createElement('input');
        hiddenGuilds.type = 'hidden';
        hiddenGuilds.name = 'target_guild_ids';
        hiddenGuilds.value = selectedGuilds.length > 0 ? JSON.stringify(selectedGuilds) : '';
        targetGuildsSelect.name = '';
        this.appendChild(hiddenGuilds);

        // Delivery Methods als JSON-Array
        var methods = [];
        document.querySelectorAll('.delivery-method-cb:checked').forEach(function(cb) {
            methods.push(cb.value);
        });
        if (methods.length === 0) methods.push('dashboard');
        var hiddenMethods = document.createElement('input');
        hiddenMethods.type = 'hidden';
        hiddenMethods.name = 'delivery_method';
        hiddenMethods.value = JSON.stringify(methods);
        this.appendChild(hiddenMethods);
    });
});
</script>

<div class="content">
    <div class="container-fluid">
        <% if (locals.toast) { %>
            <div class="alert alert-<%= toast.type %> alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <%= toast.message %>
            </div>
        <% } %>

        <form class="guild-ajax-form" 
              data-form-type="notification-save" 
              data-method="POST"
              action="/admin/notifications/save" 
              method="POST">
            <input type="hidden" name="guildId" value="<%= guildId %>">
            <% if (notification && notification.id) { %>
                <input type="hidden" name="notificationId" value="<%= notification.id %>">
            <% } %>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><%= tr('NOTIFICATIONS.DETAILS') %></h3>
                </div>
                <div class="card-body">
                    <!-- Sprach-Tabs -->
                    <ul class="nav nav-tabs mb-3" id="langTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="de-tab" data-toggle="tab" href="#de-content" role="tab">
                                <i class="fas fa-flag mr-1"></i> Deutsch
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="en-tab" data-toggle="tab" href="#en-content" role="tab">
                                <i class="fas fa-flag mr-1"></i> English
                            </a>
                        </li>
                    </ul>

                    <div class="tab-content" id="langTabContent">
                        <!-- Deutsch Tab -->
                        <div class="tab-pane fade show active" id="de-content" role="tabpanel">
                            <div class="form-group">
                                <label for="title_de"><%= tr('NOTIFICATIONS.FORM.TITLE') %> (DE) <span class="text-danger">*</span></label>
                                <input type="text" 
                                       class="form-control" 
                                       id="title_de" 
                                       name="title_de" 
                                       value="<%= notification?.title_de || '' %>"
                                       required>
                            </div>

                            <div class="form-group">
                                <label for="message_de"><%= tr('NOTIFICATIONS.FORM.MESSAGE') %> (DE) <span class="text-danger">*</span></label>
                                <textarea class="form-control" 
                                          id="message_de" 
                                          name="message_de" 
                                          rows="4" 
                                          required><%= notification?.message_de || '' %></textarea>
                            </div>

                            <div class="form-group">
                                <label for="action_text_de"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT') %> (DE)</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="action_text_de" 
                                       name="action_text_de" 
                                       value="<%= notification?.action_text_de || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT_HELP') %></small>
                            </div>
                        </div>

                        <!-- English Tab -->
                        <div class="tab-pane fade" id="en-content" role="tabpanel">
                            <div class="form-group">
                                <label for="title_en"><%= tr('NOTIFICATIONS.FORM.TITLE') %> (EN) <small class="text-muted">(optional)</small></label>
                                <input type="text" 
                                       class="form-control" 
                                       id="title_en" 
                                       name="title_en" 
                                       value="<%= notification?.title_en || '' %>">
                            </div>

                            <div class="form-group">
                                <label for="message_en"><%= tr('NOTIFICATIONS.FORM.MESSAGE') %> (EN) <small class="text-muted">(optional)</small></label>
                                <textarea class="form-control" 
                                          id="message_en" 
                                          name="message_en" 
                                          rows="4"><%= notification?.message_en || '' %></textarea>
                            </div>

                            <div class="form-group">
                                <label for="action_text_en"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT') %> (EN)</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="action_text_en" 
                                       name="action_text_en" 
                                       value="<%= notification?.action_text_en || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT_HELP') %></small>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <!-- Gemeinsame Felder -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="type"><%= tr('NOTIFICATIONS.FORM.TYPE') %> <span class="text-danger">*</span></label>
                                <select class="form-control" id="type" name="type" required>
                                    <option value="info" <%= notification?.type === 'info' ? 'selected' : '' %>>
                                        <i class="fas fa-info-circle"></i> Info
                                    </option>
                                    <option value="warning" <%= notification?.type === 'warning' ? 'selected' : '' %>>
                                        <i class="fas fa-exclamation-triangle"></i> Warning
                                    </option>
                                    <option value="error" <%= notification?.type === 'error' ? 'selected' : '' %>>
                                        <i class="fas fa-exclamation-circle"></i> Error
                                    </option>
                                    <option value="success" <%= notification?.type === 'success' ? 'selected' : '' %>>
                                        <i class="fas fa-check-circle"></i> Success
                                    </option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="action_url"><%= tr('NOTIFICATIONS.FORM.ACTION_URL') %></label>
                                <input type="url" 
                                       class="form-control" 
                                       id="action_url" 
                                       name="action_url" 
                                       value="<%= notification?.action_url || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_URL_HELP') %></small>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="expiry"><%= tr('NOTIFICATIONS.FORM.EXPIRES_AT') %></label>
                        <input type="datetime-local" 
                               class="form-control" 
                               id="expiry" 
                               name="expiry" 
                               value="<%= notification?.expiry ? new Date(notification.expiry).toISOString().slice(0, 16) : '' %>">
                        <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.EXPIRES_AT_HELP') %></small>
                    </div>

                    <hr>

                    <!-- Delivery Options -->
                    <h5 class="mb-3"><i class="fas fa-paper-plane mr-2"></i> Zustellungs-Optionen</h5>
                    
                    <div class="form-group">
                        <label>Wie soll die Benachrichtigung zugestellt werden?</label>
                        <div class="ml-2">
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_dashboard" value="dashboard"
                                       <%= deliveryMethods.includes('dashboard') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_dashboard">
                                    📊 Im Dashboard anzeigen
                                </label>
                            </div>
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_system_channel" value="system_channel"
                                       <%= deliveryMethods.includes('system_channel') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_system_channel">
                                    📢 Im System-Channel senden
                                </label>
                            </div>
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_discord_channel" value="discord_channel"
                                       <%= deliveryMethods.includes('discord_channel') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_discord_channel">
                                    💬 Im ausgewählten Discord-Channel senden
                                </label>
                            </div>
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_discord_dm" value="discord_dm"
                                       <%= deliveryMethods.includes('discord_dm') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_discord_dm">
                                    ✉️ DM an Server-Admins senden
                                </label>
                            </div>
                        </div>
                        <small class="form-text text-muted">
                            Mehrere Methoden gleichzeitig auswählbar
                        </small>
                    </div>

                    <div id="discord-options-section" style="display: none;">
                        <div class="form-group" id="channel-picker-group" style="display: none;">
                            <label for="discord_channel_id">Discord-Channel</label>
                            <select class="form-control" id="discord_channel_id" name="discord_channel_id" disabled>
                                <option value="">Zuerst einen Server wählen</option>
                            </select>
                            <small class="form-text text-muted">
                                Leer lassen = System-Channel verwenden. Wähle zuerst genau einen Ziel-Server.
                            </small>
                        </div>

                        <div class="form-group">
                            <label for="target_guild_ids">Ziel-Server (optional)</label>
                            <select class="form-control" 
                                    id="target_guild_ids" 
                                    name="target_guild_ids" 
                                    multiple
                                    size="8"
                                    style="height: auto;">
                                <option value="" disabled>Lade Server-Liste...</option>
                            </select>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle"></i> Halte <kbd>Strg</kbd> (Windows) oder <kbd>Cmd</kbd> (Mac) gedrückt, um mehrere Server auszuwählen. Leer lassen = an alle Server senden.
                            </small>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i><%= tr('NOTIFICATIONS.FORM.SAVE') %>
                    </button>
                    <a href="/admin/notifications" class="btn btn-secondary">
                        <i class="fas fa-times mr-2"></i><%= tr('NOTIFICATIONS.FORM.CANCEL') %>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
