<% const _backUrl = typeof backUrl !== 'undefined' ? backUrl : '/admin/content?tab=notifications'; %>
<%- include('../../partials/admin/content-nav', { contentTab: typeof contentTab !== 'undefined' ? contentTab : 'notifications' }) %>

<%
    // Parse delivery_methods (backwards compat: string → array)
    let deliveryMethods = [];
    if (notification?.delivery_method) {
        try {
            const parsed = JSON.parse(notification.delivery_method);
            deliveryMethods = Array.isArray(parsed) ? parsed : [notification.delivery_method];
        } catch(e) {
            deliveryMethods = [notification.delivery_method];
        }
    }
    if (deliveryMethods.length === 0) {
        deliveryMethods = ['dashboard'];
    }
    // Expand legacy 'all' value
    if (deliveryMethods.includes('all')) {
        deliveryMethods = ['dashboard', 'system_channel', 'discord_channel', 'discord_dm'];
    }
    // Migrate old 'discord_channel' (was system channel) if no system_channel present
    // Keep as-is for new multi-select
%>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    const categorySelect = document.getElementById('category');
    const channelConfigBox = document.getElementById('category-channel-config');
    const channelHint = document.getElementById('category-channel-hint');
    const resolvedChannelName = document.getElementById('resolved-channel-name');
    let channelConfig = {};

    // Lade Channel-Konfiguration pro Kategorie
    try {
        const resp = await fetch('/admin/content/notifications/api/channel-config');
        const data = await resp.json();
        if (data.success) channelConfig = data.config || {};
    } catch (e) {
        console.error('Channel-Config laden fehlgeschlagen:', e);
    }

    // Toggle Discord-Optionen + Channel-Anzeige
    function updateChannelInfo() {
        const discordChecked = document.getElementById('dm_discord_category')?.checked;
        const cat = categorySelect.value;
        const cfg = channelConfig[cat];

        if (discordChecked && cfg?.channel_id) {
            channelConfigBox.style.display = 'block';
            resolvedChannelName.textContent = '#' + (cfg.channel_name || cfg.channel_id);
            channelHint.textContent = 'Channel "' + (cfg.channel_name || cfg.channel_id) + '" ist für ' + cat + ' konfiguriert.';
        } else if (discordChecked) {
            channelConfigBox.style.display = 'block';
            resolvedChannelName.innerHTML = '<span class="text-warning">Kein Channel für "' + cat + '" konfiguriert!</span>';
            channelHint.innerHTML = '<span class="text-warning">⚠ Kein Channel konfiguriert — bitte <a href="/admin/content?tab=settings">hier einrichten</a>.</span>';
        } else {
            channelConfigBox.style.display = 'none';
            channelHint.textContent = 'Der Channel wird aus der Kategorie-Konfiguration geladen...';
        }
    }

    // Delivery-Methods hidden field bei jeder Änderung aktualisieren
    function updateDeliveryMethodField() {
        var methods = [];
        document.querySelectorAll('.delivery-method-cb:checked').forEach(function(cb) {
            methods.push(cb.value);
        });
        if (methods.length === 0) methods.push('dashboard');
        document.getElementById('delivery_method_hidden').value = JSON.stringify(methods);
    }

    document.querySelectorAll('.delivery-method-cb').forEach(cb => {
        cb.addEventListener('change', function() {
            updateChannelInfo();
            updateDeliveryMethodField();
        });
    });
    categorySelect.addEventListener('change', updateChannelInfo);
    updateChannelInfo();
});
</script>

<div class="content">
    <div class="container-fluid">
        <% if (locals.toast) { %>
            <div class="alert alert-<%= toast.type %> alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <%= toast.message %>
            </div>
        <% } %>

        <form class="guild-ajax-form" 
              data-form-type="notification-save" 
              data-method="POST"
              data-success-url="<%= _backUrl %>"
              action="/admin/content/notifications/save" 
              method="POST">
            <input type="hidden" name="guildId" value="<%= guildId %>">
            <input type="hidden" name="delivery_method" id="delivery_method_hidden" value="<%= JSON.stringify(deliveryMethods) %>">
            <% if (notification && notification.id) { %>
                <input type="hidden" name="notificationId" value="<%= notification.id %>">
            <% } %>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><%= tr('NOTIFICATIONS.DETAILS') %></h3>
                </div>
                <div class="card-body">
                    <!-- Sprach-Tabs -->
                    <ul class="nav nav-tabs mb-3" id="langTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="de-tab" data-toggle="tab" href="#de-content" role="tab">
                                <i class="fas fa-flag mr-1"></i> Deutsch
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="en-tab" data-toggle="tab" href="#en-content" role="tab">
                                <i class="fas fa-flag mr-1"></i> English
                            </a>
                        </li>
                    </ul>

                    <div class="tab-content" id="langTabContent">
                        <!-- Deutsch Tab -->
                        <div class="tab-pane fade show active" id="de-content" role="tabpanel">
                            <div class="form-group">
                                <label for="title_de"><%= tr('NOTIFICATIONS.FORM.TITLE') %> (DE) <span class="text-danger">*</span></label>
                                <input type="text" 
                                       class="form-control" 
                                       id="title_de" 
                                       name="title_de" 
                                       value="<%= notification?.title_de || '' %>"
                                       required>
                            </div>

                            <div class="form-group">
                                <label for="message_de"><%= tr('NOTIFICATIONS.FORM.MESSAGE') %> (DE) <span class="text-danger">*</span></label>
                                <textarea class="form-control" 
                                          id="message_de" 
                                          name="message_de" 
                                          rows="4" 
                                          required><%= notification?.message_de || '' %></textarea>
                            </div>

                            <div class="form-group">
                                <label for="action_text_de"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT') %> (DE)</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="action_text_de" 
                                       name="action_text_de" 
                                       value="<%= notification?.action_text_de || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT_HELP') %></small>
                            </div>
                        </div>

                        <!-- English Tab -->
                        <div class="tab-pane fade" id="en-content" role="tabpanel">
                            <div class="form-group">
                                <label for="title_en"><%= tr('NOTIFICATIONS.FORM.TITLE') %> (EN) <small class="text-muted">(optional)</small></label>
                                <input type="text" 
                                       class="form-control" 
                                       id="title_en" 
                                       name="title_en" 
                                       value="<%= notification?.title_en || '' %>">
                            </div>

                            <div class="form-group">
                                <label for="message_en"><%= tr('NOTIFICATIONS.FORM.MESSAGE') %> (EN) <small class="text-muted">(optional)</small></label>
                                <textarea class="form-control" 
                                          id="message_en" 
                                          name="message_en" 
                                          rows="4"><%= notification?.message_en || '' %></textarea>
                            </div>

                            <div class="form-group">
                                <label for="action_text_en"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT') %> (EN)</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="action_text_en" 
                                       name="action_text_en" 
                                       value="<%= notification?.action_text_en || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_TEXT_HELP') %></small>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <!-- Gemeinsame Felder -->
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="type"><%= tr('NOTIFICATIONS.FORM.TYPE') %> <span class="text-danger">*</span></label>
                                <select class="form-control" id="type" name="type" required>
                                    <option value="info" <%= notification?.type === 'info' ? 'selected' : '' %>>
                                        <i class="fas fa-info-circle"></i> Info
                                    </option>
                                    <option value="warning" <%= notification?.type === 'warning' ? 'selected' : '' %>>
                                        <i class="fas fa-exclamation-triangle"></i> Warning
                                    </option>
                                    <option value="error" <%= notification?.type === 'error' ? 'selected' : '' %>>
                                        <i class="fas fa-exclamation-circle"></i> Error
                                    </option>
                                    <option value="success" <%= notification?.type === 'success' ? 'selected' : '' %>>
                                        <i class="fas fa-check-circle"></i> Success
                                    </option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="category">Kategorie</label>
                                <select class="form-control" id="category" name="category">
                                    <option value="announcement" <%= notification?.category === 'announcement' ? 'selected' : '' %>>📢 Announcement</option>
                                    <option value="changelog" <%= notification?.category === 'changelog' ? 'selected' : '' %>>📋 Changelog</option>
                                    <option value="status" <%= notification?.category === 'status' ? 'selected' : '' %>>🔔 Status</option>
                                    <option value="maintenance" <%= notification?.category === 'maintenance' ? 'selected' : '' %>>🔧 Maintenance</option>
                                    <option value="other" <%= notification?.category === 'other' ? 'selected' : '' %>>📌 Sonstige</option>
                                </select>
                                <small class="form-text text-muted">
                                    Bestimmt den Discord-Channel (per Kategorie konfigurierbar)
                                </small>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="action_url"><%= tr('NOTIFICATIONS.FORM.ACTION_URL') %></label>
                                <input type="url" 
                                       class="form-control" 
                                       id="action_url" 
                                       name="action_url" 
                                       value="<%= notification?.action_url || '' %>">
                                <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.ACTION_URL_HELP') %></small>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="expiry"><%= tr('NOTIFICATIONS.FORM.EXPIRES_AT') %></label>
                        <input type="datetime-local" 
                               class="form-control" 
                               id="expiry" 
                               name="expiry" 
                               value="<%= notification?.expiry ? new Date(notification.expiry).toISOString().slice(0, 16) : '' %>">
                        <small class="form-text text-muted"><%= tr('NOTIFICATIONS.FORM.EXPIRES_AT_HELP') %></small>
                    </div>

                    <hr>

                    <!-- Delivery Options -->
                    <h5 class="mb-3"><i class="fas fa-paper-plane mr-2"></i> Zustellungs-Optionen</h5>
                    
                    <div class="form-group">
                        <label>Wie soll die Benachrichtigung zugestellt werden?</label>
                        <div class="ml-2">
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_dashboard" value="dashboard"
                                       <%= deliveryMethods.includes('dashboard') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_dashboard">
                                    📊 Im Dashboard anzeigen
                                </label>
                            </div>
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_discord_category" value="discord_category"
                                       <%= deliveryMethods.includes('discord_category') || deliveryMethods.includes('discord_channel') || deliveryMethods.includes('system_channel') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_discord_category">
                                    📢 Im konfigurierten Discord-Channel posten (nach Kategorie)
                                </label>
                                <small class="form-text text-muted ml-4" id="category-channel-info">
                                    <i class="fas fa-info-circle"></i> <span id="category-channel-hint">Der Channel wird aus der Kategorie-Konfiguration geladen...</span>
                                </small>
                            </div>
                            <div class="custom-control custom-checkbox mb-2">
                                <input type="checkbox" class="custom-control-input delivery-method-cb" 
                                       id="dm_discord_dm" value="discord_dm"
                                       <%= deliveryMethods.includes('discord_dm') ? 'checked' : '' %>>
                                <label class="custom-control-label" for="dm_discord_dm">
                                    ✉️ DM an Server-Admins senden
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Konfigurierte Channels (nur Anzeige) -->
                    <div id="category-channel-config" class="alert alert-info" style="display: none;">
                        <i class="fas fa-hashtag mr-1"></i>
                        <strong>Ziel-Channel:</strong> <span id="resolved-channel-name">Wird geladen...</span>
                        <a href="/admin/content?tab=settings" class="btn btn-sm btn-outline-primary float-right">
                            <i class="fas fa-cog"></i> Channel-Konfiguration
                        </a>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i><%= tr('NOTIFICATIONS.FORM.SAVE') %>
                    </button>
                    <a href="<%= _backUrl %>" class="btn btn-secondary">
                        <i class="fas fa-times mr-2"></i><%= tr('NOTIFICATIONS.FORM.CANCEL') %>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
