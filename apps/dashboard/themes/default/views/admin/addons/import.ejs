<%# Admin: Addon Import (Pterodactyl + LinuxGSM) %>

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-download"></i>
                        Addon Import
                    </h1>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <a href="/admin/addons" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Zurück zur Übersicht
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">
            
            <%# Info-Alert %>
            <div class="alert alert-info">
                <h5><i class="icon fa-solid fa-info-circle"></i> SuperAdmin Import</h5>
                <p>
                    Importiere Addons aus Pterodactyl oder LinuxGSM und konvertiere sie automatisch ins DuneBot-Format.
                    <strong>Dieser Bereich ist nur für dich als Bot-Owner sichtbar!</strong>
                </p>
                <ul>
                    <li>✅ Automatische Konvertierung zu DuneBot-Format</li>
                    <li>✅ SteamCMD-Spiele: direkt lauffähig (AppID wird extrahiert)</li>
                    <li>✅ Variables & Ports werden extrahiert</li>
                    <li>⚠️ Nach Import: Review, Testing und Approval nötig!</li>
                </ul>
            </div>

            <%# Tab Navigation %>
            <ul class="nav nav-tabs mb-0" id="importTabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" id="ptero-tab-link" data-toggle="tab" href="#ptero-tab" role="tab">
                        <i class="fa-solid fa-egg"></i> Pterodactyl
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="lgsm-tab-link" data-toggle="tab" href="#lgsm-tab" role="tab">
                        <i class="fa-solid fa-terminal"></i> LinuxGSM
                    </a>
                </li>
            </ul>

            <div class="tab-content border border-top-0 rounded-bottom bg-white p-3 mb-3" id="importTabContent">

                <%# ─── TAB 1: Pterodactyl ─────────────────────────────────────── %>
                <div class="tab-pane fade show active" id="ptero-tab" role="tabpanel">
                    <div class="pt-3">

                    <%# Schritt 1: Kategorie wählen %>
                    <div class="form-group">
                        <label><i class="fa-solid fa-folder"></i> Kategorie</label>
                        <select id="pterodactylCategory" class="form-control">
                            <option value="">-- Kategorie wählen --</option>
                            <option value="games-steamcmd">🎮 SteamCMD Games</option>
                            <option value="minecraft">⛏️ Minecraft</option>
                        </select>
                        <small class="form-text text-muted">Voice-Server und Databases sind nicht verfügbar für Gameserver-Addons</small>
                    </div>

                    <%# Schritt 2: Egg wählen (dynamisch geladen) %>
                    <div class="form-group" id="ptero-eggSelectGroup" style="display:none;">
                        <label><i class="fa-solid fa-egg"></i> Egg</label>
                        <select id="pterodactylEgg" class="form-control">
                            <option value="">-- Erst Kategorie wählen --</option>
                        </select>
                    </div>

                    <%# Loading Spinner %>
                    <div id="ptero-loadingSpinner" style="display:none;" class="text-center my-3">
                        <i class="fa-solid fa-spinner fa-spin fa-3x text-primary"></i>
                        <p class="mt-2">Lade Pterodactyl Egg...</p>
                    </div>

                    <%# Preview %>
                    <div id="ptero-importPreview" style="display:none;">
                        <hr>
                        <h5><i class="fa-solid fa-eye"></i> Import-Preview</h5>
                        <div class="row">
                            <div class="col-md-6">
                                <dl>
                                    <dt>Name:</dt><dd id="ptero-previewName">-</dd>
                                    <dt>Beschreibung:</dt><dd id="ptero-previewDescription">-</dd>
                                    <dt>Runtime Type:</dt><dd id="ptero-previewRuntime">-</dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl>
                                    <dt>Variables:</dt><dd id="ptero-previewVariables">-</dd>
                                    <dt>Ports:</dt><dd id="ptero-previewPorts">-</dd>
                                    <dt>Source:</dt><dd><span class="badge badge-info">Pterodactyl</span></dd>
                                </dl>
                            </div>
                        </div>
                        <div class="alert alert-warning">
                            <i class="fa-solid fa-exclamation-triangle"></i>
                            <strong>Wichtig:</strong> Nach dem Import musst du das Addon noch bearbeiten, testen und freigeben!
                        </div>
                        <div id="ptero-reviewHint" class="alert alert-danger" style="display:none;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <strong>Manuelle Prüfung erforderlich!</strong><br>
                            Kein SteamCMD-Standard erkannt. Install-Script wurde übersetzt, muss aber vor der Aktivierung geprüft werden.
                            Das Addon wird als <em>Entwurf</em> gespeichert.
                        </div>
                    </div>

                    <div class="mt-3">
                        <button id="ptero-btnImport" class="btn btn-primary" disabled>
                            <i class="fa-solid fa-download"></i> Egg importieren
                        </button>
                        <button id="ptero-btnSave" class="btn btn-success ml-2" style="display:none;">
                            <i class="fa-solid fa-save"></i> Als Addon speichern (Draft)
                        </button>
                    </div>

                    </div><%# /pt-3 %>
                </div><%# /ptero-tab %>


                <%# ─── TAB 2: LinuxGSM ───────────────────────────────────────── %>
                <div class="tab-pane fade" id="lgsm-tab" role="tabpanel">
                    <div class="pt-3">

                    <div class="alert alert-secondary mb-3">
                        <i class="fa-solid fa-terminal"></i>
                        Importiert Spiele direkt aus dem <strong>LinuxGSM</strong> GitHub-Repository.
                        Alle Steam-Spiele werden automatisch mit korrekter AppID und Standard-Script importiert.
                    </div>

                    <%# Spiel-Auswahl %>
                    <div class="form-group">
                        <label><i class="fa-solid fa-gamepad"></i> Spiel auswählen</label>
                        <div class="input-group">
                            <input type="text" id="lgsm-search" class="form-control" placeholder="Suche (z.B. valheim, rust, csgo)...">
                            <div class="input-group-append">
                                <button id="lgsm-btnLoadList" class="btn btn-outline-secondary" type="button">
                                    <i class="fa-solid fa-refresh"></i> Laden
                                </button>
                            </div>
                        </div>
                        <small class="form-text text-muted" id="lgsm-listInfo">Spieleliste wird beim ersten Tippen oder Klick auf "Laden" automatisch geladen.</small>
                    </div>
                    <div class="form-group" id="lgsm-gameSelectGroup" style="display:none;">
                        <select id="lgsm-gameSelect" class="form-control" size="8" style="height:auto;">
                            <option value="">-- Spieleliste wird geladen --</option>
                        </select>
                    </div>

                    <%# Loading Spinner %>
                    <div id="lgsm-loadingSpinner" style="display:none;" class="text-center my-3">
                        <i class="fa-solid fa-spinner fa-spin fa-3x text-success"></i>
                        <p class="mt-2">Lade LGSM-Daten von GitHub...</p>
                    </div>

                    <%# Preview %>
                    <div id="lgsm-importPreview" style="display:none;">
                        <hr>
                        <h5><i class="fa-solid fa-eye"></i> Import-Preview</h5>
                        <div class="row">
                            <div class="col-md-6">
                                <dl>
                                    <dt>Name:</dt><dd id="lgsm-previewName">-</dd>
                                    <dt>Beschreibung:</dt><dd id="lgsm-previewDescription">-</dd>
                                    <dt>Steam AppID:</dt><dd id="lgsm-previewAppId">-</dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl>
                                    <dt>Variables:</dt><dd id="lgsm-previewVariables">-</dd>
                                    <dt>Ports:</dt><dd id="lgsm-previewPorts">-</dd>
                                    <dt>Source:</dt><dd><span class="badge badge-success">LinuxGSM</span></dd>
                                </dl>
                            </div>
                        </div>
                        <div id="lgsm-steamBadge" class="alert alert-success" style="display:none;">
                            <i class="fa-brands fa-steam"></i>
                            <strong>Steam-Spiel erkannt!</strong> Standard SteamCMD-Script wird generiert. Direkt lauffähig nach Approval.
                        </div>
                        <div id="lgsm-reviewHint" class="alert alert-warning" style="display:none;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <strong>Kein Steam-Game:</strong> Install-Script muss manuell erstellt werden.
                            Das Addon wird als <em>Entwurf</em> gespeichert.
                        </div>
                    </div>

                    <div class="mt-3">
                        <button id="lgsm-btnImport" class="btn btn-success" disabled>
                            <i class="fa-solid fa-download"></i> LGSM-Game importieren
                        </button>
                        <button id="lgsm-btnSave" class="btn btn-primary ml-2" style="display:none;">
                            <i class="fa-solid fa-save"></i> Als Addon speichern
                        </button>
                    </div>

                    </div><%# /pt-3 %>
                </div><%# /lgsm-tab %>

            </div><%# /tab-content %>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

    // ══════════════════════════════════════
    // Gemeinsame Hilfsfunktion: Addon speichern
    // ══════════════════════════════════════
    async function saveAddon(importedData, sourceType, saveBtnEl) {
        saveBtnEl.disabled = true;
        saveBtnEl.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichert...';

        try {
            const importMeta = importedData._import_meta || {};
            const isSteam    = importMeta.isSteamcmd || importMeta.isSteam;

            const payload = {
                name:         importedData.meta?.name        || 'Imported Addon',
                slug:         (importedData.meta?.name || 'addon').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''),
                description:  importedData.meta?.description || '',
                category:     importMeta.category            || 'other',
                runtime_type: isSteam ? 'native' : 'other',
                source_type:  sourceType,
                meta:         importedData.meta,
                installation: importedData.installation,
                startup:      importedData.startup,
                variables:    importedData.variables || [],
                ports:        importedData.ports     || {},
            };

            const response = await fetch('/admin/addons', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload),
            });

            const result = await response.json();

            if (result.success) {
                toastr.success(result.message || 'Addon erfolgreich importiert!');
                setTimeout(() => { window.location.href = `/admin/addons/${result.id}`; }, 1500);
            } else {
                toastr.error(result.message || 'Fehler beim Speichern');
                saveBtnEl.disabled = false;
                saveBtnEl.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern';
            }
        } catch (err) {
            console.error('[Import] Save error:', err);
            toastr.error('Netzwerkfehler beim Speichern');
            saveBtnEl.disabled = false;
            saveBtnEl.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern';
        }
    }

    // ══════════════════════════════════════
    // TAB 1: Pterodactyl
    // ══════════════════════════════════════
    (() => {
        let importedData = null;

        const categoryEl = document.getElementById('pterodactylCategory');
        const eggEl      = document.getElementById('pterodactylEgg');
        const eggGroup   = document.getElementById('ptero-eggSelectGroup');
        const spinner    = document.getElementById('ptero-loadingSpinner');
        const preview    = document.getElementById('ptero-importPreview');
        const btnImport  = document.getElementById('ptero-btnImport');
        const btnSave    = document.getElementById('ptero-btnSave');

        categoryEl.addEventListener('change', async function() {
            const category = this.value;
            if (!category) { eggGroup.style.display = 'none'; return; }

            try {
                const res  = await fetch(`/admin/addons/pterodactyl/eggs/${category}`);
                const data = await res.json();
                const eggs = data.eggs || [];

                eggEl.innerHTML = '<option value="">-- Egg wählen --</option>';
                eggs.forEach(egg => {
                    const opt = document.createElement('option');
                    opt.value = opt.textContent = egg.name;
                    eggEl.appendChild(opt);
                });
                eggGroup.style.display = 'block';
            } catch (err) {
                toastr.error('Fehler beim Laden der Eggs aus GitHub');
            }
        });

        eggEl.addEventListener('change', () => { btnImport.disabled = !eggEl.value; });

        btnImport.addEventListener('click', async () => {
            const category = categoryEl.value;
            const eggName  = eggEl.value;
            if (!category || !eggName) return;

            spinner.style.display = 'block';
            preview.style.display = 'none';
            btnSave.style.display = 'none';
            importedData = null;

            try {
                const res  = await fetch(`/admin/addons/pterodactyl/fetch/${category}?egg=${encodeURIComponent(eggName)}`);
                const data = await res.json();
                if (!data.success) throw new Error(data.message || 'Import fehlgeschlagen');

                importedData = data.data;
                const meta = importedData._import_meta || {};

                document.getElementById('ptero-previewName').textContent        = importedData.meta?.name        || '?';
                document.getElementById('ptero-previewDescription').textContent  = importedData.meta?.description || '-';

                let badge = meta.isSteamcmd
                    ? '<span class="badge badge-success">SteamCMD – direkt lauffähig</span>'
                    : '<span class="badge badge-warning">Manuell prüfen</span>';
                if (meta.steamAppId) badge += ` <span class="badge badge-secondary">AppID: ${meta.steamAppId}</span>`;
                document.getElementById('ptero-previewRuntime').innerHTML = badge;

                const vars  = Array.isArray(importedData.variables) ? importedData.variables.length : Object.keys(importedData.variables || {}).length;
                const ports = Object.keys(importedData.ports || {}).length;
                document.getElementById('ptero-previewVariables').textContent = vars;
                document.getElementById('ptero-previewPorts').textContent     = ports;

                document.getElementById('ptero-reviewHint').style.display = meta.needsReview ? 'block' : 'none';

                preview.style.display = 'block';
                btnSave.style.display = 'inline-block';
                btnSave.innerHTML = meta.needsReview
                    ? '<i class="fa-solid fa-pen"></i> Als Entwurf speichern (Prüfung nötig)'
                    : '<i class="fa-solid fa-save"></i> Als Addon speichern';
            } catch (err) {
                toastr.error(`Fehler: ${err.message}`);
            } finally {
                spinner.style.display = 'none';
            }
        });

        btnSave.addEventListener('click', () => saveAddon(importedData, 'pterodactyl', btnSave));
    })();

    // ══════════════════════════════════════
    // TAB 2: LinuxGSM
    // ══════════════════════════════════════
    (() => {
        let importedData = null;
        let allGames     = [];

        const searchEl    = document.getElementById('lgsm-search');
        const selectEl    = document.getElementById('lgsm-gameSelect');
        const selectGroup = document.getElementById('lgsm-gameSelectGroup');
        const spinner     = document.getElementById('lgsm-loadingSpinner');
        const preview     = document.getElementById('lgsm-importPreview');
        const listInfo    = document.getElementById('lgsm-listInfo');
        const btnLoad     = document.getElementById('lgsm-btnLoadList');
        const btnImport   = document.getElementById('lgsm-btnImport');
        const btnSave     = document.getElementById('lgsm-btnSave');

        function renderGameList(filter = '') {
            const lc = filter.toLowerCase();
            const filtered = allGames.filter(g =>
                !lc || g.shortname.toLowerCase().includes(lc) || g.displayName.toLowerCase().includes(lc)
            );
            selectEl.innerHTML = filtered.length
                ? filtered.map(g => `<option value="${g.shortname}">${g.displayName} (${g.shortname})</option>`).join('')
                : '<option value="">Keine Treffer</option>';
            btnImport.disabled = filtered.length === 0;
        }

        let listLoading = false;

        async function loadGamesList() {
            if (listLoading || allGames.length > 0) return;
            listLoading = true;
            btnLoad.disabled = true;
            btnLoad.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            listInfo.textContent = 'Lade Spieleliste von GitHub...';

            try {
                const res  = await fetch('/admin/addons/lgsm/games');
                const data = await res.json();
                if (!data.success) throw new Error(data.message);

                allGames = data.games || [];
                renderGameList(searchEl.value);
                selectGroup.style.display = 'block';
                listInfo.textContent = `${allGames.length} LGSM-Spiele geladen`;
                btnLoad.innerHTML = '<i class="fa-solid fa-check"></i> Geladen';
                btnLoad.disabled = false;
            } catch (err) {
                listInfo.textContent = `Fehler: ${err.message}`;
                toastr.error(`LGSM Spieleliste: ${err.message}`);
                btnLoad.disabled = false;
                btnLoad.innerHTML = '<i class="fa-solid fa-refresh"></i> Laden';
                listLoading = false; // Retry erlauben
            }
        }

        btnLoad.addEventListener('click', () => {
            listLoading = false; // Neuladung auch wenn schon geladen
            allGames = [];
            loadGamesList();
        });

        // Auto-Load beim ersten Tippen ins Suchfeld
        searchEl.addEventListener('focus', () => loadGamesList());
        searchEl.addEventListener('input', () => {
            loadGamesList();
            renderGameList(searchEl.value);
            btnImport.disabled = !selectEl.value;
        });
        selectEl.addEventListener('change', () => { btnImport.disabled = !selectEl.value; });

        btnImport.addEventListener('click', async () => {
            const shortname = selectEl.value;
            if (!shortname) return;

            spinner.style.display = 'block';
            preview.style.display = 'none';
            btnSave.style.display = 'none';
            importedData = null;

            try {
                const res  = await fetch(`/admin/addons/lgsm/fetch?game=${encodeURIComponent(shortname)}`);
                const data = await res.json();
                if (!data.success) throw new Error(data.message || 'Import fehlgeschlagen');

                importedData = data.data;
                const meta   = importedData._import_meta || {};

                document.getElementById('lgsm-previewName').textContent        = importedData.meta?.name        || shortname;
                document.getElementById('lgsm-previewDescription').textContent  = importedData.meta?.description || '-';
                document.getElementById('lgsm-previewAppId').innerHTML          = meta.steamAppId
                    ? `<span class="badge badge-success">${meta.steamAppId}</span>`
                    : '<span class="text-muted">–</span>';

                const vars  = Array.isArray(importedData.variables) ? importedData.variables.length : 0;
                const ports = Object.keys(importedData.ports || {}).length;
                document.getElementById('lgsm-previewVariables').textContent = vars;
                document.getElementById('lgsm-previewPorts').textContent     = ports;

                document.getElementById('lgsm-steamBadge').style.display  = meta.isSteam     ? 'block' : 'none';
                document.getElementById('lgsm-reviewHint').style.display   = meta.needsReview ? 'block' : 'none';

                preview.style.display = 'block';
                btnSave.style.display = 'inline-block';
                btnSave.innerHTML = meta.needsReview
                    ? '<i class="fa-solid fa-pen"></i> Als Entwurf speichern'
                    : '<i class="fa-solid fa-save"></i> Als Addon speichern';
            } catch (err) {
                toastr.error(`Fehler: ${err.message}`);
            } finally {
                spinner.style.display = 'none';
            }
        });

        btnSave.addEventListener('click', () => saveAddon(importedData, 'lgsm', btnSave));
    })();

});
</script>

