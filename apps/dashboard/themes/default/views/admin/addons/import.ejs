<%# Admin: Egg Import (Pelican / FIREBOT_v2) %>
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-egg"></i>
                        Egg importieren
                    </h1>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <a href="/admin/addons" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Zurück zur Übersicht
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">

            <div class="alert alert-info alert-dismissible">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                <h5><i class="icon fa-solid fa-info-circle"></i> Pelican Egg Import</h5>
                Importiert Eggs aus dem offiziellen <strong>Pelican</strong>-Repository
                (<a href="https://github.com/pelican-eggs" target="_blank" rel="noreferrer">github.com/pelican-eggs</a>)
                und konvertiert sie automatisch ins <strong>FIREBOT_v2</strong>-Format.<br>
                Nach dem Import muss das Addon noch bearbeitet, getestet und freigegeben werden.
            </div>

            <%# ── Schritt-Anzeige ─────────────────────────────────────────── %>
            <div class="row mb-3" id="stepIndicator">
                <div class="col-12">
                    <div class="bs-stepper-header d-flex align-items-center">
                        <div class="step" id="step1-indicator">
                            <button class="step-trigger active-step font-weight-bold">
                                <span class="bs-stepper-circle bg-primary text-white">1</span>
                                <span class="bs-stepper-label">Repository</span>
                            </button>
                        </div>
                        <div class="bs-stepper-line flex-fill mx-2" style="height:2px;background:#dee2e6;"></div>
                        <div class="step" id="step2-indicator">
                            <button class="step-trigger">
                                <span class="bs-stepper-circle bg-secondary text-white">2</span>
                                <span class="bs-stepper-label">Egg wählen</span>
                            </button>
                        </div>
                        <div class="bs-stepper-line flex-fill mx-2" style="height:2px;background:#dee2e6;"></div>
                        <div class="step" id="step3-indicator">
                            <button class="step-trigger">
                                <span class="bs-stepper-circle bg-secondary text-white">3</span>
                                <span class="bs-stepper-label">Vorschau &amp; Speichern</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <%# ── Schritt 1: Repository wählen ──────────────────────────────── %>
            <div id="step1" class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-folder-open"></i> Schritt 1: Repository wählen</h5>
                </div>
                <div class="card-body">
                    <div id="repoLoading" class="text-center p-4">
                        <i class="fa-solid fa-spinner fa-spin fa-2x text-primary"></i>
                        <p class="mt-2">Lade Repositories...</p>
                    </div>
                    <div id="repoList" class="row" style="display:none;"></div>
                </div>
            </div>

            <%# ── Schritt 2: Egg wählen ─────────────────────────────────────── %>
            <div id="step2" class="card mt-3" style="display:none;">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fa-solid fa-egg"></i> Schritt 2: Egg wählen</h5>
                    <button class="btn btn-sm btn-outline-light" id="btnBackToStep1">
                        <i class="fa-solid fa-arrow-left"></i> Anderes Repository
                    </button>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <input type="text" id="eggSearch" class="form-control" placeholder="Egg suchen...">
                    </div>
                    <div id="eggLoading" class="text-center p-4">
                        <i class="fa-solid fa-spinner fa-spin fa-2x text-secondary"></i>
                        <p class="mt-2">Lade Eggs...</p>
                    </div>
                    <div id="eggList" class="list-group" style="display:none;"></div>
                </div>
            </div>

            <%# ── Schritt 3: Vorschau & Speichern ───────────────────────────── %>
            <div id="step3" class="card mt-3" style="display:none;">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fa-solid fa-eye"></i> Schritt 3: Vorschau &amp; Speichern</h5>
                    <button class="btn btn-sm btn-outline-light" id="btnBackToStep2">
                        <i class="fa-solid fa-arrow-left"></i> Anderes Egg
                    </button>
                </div>
                <div class="card-body">
                    <div id="previewLoading" class="text-center p-4" style="display:none;">
                        <i class="fa-solid fa-spinner fa-spin fa-2x text-success"></i>
                        <p class="mt-2">Egg wird konvertiert...</p>
                    </div>
                    <div id="previewContent" style="display:none;">
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr><th>Name</th><td id="prev-name">-</td></tr>
                                        <tr><th>Beschreibung</th><td id="prev-desc">-</td></tr>
                                        <tr><th>Runtime</th><td id="prev-runtime">-</td></tr>
                                        <tr><th>Docker-Image</th><td id="prev-image">-</td></tr>
                                        <tr><th>Variables</th><td id="prev-vars">-</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <label class="font-weight-bold">Startup-Kommando:</label>
                                <code id="prev-startup" class="d-block bg-dark text-white p-2 small rounded mb-3"></code>
                                <label class="font-weight-bold">Install-Container:</label>
                                <code id="prev-install-container" class="d-block bg-dark text-white p-2 small rounded"></code>
                            </div>
                        </div>

                        <div class="form-group mt-3">
                            <label><i class="fa-solid fa-tag"></i> Name (editierbar)</label>
                            <input type="text" id="saveAddonName" class="form-control" placeholder="Addon-Name">
                        </div>
                        <div class="form-group">
                            <label><i class="fa-solid fa-align-left"></i> Beschreibung (optional)</label>
                            <textarea id="saveAddonDesc" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label><i class="fa-solid fa-folder"></i> Kategorie</label>
                            <select id="saveAddonCategory" class="form-control">
                                <option value="other">Sonstiges</option>
                                <option value="shooter">Shooter</option>
                                <option value="survival">Survival</option>
                                <option value="sandbox">Sandbox</option>
                                <option value="racing">Racing</option>
                                <option value="minecraft">Minecraft</option>
                                <option value="database">Datenbank</option>
                                <option value="software">Software</option>
                            </select>
                        </div>

                        <div class="alert alert-warning">
                            <i class="fa-solid fa-exclamation-triangle"></i>
                            <strong>Hinweis:</strong> Das Addon wird als <em>pending_review</em> gespeichert.
                            Bitte nach dem Import prüfen, anpassen und freigeben.
                        </div>

                        <div class="d-flex gap-2">
                            <button id="btnSaveAddon" class="btn btn-success">
                                <i class="fa-solid fa-save"></i> Als Addon speichern
                            </button>
                            <details class="ml-3">
                                <summary class="text-muted small" style="cursor:pointer;">game_data (raw JSON) anzeigen</summary>
                                <pre id="rawJson" class="bg-dark text-white p-2 rounded mt-2 small" style="max-height:300px;overflow:auto;"></pre>
                            </details>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
.bs-stepper-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    font-weight: 600;
    margin-right: 0.4rem;
}
.repo-card { cursor: pointer; transition: transform .15s, box-shadow .15s; }
.repo-card:hover { transform: translateY(-3px); box-shadow: 0 4px 12px rgba(0,0,0,.15); }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {

    let currentRepo = null;
    let currentEggs = [];
    let currentGameData = null;

    // ── Hilfsfunktionen ──────────────────────────────────────────────────────

    function setStep(n) {
        [1, 2, 3].forEach(i => {
            const circle = document.querySelector(`#step${i}-indicator .bs-stepper-circle`);
            document.getElementById(`step${i}`).style.display = (i === n) ? 'block' : 'none';
            if (circle) {
                circle.classList.toggle('bg-primary', i === n);
                circle.classList.toggle('bg-success', i < n);
                circle.classList.toggle('bg-secondary', i > n);
            }
        });
    }

    function filterEggs(search) {
        const lc = search.toLowerCase();
        const filtered = lc
            ? currentEggs.filter(e => e.displayName.toLowerCase().includes(lc) || e.name.toLowerCase().includes(lc))
            : currentEggs;
        renderEggList(filtered);
    }

    function renderEggList(eggs) {
        const list = document.getElementById('eggList');
        list.innerHTML = eggs.length
            ? eggs.map(e => `
                <button type="button" class="list-group-item list-group-item-action egg-item"
                        data-url="${e.downloadUrl}" data-name="${e.displayName}">
                    <i class="fa-solid fa-egg mr-2 text-warning"></i>
                    <strong>${e.displayName}</strong>
                    <small class="text-muted ml-2">${e.name}</small>
                </button>`).join('')
            : '<p class="text-muted p-2">Keine Eggs gefunden.</p>';

        list.querySelectorAll('.egg-item').forEach(el => {
            el.addEventListener('click', function() {
                loadEgg(this.dataset.url, this.dataset.name);
            });
        });
    }

    // ── Schritt 1: Repositories laden ────────────────────────────────────────

    (async function loadRepos() {
        setStep(1);
        try {
            const res  = await fetch('/admin/addons/repositories');
            const data = await res.json();

            const icons = {
                'games-steamcmd':  'fa-brands fa-steam',
                'games-standalone': 'fa-solid fa-cube',
                'minecraft':        'fa-solid fa-cube',
                'database':         'fa-solid fa-database',
                'software':         'fa-solid fa-terminal',
            };
            const colors = {
                'games-steamcmd':   'info',
                'games-standalone': 'secondary',
                'minecraft':        'success',
                'database':         'warning',
                'software':         'dark',
            };

            const repoList = document.getElementById('repoList');
            repoList.innerHTML = data.repositories.map(r => `
                <div class="col-md-4 col-sm-6 mb-3">
                    <div class="card repo-card border-${colors[r.id] || 'primary'}" data-repo="${r.id}">
                        <div class="card-body text-center">
                            <i class="${icons[r.id] || 'fa-solid fa-folder'} fa-3x text-${colors[r.id] || 'primary'} mb-2"></i>
                            <h5>${r.name}</h5>
                            <small class="text-muted">${r.id}</small>
                        </div>
                    </div>
                </div>
            `).join('');

            repoList.querySelectorAll('.repo-card').forEach(card => {
                card.addEventListener('click', function() { loadEggs(this.dataset.repo); });
            });

            document.getElementById('repoLoading').style.display = 'none';
            repoList.style.display = 'flex';
            repoList.classList.add('flex-wrap');

        } catch (err) {
            document.getElementById('repoLoading').innerHTML =
                `<p class="text-danger"><i class="fa-solid fa-times-circle"></i> ${err.message}</p>`;
        }
    })();

    document.getElementById('btnBackToStep1').addEventListener('click', () => setStep(1));
    document.getElementById('btnBackToStep2').addEventListener('click', () => {
        setStep(2);
        currentGameData = null;
    });

    // ── Schritt 2: Eggs laden ─────────────────────────────────────────────────

    async function loadEggs(repoId) {
        currentRepo = repoId;
        setStep(2);
        document.getElementById('eggLoading').style.display = 'block';
        document.getElementById('eggList').style.display    = 'none';
        document.getElementById('eggSearch').value          = '';

        try {
            const res  = await fetch(`/admin/addons/repositories/${encodeURIComponent(repoId)}/eggs`);
            const data = await res.json();
            if (!data.success) throw new Error(data.message);

            currentEggs = data.eggs;
            document.getElementById('eggLoading').style.display = 'none';
            document.getElementById('eggList').style.display    = 'block';
            filterEggs('');
        } catch (err) {
            document.getElementById('eggLoading').innerHTML =
                `<p class="text-danger"><i class="fa-solid fa-times-circle"></i> ${err.message}</p>`;
        }
    }

    document.getElementById('eggSearch').addEventListener('input', function() {
        filterEggs(this.value);
    });

    // ── Schritt 3: Egg laden + Vorschau ──────────────────────────────────────

    async function loadEgg(url, displayName) {
        setStep(3);
        document.getElementById('previewLoading').style.display  = 'block';
        document.getElementById('previewContent').style.display  = 'none';
        currentGameData = null;

        try {
            const res  = await fetch(`/admin/addons/repositories/${encodeURIComponent(currentRepo)}/eggs/fetch?url=${encodeURIComponent(url)}`);
            const data = await res.json();
            if (!data.success) throw new Error(data.message);

            currentGameData = data.gameData;
            const gd = currentGameData;

            const dockerImages  = gd.docker_images || {};
            const firstImageKey = Object.keys(dockerImages)[0] || '–';
            const firstImage    = dockerImages[firstImageKey] || firstImageKey;

            const hasSteam = (gd.scripts?.installation?.script || '').toLowerCase().includes('steamcmd')
                || (gd.variables || []).some(v => v.env_variable === 'SRCDS_APPID' || v.env_variable === 'STEAM_APPID');

            document.getElementById('prev-name').textContent    = gd.meta?.name        || displayName;
            document.getElementById('prev-desc').textContent    = gd.meta?.description || '–';
            document.getElementById('prev-runtime').innerHTML   = hasSteam
                ? '<span class="badge badge-primary"><i class="fa-brands fa-docker"></i> docker_steam</span>'
                : '<span class="badge badge-info"><i class="fa-solid fa-cube"></i> docker_standalone</span>';
            document.getElementById('prev-image').textContent    = firstImage;
            document.getElementById('prev-vars').textContent     = (gd.variables || []).length;
            document.getElementById('prev-startup').textContent  = gd.startup?.command || '–';
            document.getElementById('prev-install-container').textContent = gd.scripts?.installation?.container || '–';

            document.getElementById('saveAddonName').value = gd.meta?.name || displayName;
            document.getElementById('saveAddonDesc').value = gd.meta?.description || '';
            document.getElementById('rawJson').textContent = JSON.stringify(gd, null, 2);

            document.getElementById('previewLoading').style.display = 'none';
            document.getElementById('previewContent').style.display = 'block';

        } catch (err) {
            document.getElementById('previewLoading').innerHTML =
                `<p class="text-danger"><i class="fa-solid fa-times-circle"></i> ${err.message}</p>`;
        }
    }

    // ── Addon speichern ───────────────────────────────────────────────────────

    document.getElementById('btnSaveAddon').addEventListener('click', async function() {
        if (!currentGameData) return;

        this.disabled = true;
        this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichert...';

        const name     = document.getElementById('saveAddonName').value.trim();
        const desc     = document.getElementById('saveAddonDesc').value.trim();
        const category = document.getElementById('saveAddonCategory').value;

        if (!name) {
            toastr.warning('Bitte einen Namen eingeben');
            this.disabled = false;
            this.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern';
            return;
        }

        try {
            const response = await fetch('/admin/addons', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({
                    name,
                    description: desc,
                    category,
                    game_data: JSON.stringify(currentGameData),
                }),
            });

            const result = await response.json();

            if (result.success) {
                toastr.success(result.message || 'Addon erfolgreich gespeichert!');
                setTimeout(() => { window.location.href = `/admin/addons/${result.id}`; }, 1500);
            } else {
                toastr.error(result.message || 'Fehler beim Speichern');
                this.disabled = false;
                this.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern';
            }
        } catch (err) {
            toastr.error(`Netzwerkfehler: ${err.message}`);
            this.disabled = false;
            this.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern';
        }
    });

});
</script>
