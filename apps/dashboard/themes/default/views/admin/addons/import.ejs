<%# Admin: Pterodactyl Egg Import %>
<%# WIEDERVERWENDUNG des bereits programmierten Gameserver-Imports! %>

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-download"></i>
                        Pterodactyl Egg Import
                    </h1>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <a href="/admin/addons" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Zurück zur Übersicht
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">
            
            <%# Info-Alert %>
            <div class="alert alert-info">
                <h5><i class="icon fa-solid fa-info-circle"></i> SuperAdmin Import</h5>
                <p>
                    Hier kannst du Pterodactyl Eggs importieren und für das DuneBot-System konvertieren.
                    <strong>Dieser Bereich ist nur für dich als Bot-Owner sichtbar!</strong>
                </p>
                <ul>
                    <li>✅ Automatische Konvertierung zu DuneBot-Format</li>
                    <li>✅ Docker-Befehle werden entfernt</li>
                    <li>✅ Variables & Ports werden extrahiert</li>
                    <li>⚠️ Nach Import: Review, Testing und Approval nötig!</li>
                </ul>
            </div>

            <%# Import-Card %>
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fa-solid fa-egg"></i>
                        Pterodactyl Egg auswählen
                    </h3>
                </div>
                <div class="card-body">
                    
                    <%# Schritt 1: Kategorie wählen %>
                    <div class="form-group">
                        <label>
                            <i class="fa-solid fa-folder"></i>
                            Kategorie
                        </label>
                        <select id="pterodactylCategory" class="form-control">
                            <option value="">-- Kategorie wählen --</option>
                            <option value="games-steamcmd">🎮 SteamCMD Games</option>
                            <option value="minecraft">⛏️ Minecraft</option>
                        </select>
                        <small class="form-text text-muted">
                            <i class="fa-solid fa-info-circle"></i>
                            Voice-Server und Databases sind nicht verfügbar für Gameserver-Addons
                        </small>
                    </div>

                    <%# Schritt 2: Egg wählen (dynamisch geladen) %>
                    <div class="form-group" id="eggSelectGroup" style="display:none;">
                        <label>
                            <i class="fa-solid fa-egg"></i>
                            Egg
                        </label>
                        <select id="pterodactylEgg" class="form-control">
                            <option value="">-- Erst Kategorie wählen --</option>
                        </select>
                    </div>

                    <%# Loading Spinner %>
                    <div id="loadingSpinner" style="display:none;" class="text-center my-3">
                        <i class="fa-solid fa-spinner fa-spin fa-3x text-primary"></i>
                        <p class="mt-2">Lade Pterodactyl Egg...</p>
                    </div>

                    <%# Preview (nach Import) %>
                    <div id="importPreview" style="display:none;">
                        <hr>
                        <h5>
                            <i class="fa-solid fa-eye"></i>
                            Import-Preview
                        </h5>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <dl>
                                    <dt>Name:</dt>
                                    <dd id="previewName">-</dd>
                                    
                                    <dt>Beschreibung:</dt>
                                    <dd id="previewDescription">-</dd>
                                    
                                    <dt>Runtime Type:</dt>
                                    <dd id="previewRuntime">-</dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl>
                                    <dt>Variables:</dt>
                                    <dd id="previewVariables">-</dd>
                                    
                                    <dt>Ports:</dt>
                                    <dd id="previewPorts">-</dd>
                                    
                                    <dt>Source:</dt>
                                    <dd><span class="badge badge-info">Pterodactyl</span></dd>
                                </dl>
                            </div>
                        </div>

                        <div class="alert alert-warning">
                            <i class="fa-solid fa-exclamation-triangle"></i>
                            <strong>Wichtig:</strong> Nach dem Import musst du das Addon noch bearbeiten, testen und freigeben!
                        </div>
                    </div>

                </div>
                <div class="card-footer">
                    <button id="btnImport" class="btn btn-primary" disabled>
                        <i class="fa-solid fa-download"></i>
                        Egg importieren
                    </button>
                    <button id="btnSaveToMarketplace" class="btn btn-success" style="display:none;">
                        <i class="fa-solid fa-save"></i>
                        Als Addon speichern (Draft)
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    
    let importedData = null;
    
    // Pterodactyl Category Change
    document.getElementById('pterodactylCategory').addEventListener('change', async function() {
        const category = this.value;
        const eggSelect = document.getElementById('pterodactylEgg');
        const eggGroup = document.getElementById('eggSelectGroup');
        
        if (!category) {
            eggGroup.style.display = 'none';
            return;
        }
        
        // Lade Eggs für Kategorie
        try {
            const response = await fetch(`/admin/addons/pterodactyl/eggs/${category}`);
            const data = await response.json();
            const eggs = data.eggs || [];
            
            // Populate Dropdown
            eggSelect.innerHTML = '<option value="">-- Egg wählen --</option>';
            eggs.forEach(egg => {
                const option = document.createElement('option');
                option.value = egg.name;
                option.textContent = egg.name;
                eggSelect.appendChild(option);
            });
            
            eggGroup.style.display = 'block';
        } catch (error) {
            console.error('Error loading eggs:', error);
            toastr.error('Fehler beim Laden der Eggs aus GitHub');
        }
    });
    
    // Egg Change → Enable Import Button
    document.getElementById('pterodactylEgg').addEventListener('change', function() {
        document.getElementById('btnImport').disabled = !this.value;
    });
    
    // Import Button Click
    document.getElementById('btnImport').addEventListener('click', async function() {
        const category = document.getElementById('pterodactylCategory').value;
        const eggName = document.getElementById('pterodactylEgg').value;
        
        if (!category || !eggName) return;
        
        const spinner = document.getElementById('loadingSpinner');
        const preview = document.getElementById('importPreview');
        const saveBtn = document.getElementById('btnSaveToMarketplace');
        
        spinner.style.display = 'block';
        preview.style.display = 'none';
        
        try {
            // Fetch Egg (nutzt SuperAdmin-Route mit Query-Parameter!)
            const response = await fetch(`/admin/addons/pterodactyl/fetch/${category}?egg=${encodeURIComponent(eggName)}`);
            
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            
            const data = await response.json();
            console.log('[Import] Response:', data);
            
            if (!data.success) {
                throw new Error(data.message || 'Import fehlgeschlagen');
            }
            
            if (data.data) {
                importedData = data.data;
                
                // PTDL_v2 Format hat meta.name und meta.description!
                const displayName = importedData.meta?.name || importedData.name || 'Unknown';
                const displayDescription = importedData.meta?.description || importedData.description || 'Keine Beschreibung';
                
                // Preview füllen
                document.getElementById('previewName').textContent = displayName;
                document.getElementById('previewDescription').textContent = displayDescription;
                
                // Runtime Type bestimmen (vereinfacht)
                let runtimeBadge = '<span class="badge badge-success">Native</span>';
                const nameStr = displayName.toLowerCase();
                if (nameStr.includes('proton')) {
                    runtimeBadge = '<span class="badge badge-primary">Proton</span>';
                } else if (nameStr.includes('wine')) {
                    runtimeBadge = '<span class="badge badge-info">Wine</span>';
                }
                document.getElementById('previewRuntime').innerHTML = runtimeBadge;
                
                document.getElementById('previewVariables').textContent = 
                    importedData.variables ? importedData.variables.length : 0;
                document.getElementById('previewPorts').textContent = 
                    importedData.ports ? importedData.ports.length : 0;
                
                preview.style.display = 'block';
                saveBtn.style.display = 'inline-block';
            } else {
                throw new Error('Keine Daten im Response erhalten');
            }
        } catch (error) {
            console.error('Error importing egg:', error);
            toastr.error(`Fehler beim Importieren: ${error.message}`);
        } finally {
            spinner.style.display = 'none';
        }
    });
    
    // Save to Marketplace Button
    document.getElementById('btnSaveToMarketplace').addEventListener('click', async function() {
        if (!importedData) return;
        
        const saveBtn = this;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichert...';
        
        try {
            // Auto-detect Runtime Type
            let runtimeType = 'native_steamcmd';
            const nameStr = (importedData.meta?.name || importedData.name || '').toLowerCase();
            if (nameStr.includes('proton')) runtimeType = 'proton';
            else if (nameStr.includes('wine')) runtimeType = 'wine';
            else if (nameStr.includes('java')) runtimeType = 'java';
            else if (nameStr.includes('nodejs') || nameStr.includes('node.js')) runtimeType = 'nodejs';
            else if (nameStr.includes('python')) runtimeType = 'python';
            
            // Addon-Payload erstellen (PTDL_v2 Format!)
            const payload = {
                name: importedData.meta?.name || importedData.name || 'Imported Addon',
                slug: (importedData.meta?.name || importedData.name || 'addon').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
                description: importedData.meta?.description || importedData.description || '',
                category: 'other',  // Default category (ENUM: fps, survival, sandbox, mmorpg, racing, strategy, horror, scifi, other)
                runtime_type: runtimeType,
                source_type: 'pterodactyl',
                // PTDL_v2 Struktur direkt übergeben
                meta: importedData.meta,
                install: importedData.install,
                installation: importedData.installation || {},  // ✅ FÜR DAEMON! (script_content)
                startup: importedData.startup,
                config: importedData.config,
                scripts: importedData.scripts,  // ℹ️ Für Kompatibilität (Dashboard nutzt das noch)
                variables: importedData.variables || [],
                ports: importedData.ports || []
            };
            
            // Save to addon_marketplace (SuperAdmin-Route!)
            const response = await fetch(`/admin/addons`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.success) {
                toastr.success(result.message || 'Addon erfolgreich importiert!');
                // Redirect zum Edit nach 1,5s
                setTimeout(() => {
                    window.location.href = `/admin/addons/${result.id}`;
                }, 1500);
            } else {
                toastr.error(result.message || 'Fehler beim Speichern des Addons');
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern (Draft)';
            }
        } catch (error) {
            console.error('Error saving addon:', error);
            toastr.error('Netzwerkfehler beim Speichern des Addons');
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="fa-solid fa-save"></i> Als Addon speichern (Draft)';
        }
    });
});
</script>
