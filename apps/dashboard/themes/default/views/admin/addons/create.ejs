<%# Admin: Addon manuell erstellen / aus externer URL importieren %>
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-plus-circle"></i>
                        Addon erstellen
                    </h1>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <a href="/admin/addons/import" class="btn btn-secondary mr-2">
                            <i class="fa-solid fa-egg"></i> Aus Pelican-Repo importieren
                        </a>
                        <a href="/admin/addons" class="btn btn-default">
                            <i class="fa-solid fa-arrow-left"></i> Zurück
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">

            <%# ── URL Import Panel ─────────────────────────────────────────── %>
            <div class="card card-outline card-info collapsed-card mb-3">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fa-solid fa-link"></i>
                        Aus externer URL automatisch befüllen <span class="badge badge-info ml-2">optional</span>
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Paste die Raw-URL zu einer Pelican-Egg JSON-Datei. Das Formular wird damit vorausgefüllt und kann danach beliebig angepasst werden.<br>
                        <small>Erlaubte Hosts: <code>raw.githubusercontent.com</code>, <code>gist.githubusercontent.com</code></small>
                    </p>
                    <div class="input-group">
                        <input type="url" id="externalUrl" class="form-control"
                               placeholder="https://raw.githubusercontent.com/pelican-eggs/games-steamcmd/main/valheim/egg-valheim.json">
                        <div class="input-group-append">
                            <button class="btn btn-info" type="button" id="btnLoadUrl">
                                <i class="fa-solid fa-download"></i> Laden & befüllen
                            </button>
                        </div>
                    </div>
                    <div id="urlLoadStatus" class="mt-2" style="display:none;"></div>
                </div>
            </div>

            <%# ── Hauptformular ────────────────────────────────────────────── %>
            <form id="createAddonForm">

                <%# Basis %>
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title"><i class="fa-solid fa-info-circle"></i> Basis-Informationen</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-tag"></i> Name <span class="text-danger">*</span></label>
                                    <input type="text" id="addonName" class="form-control" placeholder="z.B. Valheim" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-fingerprint"></i> Slug</label>
                                    <input type="text" id="addonSlug" class="form-control" placeholder="z.B. valheim">
                                    <small class="form-text text-muted">Wird automatisch aus dem Namen generiert. Muss eindeutig sein.</small>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label><i class="fa-solid fa-align-left"></i> Beschreibung</label>
                            <textarea id="addonDescription" class="form-control" rows="2" placeholder="Kurze Beschreibung des Spiels / der Anwendung"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-folder"></i> Kategorie</label>
                                    <select id="addonCategory" class="form-control">
                                        <option value="other">Sonstiges</option>
                                        <option value="fps">FPS / Shooter</option>
                                        <option value="survival">Survival</option>
                                        <option value="sandbox">Sandbox</option>
                                        <option value="mmorpg">MMORPG</option>
                                        <option value="racing">Racing</option>
                                        <option value="strategy">Strategie</option>
                                        <option value="horror">Horror</option>
                                        <option value="scifi">Sci-Fi</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-database"></i> Source-Typ</label>
                                    <select id="addonSourceType" class="form-control">
                                        <option value="community">Community</option>
                                        <option value="pelican">Pelican</option>
                                        <option value="native">Native</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-user-pen"></i> Autor</label>
                                    <input type="text" id="addonAuthor" class="form-control" placeholder="Pelican Community" value="Community">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <%# Docker & Runtime %>
                <div class="card mt-3">
                    <div class="card-header bg-secondary text-white">
                        <h3 class="card-title"><i class="fa-brands fa-docker"></i> Docker & Runtime</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-box"></i> Primäres Docker-Image <span class="text-danger">*</span></label>
                                    <input type="text" id="dockerImage" class="form-control font-mono"
                                           placeholder="ghcr.io/parkervcp/games:valheim">
                                    <small class="form-text text-muted">Das Standard-Runtime-Image</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-tag"></i> Image-Label</label>
                                    <input type="text" id="dockerImageLabel" class="form-control" placeholder="Valheim Latest">
                                </div>
                            </div>
                        </div>
                        <div id="additionalImages"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary mb-3" id="btnAddImage">
                            <i class="fa-solid fa-plus"></i> Weiteres Docker-Image
                        </button>
                        <div class="form-group">
                            <label><i class="fa-solid fa-terminal"></i> Startup-Befehl <span class="text-danger">*</span></label>
                            <input type="text" id="startupCommand" class="form-control font-mono"
                                   placeholder="./${EXECUTABLE} -port {{SERVER_PORT}} -name {{SERVER_NAME}}">
                            <small class="form-text text-muted">Platzhalter im Format <code>{{ENV_VARIABLE}}</code></small>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-circle-check"></i> Startup-Done Pattern</label>
                                    <input type="text" id="startupDone" class="form-control font-mono"
                                           placeholder='z.B. "Game server connected"'>
                                    <small class="form-text text-muted">Regex/String im Log wenn Server bereit ist</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-stop-circle"></i> Stop-Befehl</label>
                                    <input type="text" id="stopCommand" class="form-control font-mono"
                                           placeholder="stop" value="stop">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <%# Installation %>
                <div class="card mt-3">
                    <div class="card-header bg-dark text-white">
                        <h3 class="card-title"><i class="fa-solid fa-gear"></i> Installation</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-cube"></i> Install-Container</label>
                                    <input type="text" id="installContainer" class="form-control font-mono"
                                           value="ghcr.io/parkervcp/yolks:debian"
                                           placeholder="ghcr.io/parkervcp/yolks:debian">
                                    <small class="form-text text-muted">Docker-Image das zum Installieren verwendet wird</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fa-solid fa-play"></i> Entrypoint</label>
                                    <input type="text" id="installEntrypoint" class="form-control font-mono"
                                           value="bash" placeholder="bash">
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label><i class="fa-solid fa-code"></i> Install-Script</label>
                            <textarea id="installScript" class="form-control font-mono" rows="12"
                                      placeholder="#!/bin/bash&#10;# Installations-Script&#10;# Wird in /mnt/server ausgeführt"></textarea>
                            <small class="form-text text-muted">
                                Bash-Script das im Install-Container ausgeführt wird. Arbeitsverzeichnis: <code>/mnt/server</code>
                            </small>
                        </div>
                    </div>
                </div>

                <%# Variablen %>
                <div class="card mt-3">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">
                            <i class="fa-solid fa-sliders-h"></i>
                            Variablen <span id="varCount" class="badge badge-light ml-2">0</span>
                        </h3>
                        <button type="button" class="btn btn-sm btn-light" id="btnAddVariable">
                            <i class="fa-solid fa-plus"></i> Variable hinzufügen
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0" id="variablesTable">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width:18%">Name</th>
                                        <th style="width:18%">ENV-Variable</th>
                                        <th style="width:16%">Default-Wert</th>
                                        <th style="width:22%">Rules</th>
                                        <th style="width:9%">Typ</th>
                                        <th style="width:8%" class="text-center">Sichtbar</th>
                                        <th style="width:9%"></th>
                                    </tr>
                                </thead>
                                <tbody id="variablesList">
                                    <tr id="noVarsRow">
                                        <td colspan="7" class="text-center text-muted p-3">
                                            <i class="fa-solid fa-info-circle"></i>
                                            Noch keine Variablen — URL laden oder manuell hinzufügen
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer text-muted small">
                            Wichtige Felder: <code>SERVER_PORT</code>, <code>SERVER_IP</code> werden vom Daemon automatisch befüllt (<code>daemon_auto_assign: true</code>).
                        </div>
                    </div>
                </div>

                <%# Config-Files (Patching vor Start) %>
                <div class="card mt-3">
                    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">
                            <i class="fa-solid fa-file-code"></i>
                            Config-Dateien <span id="cfgCount" class="badge badge-dark ml-2">0</span>
                        </h3>
                        <button type="button" class="btn btn-sm btn-dark" id="btnAddConfigFile">
                            <i class="fa-solid fa-plus"></i> Datei hinzufügen
                        </button>
                    </div>
                    <div class="card-body" id="configFilesContainer">
                        <p class="text-muted small mb-2" id="cfgEmptyHint">
                            <i class="fa-solid fa-info-circle"></i>
                            Keine Config-Dateien definiert. Bei Egg-Import werden diese automatisch befüllt.
                        </p>
                    </div>
                    <div class="card-footer text-muted small">
                        Config-Dateien werden <strong>vor jedem Server-Start</strong> automatisch gepatcht.
                        Werte können Variablen enthalten: <code>{{SERVER_PORT}}</code>, <code>{{SERVER_NAME}}</code> etc.
                    </div>
                </div>

                <%# Templates Builder %>
                <div class="card mt-3">
                    <div class="card-header bg-info">
                        <h3 class="card-title">
                            <i class="fa-solid fa-layer-group"></i> Templates
                            <span class="badge badge-light ml-2" id="templates-count">0</span>
                        </h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-light" id="btnAddTemplate">
                                <i class="fa-solid fa-plus"></i> Template hinzufügen
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-2">
                            Templates definieren Server-Vorlagen (z.B. "Competitive 5v5") mit vordefinierten Variablen und Config-Overrides.
                        </p>
                        <div id="templates-container"></div>
                        <div id="no-templates-msg" class="text-muted small" style="display: none;">
                            <i class="fa-solid fa-info-circle"></i> Keine Templates definiert.
                        </div>
                    </div>
                </div>

                <%# JSON-Vorschau %>
                <div class="card mt-3 collapsed-card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fa-solid fa-code"></i> game_data JSON Vorschau
                        </h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" id="btnRefreshPreview" title="Aktualisieren">
                                <i class="fa-solid fa-sync"></i>
                            </button>
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <pre id="jsonPreview" class="bg-dark text-white p-3 rounded small" style="max-height:450px;overflow:auto;white-space:pre-wrap;word-break:break-all;"></pre>
                    </div>
                </div>

                <%# Submit %>
                <div class="card mt-3">
                    <div class="card-body">
                        <div class="alert alert-warning mb-3">
                            <i class="fa-solid fa-exclamation-triangle"></i>
                            Das Addon wird als <strong>pending_review</strong> gespeichert. Nach dem Speichern in der Detail-Ansicht prüfen und freigeben.
                        </div>
                        <button type="submit" class="btn btn-success btn-lg" id="btnSave">
                            <i class="fa-solid fa-save"></i> Addon speichern
                        </button>
                        <a href="/admin/addons" class="btn btn-secondary btn-lg ml-2">Abbrechen</a>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<style>
.font-mono { font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important; }
.var-row td { vertical-align: middle !important; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── State ─────────────────────────────────────────────────────────────
    let variables = [];
    // Felder die nicht im Formular abgebildet sind (config, ports, query, templates)
    // Werden beim Import/URL-Laden gespeichert und beim Speichern wieder eingemischt.
    let _preservedGameData = {};

    // ── Slug auto-generation ──────────────────────────────────────────────
    const nameInput = document.getElementById('addonName');
    const slugInput = document.getElementById('addonSlug');
    let slugEdited = false;

    slugInput.addEventListener('input', () => { slugEdited = true; });
    nameInput.addEventListener('input', () => {
        if (!slugEdited) {
            slugInput.value = nameInput.value
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
        }
    });

    // ── Zusätzliche Docker-Images ─────────────────────────────────────────
    document.getElementById('btnAddImage').addEventListener('click', () => {
        const container = document.getElementById('additionalImages');
        const row = document.createElement('div');
        row.className = 'row mb-2 extra-image-row';
        row.innerHTML = `
            <div class="col-md-7">
                <input type="text" class="form-control form-control-sm font-mono extra-image-url" placeholder="docker.io/org/image:tag">
            </div>
            <div class="col-md-4">
                <input type="text" class="form-control form-control-sm extra-image-label" placeholder="Label">
            </div>
            <div class="col-md-1 pl-0">
                <button type="button" class="btn btn-sm btn-danger btn-block" onclick="this.closest('.extra-image-row').remove()">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
    });

    // ── Variablen rendern ─────────────────────────────────────────────────
    function renderVariables() {
        const tbody  = document.getElementById('variablesList');
        const noRow  = document.getElementById('noVarsRow');
        const badge  = document.getElementById('varCount');

        tbody.querySelectorAll('tr.var-row').forEach(r => r.remove());
        badge.textContent = variables.length;

        if (variables.length === 0) {
            noRow.style.display = '';
            return;
        }
        noRow.style.display = 'none';

        variables.forEach((v, idx) => {
            const tr = document.createElement('tr');
            tr.className = 'var-row';
            tr.dataset.idx = idx;
            tr.innerHTML = `
                <td><input type="text" class="form-control form-control-sm var-name" value="${escHtml(v.name || '')}" placeholder="Anzeigename"></td>
                <td><input type="text" class="form-control form-control-sm font-mono var-env" value="${escHtml(v.env_variable || '')}" placeholder="ENV_KEY"></td>
                <td><input type="text" class="form-control form-control-sm var-default" value="${escHtml(String(v.default_value ?? ''))}" placeholder="Default"></td>
                <td><input type="text" class="form-control form-control-sm font-mono var-rules" value="${escHtml(v.rules || 'nullable|string')}" placeholder="nullable|string"></td>
                <td>
                    <select class="form-control form-control-sm var-type">
                        <option value="text"${v.field_type === 'text' ? ' selected' : ''}>text</option>
                        <option value="number"${v.field_type === 'number' ? ' selected' : ''}>number</option>
                        <option value="password"${v.field_type === 'password' ? ' selected' : ''}>password</option>
                        <option value="boolean"${v.field_type === 'boolean' ? ' selected' : ''}>boolean</option>
                        <option value="select"${v.field_type === 'select' ? ' selected' : ''}>select</option>
                    </select>
                </td>
                <td class="text-center">
                    <div class="custom-control custom-switch">
                        <input type="checkbox" class="custom-control-input var-viewable" id="varView_${idx}"${v.user_viewable !== false ? ' checked' : ''}>
                        <label class="custom-control-label" for="varView_${idx}"></label>
                    </div>
                </td>
                <td>
                    <button type="button" class="btn btn-sm btn-danger btn-remove-var" data-idx="${idx}">
                        <i class="fa-solid fa-times"></i>
                    </button>
                </td>
            `;

            // ENV uppercase erzwingen
            const envInput = tr.querySelector('.var-env');
            envInput.addEventListener('input', () => {
                const pos = envInput.selectionStart;
                envInput.value = envInput.value.toUpperCase().replace(/[^A-Z0-9_]/g, '_');
                try { envInput.setSelectionRange(pos, pos); } catch {}
            });

            // Änderungen zurückschreiben
            tr.querySelectorAll('input, select').forEach(el => {
                el.addEventListener('change', () => syncRow(tr, idx));
                el.addEventListener('input',  () => syncRow(tr, idx));
            });

            tbody.appendChild(tr);
        });

        // Remove-Buttons
        tbody.querySelectorAll('.btn-remove-var').forEach(btn => {
            btn.addEventListener('click', () => {
                variables.splice(parseInt(btn.dataset.idx, 10), 1);
                renderVariables();
            });
        });
    }

    function syncRow(tr, idx) {
        if (!variables[idx]) return;
        variables[idx] = {
            ...variables[idx],
            name:           tr.querySelector('.var-name').value,
            env_variable:   tr.querySelector('.var-env').value.toUpperCase().replace(/[^A-Z0-9_]/g, '_'),
            default_value:  tr.querySelector('.var-default').value,
            rules:          tr.querySelector('.var-rules').value,
            field_type:     tr.querySelector('.var-type').value,
            user_viewable:  tr.querySelector('.var-viewable').checked,
        };
    }

    document.getElementById('btnAddVariable').addEventListener('click', () => {
        variables.push({
            name: '', env_variable: '', default_value: '',
            description: '', user_viewable: true, user_editable: true,
            rules: 'nullable|string', field_type: 'text',
        });
        renderVariables();
        const rows = document.querySelectorAll('.var-row');
        if (rows.length) rows[rows.length - 1].querySelector('.var-name').focus();
    });

    // ── Config-Files Editor ──────────────────────────────────────────────
    function renderConfigFiles() {
        const container = document.getElementById('configFilesContainer');
        const files = (_preservedGameData.config && _preservedGameData.config.files) || {};
        const fileNames = Object.keys(files);
        const badge = document.getElementById('cfgCount');
        const hint = document.getElementById('cfgEmptyHint');

        // Alte Blöcke entfernen
        container.querySelectorAll('.cfg-file-block').forEach(b => b.remove());
        badge.textContent = fileNames.length;

        if (fileNames.length === 0) {
            hint.style.display = '';
            return;
        }
        hint.style.display = 'none';

        fileNames.forEach(fileName => {
            const entry = files[fileName] || {};
            const parser = entry.parser || 'file';
            const find = entry.find || {};

            const block = document.createElement('div');
            block.className = 'cfg-file-block card card-outline card-secondary mb-2';
            block.innerHTML = `
                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                    <span>
                        <i class="fa-solid fa-file-alt"></i>
                        <input type="text" class="form-control form-control-sm d-inline-block font-mono cfg-filename" 
                               value="${escHtml(fileName)}" style="width:320px" data-original="${escHtml(fileName)}">
                        <select class="form-control form-control-sm d-inline-block cfg-parser ml-2" style="width:130px">
                            <option value="file"${parser==='file'?' selected':''}>file (text)</option>
                            <option value="properties"${parser==='properties'?' selected':''}>properties</option>
                            <option value="yaml"${parser==='yaml'?' selected':''}>yaml</option>
                            <option value="json"${parser==='json'?' selected':''}>json</option>
                            <option value="ini"${parser==='ini'?' selected':''}>ini</option>
                            <option value="xml"${parser==='xml'?' selected':''}>xml</option>
                        </select>
                    </span>
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-info cfg-add-key" title="Key hinzufügen">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger cfg-remove-file" title="Datei entfernen">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body py-2 px-3 cfg-keys-body">
                    ${Object.keys(find).length === 0 ? '<span class="text-muted small">Keine Keys</span>' : ''}
                </div>
            `;

            const keysBody = block.querySelector('.cfg-keys-body');
            // Keys rendern
            Object.entries(find).forEach(([key, val]) => {
                keysBody.appendChild(createKeyRow(key, typeof val === 'object' ? JSON.stringify(val) : String(val)));
            });

            // Events
            block.querySelector('.cfg-remove-file').addEventListener('click', () => {
                const origName = block.querySelector('.cfg-filename').dataset.original;
                delete files[origName];
                renderConfigFiles();
            });

            block.querySelector('.cfg-add-key').addEventListener('click', () => {
                keysBody.querySelector('.text-muted')?.remove();
                keysBody.appendChild(createKeyRow('', ''));
                keysBody.lastElementChild.querySelector('.cfg-key').focus();
            });

            // Filename/Parser Änderung → sync
            block.querySelector('.cfg-filename').addEventListener('change', () => syncConfigFiles());
            block.querySelector('.cfg-parser').addEventListener('change', () => syncConfigFiles());

            container.appendChild(block);
        });
    }

    function createKeyRow(key, val) {
        const row = document.createElement('div');
        row.className = 'row mb-1 cfg-key-row';
        row.innerHTML = `
            <div class="col-md-4">
                <input type="text" class="form-control form-control-sm font-mono cfg-key" value="${escHtml(key)}" placeholder="Key (z.B. server-port)">
            </div>
            <div class="col-md-7">
                <input type="text" class="form-control form-control-sm font-mono cfg-val" value="${escHtml(val)}" placeholder="Value (z.B. {{SERVER_PORT}})">
            </div>
            <div class="col-md-1 pl-0">
                <button type="button" class="btn btn-sm btn-danger btn-block cfg-remove-key">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        `;
        row.querySelector('.cfg-remove-key').addEventListener('click', () => {
            row.remove();
            syncConfigFiles();
        });
        row.querySelector('.cfg-key').addEventListener('change', () => syncConfigFiles());
        row.querySelector('.cfg-val').addEventListener('change', () => syncConfigFiles());
        return row;
    }

    function syncConfigFiles() {
        const files = {};
        document.querySelectorAll('.cfg-file-block').forEach(block => {
            const fileName = block.querySelector('.cfg-filename').value.trim();
            if (!fileName) return;
            const parser = block.querySelector('.cfg-parser').value;
            const find = {};
            block.querySelectorAll('.cfg-key-row').forEach(row => {
                const k = row.querySelector('.cfg-key').value.trim();
                const v = row.querySelector('.cfg-val').value;
                if (k) find[k] = v;
            });
            files[fileName] = { parser, find };
            // Original-Name updaten für nächsten Sync-Zyklus
            block.querySelector('.cfg-filename').dataset.original = fileName;
        });
        if (!_preservedGameData.config) _preservedGameData.config = { files: {}, logs: [] };
        _preservedGameData.config.files = files;
        document.getElementById('cfgCount').textContent = Object.keys(files).length;
    }

    document.getElementById('btnAddConfigFile').addEventListener('click', () => {
        if (!_preservedGameData.config) _preservedGameData.config = { files: {}, logs: [] };
        // Leere Datei hinzufügen (Name kann editiert werden)
        const newName = 'config-file-' + (Object.keys(_preservedGameData.config.files).length + 1);
        _preservedGameData.config.files[newName] = { parser: 'file', find: {} };
        renderConfigFiles();
    });

    // ── Template Builder ──────────────────────────────────────────────────
    function renderTemplates() {
        const container = document.getElementById('templates-container');
        container.innerHTML = '';
        const templates = _preservedGameData.templates || [];
        templates.forEach((tpl, idx) => {
            const card = document.createElement('div');
            card.className = 'tpl-card card card-outline card-info mb-3';
            card.dataset.idx = idx;

            const varsHtml = Object.entries(tpl.variables || {}).map(([k, v]) =>
                `<div class="input-group input-group-sm mb-1 tpl-var-row">
                    <input type="text" class="form-control font-monospace tpl-var-key" value="${escHtml(k)}" placeholder="ENV_KEY">
                    <input type="text" class="form-control font-monospace tpl-var-val" value="${escHtml(v)}" placeholder="Wert">
                    <div class="input-group-append"><button type="button" class="btn btn-outline-danger tpl-remove-var"><i class="fa-solid fa-times"></i></button></div>
                </div>`
            ).join('');

            const ovHtml = Object.entries(tpl.config_overrides || {}).map(([fname, keys]) =>
                `<div class="tpl-ov-file card card-outline card-secondary mb-2">
                    <div class="card-header py-1">
                        <input type="text" class="form-control form-control-sm font-monospace tpl-ov-filename" value="${escHtml(fname)}" placeholder="config/server.cfg">
                        <div class="card-tools"><button type="button" class="btn btn-sm btn-outline-danger tpl-remove-ov-file"><i class="fa-solid fa-trash"></i></button></div>
                    </div>
                    <div class="card-body py-1 tpl-ov-keys">${Object.entries(keys).map(([k, v]) =>
                        `<div class="input-group input-group-sm mb-1 tpl-ov-row">
                            <input type="text" class="form-control font-monospace tpl-ov-key" value="${escHtml(k)}" placeholder="key">
                            <input type="text" class="form-control font-monospace tpl-ov-val" value="${escHtml(v)}" placeholder="value">
                            <div class="input-group-append"><button type="button" class="btn btn-outline-danger tpl-remove-ov"><i class="fa-solid fa-times"></i></button></div>
                        </div>`
                    ).join('')}</div>
                    <div class="card-footer py-1"><button type="button" class="btn btn-xs btn-outline-success tpl-add-ov-key"><i class="fa-solid fa-plus"></i> Key</button></div>
                </div>`
            ).join('');

            card.innerHTML = `
                <div class="card-header py-2">
                    <div class="row align-items-center">
                        <div class="col-md-3"><input type="text" class="form-control form-control-sm tpl-name" value="${escHtml(tpl.name || '')}" placeholder="template-name"></div>
                        <div class="col-md-3"><input type="text" class="form-control form-control-sm tpl-label" value="${escHtml(tpl.label || '')}" placeholder="Anzeigename"></div>
                        <div class="col-md-3"><input type="text" class="form-control form-control-sm tpl-icon" value="${escHtml(tpl.icon || '')}" placeholder="fa-trophy"></div>
                        <div class="col-md-3 text-right"><button type="button" class="btn btn-sm btn-danger tpl-remove"><i class="fa-solid fa-trash"></i></button></div>
                    </div>
                </div>
                <div class="card-body py-2">
                    <input type="text" class="form-control form-control-sm mb-2 tpl-desc" value="${escHtml(tpl.description || '')}" placeholder="Beschreibung">
                    <p class="mb-1 text-muted small"><strong>Variable-Overrides:</strong></p>
                    <div class="tpl-vars-container">${varsHtml}</div>
                    <button type="button" class="btn btn-xs btn-outline-success mb-2 tpl-add-var"><i class="fa-solid fa-plus"></i> Variable</button>
                    <p class="mb-1 text-muted small"><strong>Config-Overrides:</strong></p>
                    <div class="tpl-overrides-container">${ovHtml}</div>
                    <button type="button" class="btn btn-xs btn-outline-info tpl-add-ov-file"><i class="fa-solid fa-plus"></i> Config-Datei</button>
                </div>
            `;
            container.appendChild(card);
        });
        bindTemplateEvents();
        updateTemplatesMessage();
    }

    function bindTemplateEvents() {
        // Remove template
        document.querySelectorAll('.tpl-remove').forEach(btn => btn.addEventListener('click', function() {
            if (confirm('Template entfernen?')) { this.closest('.tpl-card').remove(); syncTemplates(); }
        }));
        // Add variable
        document.querySelectorAll('.tpl-add-var').forEach(btn => btn.addEventListener('click', function() {
            const vc = this.closest('.card-body').querySelector('.tpl-vars-container');
            vc.insertAdjacentHTML('beforeend', `<div class="input-group input-group-sm mb-1 tpl-var-row">
                <input type="text" class="form-control font-monospace tpl-var-key" value="" placeholder="ENV_KEY">
                <input type="text" class="form-control font-monospace tpl-var-val" value="" placeholder="Wert">
                <div class="input-group-append"><button type="button" class="btn btn-outline-danger tpl-remove-var"><i class="fa-solid fa-times"></i></button></div>
            </div>`);
            bindTemplateEvents();
        }));
        // Remove variable
        document.querySelectorAll('.tpl-remove-var').forEach(btn => btn.addEventListener('click', function() {
            this.closest('.tpl-var-row').remove(); syncTemplates();
        }));
        // Add config override file
        document.querySelectorAll('.tpl-add-ov-file').forEach(btn => btn.addEventListener('click', function() {
            const oc = this.closest('.card-body')
                ? this.closest('.card-body').querySelector('.tpl-overrides-container')
                : this.previousElementSibling;
            if (!oc) return;
            oc.insertAdjacentHTML('beforeend', `<div class="tpl-ov-file card card-outline card-secondary mb-2">
                <div class="card-header py-1">
                    <input type="text" class="form-control form-control-sm font-monospace tpl-ov-filename" value="" placeholder="config/server.cfg">
                    <div class="card-tools"><button type="button" class="btn btn-sm btn-outline-danger tpl-remove-ov-file"><i class="fa-solid fa-trash"></i></button></div>
                </div>
                <div class="card-body py-1 tpl-ov-keys"></div>
                <div class="card-footer py-1"><button type="button" class="btn btn-xs btn-outline-success tpl-add-ov-key"><i class="fa-solid fa-plus"></i> Key</button></div>
            </div>`);
            bindTemplateEvents();
        }));
        // Remove config override file
        document.querySelectorAll('.tpl-remove-ov-file').forEach(btn => btn.addEventListener('click', function() {
            this.closest('.tpl-ov-file').remove(); syncTemplates();
        }));
        // Add key to config override
        document.querySelectorAll('.tpl-add-ov-key').forEach(btn => btn.addEventListener('click', function() {
            const kc = this.closest('.tpl-ov-file').querySelector('.tpl-ov-keys');
            kc.insertAdjacentHTML('beforeend', `<div class="input-group input-group-sm mb-1 tpl-ov-row">
                <input type="text" class="form-control font-monospace tpl-ov-key" value="" placeholder="key">
                <input type="text" class="form-control font-monospace tpl-ov-val" value="" placeholder="value">
                <div class="input-group-append"><button type="button" class="btn btn-outline-danger tpl-remove-ov"><i class="fa-solid fa-times"></i></button></div>
            </div>`);
            bindTemplateEvents();
        }));
        // Remove override key
        document.querySelectorAll('.tpl-remove-ov').forEach(btn => btn.addEventListener('click', function() {
            this.closest('.tpl-ov-row').remove(); syncTemplates();
        }));
    }

    function syncTemplates() {
        const templates = [];
        document.querySelectorAll('.tpl-card').forEach(card => {
            const name = card.querySelector('.tpl-name').value.trim();
            if (!name) return;
            const variables = {};
            card.querySelectorAll('.tpl-var-row').forEach(row => {
                const k = row.querySelector('.tpl-var-key').value.trim();
                if (k) variables[k] = row.querySelector('.tpl-var-val').value;
            });
            const config_overrides = {};
            card.querySelectorAll('.tpl-ov-file').forEach(fileBlock => {
                const fname = fileBlock.querySelector('.tpl-ov-filename').value.trim();
                if (!fname) return;
                const keys = {};
                fileBlock.querySelectorAll('.tpl-ov-row').forEach(row => {
                    const k = row.querySelector('.tpl-ov-key').value.trim();
                    if (k) keys[k] = row.querySelector('.tpl-ov-val').value;
                });
                config_overrides[fname] = keys;
            });
            templates.push({
                name,
                label: card.querySelector('.tpl-label').value.trim() || name,
                description: card.querySelector('.tpl-desc').value.trim(),
                icon: card.querySelector('.tpl-icon').value.trim() || 'fa-server',
                variables,
                config_overrides,
            });
        });
        _preservedGameData.templates = templates;
        updateTemplatesMessage();
        updatePreview();
    }

    function updateTemplatesMessage() {
        const count = document.querySelectorAll('.tpl-card').length;
        document.getElementById('no-templates-msg').style.display = count === 0 ? 'block' : 'none';
        document.getElementById('templates-count').textContent = count;
    }

    document.getElementById('btnAddTemplate').addEventListener('click', () => {
        if (!_preservedGameData.templates) _preservedGameData.templates = [];
        _preservedGameData.templates.push({
            name: 'template-' + (_preservedGameData.templates.length + 1),
            label: '', description: '', icon: 'fa-server',
            variables: {}, config_overrides: {}
        });
        renderTemplates();
        updatePreview();
    });

    // ── URL laden ─────────────────────────────────────────────────────────
    document.getElementById('btnLoadUrl').addEventListener('click', async () => {
        const url    = document.getElementById('externalUrl').value.trim();
        const status = document.getElementById('urlLoadStatus');
        const btn    = document.getElementById('btnLoadUrl');

        if (!url) {
            showStatus(status, 'warning', 'Bitte zuerst eine URL eingeben.');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Laden…';
        showStatus(status, 'info', '<i class="fa-solid fa-spinner fa-spin"></i> Egg wird geladen und konvertiert…');

        try {
            const resp = await fetch('/admin/addons/fetch-external?url=' + encodeURIComponent(url));
            const data = await resp.json();

            if (!data.success) {
                showStatus(status, 'danger', '<i class="fa-solid fa-times-circle"></i> ' + escHtml(data.message));
                return;
            }

            fillForm(data.gameData);
            // source_type auf pelican setzen wenn aus bekanntem GitHub-Repo
            document.getElementById('addonSourceType').value = 'pelican';
            showStatus(status, 'success', '<i class="fa-solid fa-check-circle"></i> Formular wurde befüllt. Bitte prüfen und ggf. anpassen.');

        } catch (err) {
            showStatus(status, 'danger', '<i class="fa-solid fa-times-circle"></i> Netzwerkfehler: ' + escHtml(err.message));
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-download"></i> Laden & befüllen';
        }
    });

    function fillForm(gd) {
        if (!gd) return;

        // Basis
        if (gd.meta?.name) {
            nameInput.value = gd.meta.name;
            slugEdited = false;
            nameInput.dispatchEvent(new Event('input'));
        }
        if (gd.meta?.description) document.getElementById('addonDescription').value = gd.meta.description;
        if (gd.meta?.author)      document.getElementById('addonAuthor').value = gd.meta.author;

        // Docker-Images
        const images    = gd.docker_images || {};
        const imgKeys   = Object.keys(images);
        if (imgKeys.length > 0) {
            document.getElementById('dockerImage').value      = imgKeys[0];
            document.getElementById('dockerImageLabel').value = images[imgKeys[0]] || '';
        }
        const addCont = document.getElementById('additionalImages');
        addCont.innerHTML = '';
        imgKeys.slice(1).forEach(key => {
            const row = document.createElement('div');
            row.className = 'row mb-2 extra-image-row';
            row.innerHTML = `
                <div class="col-md-7">
                    <input type="text" class="form-control form-control-sm font-mono extra-image-url" value="${escHtml(key)}">
                </div>
                <div class="col-md-4">
                    <input type="text" class="form-control form-control-sm extra-image-label" value="${escHtml(images[key] || '')}">
                </div>
                <div class="col-md-1 pl-0">
                    <button type="button" class="btn btn-sm btn-danger btn-block" onclick="this.closest('.extra-image-row').remove()">
                        <i class="fa-solid fa-times"></i>
                    </button>
                </div>
            `;
            addCont.appendChild(row);
        });

        // Startup
        if (gd.startup?.command) document.getElementById('startupCommand').value = gd.startup.command;
        if (gd.startup?.done)    document.getElementById('startupDone').value    = gd.startup.done;
        if (gd.startup?.stop)    document.getElementById('stopCommand').value    = gd.startup.stop;

        // Installation
        const inst = gd.scripts?.installation || {};
        if (inst.container)  document.getElementById('installContainer').value  = inst.container;
        if (inst.entrypoint) document.getElementById('installEntrypoint').value = inst.entrypoint;
        if (inst.script)     document.getElementById('installScript').value     = inst.script;

        // Variablen
        variables = Array.isArray(gd.variables) ? gd.variables.map(v => ({ ...v })) : [];
        renderVariables();

        // Nicht-UI-Felder für späteren Merge speichern
        _preservedGameData = {
            config:    gd.config    || { files: {}, logs: [] },
            ports:     gd.ports     || undefined,
            query:     gd.query     || undefined,
            templates: gd.templates || [],
        };

        renderConfigFiles();
        renderTemplates();
        updatePreview();

        // Zum Formular scrollen
        document.getElementById('addonName').scrollIntoView({ behavior: 'smooth', block: 'center' });

        // Config-Files rendern (falls Egg config.files hatte)
        renderConfigFiles();
    }

    // ── Vorschau ──────────────────────────────────────────────────────────
    function collectGameData() {
        const imgKey   = document.getElementById('dockerImage').value.trim();
        const imgLabel = document.getElementById('dockerImageLabel').value.trim() || imgKey;
        const dockerImages = {};
        if (imgKey) dockerImages[imgKey] = imgLabel;
        document.querySelectorAll('.extra-image-row').forEach(row => {
            const u = row.querySelector('.extra-image-url').value.trim();
            const l = row.querySelector('.extra-image-label').value.trim();
            if (u) dockerImages[u] = l || u;
        });

        // Alle sichtbaren Rows erst synchronisieren
        document.querySelectorAll('.var-row').forEach(tr => {
            syncRow(tr, parseInt(tr.dataset.idx, 10));
        });

        // Config-Files UI → State synchronisieren
        syncConfigFiles();
        syncTemplates();

        return {
            meta: {
                version:     'FIREBOT_v2',
                name:        document.getElementById('addonName').value.trim(),
                author:      document.getElementById('addonAuthor').value.trim() || 'Community',
                description: document.getElementById('addonDescription').value.trim(),
            },
            docker_images: dockerImages,
            startup: {
                command: document.getElementById('startupCommand').value.trim(),
                done:    document.getElementById('startupDone').value.trim(),
                stop:    document.getElementById('stopCommand').value.trim() || 'stop',
            },
            config: _preservedGameData.config || { files: {}, logs: [] },
            scripts: {
                installation: {
                    container:  document.getElementById('installContainer').value.trim(),
                    entrypoint: document.getElementById('installEntrypoint').value.trim() || 'bash',
                    script:     document.getElementById('installScript').value,
                },
            },
            variables,
            ...(_preservedGameData.ports ? { ports: _preservedGameData.ports } : {}),
            ...(_preservedGameData.query ? { query: _preservedGameData.query } : {}),
            templates: _preservedGameData.templates || [],
        };
    }

    function updatePreview() {
        const pre = document.getElementById('jsonPreview');
        try {
            pre.textContent = JSON.stringify(collectGameData(), null, 2);
        } catch (e) {
            pre.textContent = 'Fehler: ' + e.message;
        }
    }

    document.getElementById('btnRefreshPreview').addEventListener('click', updatePreview);

    // ── Submit ────────────────────────────────────────────────────────────
    document.getElementById('createAddonForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const name     = document.getElementById('addonName').value.trim();
        const dockerImg = document.getElementById('dockerImage').value.trim();

        if (!name) {
            alert('Name ist erforderlich.');
            document.getElementById('addonName').focus();
            return;
        }
        if (!dockerImg) {
            alert('Docker-Image ist erforderlich.');
            document.getElementById('dockerImage').focus();
            return;
        }

        const btn = document.getElementById('btnSave');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichere…';

        const gameData = collectGameData();
        const payload  = {
            name,
            slug:        document.getElementById('addonSlug').value.trim(),
            description: document.getElementById('addonDescription').value.trim(),
            category:    document.getElementById('addonCategory').value,
            source_type: document.getElementById('addonSourceType').value,
            game_data:   JSON.stringify(gameData),
        };

        try {
            const resp = await fetch('/admin/addons', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload),
            });
            const data = await resp.json();

            if (data.success) {
                window.location.href = '/admin/addons/' + data.id;
            } else {
                alert('Fehler: ' + data.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-save"></i> Addon speichern';
            }
        } catch (err) {
            alert('Netzwerkfehler: ' + err.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-save"></i> Addon speichern';
        }
    });

    // ── Helper ────────────────────────────────────────────────────────────
    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function showStatus(el, type, msg) {
        el.style.display = '';
        el.className = 'alert alert-' + type + ' py-2 mb-0';
        el.innerHTML = msg;
    }

    // Init
    renderVariables();
    renderConfigFiles();
    renderTemplates();
    updatePreview();
});
</script>
