<%# Admin: Addon Edit/Review %>
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-edit"></i>
                        <%= addon.name %>
                    </h1>
                    <p class="text-muted">
                        ID: <%= addon.id %> | Slug: <%= addon.slug %>
                    </p>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <a href="/admin/addons" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Zurück
                        </a>
                        <button class="btn btn-success" id="btnApprove">
                            <i class="fa-solid fa-check"></i> Approve & Publish
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">
            
            <%# Status-Badges %>
            <div class="row mb-3">
                <div class="col-md-12">
                    <span class="badge badge-lg <%= addon.trust_level === 'official' ? 'badge-success' : addon.trust_level === 'verified' ? 'badge-info' : 'badge-secondary' %>">
                        Trust: <%= addon.trust_level %>
                    </span>
                    <span class="badge badge-lg <%= addon.visibility === 'public' || addon.visibility === 'official' ? 'badge-success' : addon.visibility === 'unlisted' ? 'badge-warning' : 'badge-secondary' %>">
                        Visibility: <%= addon.visibility %>
                    </span>
                    <span class="badge badge-lg <%= addon.runtime_type === 'docker_steam' ? 'badge-primary' : addon.runtime_type === 'docker_standalone' ? 'badge-info' : 'badge-secondary' %>">
                        <i class="fa-brands fa-docker"></i> <%= addon.runtime_type %>
                    </span>
                    <% if (addon.source_type === 'pelican') { %>
                        <span class="badge badge-lg badge-warning">
                            <i class="fa-solid fa-egg"></i> Pelican Import
                        </span>
                    <% } else if (addon.source_type === 'native') { %>
                        <span class="badge badge-lg badge-success">
                            <i class="fa-solid fa-crown"></i> Native
                        </span>
                    <% } %>
                </div>
            </div>

            <div class="row">
                
                <%# Linke Spalte: Metadata %>
                <div class="col-md-6">
                    
                    <%# Basis-Informationen %>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fa-solid fa-info-circle"></i>
                                Basis-Informationen
                            </h3>
                        </div>
                        <div class="card-body">
                            <form id="metadataForm">
                                <div class="form-group">
                                    <label>Name</label>
                                    <input type="text" class="form-control" name="name" value="<%= addon.name %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label>Slug</label>
                                    <input type="text" class="form-control" name="slug" value="<%= addon.slug %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label>Beschreibung</label>
                                    <textarea class="form-control" name="description" rows="4"><%= addon.description || '' %></textarea>
                                </div>
                                
                                <div class="form-group">
                                    <label>Runtime Type <small class="text-muted">(wird automatisch aus game_data ermittelt)</small></label>
                                    <select class="form-control" name="runtime_type" disabled>
                                        <option value="docker_steam"      <%= addon.runtime_type === 'docker_steam'      ? 'selected' : '' %>>Docker + SteamCMD</option>
                                        <option value="docker_standalone" <%= addon.runtime_type === 'docker_standalone' ? 'selected' : '' %>>Docker Standalone</option>
                                    </select>
                                    <small class="form-text text-muted">Wird beim Speichern von game_data neu berechnet.</small>
                                </div>
                                
                                <div class="form-group">
                                    <label>Tags (comma-separated)</label>
                                    <input type="text" class="form-control" name="tags" 
                                           value="<%= addon.tags ? (() => { try { return JSON.parse(addon.tags).join(', '); } catch(e) { return addon.tags; } })() : '' %>">
                                </div>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-save"></i> Speichern
                                </button>
                            </form>
                        </div>
                    </div>

                    <%# Approval-Settings %>
                    <div class="card">
                        <div class="card-header bg-warning">
                            <h3 class="card-title">
                                <i class="fa-solid fa-shield-check"></i>
                                SuperAdmin Approval
                            </h3>
                        </div>
                        <div class="card-body">
                            <form id="approvalForm">
                                <div class="form-group">
                                    <label>Trust Level</label>
                                    <select class="form-control" name="trust_level">
                                        <option value="unverified" <%= addon.trust_level === 'unverified' ? 'selected' : '' %>>
                                            Unverified (Neu, nicht getestet)
                                        </option>
                                        <option value="verified" <%= addon.trust_level === 'verified' ? 'selected' : '' %>>
                                            Verified (Getestet, funktioniert)
                                        </option>
                                        <option value="trusted" <%= addon.trust_level === 'trusted' ? 'selected' : '' %>>
                                            Trusted (10+ Installs, 4+ Rating)
                                        </option>
                                        <option value="official" <%= addon.trust_level === 'official' ? 'selected' : '' %>>
                                            Official (FireBot Team)
                                        </option>
                                    </select>
                                </div>
                                
                                <div class="form-group">
                                    <label>Visibility</label>
                                    <select class="form-control" name="visibility">
                                        <option value="unlisted" <%= addon.visibility === 'unlisted' ? 'selected' : '' %>>
                                            Unlisted (Nicht gelistet, über Link erreichbar)
                                        </option>
                                        <option value="public" <%= addon.visibility === 'public' ? 'selected' : '' %>>
                                            Public (Im Marketplace sichtbar)
                                        </option>
                                        <option value="private" <%= addon.visibility === 'private' ? 'selected' : '' %>>
                                            Private (Nur für bestimmte Guilds)
                                        </option>
                                        <option value="official" <%= addon.visibility === 'official' ? 'selected' : '' %>>
                                            Official (Offiziell von FireBot Team)
                                        </option>
                                    </select>
                                </div>
                                
                                <div class="alert alert-info">
                                    <i class="fa-solid fa-info-circle"></i>
                                    <strong>Verified:</strong> <%= addon.verified_at ? new Date(addon.verified_at).toLocaleString('de-DE') : 'Noch nicht verifiziert' %><br>
                                    <strong>Last Tested:</strong> <%= addon.last_tested_at ? new Date(addon.last_tested_at).toLocaleString('de-DE') : 'Nie' %>
                                </div>
                                
                                <button type="submit" class="btn btn-success btn-block">
                                    <i class="fa-solid fa-check"></i> Approve & Update
                                </button>
                            </form>
                        </div>
                    </div>

                </div>

                <%# Rechte Spalte: Technical Details %>
                <div class="col-md-6">
                    
                    <%# Docker Images %>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fa-brands fa-docker"></i> Docker Images</h3>
                        </div>
                        <div class="card-body">
                            <% const dockerImages = addon.game_data?.docker_images || {}; %>
                            <% const imageEntries = Object.entries(dockerImages); %>
                            <% if (imageEntries.length > 0) { %>
                                <ul class="list-group list-group-flush">
                                    <% imageEntries.forEach(([img, label]) => { %>
                                        <li class="list-group-item py-1 px-2 small">
                                            <code><%= img %></code>
                                            <% if (label && label !== img) { %>
                                                <span class="text-muted ml-2">(<%= label %>)</span>
                                            <% } %>
                                        </li>
                                    <% }); %>
                                </ul>
                            <% } else { %>
                                <p class="text-muted">Keine Docker-Images definiert</p>
                            <% } %>
                        </div>
                    </div>

                    <%# Startup %>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fa-solid fa-play"></i> Startup</h3>
                        </div>
                        <div class="card-body">
                            <label class="small font-weight-bold">Command:</label>
                            <code class="d-block bg-dark text-white p-2 small rounded mb-2"><%= addon.game_data?.startup?.command || '–' %></code>
                            <label class="small font-weight-bold">Done-String:</label>
                            <code class="d-block bg-dark text-white p-2 small rounded"><%= addon.game_data?.startup?.done || '–' %></code>
                        </div>
                    </div>

                    <%# Variables %>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fa-solid fa-sliders"></i> Variables</h3>
                        </div>
                        <div class="card-body">
                            <% const vars = addon.game_data?.variables || []; %>
                            <p class="text-muted">
                                <strong><%= vars.length %></strong> Variable(n) definiert
                                <small class="ml-2">(aus game_data — im Guild-Kontext bearbeitbar)</small>
                            </p>
                            <% if (vars.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead><tr><th>ENV</th><th>Default</th><th>Typ</th></tr></thead>
                                        <tbody>
                                            <% vars.forEach(v => { %>
                                                <tr>
                                                    <td><code><%= v.env_variable %></code></td>
                                                    <td class="text-muted small"><%= v.default_value || '–' %></td>
                                                    <td><span class="badge badge-secondary"><%= v.field_type || 'text' %></span></td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <%# Installation Script %>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fa-solid fa-terminal"></i> Installation Script</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="small font-weight-bold">Container:</label>
                                    <code class="d-block bg-dark text-white p-2 small rounded mb-2"><%= addon.game_data?.scripts?.installation?.container || '–' %></code>
                                    <label class="small font-weight-bold">Entrypoint:</label>
                                    <code class="d-block bg-dark text-white p-2 small rounded"><%= addon.game_data?.scripts?.installation?.entrypoint || 'bash' %></code>
                                </div>
                                <div class="col-md-6">
                                    <label class="small font-weight-bold">Script (read-only Vorschau):</label>
                                    <textarea class="form-control bg-dark text-light" rows="8"
                                              style="font-family:monospace;font-size:0.8rem;resize:vertical;" readonly
                                    ><%= addon.game_data?.scripts?.installation?.script || '' %></textarea>
                                    <small class="text-muted">Skript über <em>game_data JSON-Editor</em> bearbeiten.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <%# game_data JSON-Editor %>
                    <div class="card">
                        <div class="card-header bg-dark text-white">
                            <h3 class="card-title"><i class="fa-solid fa-code"></i> game_data (FIREBOT_v2 JSON)</h3>
                        </div>
                        <div class="card-body">
                            <textarea id="gameDataTextarea" class="form-control bg-dark text-white"
                                      rows="14" style="font-family:monospace;font-size:0.8rem;resize:vertical;"
                            ><%= JSON.stringify(addon.game_data || {}, null, 2) %></textarea>
                            <div class="mt-2">
                                <button type="button" id="btnSaveGameData" class="btn btn-warning btn-sm">
                                    <i class="fa-solid fa-save"></i> game_data speichern
                                </button>
                                <small class="text-muted ml-2">runtime_type wird automatisch neu berechnet.</small>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const addonId = <%= addon.id %>;
    
    // Metadata-Form Submit
    document.getElementById('metadataForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const payload = {
            name:        formData.get('name'),
            slug:        formData.get('slug'),
            description: formData.get('description'),
            tags:        formData.get('tags'),
        };
        
        try {
            const response = await fetch(`/admin/addons/${addonId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.success) {
                toastr.success('Metadaten erfolgreich gespeichert!');
            } else {
                toastr.error(result.message || 'Fehler beim Speichern der Metadaten');
            }
        } catch (error) {
            console.error('Error:', error);
            toastr.error('Fehler beim Speichern der Metadaten');
        }
    });
    
    // Approval-Form Submit
    document.getElementById('approvalForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const payload = Object.fromEntries(formData);
        
        if (!confirm('Addon wirklich mit diesen Einstellungen freigeben?')) return;
        
        try {
            const response = await fetch(`/admin/addons/${addonId}/approve`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            const result = await response.json();
            
            if (result.success) {
                toastr.success('Addon erfolgreich freigegeben!');
                setTimeout(() => location.reload(), 1500);
            } else {
                toastr.error(result.message || 'Fehler beim Freigeben des Addons');
            }
        } catch (error) {
            console.error('Error:', error);
            toastr.error('Fehler beim Freigeben des Addons');
        }
    });
    
    // Quick-Approve Button (Header)
    document.getElementById('btnApprove').addEventListener('click', async function() {
        if (!confirm('Addon als VERIFIED und PUBLIC freigeben?')) return;
        
        try {
            const response = await fetch(`/admin/addons/${addonId}/approve`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    trust_level: 'verified',
                    visibility: 'public'
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                toastr.success('Addon erfolgreich freigegeben!');
                setTimeout(() => location.reload(), 1500);
            } else {
                toastr.error(result.message || 'Fehler beim Freigeben des Addons');
            }
        } catch (error) {
            console.error('Error:', error);
            toastr.error('Fehler beim Freigeben des Addons');
        }
    });

    // game_data JSON-Editor speichern
    document.getElementById('btnSaveGameData').addEventListener('click', async function() {
        const rawJson = document.getElementById('gameDataTextarea').value;

        let gameData;
        try {
            gameData = JSON.parse(rawJson);
        } catch {
            toastr.error('Ungültiges JSON — bitte Syntax prüfen');
            return;
        }
        if (gameData?.meta?.version !== 'FIREBOT_v2') {
            toastr.error('meta.version muss "FIREBOT_v2" sein');
            return;
        }

        this.disabled = true;
        this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Speichert...';

        const form = document.getElementById('metadataForm');
        const payload = {
            name:        form.querySelector('[name=name]').value,
            slug:        form.querySelector('[name=slug]').value,
            description: form.querySelector('[name=description]').value,
            tags:        form.querySelector('[name=tags]').value,
            game_data:   JSON.stringify(gameData),
        };

        try {
            const response = await fetch(`/admin/addons/${addonId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            const result = await response.json();
            if (result.success) {
                toastr.success('game_data gespeichert!');
                setTimeout(() => location.reload(), 1200);
            } else {
                toastr.error(result.message || 'Fehler beim Speichern');
            }
        } catch (error) {
            console.error('Error:', error);
            toastr.error('Netzwerkfehler beim Speichern');
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fa-solid fa-save"></i> game_data speichern';
        }
    });
});
</script>
