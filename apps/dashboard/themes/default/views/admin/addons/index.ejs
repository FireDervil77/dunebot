<%# Admin: Addon Marketplace Management - Hauptseite %>
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">
                        <i class="fa-solid fa-puzzle-piece"></i>
                        Addon Marketplace Management
                    </h1>
                </div>
                <div class="col-sm-6">
                    <div class="float-sm-right">
                        <button type="button" class="btn btn-warning" data-toggle="modal" data-target="#modalJsonPaste">
                            <i class="fa-solid fa-code"></i> Per JSON einfügen
                        </button>
                        <a href="/admin/addons/import" class="btn btn-primary">
                            <i class="fa-solid fa-download"></i> Egg importieren
                        </a>
                        <a href="/admin/addons/create" class="btn btn-success">
                            <i class="fa-solid fa-plus"></i> Manuell erstellen
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">
            
            <%# Stats-Cards %>
            <div class="row">
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3><%= stats.total %></h3>
                            <p>Total Addons</p>
                        </div>
                        <div class="icon">
                            <i class="fa-solid fa-puzzle-piece"></i>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3><%= stats.official %></h3>
                            <p>Official</p>
                        </div>
                        <div class="icon">
                            <i class="fa-solid fa-crown"></i>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3><%= stats.pending_review %></h3>
                            <p>Pending Review</p>
                        </div>
                        <div class="icon">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-primary">
                        <div class="inner">
                            <h3><%= stats.docker_steam %></h3>
                            <p>Docker + SteamCMD</p>
                        </div>
                        <div class="icon">
                            <i class="fa-brands fa-docker"></i>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-secondary">
                        <div class="inner">
                            <h3><%= stats.docker_standalone %></h3>
                            <p>Docker Standalone</p>
                        </div>
                        <div class="icon">
                            <i class="fa-solid fa-cube"></i>
                        </div>
                    </div>
                </div>
            </div>

            <%# Addon-Tabelle %>
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fa-solid fa-list"></i>
                        Alle Addons
                    </h3>
                    <div class="card-tools">
                        <div class="input-group input-group-sm" style="width: 300px;">
                            <input type="text" id="addonSearch" class="form-control float-right" placeholder="Suchen...">
                            <div class="input-group-append">
                                <button type="button" class="btn btn-default">
                                    <i class="fa-solid fa-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap" id="addonsTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Runtime</th>
                                <th>Source</th>
                                <th>Status</th>
                                <th>Trust Level</th>
                                <th>Visibility</th>
                                <th>Last Tested</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (addons && addons.length > 0) { %>
                                <% addons.forEach(addon => { %>
                                    <tr>
                                        <td><%= addon.id %></td>
                                        <td>
                                            <strong><%= addon.name %></strong><br>
                                            <small class="text-muted"><%= addon.slug %></small>
                                        </td>
                                        <td>
                                            <% if (addon.runtime_type === 'docker_steam') { %>
                                                <span class="badge badge-primary">
                                                    <i class="fa-brands fa-docker"></i> Docker + Steam
                                                </span>
                                            <% } else if (addon.runtime_type === 'docker_standalone') { %>
                                                <span class="badge badge-info">
                                                    <i class="fa-solid fa-cube"></i> Docker Standalone
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-secondary">
                                                    <i class="fa-solid fa-question"></i> <%= addon.runtime_type || 'Unbekannt' %>
                                                </span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (addon.source_type === 'pelican') { %>
                                                <i class="fa-solid fa-egg"></i> Pelican
                                            <% } else if (addon.source_type === 'native') { %>
                                                <i class="fa-solid fa-crown"></i> Native
                                            <% } else { %>
                                                <i class="fa-solid fa-users"></i> Community
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (addon.status === 'approved') { %>
                                                <span class="badge badge-success">
                                                    <i class="fa-solid fa-check"></i> Approved
                                                </span>
                                            <% } else if (addon.status === 'pending_review') { %>
                                                <span class="badge badge-warning">
                                                    <i class="fa-solid fa-clock"></i> Pending
                                                </span>
                                            <% } else if (addon.status === 'rejected') { %>
                                                <span class="badge badge-danger">
                                                    <i class="fa-solid fa-times"></i> Rejected
                                                </span>
                                            <% } else if (addon.status === 'draft') { %>
                                                <span class="badge badge-secondary">
                                                    <i class="fa-solid fa-file"></i> Draft
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-secondary">
                                                    <i class="fa-solid fa-question"></i> <%= addon.status || 'Unknown' %>
                                                </span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (addon.trust_level === 'official') { %>
                                                <span class="badge badge-success">
                                                    <i class="fa-solid fa-crown"></i> Official
                                                </span>
                                            <% } else if (addon.trust_level === 'trusted') { %>
                                                <span class="badge badge-primary">
                                                    <i class="fa-solid fa-shield-check"></i> Trusted
                                                </span>
                                            <% } else if (addon.trust_level === 'verified') { %>
                                                <span class="badge badge-info">
                                                    <i class="fa-solid fa-check-circle"></i> Verified
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-secondary">
                                                    <i class="fa-solid fa-question-circle"></i> Unverified
                                                </span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (addon.visibility === 'official') { %>
                                                <span class="badge badge-danger">
                                                    <i class="fa-solid fa-crown"></i> Official
                                                </span>
                                            <% } else if (addon.visibility === 'public') { %>
                                                <span class="badge badge-success">
                                                    <i class="fa-solid fa-eye"></i> Public
                                                </span>
                                            <% } else if (addon.visibility === 'unlisted') { %>
                                                <span class="badge badge-info">
                                                    <i class="fa-solid fa-link"></i> Unlisted
                                                </span>
                                            <% } else if (addon.visibility === 'private') { %>
                                                <span class="badge badge-secondary">
                                                    <i class="fa-solid fa-eye-slash"></i> Private
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-warning">
                                                    <i class="fa-solid fa-question"></i> <%= addon.visibility || 'Unknown' %>
                                                </span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (addon.last_tested_at) { %>
                                                <small><%= new Date(addon.last_tested_at).toLocaleDateString('de-DE') %></small>
                                            <% } else { %>
                                                <small class="text-muted">Nie</small>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="/admin/addons/<%= addon.id %>" 
                                                   class="btn btn-info" title="Edit">
                                                    <i class="fa-solid fa-edit"></i>
                                                </a>
                                                <button class="btn btn-success btn-test-addon" 
                                                        data-addon-id="<%= addon.id %>" title="Test Installation">
                                                    <i class="fa-solid fa-flask"></i>
                                                </button>
                                                <button class="btn btn-danger btn-delete-addon" 
                                                        data-addon-id="<%= addon.id %>" 
                                                        data-addon-name="<%= addon.name %>" 
                                                        title="Delete">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9" class="text-center text-muted">
                                        <i class="fa-solid fa-inbox"></i><br>
                                        Keine Addons vorhanden<br>
                                        <a href="/admin/addons/import" class="btn btn-primary btn-sm mt-2">
                                            <i class="fa-solid fa-download"></i> Egg importieren
                                        </a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    
    
    // Search-Funktionalität
    document.getElementById('addonSearch').addEventListener('keyup', function() {
        const searchTerm = this.value.toLowerCase();
        const rows = document.querySelectorAll('#addonsTable tbody tr');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });
    
    // Test-Installation
    document.querySelectorAll('.btn-test-addon').forEach(btn => {
        btn.addEventListener('click', async function() {
            const addonId = this.dataset.addonId;
            
            if (!confirm('Test-Installation für dieses Addon starten?')) return;
            
            try {
                const response = await fetch(`/admin/addons/${addonId}/test`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('✅ ' + result.message);
                } else {
                    alert('❌ ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Fehler beim Starten des Tests');
            }
        });
    });
    
    // Delete-Addon
    document.querySelectorAll('.btn-delete-addon').forEach(btn => {
        btn.addEventListener('click', async function() {
            const addonId = this.dataset.addonId;
            const addonName = this.dataset.addonName || 'dieses Addon';
            
            // ✅ Erste Bestätigung bleibt
            if (!confirm(`Addon "${addonName}" wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden!`)) return;
            
            try {
                const response = await fetch(`/admin/addons/${addonId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const result = await response.json();
                
                // ✅ Zweite Bestätigung durch Toast ersetzt
                if (result.success) {
                    toastr.success(result.message || 'Addon erfolgreich gelöscht');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error(result.message || 'Fehler beim Löschen');
                }
            } catch (error) {
                console.error('Error:', error);
                toastr.error('Netzwerkfehler beim Löschen des Addons');
            }
        });
    });

    // ── JSON-Paste Modal ─────────────────────────────────────────────────────

    const jsonTextarea = document.getElementById('jsonPasteContent');
    const jsonNameField = document.getElementById('jsonPasteName');
    const jsonSlugField = document.getElementById('jsonPasteSlug');

    // JSON einfügen → Felder auto-befüllen
    if (jsonTextarea) {
        jsonTextarea.addEventListener('input', function () {
            try {
                const parsed = JSON.parse(this.value.trim());
                const meta = parsed?.meta || {};
                if (meta.name && !jsonNameField.value) jsonNameField.value = meta.name;
                if (meta.slug && !jsonSlugField.value) jsonSlugField.value = meta.slug;
            } catch (_) { /* JSON noch unvollständig */ }
        });
    }

    document.getElementById('btnJsonPasteSubmit')?.addEventListener('click', async function () {
        const rawJson = jsonTextarea?.value?.trim();
        const name    = jsonNameField?.value?.trim();
        const slug    = jsonSlugField?.value?.trim();
        const category = document.getElementById('jsonPasteCategory')?.value;

        if (!rawJson) return toastr.error('Bitte JSON einfügen');
        if (!name)    return toastr.error('Bitte einen Namen angeben');
        if (!slug)    return toastr.error('Bitte einen Slug angeben');

        let parsed;
        try {
            parsed = JSON.parse(rawJson);
        } catch (e) {
            return toastr.error('Ungültiges JSON: ' + e.message);
        }

        const btn = this;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i> Speichere…';

        try {
            const response = await fetch('/admin/addons/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name,
                    slug,
                    description: parsed?.meta?.description || '',
                    category,
                    game_data: JSON.stringify(parsed),
                    source_type: 'native'
                })
            });
            const result = await response.json();
            if (result.success) {
                toastr.success('Addon gespeichert – Weiterleitung…');
                setTimeout(() => window.location.href = `/admin/addons/${result.id || ''}`, 1200);
            } else {
                toastr.error(result.message || 'Fehler beim Speichern');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-save mr-1"></i> Speichern';
            }
        } catch (error) {
            console.error('JSON-Paste Fehler:', error);
            toastr.error('Netzwerkfehler');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-save mr-1"></i> Speichern';
        }
    });

});
</script>

<!-- ── Modal: Addon per JSON einfügen ──────────────────────────────────── -->
<div class="modal fade" id="modalJsonPaste" tabindex="-1" role="dialog" aria-labelledby="modalJsonPasteLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalJsonPasteLabel">
                    <i class="fa-solid fa-code mr-2"></i>Addon per JSON einfügen
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="jsonPasteContent">
                        <strong>FIREBOT_v2 JSON</strong>
                        <span class="text-muted ml-2">— vollständige Addon-Definition einfügen</span>
                    </label>
                    <textarea
                        id="jsonPasteContent"
                        class="form-control font-monospace"
                        rows="10"
                        placeholder='{ "meta": { "version": "FIREBOT_v2", "name": "My Server", ... }, ... }'
                        style="font-size:12px;"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group">
                            <label for="jsonPasteName">Name <span class="text-danger">*</span></label>
                            <input type="text" id="jsonPasteName" class="form-control" placeholder="wird aus JSON befüllt">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="jsonPasteSlug">Slug <span class="text-danger">*</span></label>
                            <input type="text" id="jsonPasteSlug" class="form-control" placeholder="z.B. valheim">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="jsonPasteCategory">Kategorie</label>
                            <select id="jsonPasteCategory" class="form-control">
                                <option value="other">Sonstiges</option>
                                <option value="fps">FPS / Shooter</option>
                                <option value="survival">Survival</option>
                                <option value="sandbox">Sandbox</option>
                                <option value="mmorpg">MMORPG</option>
                                <option value="racing">Racing</option>
                                <option value="strategy">Strategie</option>
                                <option value="horror">Horror</option>
                                <option value="scifi">Sci-Fi</option>
                                <option value="community">Community</option>
                                <option value="pelican">Pelican</option>
                                <option value="native">Native</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="alert alert-info mb-0">
                    <i class="fa-solid fa-circle-info mr-1"></i>
                    Das Addon wird mit Status <strong>Pending Review</strong> gespeichert.
                    Name und Slug werden automatisch aus dem <code>meta</code>-Block befüllt, können aber manuell überschrieben werden.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
                <button type="button" id="btnJsonPasteSubmit" class="btn btn-warning">
                    <i class="fa-solid fa-save mr-1"></i> Speichern
                </button>
            </div>
        </div>
    </div>
</div>
