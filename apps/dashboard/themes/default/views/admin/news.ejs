<%# 
  * News Verwaltung
  * Übersicht aller News
  %>

<div class="app-content">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-md-6">
                <h2>News Verwaltung</h2>
            </div>
            <div class="col-md-6 text-end">
                <a href="/admin/news/new" class="btn btn-success">
                    <i class="fa-solid fa-plus me-2"></i>Neue News erstellen
                </a>
            </div>
        </div>

        <!-- News Liste -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Titel</th>
                                    <th>Autor</th>
                                    <th>Status</th>
                                    <th>Datum</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (newsList && newsList.length > 0) { %>
                                    <% newsList.forEach(news => { %>
                                        <tr>
                                            <td><%= news.title %></td>
                                            <td><%= news.author %></td>
                                            <td>
                                                <span class="badge bg-<%= news.status === 'published' ? 'success' : 'warning' %>">
                                                    <%= news.status %>
                                                </span>
                                            </td>
                                            <td><%= new Date(news.date).toLocaleDateString('de-DE') %></td>
                                            <td>
                                                <a href="/admin/news/edit/<%= news._id %>" 
                                                   class="btn btn-sm btn-primary">
                                                    <i class="fa-solid fa-edit"></i>
                                                </a>
                                                <form method="POST" 
                                                      action="/admin/news/delete/<%= news._id %>" 
                                                      class="guild-ajax-form"
                                                      data-form-type="news-delete"
                                                      style="display:inline;" 
                                                      onsubmit="return confirm('News wirklich löschen?');">
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">
                                            Keine News vorhanden
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
