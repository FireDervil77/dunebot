<%#
 * Admin Content Hub — Unified Content Management
 * Vereint: News, Changelogs, Benachrichtigungen, Einstellungen
 *
 * @context {string} activeTab   — 'news' | 'changelogs' | 'notifications' | 'settings'
 * @context {Array}  newsList    — lokalisierte News
 * @context {Array}  changelogsList — lokalisierte Changelogs
 * @context {Array}  notifications — Alle Benachrichtigungen (inkl. Ankündigungen)
 * @context {string} currentLocale
 * @context {Object} channelConfig — Channel-Config pro Kategorie
 * @context {Array}  categories    — Kategorie-Liste
 * @context {string} controlGuildId
%>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-layer-group mr-2"></i>Content Management</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
                    <li class="breadcrumb-item active">Content</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">

        <%# ====== TAB NAVIGATION ====== %>
        <div class="card card-outline card-primary">
            <div class="card-header p-0 pt-1 border-bottom-0">
                <ul class="nav nav-tabs" id="contentTabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link <%= activeTab === 'news' ? 'active' : '' %>"
                           href="/admin/content?tab=news" data-tab="news">
                            <i class="fas fa-newspaper mr-1"></i> News
                            <span class="badge badge-info ml-1"><%= newsList ? newsList.length : 0 %></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= activeTab === 'changelogs' ? 'active' : '' %>"
                           href="/admin/content?tab=changelogs" data-tab="changelogs">
                            <i class="fas fa-code-branch mr-1"></i> Changelogs
                            <span class="badge badge-info ml-1"><%= changelogsList ? changelogsList.length : 0 %></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= activeTab === 'notifications' ? 'active' : '' %>"
                           href="/admin/content?tab=notifications" data-tab="notifications">
                            <i class="fas fa-bell mr-1"></i> Benachrichtigungen
                            <span class="badge badge-info ml-1"><%= notifications ? notifications.length : 0 %></span>
                        </a>
                    </li>
                    <li class="nav-item ml-auto">
                        <a class="nav-link <%= activeTab === 'settings' ? 'active' : '' %>"
                           href="/admin/content?tab=settings" data-tab="settings">
                            <i class="fas fa-cog mr-1"></i> Einstellungen
                        </a>
                    </li>
                </ul>
            </div>

            <div class="card-body">
                <div class="tab-content" id="contentTabContent">

                    <%# ====== NEWS TAB ====== %>
                    <div class="tab-pane fade <%= activeTab === 'news' ? 'show active' : '' %>" id="tab-news">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="mb-0">News Verwalten</h4>
                            <a href="/admin/content/news/new" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus mr-1"></i> Neue News
                            </a>
                        </div>

                        <% if (newsList && newsList.length > 0) { %>
                        <table class="table table-striped table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Titel</th>
                                    <th>Status</th>
                                    <th>Autor</th>
                                    <th>Datum</th>
                                    <th style="width:140px">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% newsList.forEach((n, i) => { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td>
                                        <strong><%= n.title || 'Ohne Titel' %></strong>
                                        <% if (n.slug) { %>
                                            <br><small class="text-muted">/news-details/<%= n.slug %></small>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge badge-<%= n.status === 'published' ? 'success' : 'warning' %>">
                                            <%= n.status || 'draft' %>
                                        </span>
                                    </td>
                                    <td><%= n.author || '—' %></td>
                                    <td><%= n.formattedDate || '—' %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/admin/content/news/edit/<%= n._id %>" class="btn btn-info" title="Bearbeiten">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-success" data-link-type="news" data-link-id="<%= n._id %>" data-link-title="<%= (n.title || '').replace(/"/g, '&quot;') %>" onclick="linkContent(this.dataset.linkType, this.dataset.linkId, this.dataset.linkTitle)" title="Verknüpfen">
                                                <i class="fas fa-link"></i>
                                            </button>
                                            <button class="btn btn-danger" onclick="deleteContent('news', '<%= n._id %>')" title="Löschen">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                            </tbody>
                        </table>
                        <% } else { %>
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-newspaper fa-3x mb-3"></i>
                            <p>Noch keine News vorhanden.</p>
                            <a href="/admin/content/news/new" class="btn btn-primary">
                                <i class="fas fa-plus mr-1"></i> Erste News erstellen
                            </a>
                        </div>
                        <% } %>
                    </div>

                    <%# ====== CHANGELOGS TAB ====== %>
                    <div class="tab-pane fade <%= activeTab === 'changelogs' ? 'show active' : '' %>" id="tab-changelogs">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="mb-0">Changelogs Verwalten</h4>
                            <a href="/admin/content/changelogs/new" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus mr-1"></i> Neuer Changelog
                            </a>
                        </div>

                        <% if (changelogsList && changelogsList.length > 0) { %>
                        <table class="table table-striped table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>Version</th>
                                    <th>Titel</th>
                                    <th>Type</th>
                                    <th>Komponente</th>
                                    <th>Status</th>
                                    <th>Release</th>
                                    <th style="width:140px">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% changelogsList.forEach(c => { %>
                                <tr>
                                    <td><span class="badge badge-<%= c.typeBadge?.color || 'secondary' %>">v<%= c.version %></span></td>
                                    <td><strong><%= c.title || 'Ohne Titel' %></strong></td>
                                    <td><%= c.type || 'minor' %></td>
                                    <td><%= c.component || 'system' %></td>
                                    <td>
                                        <span class="badge badge-<%= c.status === 'published' ? 'success' : 'warning' %>">
                                            <%= c.status || 'draft' %>
                                        </span>
                                    </td>
                                    <td><%= c.formattedDate || '—' %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/admin/content/changelogs/edit/<%= c.id %>" class="btn btn-info" title="Bearbeiten">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-success" data-link-type="changelog" data-link-id="<%= c.id %>" data-link-title="v<%= c.version %>" onclick="linkContent(this.dataset.linkType, this.dataset.linkId, this.dataset.linkTitle)" title="Verknüpfen">
                                                <i class="fas fa-link"></i>
                                            </button>
                                            <button class="btn btn-danger" onclick="deleteContent('changelogs', '<%= c.id %>')" title="Löschen">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                            </tbody>
                        </table>
                        <% } else { %>
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-code-branch fa-3x mb-3"></i>
                            <p>Noch keine Changelogs vorhanden.</p>
                            <a href="/admin/content/changelogs/new" class="btn btn-primary">
                                <i class="fas fa-plus mr-1"></i> Ersten Changelog erstellen
                            </a>
                        </div>
                        <% } %>
                    </div>

                    <%# ====== BENACHRICHTIGUNGEN TAB ====== %>
                    <div class="tab-pane fade <%= activeTab === 'notifications' ? 'show active' : '' %>" id="tab-notifications">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="mb-0">Benachrichtigungen</h4>
                            <a href="/admin/content/notifications/new" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus mr-1"></i> Neue Benachrichtigung
                            </a>
                        </div>

                        <% if (notifications && notifications.length > 0) { %>
                        <table class="table table-striped table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Titel</th>
                                    <th>Type</th>
                                    <th>Kategorie</th>
                                    <th>Zustellung</th>
                                    <th>Erstellt</th>
                                    <th style="width:120px">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% notifications.forEach((n, i) => { %>
                                <%
                                const catEmojis = { changelog: '📋', status: '🔔', maintenance: '🔧', other: '📌' };
                                let deliveryBadges = '';
                                try {
                                    const dm = typeof n.delivery_method === 'string' ? JSON.parse(n.delivery_method) : (n.delivery_method || ['dashboard']);
                                    deliveryBadges = dm.map(m => {
                                        const icons = { dashboard: '🖥️', discord_category: '📂', system_channel: '📡', discord_channel: '#️⃣', discord_dm: '✉️' };
                                        return icons[m] || m;
                                    }).join(' ');
                                } catch(e) { deliveryBadges = '🖥️'; }
                                %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td><strong><%= n.title || 'Untitled' %></strong></td>
                                    <td>
                                        <% const tIcons = { info:'info-circle text-info', warning:'exclamation-triangle text-warning', error:'exclamation-circle text-danger', success:'check-circle text-success' }; %>
                                        <i class="fas fa-<%= tIcons[n.type] || 'bell' %>"></i> <%= n.type %>
                                    </td>
                                    <td><%= catEmojis[n.category] || '📌' %> <%= n.category || 'other' %></td>
                                    <td><%= deliveryBadges %></td>
                                    <td><%= new Date(n.created_at).toLocaleDateString(currentLocale) %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/admin/content/notifications/edit/<%= n.id %>" class="btn btn-info" title="Bearbeiten">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-danger" onclick="deleteContent('notifications', '<%= n.id %>')" title="Löschen">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                            </tbody>
                        </table>
                        <% } else { %>
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-bell fa-3x mb-3"></i>
                            <p>Keine Benachrichtigungen vorhanden.</p>
                            <a href="/admin/content/notifications/new" class="btn btn-primary">
                                <i class="fas fa-plus mr-1"></i> Erste Benachrichtigung
                            </a>
                        </div>
                        <% } %>
                    </div>

                    <%# ====== EINSTELLUNGEN TAB ====== %>
                    <div class="tab-pane fade <%= activeTab === 'settings' ? 'show active' : '' %>" id="tab-settings">
                        <h4 class="mb-3"><i class="fas fa-cog mr-2"></i>Channel-Konfiguration</h4>

                        <div class="callout callout-info">
                            <h5><i class="fas fa-info-circle mr-1"></i> Hinweis</h5>
                            <p class="mb-0">
                                Hier legst du fest, in welchem Discord-Channel Inhalte je nach Kategorie gepostet werden.
                                Die Channels beziehen sich auf den <strong>Control-Server</strong>
                                <% if (controlGuildId) { %>(ID: <code><%= controlGuildId %></code>)<% } %>.
                            </p>
                        </div>

                        <form id="channel-config-form" method="POST">

                            <div class="card">
                                <div class="card-header">
                                    <h3 class="card-title"><i class="fas fa-hashtag mr-2"></i>Channel pro Kategorie</h3>
                                </div>
                                <div class="card-body">
                                    <div id="channels-loading" class="text-center py-4">
                                        <i class="fas fa-spinner fa-spin fa-2x"></i>
                                        <p class="mt-2 text-muted">Lade Discord-Channels...</p>
                                    </div>

                                    <div id="channels-content" style="display: none;">
                                        <%
                                        const settingsCatLabels = {
                                            announcement: '📢 Ankündigungen',
                                            changelog: '📋 Changelogs',
                                            news: '📰 News',
                                            status: '🔔 Status',
                                            maintenance: '🔧 Wartung',
                                            other: '📌 Sonstige'
                                        };
                                        %>
                                        <% for (const cat of categories) { %>
                                            <div class="form-group row">
                                                <label class="col-sm-3 col-form-label">
                                                    <%= settingsCatLabels[cat] || cat %>
                                                </label>
                                                <div class="col-sm-7">
                                                    <select class="form-control channel-select"
                                                            id="channel_<%= cat %>"
                                                            name="channel_<%= cat %>"
                                                            data-category="<%= cat %>">
                                                        <option value="">— Kein Channel (deaktiviert) —</option>
                                                    </select>
                                                    <input type="hidden" name="channel_name_<%= cat %>" id="channel_name_<%= cat %>" value="">
                                                </div>
                                                <div class="col-sm-2">
                                                    <span class="channel-status-<%= cat %>">
                                                    <% if (channelConfig[cat]?.channel_id) { %>
                                                        <span class="badge badge-success mt-2 d-inline-block">
                                                            <i class="fas fa-check"></i> Konfiguriert
                                                        </span>
                                                    <% } else { %>
                                                        <span class="badge badge-warning mt-2 d-inline-block">
                                                            <i class="fas fa-exclamation-triangle"></i> Nicht gesetzt
                                                        </span>
                                                    <% } %>
                                                    </span>
                                                </div>
                                            </div>
                                        <% } %>
                                    </div>

                                    <div id="channels-error" class="alert alert-danger" style="display: none;">
                                        <i class="fas fa-exclamation-triangle mr-1"></i>
                                        <span id="channels-error-msg">Fehler beim Laden der Channels.</span>
                                    </div>

                                    <div id="channels-save-result" style="display: none;"></div>
                                </div>
                                <div class="card-footer">
                                    <button type="submit" class="btn btn-primary" id="btn-save-channels" disabled>
                                        <i class="fas fa-save mr-2"></i>Speichern
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                </div><%# /tab-content %>
            </div><%# /card-body %>
        </div><%# /card %>

    </div>
</div>

<%# ====== VERKNÜPFUNGS-MODAL ====== %>
<div class="modal fade" id="linkModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-link mr-2"></i>Inhalt verknüpfen</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <p>Verknüpfe <strong id="link-source-name"></strong> mit:</p>
                <div class="list-group" id="link-targets">
                    <a href="#" class="list-group-item list-group-item-action" data-action="copy-url">
                        <i class="fas fa-clipboard mr-2"></i> URL in Zwischenablage kopieren
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" data-action="create-news">
                        <i class="fas fa-newspaper mr-2"></i> Neue News mit Verweis erstellen
                    </a>
                    <a href="#" class="list-group-item list-group-item-action" data-action="create-notification">
                        <i class="fas fa-bell mr-2"></i> Neue Benachrichtigung mit Verweis erstellen
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

    // ====== SETTINGS: Channel-Loader ======
    const activeTab = '<%= activeTab %>';
    if (activeTab === 'settings') {
        loadChannelConfig();
    }
    // Auch bei Tab-Wechsel zu Settings laden (falls JS-Tab-Wechsel)
    document.querySelectorAll('[data-tab="settings"]').forEach(el => {
        el.addEventListener('click', () => setTimeout(loadChannelConfig, 100));
    });

    async function loadChannelConfig() {
        const controlGuildId = '<%= controlGuildId %>';
        const savedConfig = <%- JSON.stringify(channelConfig || {}) %>;

        if (!controlGuildId) {
            document.getElementById('channels-loading').style.display = 'none';
            document.getElementById('channels-error').style.display = 'block';
            document.getElementById('channels-error-msg').textContent = 'CONTROL_GUILD_ID nicht gesetzt.';
            return;
        }

        try {
            const resp = await fetch('/api/guild-channels/' + controlGuildId);
            const data = await resp.json();
            if (!data.success || !data.channels) throw new Error(data.error || 'Keine Channels');

            const textChannels = data.channels
                .filter(ch => ch.type === 0 || ch.type === 5)
                .sort((a, b) => a.name.localeCompare(b.name));

            document.querySelectorAll('.channel-select').forEach(select => {
                if (select.options.length > 1) return; // Bereits geladen
                const cat = select.dataset.category;
                textChannels.forEach(ch => {
                    const opt = document.createElement('option');
                    opt.value = ch.id;
                    opt.textContent = '#' + ch.name + (ch.type === 5 ? ' (Announcement)' : '');
                    if (savedConfig[cat]?.channel_id === ch.id) opt.selected = true;
                    select.appendChild(opt);
                });

                select.addEventListener('change', function() {
                    const opt = this.options[this.selectedIndex];
                    document.getElementById('channel_name_' + cat).value = opt.value ? opt.textContent.replace(/^#/, '') : '';
                });

                const currentOpt = select.options[select.selectedIndex];
                if (currentOpt && currentOpt.value) {
                    document.getElementById('channel_name_' + cat).value = currentOpt.textContent.replace(/^#/, '');
                }
            });

            document.getElementById('channels-loading').style.display = 'none';
            document.getElementById('channels-content').style.display = 'block';
            document.getElementById('btn-save-channels').disabled = false;
        } catch (err) {
            console.error('[Content] Channel-Load fehlgeschlagen:', err);
            document.getElementById('channels-loading').style.display = 'none';
            document.getElementById('channels-error').style.display = 'block';
            document.getElementById('channels-error-msg').textContent = 'Fehler: ' + err.message;
        }
    }

    // ====== SETTINGS: Channel-Config SAVE ======
    const channelForm = document.getElementById('channel-config-form');
    if (channelForm) {
        channelForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btn-save-channels');
            const resultDiv = document.getElementById('channels-save-result');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Speichere...';
            resultDiv.style.display = 'none';

            // Formulardaten sammeln
            const formData = {};
            document.querySelectorAll('.channel-select').forEach(select => {
                const cat = select.dataset.category;
                formData['channel_' + cat] = select.value || '';
                formData['channel_name_' + cat] = document.getElementById('channel_name_' + cat)?.value || '';
            });

            console.log('[Content] Channel-Config speichern:', formData);

            try {
                const resp = await fetch('/admin/content/settings/channels/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                    },
                    body: JSON.stringify(formData)
                });

                console.log('[Content] Save Response Status:', resp.status);

                if (!resp.ok) {
                    const text = await resp.text();
                    console.error('[Content] Save Response Body:', text);
                    throw new Error('HTTP ' + resp.status + ': ' + text.substring(0, 200));
                }

                const result = await resp.json();
                console.log('[Content] Save Result:', result);

                if (result.success) {
                    resultDiv.className = 'alert alert-success';
                    resultDiv.innerHTML = '<i class="fas fa-check mr-2"></i>' + (result.message || 'Gespeichert!');
                    resultDiv.style.display = 'block';
                    if (typeof toastr !== 'undefined') toastr.success(result.message || 'Gespeichert!');
                } else {
                    resultDiv.className = 'alert alert-danger';
                    resultDiv.innerHTML = '<i class="fas fa-times mr-2"></i>' + (result.message || 'Fehler beim Speichern');
                    resultDiv.style.display = 'block';
                    if (typeof toastr !== 'undefined') toastr.error(result.message || 'Fehler');
                }
            } catch (err) {
                console.error('[Content] Channel-Save fehlgeschlagen:', err);
                resultDiv.className = 'alert alert-danger';
                resultDiv.innerHTML = '<i class="fas fa-exclamation-triangle mr-2"></i>Fehler: ' + err.message;
                resultDiv.style.display = 'block';
                if (typeof toastr !== 'undefined') toastr.error('Speichern fehlgeschlagen: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        });
    }
});

// ====== DELETE HANDLER ======
function deleteContent(type, id) {
    if (!confirm('Wirklich löschen?')) return;

    fetch('/admin/content/' + type + '/delete/' + id, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            toastr.error(data.message || 'Fehler beim Löschen');
        }
    })
    .catch(err => toastr.error('Fehler: ' + err.message));
}

// ====== VERKNÜPFUNGS-LOGIK ======
let _linkType = '', _linkId = '', _linkTitle = '';

function linkContent(type, id, title) {
    _linkType = type;
    _linkId = id;
    _linkTitle = title;
    document.getElementById('link-source-name').textContent = title;
    $('#linkModal').modal('show');
}

document.querySelectorAll('#link-targets [data-action]').forEach(el => {
    el.addEventListener('click', function(e) {
        e.preventDefault();
        const action = this.dataset.action;

        let url = '';
        if (_linkType === 'news') url = '/news-details/' + _linkId;
        if (_linkType === 'changelog') url = '/changelogs/v' + _linkTitle.replace('v', '');

        if (action === 'copy-url') {
            const fullUrl = window.location.origin + url;
            navigator.clipboard.writeText(fullUrl).then(() => {
                toastr.success('URL kopiert: ' + fullUrl);
                $('#linkModal').modal('hide');
            });
        } else if (action === 'create-news') {
            $('#linkModal').modal('hide');
            window.location.href = '/admin/content/news/new?link_url=' + encodeURIComponent(url) + '&link_title=' + encodeURIComponent(_linkTitle);
        } else if (action === 'create-notification') {
            $('#linkModal').modal('hide');
            window.location.href = '/admin/content/notifications/new?link_url=' + encodeURIComponent(url) + '&link_title=' + encodeURIComponent(_linkTitle);
        }
    });
});
</script>
