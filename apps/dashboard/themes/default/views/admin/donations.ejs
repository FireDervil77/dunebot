<!-- Admin Donations Management Page -->

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-heart me-2"></i>Donations Management
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
                    <li class="breadcrumb-item active">Donations</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        
        <!-- Statistik Info-Boxen -->
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>€<%= stats.total_amount ? parseFloat(stats.total_amount).toFixed(2) : '0.00' %></h3>
                        <p>Gesamtbetrag</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-euro-sign"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3><%= stats.total_donations || 0 %></h3>
                        <p>Donations insgesamt</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-hand-holding-heart"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>€<%= stats.average_donation ? parseFloat(stats.average_donation).toFixed(2) : '0.00' %></h3>
                        <p>Durchschnitt</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3><%= stats.unique_supporters || 0 %></h3>
                        <p>Einzigartige Supporter</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <!-- Donations Liste -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-list me-2"></i>Alle Donations
                        </h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-success" data-toggle="modal" data-target="#createDonationModal">
                                <i class="fas fa-plus me-1"></i>Manuelle Donation
                            </button>
                        </div>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover table-striped" id="donationsTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>User</th>
                                    <th>Betrag</th>
                                    <th>Status</th>
                                    <th>Provider</th>
                                    <th>Datum</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (donations && donations.length > 0) { %>
                                    <% donations.forEach(donation => { %>
                                    <tr>
                                        <td>#<%= donation.id %></td>
                                        <td>
                                            <% if (donation.avatar) { %>
                                            <img src="https://cdn.discordapp.com/avatars/<%= donation.user_id %>/<%= donation.avatar %>.png?size=32" 
                                                 class="img-circle elevation-2" 
                                                 width="25" height="25"
                                                 alt="Avatar">
                                            <% } %>
                                            <%= donation.full_username || donation.user_id %>
                                        </td>
                                        <td class="text-success font-weight-bold">€<%= parseFloat(donation.amount || 0).toFixed(2) %></td>
                                        <td>
                                            <% if (donation.payment_status === 'completed') { %>
                                                <span class="badge badge-success">Erfolgreich</span>
                                            <% } else if (donation.payment_status === 'pending') { %>
                                                <span class="badge badge-warning">Ausstehend</span>
                                            <% } else if (donation.payment_status === 'refunded') { %>
                                                <span class="badge badge-danger">Erstattet</span>
                                            <% } else if (donation.payment_status === 'expired') { %>
                                                <span class="badge badge-secondary">Abgelaufen</span>
                                            <% } else { %>
                                                <span class="badge badge-dark"><%= donation.payment_status %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (donation.payment_provider === 'stripe') { %>
                                                <i class="fab fa-stripe text-primary"></i> Stripe
                                            <% } else if (donation.payment_provider === 'manual') { %>
                                                <i class="fas fa-hand-paper text-info"></i> Manuell
                                            <% } else { %>
                                                <%= donation.payment_provider %>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(donation.created_at).toLocaleString('de-DE') %></td>
                                        <td>
                                            <% if (donation.payment_status === 'completed') { %>
                                            <button class="btn btn-sm btn-danger" onclick="refundDonation('<%= donation.id %>')">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">
                                            <i class="fas fa-info-circle me-2"></i>Keine Donations vorhanden
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Top Donors -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-trophy me-2"></i>Top Donors
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="products-list product-list-in-card pl-2 pr-2">
                            <% topDonors.forEach((donor, index) => { %>
                            <li class="item">
                                <div class="product-img">
                                    <% if (donor.avatar) { %>
                                    <img src="https://cdn.discordapp.com/avatars/<%= donor.user_id %>/<%= donor.avatar %>.png?size=64" 
                                         class="img-circle" 
                                         alt="Avatar">
                                    <% } else { %>
                                    <span class="img-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        #<%= index + 1 %>
                                    </span>
                                    <% } %>
                                </div>
                                <div class="product-info">
                                    <span class="product-title">
                                        <%= donor.full_username || donor.user_id %>
                                        <% if (donor.badge_level === 'platinum') { %>
                                            <i class="fas fa-crown text-info float-right"></i>
                                        <% } else if (donor.badge_level === 'gold') { %>
                                            <i class="fas fa-trophy text-warning float-right"></i>
                                        <% } else if (donor.badge_level === 'silver') { %>
                                            <i class="fas fa-medal text-secondary float-right"></i>
                                        <% } else if (donor.badge_level === 'bronze') { %>
                                            <i class="fas fa-award text-danger float-right"></i>
                                        <% } %>
                                    </span>
                                    <span class="product-description">
                                        <strong class="text-success">€<%= parseFloat(donor.total_donated || 0).toFixed(2) %></strong>
                                        <small class="text-muted">(<%= donor.donation_count %> Donations)</small>
                                    </span>
                                </div>
                            </li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
                
                <!-- Badge Distribution -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-chart-pie me-2"></i>Badge-Verteilung
                        </h3>
                    </div>
                    <div class="card-body">
                        <% const badgeCounts = {}; badgeDistribution.forEach(b => badgeCounts[b.badge_level] = b.count); %>
                        <div class="progress-group">
                            <i class="fas fa-crown text-info me-2"></i> Platinum
                            <span class="float-right"><%= badgeCounts.platinum || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-info" style="width: <%= (badgeCounts.platinum || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-trophy text-warning me-2"></i> Gold
                            <span class="float-right"><%= badgeCounts.gold || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-warning" style="width: <%= (badgeCounts.gold || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-medal text-secondary me-2"></i> Silver
                            <span class="float-right"><%= badgeCounts.silver || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-secondary" style="width: <%= (badgeCounts.silver || 0) * 10 %>%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            <i class="fas fa-award text-danger me-2"></i> Bronze
                            <span class="float-right"><%= badgeCounts.bronze || 0 %></span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-danger" style="width: <%= (badgeCounts.bronze || 0) * 10 %>%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</section>

<!-- Create Donation Modal -->
<div class="modal fade" id="createDonationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manuelle Donation erstellen</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="createDonationForm">
                <div class="modal-body">
                    <div class="form-group">
                        <label>User ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="user_id" required 
                               placeholder="Discord User ID">
                        <small class="form-text text-muted">
                            Die Discord User-ID des Spenders
                        </small>
                    </div>
                    <div class="form-group">
                        <label>Betrag (€) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" name="amount" required 
                               min="0.01" step="0.01" placeholder="10.00">
                    </div>
                    <div class="form-group">
                        <label>Zahlungsart</label>
                        <select class="form-control" name="payment_provider">
                            <option value="manual">Manuell</option>
                            <option value="bank_transfer">Überweisung</option>
                            <option value="cash">Bargeld</option>
                            <option value="other">Sonstiges</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Notiz</label>
                        <textarea class="form-control" name="note" rows="3" 
                                  placeholder="Zusätzliche Informationen..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-success">Erstellen</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// DataTable initialisieren
$(document).ready(function() {
    $('#donationsTable').DataTable({
        order: [[0, 'desc']],
        pageLength: 25,
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/de-DE.json'
        }
    });
});

// Manuelle Donation erstellen
document.getElementById('createDonationForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    try {
        const response = await fetch('/admin/donations/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            toastr.success(result.message);
            $('#createDonationModal').modal('hide');
            setTimeout(() => window.location.reload(), 1500);
        } else {
            toastr.error(result.message);
        }
    } catch (error) {
        console.error('Error creating donation:', error);
        toastr.error('Fehler beim Erstellen der Donation');
    }
});

// Donation erstatten
async function refundDonation(donationId) {
    const confirmMessage = 'Möchtest du diese Donation wirklich erstatten?\n\nDieser Vorgang kann nicht rückgängig gemacht werden.';
    if (!confirm(confirmMessage)) {
        return;
    }
    
    try {
        const response = await fetch(`/admin/donations/${donationId}`, {
            method: 'DELETE'
        });
        
        const result = await response.json();
        
        if (result.success) {
            toastr.success(result.message);
            setTimeout(() => window.location.reload(), 1500);
        } else {
            toastr.error(result.message);
        }
    } catch (error) {
        console.error('Error refunding donation:', error);
        toastr.error('Fehler beim Erstatten der Donation');
    }
}
</script>
