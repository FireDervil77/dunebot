<!-- Donation Erfolg-Seite -->

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12 text-center">
                <h1 class="m-0">
                    <i class="fas fa-check-circle text-success fa-3x mb-3"></i>
                    <br>
                    Vielen Dank für deine Spende!
                </h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8">
                
                <div class="card card-success">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-heart me-2"></i>Zahlung erfolgreich
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        
                        <div class="alert alert-success mb-4">
                            <i class="fas fa-check-circle fa-3x mb-3"></i>
                            <h4>Deine Spende wurde erfolgreich verarbeitet!</h4>
                            <p class="mb-0">
                                Du erhältst in Kürze:
                            </p>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="info-box bg-light">
                                    <span class="info-box-icon bg-success">
                                        <i class="fas fa-award"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Supporter-Badge</span>
                                        <span class="info-box-number">Im Dashboard</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <div class="info-box bg-light">
                                    <span class="info-box-icon bg-info">
                                        <i class="fab fa-discord"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Discord-Role</span>
                                        <span class="info-box-number">Auf allen Servern</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-4 mb-3">
                                <div class="info-box bg-light">
                                    <span class="info-box-icon bg-warning">
                                        <i class="fas fa-trophy"></i>
                                    </span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Hall of Fame</span>
                                        <span class="info-box-number">Eintrag</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <hr>
                        
                        <p class="mb-4">
                            <i class="fas fa-info-circle text-info me-2"></i>
                            Die Aktivierung erfolgt automatisch innerhalb weniger Sekunden.<br>
                            <small class="text-muted">Session-ID: <code><%= sessionId %></code></small>
                        </p>
                        
                        <div class="btn-group" role="group">
                            <a href="/guild/<%= guildId %>" class="btn btn-primary">
                                <i class="fas fa-home me-2"></i>Zum Dashboard
                            </a>
                            <a href="/guild/<%= guildId %>/plugins/core/donate" class="btn btn-outline-success">
                                <i class="fas fa-heart me-2"></i>Weitere Spende
                            </a>
                        </div>
                        
                    </div>
                </div>
                
                <!-- FAQ -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-question-circle me-2"></i>Was passiert jetzt?
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            <div>
                                <i class="fas fa-check bg-success"></i>
                                <div class="timeline-item">
                                    <h3 class="timeline-header">Zahlung bestätigt</h3>
                                    <div class="timeline-body">
                                        Stripe hat deine Zahlung erfolgreich verarbeitet.
                                    </div>
                                </div>
                            </div>
                            
                            <div>
                                <i class="fas fa-cog fa-spin bg-info"></i>
                                <div class="timeline-item">
                                    <h3 class="timeline-header">Badge wird vergeben</h3>
                                    <div class="timeline-body">
                                        Dein Supporter-Badge wird in der Datenbank gespeichert.
                                    </div>
                                </div>
                            </div>
                            
                            <div>
                                <i class="fas fa-cog fa-spin bg-primary"></i>
                                <div class="timeline-item">
                                    <h3 class="timeline-header">Discord-Role wird vergeben</h3>
                                    <div class="timeline-body">
                                        Der Bot vergibt automatisch deine Supporter-Role auf allen Servern.
                                    </div>
                                </div>
                            </div>
                            
                            <div>
                                <i class="fas fa-clock bg-secondary"></i>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</section>
