<!-- 
    DuneBot - Donation-Seite
    User-facing Seite für Spenden via Stripe
    Path: /guild/:guildId/plugins/core/donate
-->

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-heart text-danger me-2"></i>
                    Unterstütze DuneBot
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>">Dashboard</a></li>
                    <li class="breadcrumb-item active">Spenden</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        
        <!-- Success/Cancel Benachrichtigungen (dynamisch via JavaScript) -->
        <div id="payment-notification"></div>
        
        <div class="row">
            <!-- Donation-Form -->
            <div class="col-md-8">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-gift me-2"></i>Jetzt spenden
                        </h3>
                    </div>
                    <div class="card-body">
                        
                        <!-- Info-Text -->
                        <div class="alert alert-info mb-4">
                            <i class="fas fa-info-circle me-2"></i>
                            DuneBot ist <strong>komplett kostenlos</strong> und Open-Source.<br>
                            Mit deiner Spende hilfst du uns, die Server-Kosten zu decken und neue Features zu entwickeln!
                        </div>
                        
                        <!-- Donation-Form -->
                        <form id="donation-form">
                            
                            <!-- Betrag wählen -->
                            <div class="form-group">
                                <label for="donation-amount">
                                    <i class="fas fa-euro-sign me-1"></i>Betrag auswählen
                                </label>
                                
                                <!-- Vordefinierte Beträge -->
                                <div class="btn-group btn-group-toggle d-flex mb-3" data-toggle="buttons">
                                    <label class="btn btn-outline-primary" onclick="setAmount(3)">
                                        <input type="radio" name="amount-preset" value="3">
                                        €3
                                    </label>
                                    <label class="btn btn-outline-primary active" onclick="setAmount(5)">
                                        <input type="radio" name="amount-preset" value="5" checked>
                                        €5
                                    </label>
                                    <label class="btn btn-outline-primary" onclick="setAmount(10)">
                                        <input type="radio" name="amount-preset" value="10">
                                        €10
                                    </label>
                                    <label class="btn btn-outline-primary" onclick="setAmount(20)">
                                        <input type="radio" name="amount-preset" value="20">
                                        €20
                                    </label>
                                    <label class="btn btn-outline-secondary" onclick="setAmount(0); document.getElementById('donation-amount').focus();">
                                        <input type="radio" name="amount-preset" value="custom">
                                        Eigener Betrag
                                    </label>
                                </div>
                                
                                <!-- Eigener Betrag -->
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-euro-sign"></i>
                                    </span>
                                    <input type="number" 
                                           id="donation-amount" 
                                           class="form-control form-control-lg" 
                                           min="1" 
                                           step="0.01"
                                           value="5.00"
                                           placeholder="Betrag eingeben">
                                    <span class="input-group-text">EUR</span>
                                </div>
                                <small class="form-text text-muted">
                                    Mindestbetrag: €1
                                </small>
                            </div>
                            
                            <!-- Optionale Nachricht -->
                            <div class="form-group">
                                <label for="donation-message">
                                    <i class="fas fa-comment me-1"></i>Nachricht (optional)
                                </label>
                                <textarea id="donation-message" 
                                          class="form-control" 
                                          rows="3"
                                          placeholder="Danke für DuneBot! Ihr macht einen tollen Job! 😊"
                                          maxlength="500"></textarea>
                                <small class="form-text text-muted">
                                    Deine Nachricht wird im SuperAdmin-Dashboard sichtbar (max. 500 Zeichen)
                                </small>
                            </div>
                            
                            <!-- Automatische Discord-ID Info -->
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle me-2"></i>
                                <strong>Dein Discord-Account wird automatisch verknüpft!</strong><br>
                                <small>
                                    Nach erfolgreicher Zahlung erhältst du automatisch:
                                    <ul class="mb-0 mt-2">
                                        <li>🏅 Supporter-Badge im Dashboard</li>
                                        <li>🎨 Spezielle Discord-Role auf allen Servern mit DuneBot</li>
                                        <li>🏆 Eintrag in der Hall of Fame</li>
                                    </ul>
                                </small>
                            </div>
                            
                            <!-- Stripe-Info -->
                            <div class="alert alert-light border">
                                <div class="d-flex align-items-center">
                                    <img src="https://stripe.com/img/v3/home/social.png" 
                                         alt="Stripe" 
                                         height="30" 
                                         class="me-3">
                                    <div>
                                        <strong>Sichere Zahlung via Stripe</strong><br>
                                        <small class="text-muted">
                                            Deine Zahlung wird über Stripe abgewickelt. 
                                            DuneBot hat keinen Zugriff auf deine Kreditkartendaten.
                                        </small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Submit-Button -->
                            <button type="button" 
                                    id="donate-button"
                                    class="btn btn-lg btn-success btn-block" 
                                    onclick="createDonation()">
                                <i class="fas fa-heart me-2"></i>
                                <span id="button-text">Jetzt spenden</span>
                                <span id="button-spinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                            </button>
                            
                            <p class="text-center text-muted mt-3 mb-0">
                                <small>
                                    <i class="fas fa-lock me-1"></i>
                                    Sichere Zahlung via Stripe | 
                                    <i class="fas fa-shield-alt me-1"></i>
                                    PCI-DSS Level 1 zertifiziert
                                </small>
                            </p>
                            
                        </form>
                        
                    </div>
                </div>
            </div>
            
            <!-- Sidebar: Info & Stats -->
            <div class="col-md-4">
                
                <!-- Deine Supporter-Info (falls vorhanden) -->
                <% if (userBadge) { %>
                <div class="card card-success">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-star me-2"></i>Dein Supporter-Status
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        
                        <!-- Badge-Icon -->
                        <% if (userBadge.badge_level === 'platinum') { %>
                            <i class="fas fa-crown fa-4x text-secondary mb-3"></i>
                            <h4 class="text-secondary">⭐⭐⭐⭐ Platinum Supporter</h4>
                        <% } else if (userBadge.badge_level === 'gold') { %>
                            <i class="fas fa-trophy fa-4x text-warning mb-3"></i>
                            <h4 class="text-warning">⭐⭐⭐ Gold Supporter</h4>
                        <% } else if (userBadge.badge_level === 'silver') { %>
                            <i class="fas fa-medal fa-4x text-secondary mb-3"></i>
                            <h4 class="text-secondary">⭐⭐ Silver Supporter</h4>
                        <% } else { %>
                            <i class="fas fa-award fa-4x text-info mb-3"></i>
                            <h4 class="text-info">⭐ Bronze Supporter</h4>
                        <% } %>
                        
                        <p class="mb-2">
                            <strong>Gesamt gespendet:</strong><br>
                            <span class="h3 text-success">€<%= parseFloat(userBadge.total_donated || 0).toFixed(2) %></span>
                        </p>
                        
                        <p class="mb-2">
                            <strong>Anzahl Spenden:</strong> <%= userBadge.donation_count %>
                        </p>
                        
                        <p class="text-muted small mb-0">
                            Supporter seit: <%= new Date(userBadge.first_donation_at).toLocaleDateString('de-DE') %>
                        </p>
                        
                        <hr>
                        
                        <p class="small mb-0">
                            <i class="fas fa-heart text-danger me-1"></i>
                            Vielen Dank für deine Unterstützung!
                        </p>
                    </div>
                </div>
                <% } %>
                
                <!-- Badge-Level Übersicht -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-info-circle me-2"></i>Supporter-Levels
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <td class="text-center">
                                        <i class="fas fa-award text-info"></i>
                                    </td>
                                    <td><strong>Bronze</strong></td>
                                    <td class="text-right">ab €5</td>
                                </tr>
                                <tr>
                                    <td class="text-center">
                                        <i class="fas fa-medal text-secondary"></i>
                                    </td>
                                    <td><strong>Silver</strong></td>
                                    <td class="text-right">ab €20</td>
                                </tr>
                                <tr>
                                    <td class="text-center">
                                        <i class="fas fa-trophy text-warning"></i>
                                    </td>
                                    <td><strong>Gold</strong></td>
                                    <td class="text-right">ab €50</td>
                                </tr>
                                <tr>
                                    <td class="text-center">
                                        <i class="fas fa-crown text-secondary"></i>
                                    </td>
                                    <td><strong>Platinum</strong></td>
                                    <td class="text-right">ab €100</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <!-- Statistiken -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-chart-bar me-2"></i>Community-Stats
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="info-box mb-3">
                            <span class="info-box-icon bg-success">
                                <i class="fas fa-euro-sign"></i>
                            </span>
                            <div class="info-box-content">
                                <span class="info-box-text">Gesamt gespendet</span>
                                <span class="info-box-number">€<%= communityStats.total_amount || 0 %></span>
                            </div>
                        </div>
                        
                        <div class="info-box mb-0">
                            <span class="info-box-icon bg-info">
                                <i class="fas fa-users"></i>
                            </span>
                            <div class="info-box-content">
                                <span class="info-box-text">Supporter</span>
                                <span class="info-box-number"><%= communityStats.supporter_count || 0 %></span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- FAQ -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-question-circle me-2"></i>Häufige Fragen
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <strong>Wofür wird das Geld verwendet?</strong>
                            <p class="small text-muted mb-0">
                                Server-Kosten, Entwicklung neuer Features und Wartung des Bots.
                            </p>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Ist meine Zahlung sicher?</strong>
                            <p class="small text-muted mb-0">
                                Ja! Wir nutzen Stripe, einen der sichersten Payment-Provider weltweit.
                            </p>
                        </div>
                        
                        <div class="mb-0">
                            <strong>Kann ich stornieren?</strong>
                            <p class="small text-muted mb-0">
                                Bei Problemen kontaktiere uns über den Support-Channel.
                            </p>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
        
    </div>
</section>

<script>
/**
 * Betrag setzen (bei Klick auf Preset-Buttons)
 */
function setAmount(amount) {
    const input = document.getElementById('donation-amount');
    if (amount === 0) {
        input.value = '';
    } else {
        input.value = amount.toFixed(2);
    }
}

/**
 * Stripe Checkout Session erstellen und zu Stripe weiterleiten
 */
async function createDonation() {
    const amount = parseFloat(document.getElementById('donation-amount').value);
    const message = document.getElementById('donation-message').value;
    const button = document.getElementById('donate-button');
    const buttonText = document.getElementById('button-text');
    const buttonSpinner = document.getElementById('button-spinner');
    
    // GuildId aus dem aktuellen URL-Path extrahieren
    const pathParts = window.location.pathname.split('/');
    const guildId = pathParts[2]; // /guild/:guildId/...
    
    console.log('[Donation] GuildId from URL:', guildId);
    
    // Validierung
    if (!amount || amount < 1) {
        showToast('error', 'Bitte gib einen Betrag von mindestens €1 ein');
        return;
    }
    
    // Button-State: Loading
    button.disabled = true;
    buttonText.textContent = 'Erstelle Zahlung...';
    buttonSpinner.classList.remove('d-none');
    
    try {
        // API-Call zum Erstellen der Stripe Checkout Session
        const response = await fetch('/api/core/donate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                amount, 
                message,
                guild_id: guildId
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            // Redirect zu Stripe Checkout
            window.location.href = result.url;
        } else {
            showToast('error', result.message || 'Fehler beim Erstellen der Zahlung');
            // Button-State: Reset
            button.disabled = false;
            buttonText.textContent = 'Jetzt spenden';
            buttonSpinner.classList.add('d-none');
        }
        
    } catch (error) {
        console.error('[Donation] Fehler:', error);
        showToast('error', 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.');
        
        // Button-State: Reset
        button.disabled = false;
        buttonText.textContent = 'Jetzt spenden';
        buttonSpinner.classList.add('d-none');
    }
}

// Payment-Status Benachrichtigungen anzeigen (nach Page-Load)
document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const paymentStatus = urlParams.get('payment');
    const sessionId = urlParams.get('session_id');
    const notificationDiv = document.getElementById('payment-notification');
    
    if (paymentStatus === 'success') {
        notificationDiv.innerHTML = `
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <h5><i class="fas fa-check-circle me-2"></i>Vielen Dank für deine Spende! ❤️</h5>
                <p class="mb-0">
                    Deine Zahlung war erfolgreich. Du erhältst in Kürze dein Supporter-Badge und die Discord-Role wird automatisch vergeben!
                </p>
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        `;
        
        // URL bereinigen (Query-Parameter entfernen nach 3 Sekunden)
        setTimeout(() => {
            const cleanUrl = window.location.pathname;
            window.history.replaceState({}, document.title, cleanUrl);
        }, 3000);
        
    } else if (paymentStatus === 'cancelled') {
        notificationDiv.innerHTML = `
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <h5><i class="fas fa-exclamation-triangle me-2"></i>Zahlung abgebrochen</h5>
                <p class="mb-0">
                    Du hast die Zahlung abgebrochen. Keine Sorge - du kannst jederzeit erneut spenden!
                </p>
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        `;
        
        // URL bereinigen (Query-Parameter entfernen nach 3 Sekunden)
        setTimeout(() => {
            const cleanUrl = window.location.pathname;
            window.history.replaceState({}, document.title, cleanUrl);
        }, 3000);
    }
});
</script>

