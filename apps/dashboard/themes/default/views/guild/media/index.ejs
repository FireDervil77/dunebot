<%# Guild Medien-Bibliothek — /guild/:guildId/media %>
<%# WordPress-Style Media Manager mit Galerie, Detail-Panel & Bild-Editor (Cropper.js) %>

<!-- Cropper.js CSS + JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>

<style>
    /* ── Galerie-Grid ── */
    .media-grid { display: grid; gap: 12px; }
    .media-grid.size-sm  { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
    .media-grid.size-md  { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
    .media-grid.size-lg  { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }

    /* ── Kachel ── */
    .media-item {
        position: relative !important; border-radius: 8px; overflow: hidden !important; cursor: pointer;
        border: 3px solid transparent; transition: all .15s;
        padding-bottom: 100% !important; height: 0 !important;
        background: #1e1e2e;
    }
    .media-item:hover { border-color: #17a2b8; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.3); }
    .media-item.selected { border-color: #007bff; box-shadow: 0 0 0 3px rgba(0,123,255,.35); }
    .media-item img { position: absolute !important; top: 0; left: 0; width: 100% !important; height: 100% !important; object-fit: cover !important; transition: transform .2s; }
    .media-item:hover img { transform: scale(1.05); }

    /* ── Hover-Overlay ── */
    .media-overlay {
        position: absolute; inset: 0; background: linear-gradient(transparent 40%, rgba(0,0,0,.85));
        display: flex; flex-direction: column; justify-content: flex-end; padding: 10px;
        opacity: 0; transition: opacity .2s;
    }
    .media-item:hover .media-overlay, .media-item.selected .media-overlay { opacity: 1; }
    .media-overlay .media-name { font-size: 12px; color: #fff; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .media-overlay .media-meta { font-size: 10px; color: #adb5bd; margin-top: 2px; }

    /* ── Check-Badge ── */
    .media-check { position: absolute; top: 6px; right: 6px; display: none; z-index: 2; }
    .media-item.selected .media-check { display: block; }

    /* ── Ordner-Badge ── */
    .media-folder-tag { position: absolute; top: 6px; left: 6px; z-index: 2; }

    /* ── Dropzone ── */
    .media-dropzone { border: 3px dashed #555; border-radius: 12px; padding: 40px; text-align: center; transition: all .2s; cursor: pointer; background: rgba(255,255,255,.02); }
    .media-dropzone.dragover { border-color: #17a2b8; background: rgba(23,162,184,.08); }

    /* ── Detail-Panel ── */
    .media-detail-panel { position: sticky; top: 20px; }

    /* ── Filter-Badges ── */
    .folder-badge { cursor: pointer; transition: opacity .2s; }
    .folder-badge:hover { opacity: .8; }
    .folder-badge.active { box-shadow: 0 0 0 2px #fff; }

    /* ── Upload-Progress ── */
    .upload-progress { display: none; }
    .upload-progress.active { display: block; }

    /* ── View-Toggle ── */
    .view-toggle .btn { padding: 0.2rem 0.5rem; }
    .view-toggle .btn.active { background: #17a2b8; color: #fff; border-color: #17a2b8; }

    /* ── Editor Modal ── */
    #editor-modal .modal-dialog { max-width: 900px; }
    #editor-canvas-wrap { max-height: 500px; overflow: hidden; background: #111; }
    #editor-canvas-wrap img { max-width: 100%; display: block; }
    .editor-toolbar .btn { margin: 0 2px; }
</style>

<div class="row mb-3">
    <div class="col-12 d-flex align-items-center justify-content-between flex-wrap">
        <div>
            <h4 class="mb-1"><i class="fa-solid fa-photo-film mr-2"></i>Medien</h4>
            <p class="text-muted mb-0">Verwalte Bilder und Icons für deinen Server.</p>
        </div>
        <div class="d-flex align-items-center flex-wrap">
            <!-- Ansichtsgröße -->
            <div class="btn-group btn-group-sm view-toggle mr-2">
                <button class="btn btn-outline-secondary" data-size="sm" title="Klein"><i class="fa-solid fa-grip"></i></button>
                <button class="btn btn-outline-secondary active" data-size="md" title="Mittel"><i class="fa-solid fa-th-large"></i></button>
                <button class="btn btn-outline-secondary" data-size="lg" title="Groß"><i class="fa-solid fa-square"></i></button>
            </div>
            <!-- Suche -->
            <div class="input-group input-group-sm mr-2" style="width: 200px;">
                <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fa-solid fa-search"></i></span>
                </div>
                <input type="text" id="media-search" class="form-control" placeholder="Suchen...">
            </div>
            <button class="btn btn-primary btn-sm" id="btn-upload-toggle">
                <i class="fa-solid fa-cloud-arrow-up mr-1"></i>Hochladen
            </button>
        </div>
    </div>
</div>

<!-- Upload-Bereich (toggle) -->
<div class="row mb-3" id="upload-area" style="display:none;">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body p-3">
                <div class="media-dropzone" id="dropzone">
                    <i class="fa-solid fa-cloud-arrow-up fa-3x mb-3 text-muted"></i>
                    <p class="mb-1">Dateien hier ablegen oder <strong>klicken</strong> zum Auswählen</p>
                    <small class="text-muted">
                        Max. <%= (maxFileSize / 1024 / 1024) %> MB pro Datei &bull; JPG, PNG, GIF, WebP, SVG, ICO
                    </small>
                    <input type="file" id="file-input" multiple accept="image/*" style="display:none;">
                </div>
                <div class="row mt-2">
                    <div class="col-md-4">
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <span class="input-group-text">Ordner</span>
                            </div>
                            <input type="text" id="upload-folder" class="form-control" value="general" placeholder="z.B. icons, banners">
                        </div>
                    </div>
                </div>
                <!-- Upload-Fortschritt -->
                <div class="upload-progress mt-3" id="upload-progress">
                    <div class="progress" style="height: 24px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" id="progress-bar" style="width: 0%">0%</div>
                    </div>
                    <small class="text-muted mt-1 d-block" id="upload-status"></small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ordner-Filter -->
<div class="row mb-3">
    <div class="col-12" id="folder-filter">
        <span class="badge badge-secondary folder-badge active mr-1" data-folder="all">
            <i class="fa-solid fa-images mr-1"></i>Alle
        </span>
    </div>
</div>

<!-- Hauptbereich: Galerie + Detail-Panel -->
<div class="row">
    <!-- Galerie -->
    <div class="col-12" id="gallery-col">
        <div class="media-grid size-md" id="media-grid"></div>
        <div id="media-empty" class="text-center text-muted py-5" style="display:none;">
            <i class="fa-solid fa-image fa-4x mb-3"></i>
            <p>Noch keine Medien hochgeladen.</p>
            <button class="btn btn-outline-primary btn-sm" id="btn-upload-empty">
                <i class="fa-solid fa-cloud-arrow-up mr-1"></i>Erste Datei hochladen
            </button>
        </div>
        <nav id="media-pagination" class="mt-3" style="display:none;">
            <ul class="pagination pagination-sm justify-content-center"></ul>
        </nav>
    </div>

    <!-- Detail-Panel (rechts, einblendbar) -->
    <div class="col-lg-4 col-xl-3" id="detail-col" style="display:none;">
        <div class="card shadow-sm media-detail-panel">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <strong id="detail-filename" class="text-truncate" style="max-width: 200px;"></strong>
                <button class="btn btn-sm btn-outline-secondary" id="btn-detail-close" title="Schließen">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="card-body p-0">
                <div class="text-center bg-dark p-2" style="max-height:250px; overflow:hidden;">
                    <img id="detail-preview" src="" alt="" style="max-width:100%; max-height:230px; object-fit:contain;">
                </div>
                <div class="p-3">
                    <table class="table table-sm table-borderless mb-3" style="font-size: .85rem;">
                        <tr><td class="text-muted" style="width:80px;">Typ</td><td id="detail-mime"></td></tr>
                        <tr><td class="text-muted">Größe</td><td id="detail-size"></td></tr>
                        <tr><td class="text-muted">Maße</td><td id="detail-dimensions"></td></tr>
                        <tr><td class="text-muted">Ordner</td><td id="detail-folder"></td></tr>
                        <tr><td class="text-muted">Datum</td><td id="detail-date"></td></tr>
                    </table>

                    <div class="form-group mb-2">
                        <label class="small text-muted mb-1">Titel</label>
                        <input type="text" class="form-control form-control-sm" id="detail-title" placeholder="Optional">
                    </div>
                    <div class="form-group mb-2">
                        <label class="small text-muted mb-1">Alt-Text</label>
                        <input type="text" class="form-control form-control-sm" id="detail-alt" placeholder="Beschreibung für Barrierefreiheit">
                    </div>
                    <div class="form-group mb-2">
                        <label class="small text-muted mb-1">Ordner</label>
                        <input type="text" class="form-control form-control-sm" id="detail-folder-edit" placeholder="general">
                    </div>

                    <div class="form-group mb-2">
                        <label class="small text-muted mb-1">URL</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" id="detail-url" readonly>
                            <div class="input-group-append">
                                <button class="btn btn-outline-secondary" id="btn-copy-url" title="URL kopieren">
                                    <i class="fa-solid fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <div>
                            <button class="btn btn-sm btn-primary" id="btn-save-meta">
                                <i class="fa-solid fa-save mr-1"></i>Speichern
                            </button>
                            <button class="btn btn-sm btn-outline-info" id="btn-edit-image" title="Bild bearbeiten" style="display:none;">
                                <i class="fa-solid fa-crop-simple mr-1"></i>Bearbeiten
                            </button>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" id="btn-delete-media">
                            <i class="fa-solid fa-trash mr-1"></i>Löschen
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- Bild-Editor Modal (Cropper.js) -->
<!-- ============================================================ -->
<div class="modal fade" id="editor-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title"><i class="fa-solid fa-crop-simple mr-2"></i>Bild bearbeiten</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body p-0">
                <!-- Toolbar -->
                <div class="editor-toolbar text-center py-2 bg-dark border-bottom">
                    <div class="btn-group btn-group-sm mr-3">
                        <button class="btn btn-outline-light" id="ed-ratio-free" title="Frei"><i class="fa-solid fa-expand"></i> Frei</button>
                        <button class="btn btn-outline-light" id="ed-ratio-1" title="1:1"><i class="fa-solid fa-square"></i> 1:1</button>
                        <button class="btn btn-outline-light" id="ed-ratio-16" title="16:9">16:9</button>
                        <button class="btn btn-outline-light" id="ed-ratio-4" title="4:3">4:3</button>
                    </div>
                    <div class="btn-group btn-group-sm mr-3">
                        <button class="btn btn-outline-light" id="ed-rotate-left" title="90° links drehen"><i class="fa-solid fa-rotate-left"></i></button>
                        <button class="btn btn-outline-light" id="ed-rotate-right" title="90° rechts drehen"><i class="fa-solid fa-rotate-right"></i></button>
                    </div>
                    <div class="btn-group btn-group-sm mr-3">
                        <button class="btn btn-outline-light" id="ed-flip-h" title="Horizontal spiegeln"><i class="fa-solid fa-arrows-left-right"></i></button>
                        <button class="btn btn-outline-light" id="ed-flip-v" title="Vertikal spiegeln"><i class="fa-solid fa-arrows-up-down"></i></button>
                    </div>
                    <button class="btn btn-sm btn-outline-warning" id="ed-reset" title="Zurücksetzen"><i class="fa-solid fa-undo mr-1"></i>Reset</button>
                </div>
                <!-- Canvas -->
                <div id="editor-canvas-wrap">
                    <img id="editor-image" src="" alt="Editor">
                </div>
            </div>
            <div class="modal-footer py-2">
                <div class="mr-auto">
                    <small class="text-muted" id="ed-crop-info"></small>
                </div>
                <button class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Abbrechen</button>
                <button class="btn btn-sm btn-outline-info" id="ed-save-copy">
                    <i class="fa-solid fa-copy mr-1"></i>Als Kopie speichern
                </button>
                <button class="btn btn-sm btn-primary" id="ed-save-replace">
                    <i class="fa-solid fa-save mr-1"></i>Original überschreiben
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const guildId = '<%= guildId %>';
    const baseUrl = `/guild/${guildId}/media`;

    // ── State ──
    let currentFolder = 'all';
    let currentPage = 1;
    let selectedMedia = null;
    let debounceTimer = null;
    let cropper = null;
    let editorFlipH = 1;
    let editorFlipV = 1;

    // ── Elements ──
    const grid = document.getElementById('media-grid');
    const emptyState = document.getElementById('media-empty');
    const detailCol = document.getElementById('detail-col');
    const galleryCol = document.getElementById('gallery-col');
    const folderFilter = document.getElementById('folder-filter');
    const searchInput = document.getElementById('media-search');
    const uploadArea = document.getElementById('upload-area');
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('file-input');
    const uploadProgress = document.getElementById('upload-progress');
    const progressBar = document.getElementById('progress-bar');
    const uploadStatus = document.getElementById('upload-status');
    const paginationNav = document.getElementById('media-pagination');

    // ── View-Größe Toggle ──
    document.querySelectorAll('.view-toggle .btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.view-toggle .btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            grid.className = `media-grid size-${btn.dataset.size}`;
        });
    });

    // ── Upload Toggle ──
    document.getElementById('btn-upload-toggle').addEventListener('click', () => {
        uploadArea.style.display = uploadArea.style.display === 'none' ? '' : 'none';
    });
    document.getElementById('btn-upload-empty')?.addEventListener('click', () => {
        uploadArea.style.display = '';
        fileInput.click();
    });

    // ── Drag & Drop ──
    dropzone.addEventListener('click', () => fileInput.click());
    dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        if (e.dataTransfer.files.length) uploadFiles(e.dataTransfer.files);
    });
    fileInput.addEventListener('change', () => {
        if (fileInput.files.length) uploadFiles(fileInput.files);
    });

    // ── Upload ──
    function uploadFiles(files) {
        const folder = document.getElementById('upload-folder').value.trim() || 'general';
        const formData = new FormData();
        for (const f of files) formData.append('files', f);
        formData.append('folder', folder);

        uploadProgress.classList.add('active');
        progressBar.style.width = '0%';
        progressBar.textContent = '0%';
        progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-info';
        uploadStatus.textContent = `${files.length} Datei(en) werden hochgeladen...`;

        const xhr = new XMLHttpRequest();
        xhr.open('POST', `${baseUrl}/api/upload`);
        xhr.upload.onprogress = e => {
            if (e.lengthComputable) {
                const pct = Math.round((e.loaded / e.total) * 100);
                progressBar.style.width = pct + '%';
                progressBar.textContent = pct + '%';
            }
        };
        xhr.onload = function() {
            try {
                const res = JSON.parse(xhr.responseText);
                if (res.success) {
                    uploadStatus.textContent = `${res.data.length} Datei(en) erfolgreich hochgeladen!`;
                    progressBar.className = 'progress-bar bg-success';
                    fileInput.value = '';
                    setTimeout(() => { uploadProgress.classList.remove('active'); loadMedia(); }, 1200);
                } else {
                    uploadStatus.textContent = 'Fehler: ' + res.message;
                    progressBar.className = 'progress-bar bg-danger';
                }
            } catch { uploadStatus.textContent = 'Unerwarteter Fehler'; }
        };
        xhr.onerror = () => { uploadStatus.textContent = 'Upload fehlgeschlagen'; progressBar.className = 'progress-bar bg-danger'; };
        xhr.send(formData);
    }

    // ══════════════════════════════════════════════════
    // GALERIE
    // ══════════════════════════════════════════════════

    async function loadMedia() {
        const search = searchInput.value.trim();
        const params = new URLSearchParams({ page: currentPage, folder: currentFolder });
        if (search) params.set('search', search);

        try {
            const res = await fetch(`${baseUrl}/api/list?${params}`);
            const data = await res.json();
            if (!data.success) return;
            renderFolders(data.folders);
            renderGrid(data.data);
            renderPagination(data.pagination);
        } catch (err) { console.error('Fehler beim Laden:', err); }
    }

    function renderFolders(folders) {
        const totalCount = folders.reduce((sum, f) => sum + f.count, 0);
        let html = `<span class="badge badge-secondary folder-badge ${currentFolder === 'all' ? 'active' : ''} mr-1" data-folder="all">
            <i class="fa-solid fa-images mr-1"></i>Alle (${totalCount})</span>`;
        const folderIcons = { icons: 'fa-icons', banners: 'fa-panorama', avatars: 'fa-user-circle', logos: 'fa-star' };
        for (const f of folders) {
            const icon = folderIcons[f.folder] || 'fa-folder';
            html += `<span class="badge badge-info folder-badge ${currentFolder === f.folder ? 'active' : ''} mr-1" data-folder="${f.folder}">
                <i class="fa-solid ${icon} mr-1"></i>${f.folder} (${f.count})</span>`;
        }
        folderFilter.innerHTML = html;
        folderFilter.querySelectorAll('.folder-badge').forEach(badge => {
            badge.addEventListener('click', () => { currentFolder = badge.dataset.folder; currentPage = 1; loadMedia(); });
        });
    }

    function renderGrid(items) {
        if (!items.length) { grid.innerHTML = ''; emptyState.style.display = ''; paginationNav.style.display = 'none'; return; }
        emptyState.style.display = 'none';

        grid.innerHTML = items.map(item => {
            const isSvg = item.mime_type === 'image/svg+xml';
            const dims = item.width ? `${item.width}\u00d7${item.height}` : '';
            const size = formatSize(item.file_size);
            return `
            <div class="media-item ${selectedMedia?.id === item.id ? 'selected' : ''}" data-id="${item.id}">
                <img src="${item.url}" alt="${esc(item.alt_text || item.filename)}" loading="lazy"
                     ${isSvg ? 'style="padding:15%; background:#fff;"' : ''}>
                <div class="media-check"><span class="badge badge-primary"><i class="fa-solid fa-check"></i></span></div>
                <span class="media-folder-tag"><span class="badge badge-dark" style="font-size:9px; opacity:.8;">${esc(item.folder)}</span></span>
                <div class="media-overlay">
                    <div class="media-name">${esc(item.filename)}</div>
                    <div class="media-meta">${size}${dims ? ' &bull; ' + dims : ''}</div>
                </div>
            </div>`;
        }).join('');

        grid.querySelectorAll('.media-item').forEach(el => {
            el.addEventListener('click', () => selectMedia(parseInt(el.dataset.id)));
        });
    }

    function renderPagination(p) {
        if (p.pages <= 1) { paginationNav.style.display = 'none'; return; }
        paginationNav.style.display = '';
        const ul = paginationNav.querySelector('ul');
        let html = '';
        if (p.page > 1) html += `<li class="page-item"><a class="page-link" href="#" data-page="${p.page - 1}">&laquo;</a></li>`;
        for (let i = 1; i <= p.pages; i++) {
            html += `<li class="page-item ${i === p.page ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
        }
        if (p.page < p.pages) html += `<li class="page-item"><a class="page-link" href="#" data-page="${p.page + 1}">&raquo;</a></li>`;
        ul.innerHTML = html;
        ul.querySelectorAll('.page-link').forEach(link => {
            link.addEventListener('click', e => { e.preventDefault(); currentPage = parseInt(link.dataset.page); loadMedia(); });
        });
    }

    // ══════════════════════════════════════════════════
    // DETAIL-PANEL
    // ══════════════════════════════════════════════════

    async function selectMedia(id) {
        try {
            const res = await fetch(`${baseUrl}/api/${id}`);
            const data = await res.json();
            if (!data.success) return;
            selectedMedia = data.data;

            grid.querySelectorAll('.media-item').forEach(el => {
                el.classList.toggle('selected', parseInt(el.dataset.id) === id);
            });

            document.getElementById('detail-filename').textContent = selectedMedia.filename;
            document.getElementById('detail-preview').src = selectedMedia.url;
            document.getElementById('detail-mime').textContent = selectedMedia.mime_type;
            document.getElementById('detail-size').textContent = formatSize(selectedMedia.file_size);
            document.getElementById('detail-dimensions').textContent =
                selectedMedia.width ? `${selectedMedia.width} \u00d7 ${selectedMedia.height} px` : '\u2013';
            document.getElementById('detail-folder').textContent = selectedMedia.folder;
            document.getElementById('detail-folder-edit').value = selectedMedia.folder;
            document.getElementById('detail-date').textContent = new Date(selectedMedia.created_at).toLocaleString('de-DE');
            document.getElementById('detail-title').value = selectedMedia.title || '';
            document.getElementById('detail-alt').value = selectedMedia.alt_text || '';
            document.getElementById('detail-url').value = window.location.origin + selectedMedia.url;

            // Bearbeiten-Button nur für bearbeitbare Rasterformate
            const editable = ['image/jpeg', 'image/png', 'image/webp'].includes(selectedMedia.mime_type);
            document.getElementById('btn-edit-image').style.display = editable ? '' : 'none';

            detailCol.style.display = '';
            galleryCol.className = 'col-lg-8 col-xl-9';
        } catch (err) { console.error('Detail-Fehler:', err); }
    }

    document.getElementById('btn-detail-close').addEventListener('click', () => {
        detailCol.style.display = 'none';
        galleryCol.className = 'col-12';
        selectedMedia = null;
        grid.querySelectorAll('.media-item').forEach(el => el.classList.remove('selected'));
    });

    document.getElementById('btn-copy-url').addEventListener('click', () => {
        const urlInput = document.getElementById('detail-url');
        navigator.clipboard.writeText(urlInput.value);
        const btn = document.getElementById('btn-copy-url');
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check text-success"></i>';
        setTimeout(() => btn.innerHTML = orig, 1500);
    });

    document.getElementById('btn-save-meta').addEventListener('click', async () => {
        if (!selectedMedia) return;
        const body = {
            title: document.getElementById('detail-title').value,
            alt_text: document.getElementById('detail-alt').value,
            folder: document.getElementById('detail-folder-edit').value
        };
        try {
            const res = await fetch(`${baseUrl}/api/${selectedMedia.id}`, {
                method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
            });
            const data = await res.json();
            if (data.success) { showToast('success', 'Metadaten gespeichert'); loadMedia(); }
            else showToast('error', data.message);
        } catch { showToast('error', 'Speichern fehlgeschlagen'); }
    });

    document.getElementById('btn-delete-media').addEventListener('click', async () => {
        if (!selectedMedia) return;
        if (!confirm(`"${selectedMedia.filename}" wirklich l\u00f6schen?`)) return;
        try {
            const res = await fetch(`${baseUrl}/api/${selectedMedia.id}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                showToast('success', 'Datei gel\u00f6scht');
                detailCol.style.display = 'none';
                galleryCol.className = 'col-12';
                selectedMedia = null;
                loadMedia();
            } else showToast('error', data.message);
        } catch { showToast('error', 'L\u00f6schen fehlgeschlagen'); }
    });

    searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => { currentPage = 1; loadMedia(); }, 300);
    });

    // ══════════════════════════════════════════════════
    // BILD-EDITOR (Cropper.js)
    // ══════════════════════════════════════════════════

    document.getElementById('btn-edit-image').addEventListener('click', () => {
        if (!selectedMedia) return;
        openEditor(selectedMedia);
    });

    function openEditor(media) {
        editorFlipH = 1;
        editorFlipV = 1;
        const editorImg = document.getElementById('editor-image');
        editorImg.src = media.url + '?t=' + Date.now();

        $('#editor-modal').modal('show');
        $('#editor-modal').one('shown.bs.modal', () => {
            if (cropper) { cropper.destroy(); cropper = null; }
            cropper = new Cropper(editorImg, {
                viewMode: 1, dragMode: 'crop', autoCropArea: 1,
                responsive: true, restore: false, guides: true, center: true,
                highlight: true, background: true,
                crop(event) {
                    const d = event.detail;
                    document.getElementById('ed-crop-info').textContent =
                        `${Math.round(d.width)} \u00d7 ${Math.round(d.height)} px`;
                }
            });
        });
    }

    $('#editor-modal').on('hidden.bs.modal', () => {
        if (cropper) { cropper.destroy(); cropper = null; }
    });

    // Aspect-Ratios
    document.getElementById('ed-ratio-free').addEventListener('click', () => cropper?.setAspectRatio(NaN));
    document.getElementById('ed-ratio-1').addEventListener('click', () => cropper?.setAspectRatio(1));
    document.getElementById('ed-ratio-16').addEventListener('click', () => cropper?.setAspectRatio(16/9));
    document.getElementById('ed-ratio-4').addEventListener('click', () => cropper?.setAspectRatio(4/3));

    // Rotate
    document.getElementById('ed-rotate-left').addEventListener('click', () => cropper?.rotate(-90));
    document.getElementById('ed-rotate-right').addEventListener('click', () => cropper?.rotate(90));

    // Flip
    document.getElementById('ed-flip-h').addEventListener('click', () => { editorFlipH *= -1; cropper?.scaleX(editorFlipH); });
    document.getElementById('ed-flip-v').addEventListener('click', () => { editorFlipV *= -1; cropper?.scaleY(editorFlipV); });

    // Reset
    document.getElementById('ed-reset').addEventListener('click', () => { editorFlipH = 1; editorFlipV = 1; cropper?.reset(); });

    // Speichern
    async function saveEditedImage(saveAs) {
        if (!cropper || !selectedMedia) return;
        const mimeMap = { 'image/jpeg': 'image/jpeg', 'image/png': 'image/png', 'image/webp': 'image/webp' };
        const outputMime = mimeMap[selectedMedia.mime_type] || 'image/png';
        const quality = outputMime === 'image/jpeg' ? 0.92 : undefined;
        const canvas = cropper.getCroppedCanvas({ imageSmoothingQuality: 'high' });
        const imageData = canvas.toDataURL(outputMime, quality);

        const btn = saveAs === 'copy' ? document.getElementById('ed-save-copy') : document.getElementById('ed-save-replace');
        const origText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i>Speichere...';

        try {
            const res = await fetch(`${baseUrl}/api/${selectedMedia.id}/edit`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ imageData, saveAs })
            });
            const data = await res.json();
            if (data.success) {
                showToast('success', data.message);
                $('#editor-modal').modal('hide');
                loadMedia();
                if (data.data?.url) document.getElementById('detail-preview').src = data.data.url;
            } else { showToast('error', data.message); }
        } catch { showToast('error', 'Speichern fehlgeschlagen'); }
        finally { btn.disabled = false; btn.innerHTML = origText; }
    }

    document.getElementById('ed-save-copy').addEventListener('click', () => saveEditedImage('copy'));
    document.getElementById('ed-save-replace').addEventListener('click', () => saveEditedImage('replace'));

    // ══════════════════════════════════════════════════
    // HELPERS
    // ══════════════════════════════════════════════════

    function formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function esc(str) {
        if (!str) return '';
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }

    function showToast(type, message) {
        if (typeof toastr !== 'undefined') { toastr[type === 'error' ? 'error' : 'success'](message); }
    }

    // ── Init ──
    loadMedia();
})();
</script>
