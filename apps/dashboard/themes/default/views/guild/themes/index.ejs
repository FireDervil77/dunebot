<%# Guild Themes-Übersicht — /guild/:guildId/themes %>

<div class="row mb-4">
    <div class="col-12 d-flex align-items-center justify-content-between">
        <div>
            <h4 class="mb-1"><i class="fa-solid fa-palette mr-2"></i>Themes</h4>
            <p class="text-muted mb-0">Wähle und verwalte das Aussehen deines Guild-Dashboards.</p>
        </div>
        <div>
            <span class="badge badge-info"><%= themes.length %> Theme<%= themes.length !== 1 ? 's' : '' %> verfügbar</span>
        </div>
    </div>
</div>

<div class="row">
    <% themes.forEach(theme => { %>
    <% const isActive = theme.name === activeThemeName; %>
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card shadow-sm h-100 <%= isActive ? 'border-success' : '' %>" style="cursor:pointer;"
             onclick="window.location.href='/guild/<%= guildId %>/themes/<%= theme.name %>'">

            <!-- Screenshot -->
            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                 style="height: 160px; overflow: hidden; position: relative;">
                <% const screenshotUrl = `/themes/${theme.name}/assets/${theme.screenshot || 'screenshot.png'}`; %>
                <img src="<%= screenshotUrl %>"
                     alt="<%= theme.displayName %> Screenshot"
                     style="width:100%; height:100%; object-fit:cover;"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div style="display:none; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; background:#343a40; color:#6c757d;">
                    <i class="fa-solid fa-image fa-3x mb-2"></i>
                    <small>Kein Screenshot</small>
                </div>

                <!-- Status-Badges -->
                <div style="position:absolute; top:8px; right:8px;">
                    <% if (isActive) { %>
                        <span class="badge badge-success"><i class="fa-solid fa-check mr-1"></i>Aktiv</span>
                    <% } %>
                    <% if (theme.parent) { %>
                        <span class="badge badge-secondary ml-1"><i class="fa-solid fa-sitemap mr-1"></i>Child</span>
                    <% } %>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body">
                <h5 class="card-title mb-1">
                    <%= theme.displayName || theme.name %>
                    <small class="text-muted ml-1">v<%= theme.version || '1.0.0' %></small>
                </h5>
                <% if (theme.parent) { %>
                    <p class="text-muted small mb-1">
                        <i class="fa-solid fa-sitemap mr-1"></i>Erbt von <strong><%= theme.parent %></strong>
                    </p>
                <% } %>
                <p class="card-text text-muted small mb-2">
                    <%= theme.description || 'Keine Beschreibung verfügbar' %>
                </p>

                <div class="small text-muted">
                    <i class="fa-solid fa-user mr-1"></i><%= theme.author || 'Unbekannt' %>
                    <% if (theme.tags && theme.tags.length > 0) { %>
                        &nbsp;·&nbsp;
                        <% theme.tags.slice(0, 3).forEach(tag => { %>
                            <span class="badge badge-light border mr-1"><%= tag %></span>
                        <% }); %>
                    <% } %>
                </div>
            </div>

            <!-- Card Footer -->
            <div class="card-footer bg-transparent d-flex gap-2">
                <% if (isActive) { %>
                    <button class="btn btn-success btn-sm flex-fill" disabled>
                        <i class="fa-solid fa-check mr-1"></i>Aktiv
                    </button>
                <% } else { %>
                    <button class="btn btn-primary btn-sm flex-fill theme-activate-btn"
                            data-theme="<%= theme.name %>"
                            data-displayname="<%= theme.displayName || theme.name %>"
                            onclick="event.stopPropagation(); activateTheme(this);">
                        <i class="fa-solid fa-paint-brush mr-1"></i>Aktivieren
                    </button>
                <% } %>
                <a href="/guild/<%= guildId %>/themes/<%= theme.name %>"
                   class="btn btn-outline-secondary btn-sm"
                   onclick="event.stopPropagation();"
                   title="Details">
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <% }); %>

    <% if (themes.length === 0) { %>
    <div class="col-12">
        <div class="alert alert-warning">
            <i class="fa-solid fa-exclamation-triangle mr-2"></i>
            Keine Themes gefunden. Bitte überprüfe das Themes-Verzeichnis.
        </div>
    </div>
    <% } %>
</div>

<script>
async function activateTheme(btn) {
    const themeName = btn.dataset.theme;
    const guildId = '<%= guildId %>';

    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i>Wird aktiviert...';

    try {
        const res = await fetch(`/guild/${guildId}/themes/activate`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: JSON.stringify({ themeName })
        });

        const data = await res.json();

        if (data.success) {
            window.location.reload();
        } else {
            alert('Fehler: ' + (data.message || 'Unbekannter Fehler'));
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-paint-brush mr-1"></i>Aktivieren';
        }
    } catch (err) {
        alert('Netzwerkfehler beim Aktivieren des Themes.');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-paint-brush mr-1"></i>Aktivieren';
    }
}
</script>
