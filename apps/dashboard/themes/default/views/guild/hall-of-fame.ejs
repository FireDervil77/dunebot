<!-- 
    DuneBot - Hall of Fame
    Top Supporters Leaderboard
    Path: /guild/:guildId/plugins/core/hall-of-fame
-->

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-trophy text-warning me-2"></i>
                    Hall of Fame
                </h1>
                <p class="text-muted mb-0">Unsere Top-Supporter, die DuneBot möglich machen! ❤️</p>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/guild/<%= guildId %>">Dashboard</a></li>
                    <li class="breadcrumb-item active">Hall of Fame</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        
        <!-- Community Stats -->
        <div class="row mb-4">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>€<%= parseFloat(communityStats.total_amount || 0).toFixed(2) %></h3>
                        <p>Gesamt gespendet</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-euro-sign"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3><%= communityStats.supporter_count || 0 %></h3>
                        <p>Supporter</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3><%= communityStats.total_donations || 0 %></h3>
                        <p>Spenden</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-gift"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>€<%= parseFloat(communityStats.avg_donation || 0).toFixed(2) %></h3>
                        <p>Ø Spende</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- User Badge Info (falls vorhanden) -->
        <% if (userBadge) { %>
        <div class="alert alert-success border-success">
            <div class="row align-items-center">
                <div class="col-auto">
                    <i class="fas fa-medal fa-3x text-<%= userBadge.badge_level === 'platinum' ? 'secondary' : userBadge.badge_level === 'gold' ? 'warning' : userBadge.badge_level === 'silver' ? 'muted' : 'danger' %>"></i>
                </div>
                <div class="col">
                    <h5 class="mb-1">
                        <i class="fas fa-crown text-warning me-1"></i>
                        Du bist ein <strong class="text-uppercase"><%= userBadge.badge_level %> Supporter</strong>!
                    </h5>
                    <p class="mb-0">
                        Gespendet: <strong>€<%= parseFloat(userBadge.total_donated || 0).toFixed(2) %></strong>
                        in <%= userBadge.donation_count || 0 %> Spende(n)
                        <% if (userRank) { %>
                            • Dein Rang: <strong>#<%= userRank %></strong>
                        <% } %>
                    </p>
                </div>
                <div class="col-auto">
                    <a href="/guild/<%= guildId %>/donate" class="btn btn-success">
                        <i class="fas fa-heart me-1"></i>Erneut spenden
                    </a>
                </div>
            </div>
        </div>
        <% } %>
        
        <!-- CTA für Nicht-Supporter -->
        <% if (!userBadge) { %>
        <div class="alert alert-info border-info">
            <div class="row align-items-center">
                <div class="col-auto">
                    <i class="fas fa-info-circle fa-3x"></i>
                </div>
                <div class="col">
                    <h5 class="mb-1">Werde Teil der Hall of Fame!</h5>
                    <p class="mb-0">
                        Unterstütze DuneBot mit einer Spende und erhalte exklusive Badges & Discord-Rollen!
                    </p>
                </div>
                <div class="col-auto">
                    <a href="/guild/<%= guildId %>/donate" class="btn btn-primary">
                        <i class="fas fa-heart me-1"></i>Jetzt spenden
                    </a>
                </div>
            </div>
        </div>
        <% } %>
        
        <!-- Leaderboard -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-ranking-star text-warning me-2"></i>
                    Top 50 Supporter
                </h3>
            </div>
            <div class="card-body p-0">
                <% if (topDonators && topDonators.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead>
                            <tr>
                                <th style="width: 60px;" class="text-center">Rang</th>
                                <th>Supporter</th>
                                <th style="width: 150px;" class="text-center">Badge</th>
                                <th style="width: 150px;" class="text-end">Gesamt</th>
                                <th style="width: 100px;" class="text-center">Spenden</th>
                                <th style="width: 180px;">Letzte Spende</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% topDonators.forEach((donator, index) => { 
                                const rank = index + 1;
                                const _currentUserId = (typeof userId !== 'undefined') ? userId : null;
                                const isCurrentUser = _currentUserId && donator.user_id === _currentUserId;
                                
                                // Badge-Farben
                                const badgeColors = {
                                    platinum: 'secondary',
                                    gold: 'warning',
                                    silver: 'light',
                                    bronze: 'danger'
                                };
                                const badgeColor = badgeColors[donator.badge_level] || 'muted';
                                
                                // Rang-Icons für Top 3
                                const rankIcons = {
                                    1: '<i class="fas fa-trophy text-warning"></i>',
                                    2: '<i class="fas fa-medal text-secondary"></i>',
                                    3: '<i class="fas fa-medal text-danger"></i>'
                                };
                            %>
                            <tr class="<%= isCurrentUser ? 'table-success' : '' %>">
                                <td class="text-center">
                                    <% if (rankIcons[rank]) { %>
                                        <%- rankIcons[rank] %>
                                    <% } else { %>
                                        <strong>#<%= rank %></strong>
                                    <% } %>
                                </td>
                                <td>
                                    <strong><%= donator.username || 'Anonymer Supporter' %></strong>
                                    <% if (isCurrentUser) { %>
                                        <span class="badge badge-success ms-2">Du</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <% if (donator.badge_level && donator.has_active_badge) { %>
                                        <span class="badge badge-<%= badgeColor %> text-uppercase">
                                            <i class="fas fa-medal me-1"></i>
                                            <%= donator.badge_level %>
                                        </span>
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <strong class="text-success">€<%= parseFloat(donator.total_donated || 0).toFixed(2) %></strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-info"><%= donator.donation_count || 0 %>×</span>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        <%= donator.last_donation ? new Date(donator.last_donation).toLocaleDateString('de-DE') : '-' %>
                                    </small>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="p-5 text-center text-muted">
                    <i class="fas fa-heart-broken fa-3x mb-3"></i>
                    <p class="mb-0">Noch keine Supporter. Sei der Erste! ❤️</p>
                </div>
                <% } %>
            </div>
        </div>
        
        <!-- Badge-Level Erklärung -->
        <div class="card mt-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-info-circle text-info me-2"></i>
                    Badge-Levels
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 text-center mb-3">
                        <i class="fas fa-medal fa-3x text-danger mb-2"></i>
                        <h5>Bronze</h5>
                        <p class="text-muted mb-0">ab €5</p>
                    </div>
                    <div class="col-md-3 text-center mb-3">
                        <i class="fas fa-medal fa-3x text-light mb-2"></i>
                        <h5>Silver</h5>
                        <p class="text-muted mb-0">ab €20</p>
                    </div>
                    <div class="col-md-3 text-center mb-3">
                        <i class="fas fa-medal fa-3x text-warning mb-2"></i>
                        <h5>Gold</h5>
                        <p class="text-muted mb-0">ab €50</p>
                    </div>
                    <div class="col-md-3 text-center mb-3">
                        <i class="fas fa-medal fa-3x text-secondary mb-2"></i>
                        <h5>Platinum</h5>
                        <p class="text-muted mb-0">ab €100</p>
                    </div>
                </div>
                <hr>
                <p class="text-muted mb-0 text-center">
                    <i class="fas fa-sparkles text-warning me-1"></i>
                    Jeder Supporter erhält ein exklusives Discord-Badge und eine spezielle Role!
                </p>
            </div>
        </div>
        
    </div>
</section>
