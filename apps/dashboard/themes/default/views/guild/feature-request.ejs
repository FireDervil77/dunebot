<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><%= tr('FEATURE_REQUEST.TITLE') %></h1>
            </div>
            <div class="col-sm-6">
                <button class="btn btn-primary float-right" data-toggle="modal" data-target="#createFeatureModal">
                    <i class="fa-solid fa-lightbulb me-1"></i> <%= tr('FEATURE_REQUEST.CREATE_NEW', 'Feature vorschlagen') %>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        
        <!-- Info-Box -->
        <div class="alert alert-info alert-dismissible fade show mb-3" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
            <h5><i class="fa-solid fa-info-circle me-2"></i><%= tr('FEATURE_REQUEST.INFO_TITLE') %></h5>
            <p class="mb-0"><%= tr('FEATURE_REQUEST.INFO_TEXT') %></p>
        </div>
        
        <!-- Statistik-Karten -->
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3><%= features.length %></h3>
                        <p><%= tr('FEATURE_REQUEST.TOTAL_FEATURES') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3><%= features.filter(f => f.status === 'planned').length %></h3>
                        <p><%= tr('FEATURE_REQUEST.PLANNED') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3><%= features.filter(f => f.status === 'implemented').length %></h3>
                        <p><%= tr('FEATURE_REQUEST.IMPLEMENTED') %></p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature Liste -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><%= tr('FEATURE_REQUEST.ALL_FEATURES', 'Alle Feature Requests') %></h3>
                <div class="card-tools">
                    <span class="badge bg-primary"><i class="fa-solid fa-arrow-up"></i> <%= tr('FEATURE_REQUEST.SORTED_BY_VOTES', 'Sortiert nach Upvotes') %></span>
                </div>
            </div>
            <div class="card-body p-0">
                <% if (features.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fa-solid fa-lightbulb fa-3x text-muted mb-3"></i>
                        <p class="text-muted"><%= tr('FEATURE_REQUEST.NO_FEATURES', 'Keine Feature Requests vorhanden') %></p>
                    </div>
                <% } else { %>
                    <div class="list-group list-group-flush">
                        <% features.forEach(feature => { %>
                            <div class="list-group-item <%= feature.admin_response ? 'border-info' : '' %>">
                                <div class="row align-items-center">
                                    <!-- Upvote Button -->
                                    <div class="col-auto text-center">
                                        <button 
                                            class="btn btn-outline-primary upvote-btn" 
                                            data-feature-id="<%= feature.id %>"
                                            style="min-width: 60px;">
                                            <i class="fas fa-arrow-up"></i>
                                            <br>
                                            <strong><%= feature.upvotes %></strong>
                                        </button>
                                    </div>
                                    
                                    <!-- Feature Content -->
                                    <div class="col">
                                        <h5 class="mb-1"><%= feature.title %></h5>
                                        <p class="mb-2 text-muted"><%= feature.description %></p>
                                        
                                        <div class="d-flex gap-2 align-items-center">
                                            <% if (feature.category) { %>
                                                <span class="badge bg-secondary"><%= feature.category %></span>
                                            <% } %>
                                            
                                            <% 
                                            const statusClass = {
                                                open: 'warning',
                                                planned: 'info',
                                                in_progress: 'primary',
                                                implemented: 'success',
                                                rejected: 'danger',
                                                closed: 'secondary'
                                            };
                                            %>
                                            <span class="badge bg-<%= statusClass[feature.status] || 'secondary' %>">
                                                <%= tr('STATUS.' + feature.status.toUpperCase(), feature.status) %>
                                            </span>
                                            
                                            <% 
                                            const priorityClass = {
                                                low: 'secondary',
                                                medium: 'primary',
                                                high: 'warning',
                                                critical: 'danger'
                                            };
                                            %>
                                            <span class="badge bg-<%= priorityClass[feature.priority] || 'secondary' %>">
                                                <%= tr('PRIORITY.' + feature.priority.toUpperCase(), feature.priority) %>
                                            </span>
                                            
                                            <small class="text-muted ms-auto">
                                                <% if (feature.guild_only) { %>
                                                    <span class="badge bg-secondary me-1"><i class="fas fa-lock me-1"></i>Diese Guild</span>
                                                <% } else { %>
                                                    <span class="badge bg-info me-1"><i class="fas fa-globe me-1"></i>Alle Guilds</span>
                                                <% } %>
                                                <i class="fas fa-user me-1"></i><%= feature.user_tag || feature.user_id || 'Unbekannt' %>
                                                <i class="fas fa-calendar ms-2 me-1"></i><%= new Date(feature.created_at).toLocaleDateString('de-DE') %>
                                            </small>
                                        </div>
                                        
                                        <!-- Admin Response -->
                                        <% if (feature.admin_response) { %>
                                            <div class="alert alert-info mt-3 mb-0">
                                                <h6 class="alert-heading">
                                                    <i class="fas fa-reply me-2"></i><strong>Admin-Antwort</strong>
                                                    <% if (feature.resolved_at) { %>
                                                        <small class="text-muted float-end">
                                                            <%= new Date(feature.resolved_at).toLocaleString('de-DE') %>
                                                        </small>
                                                    <% } %>
                                                </h6>
                                                <p class="mb-0"><%= feature.admin_response %></p>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Feature erstellen -->
<div class="modal fade" id="createFeatureModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><%= tr('FEATURE_REQUEST.CREATE_NEW', 'Feature vorschlagen') %></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="featureRequestForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label"><%= tr('FEATURE_REQUEST.TITLE_LABEL', 'Titel') %></label>
                        <input type="text" class="form-control" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= tr('FEATURE_REQUEST.CATEGORY_LABEL', 'Kategorie') %></label>
                        <select class="form-select" name="category">
                            <option value="">Allgemein</option>
                            <option value="commands">Commands</option>
                            <option value="dashboard">Dashboard</option>
                            <option value="plugins">Plugins</option>
                            <option value="integration">Integration</option>
                            <option value="ui">Benutzeroberfläche</option>
                            <option value="other">Sonstiges</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= tr('FEATURE_REQUEST.DESCRIPTION_LABEL', 'Beschreibung') %></label>
                        <textarea class="form-control" name="description" rows="6" required></textarea>
                        <small class="text-muted"><%= tr('FEATURE_REQUEST.DESCRIPTION_HINT', 'Beschreibe das Feature so detailliert wie möglich') %></small>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="guild_only" id="featureGuildOnly" value="on">
                            <label class="form-check-label" for="featureGuildOnly">
                                <i class="fas fa-lock me-1"></i>Nur in dieser Guild anzeigen
                            </label>
                            <small class="d-block text-muted">Wenn nicht gesetzt, können alle Guilds diesen Feature Request sehen.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= tr('BTN_CANCEL', 'Abbrechen') %></button>
                    <button type="submit" class="btn btn-primary"><%= tr('BTN_SUBMIT', 'Absenden') %></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Feature Request erstellen
document.getElementById('featureRequestForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    try {
        const response = await fetch(window.location.pathname, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            $('#createFeatureModal').modal('hide');
            window.location.reload();
        } else {
            alert(result.message);
        }
    } catch (error) {
        alert('Fehler beim Erstellen des Feature Requests');
    }
});

// Upvote Handler
document.querySelectorAll('.upvote-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const featureId = btn.dataset.featureId;
        
        try {
            const response = await fetch(`${window.location.pathname}/${featureId}/upvote`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const result = await response.json();
            
            if (result.success) {
                // Update Button UI
                const countElement = btn.querySelector('strong');
                countElement.textContent = result.upvotes;
                
                // Toggle Button Style
                if (result.hasVoted) {
                    btn.classList.remove('btn-outline-primary');
                    btn.classList.add('btn-primary');
                } else {
                    btn.classList.remove('btn-primary');
                    btn.classList.add('btn-outline-primary');
                }
            }
        } catch (error) {
            alert('Fehler beim Upvoten');
        }
    });
});
</script>
