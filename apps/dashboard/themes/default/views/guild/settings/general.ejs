<!-- Core Plugin - Allgemeine Einstellungen -->
<div class="row">
  <div class="col-lg-8">
    <!-- Hauptformular -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fa-solid fa-sliders me-2"></i>
          <%= tr('core:SETTINGS.GENERAL.TITLE') %>
        </h5>
      </div>
      <div class="card-body">
        <form id="general-settings-form" 
              class="guild-ajax-form" 
              data-form-type="core-settings" 
              data-method="PUT"
              action="/guild/<%= guildId %>/settings/general">
          
          <!-- Bot-Präfix -->
          <div class="mb-4">
            <label for="botPrefix" class="form-label fw-bold">
              <i class="fa-solid fa-terminal me-1 text-primary"></i>
              <%= tr('core:SETTINGS.GENERAL.PREFIX_LABEL') %>
            </label>
            <input 
              type="text" 
              class="form-control" 
              id="botPrefix" 
              name="prefix" 
              value="<%= settings?.prefix || '!' %>"
              maxlength="5"
              placeholder="!"
              required
            >
            <div class="form-text">
              <%- tr('core:SETTINGS.GENERAL.PREFIX_HELP') %>
            </div>
          </div>

          <!-- Standard-Sprache -->
          <div class="mb-4">
            <label for="defaultLocale" class="form-label fw-bold">
              <i class="fa-solid fa-language me-1 text-success"></i>
              <%= tr('core:SETTINGS.GENERAL.LOCALE_LABEL') %>
            </label>
            <select class="form-select" id="defaultLocale" name="locale">
              <% (languagesMeta || []).forEach(lang => { %>
                <option value="<%= lang.name %>" <%= (settings?.locale || 'de-DE') === lang.name ? 'selected' : '' %>>
                  <%= lang.nativeName %> (<%= lang.name %>)
                </option>
              <% }); %>
            </select>
            <div class="form-text">
              <%= tr('core:SETTINGS.GENERAL.LOCALE_HELP') %>
            </div>
          </div>

          <!-- Theme-Auswahl -->
          <div class="mb-4">
            <label for="theme" class="form-label fw-bold">
              <i class="fa-solid fa-palette me-1 text-warning"></i>
              <%= tr('core:SETTINGS.GENERAL.THEME_LABEL') %>
            </label>
            <select class="form-select" id="theme" name="theme">
              <option value="default" <%= (settings?.theme || 'default') === 'default' ? 'selected' : '' %>><%= tr('core:SETTINGS.GENERAL.THEME_DEFAULT') %></option>
              <option value="dark" <%= settings?.theme === 'dark' ? 'selected' : '' %>><%= tr('core:SETTINGS.GENERAL.THEME_DARK') %></option>
              <option value="nord" <%= settings?.theme === 'nord' ? 'selected' : '' %>><%= tr('core:SETTINGS.GENERAL.THEME_NORD') %></option>
            </select>
            <div class="form-text">
              <i class="fa-solid fa-info-circle me-1"></i>
              <%= tr('core:SETTINGS.GENERAL.THEME_HELP') %>
            </div>
          </div>

          <hr class="my-4">

          <!-- Features-Toggles -->
          <h6 class="mb-3">
            <i class="fa-solid fa-toggle-on me-2"></i>
            <%= tr('core:SETTINGS.GENERAL.FEATURES_TITLE') %>
          </h6>

          <!-- Slash-Commands -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input 
                class="form-check-input" 
                type="checkbox" 
                id="slashCommands" 
                name="slashCommands"
                <%= (settings?.slashCommands !== false) ? 'checked' : '' %>
              >
              <label class="form-check-label" for="slashCommands">
                <i class="fa-solid fa-slash me-1 text-info"></i>
                <strong><%= tr('core:SETTINGS.GENERAL.SLASH_LABEL') %></strong>
                <div class="text-muted small">
                  <%- tr('core:SETTINGS.GENERAL.SLASH_HELP') %>
                </div>
              </label>
            </div>
          </div>

          <!-- Erweiterte Logs -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input 
                class="form-check-input" 
                type="checkbox" 
                id="verboseLogs" 
                name="verboseLogs"
                <%= settings?.verboseLogs ? 'checked' : '' %>
              >
              <label class="form-check-label" for="verboseLogs">
                <i class="fa-solid fa-file-lines me-1 text-secondary"></i>
                <strong><%= tr('core:SETTINGS.GENERAL.VERBOSE_LABEL') %></strong>
                <div class="text-muted small">
                  <%= tr('core:SETTINGS.GENERAL.VERBOSE_HELP') %>
                </div>
              </label>
            </div>
          </div>

          <!-- Debug-Modus (nur für Power-User) -->
          <div class="mb-3">
            <div class="form-check form-switch">
              <input 
                class="form-check-input" 
                type="checkbox" 
                id="debugMode" 
                name="debugMode"
                <%= settings?.debugMode ? 'checked' : '' %>
              >
              <label class="form-check-label" for="debugMode">
                <i class="fa-solid fa-bug me-1 text-danger"></i>
                <strong><%= tr('core:SETTINGS.GENERAL.DEBUG_LABEL') %></strong>
                <span class="badge bg-warning text-dark ms-2"><%= tr('core:SETTINGS.GENERAL.DEBUG_BADGE') %></span>
                <div class="text-muted small">
                  <%= tr('core:SETTINGS.GENERAL.DEBUG_HELP') %>
                </div>
              </label>
            </div>
          </div>

          <hr class="my-4">

          <!-- Speichern Button -->
          <div class="d-flex justify-content-end gap-2">
            <button type="reset" class="btn btn-outline-secondary">
              <i class="fa-solid fa-rotate-left me-1"></i>
              <%= tr('core:SETTINGS.GENERAL.RESET_BTN') %>
            </button>
            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-save me-1"></i>
              <%= tr('core:SETTINGS.GENERAL.SAVE_BTN') %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Seitenleiste mit Hilfe -->
  <div class="col-lg-4">
    <!-- Hilfe-Card -->
    <div class="card mb-3">
      <div class="card-header bg-info text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-circle-info me-2"></i>
          <%= tr('core:SETTINGS.HELP.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <h6 class="fw-bold"><%= tr('core:SETTINGS.HELP.PREFIX_TITLE') %></h6>
        <p class="small mb-3">
          <%- tr('core:SETTINGS.HELP.PREFIX_TEXT') %>
        </p>

        <h6 class="fw-bold"><%= tr('core:SETTINGS.HELP.SLASH_TITLE') %></h6>
        <p class="small mb-3">
          <%= tr('core:SETTINGS.HELP.SLASH_TEXT') %>
        </p>

        <h6 class="fw-bold"><%= tr('core:SETTINGS.HELP.DEBUG_TITLE') %></h6>
        <p class="small mb-0">
          <span class="badge bg-warning text-dark mb-2"><%= tr('core:SETTINGS.HELP.DEBUG_WARNING') %></span><br>
          <%= tr('core:SETTINGS.HELP.DEBUG_TEXT') %>
        </p>
      </div>
    </div>

    <!-- Status-Card -->
    <div class="card">
      <div class="card-header bg-success text-white">
        <h6 class="mb-0">
          <i class="fa-solid fa-check-circle me-2"></i>
          <%= tr('core:SETTINGS.STATUS.TITLE') %>
        </h6>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0 small">
          <li class="mb-2">
            <strong><%= tr('core:SETTINGS.STATUS.PREFIX') %>:</strong> <code><%= settings?.prefix || '!' %></code>
          </li>
          <li class="mb-2">
            <strong><%= tr('core:SETTINGS.STATUS.LOCALE') %>:</strong> <%= settings?.locale || 'de-DE' %>
          </li>
          <li class="mb-2">
            <strong><%= tr('core:SETTINGS.STATUS.THEME') %>:</strong> <%= settings?.theme || 'default' %>
          </li>
          <li class="mb-2">
            <strong><%= tr('core:SETTINGS.STATUS.SLASH') %>:</strong>
            <% if (settings?.slashCommands !== false) { %>
              <span class="badge bg-success"><%= tr('core:SETTINGS.STATUS.ACTIVE') %></span>
            <% } else { %>
              <span class="badge bg-secondary"><%= tr('core:SETTINGS.STATUS.INACTIVE') %></span>
            <% } %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
