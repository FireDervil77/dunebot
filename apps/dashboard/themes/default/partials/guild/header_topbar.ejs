<!--begin::Header-->
      <nav class="app-header navbar navbar-expand bg-body">
        <!--begin::Container-->
        <div class="container-fluid">
          <!--begin::Start Navbar Links-->
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                <i class="bi bi-list"></i>
              </a>
            </li>
            <li class="nav-item d-none d-md-block"> <a href="/" class="nav-link"><i class="fa-solid fa-home"></i> <%= tr('SIDEBAR.HOME') %></a></li>
            <li class="nav-item d-none d-md-block"> <a href="<%= supportUrl || '#' %>" class="nav-link"><i class="fab fa-discord"></i> <%= tr('SIDEBAR.SUPPORT_DISCORD') %></a></li>
          </ul>
          <!--end::Start Navbar Links-->
          <!--begin::End Navbar Links-->
          <ul class="navbar-nav ms-auto">
            <!--begin::Guild Switcher-->
            <% 
              // Discord Permission Flags
              const MANAGE_GUILD = 0x0000000020n;
              const ADMINISTRATOR = 0x0000000008n;
              
              // Permission-Check Helper-Funktion (ohne Error-Handling für bessere Performance)
              const hasGuildPermission = (g) => {
                if (!g.botPresent) return false; // Bot muss auf Server sein
                if (g.owner) return true; // Owner hat immer Zugriff
                
                // Permission Check mit Safe-Parse
                if (!g.permissions) return false;
                const permBigInt = BigInt(g.permissions);
                const hasManageGuild = (permBigInt & MANAGE_GUILD) === MANAGE_GUILD;
                const hasAdministrator = (permBigInt & ADMINISTRATOR) === ADMINISTRATOR;
                return hasManageGuild || hasAdministrator;
              };
              
              // WordPress-Stil: user ist direkt verfügbar, Fallback auf locals.user
              const sessionUser = typeof user !== 'undefined' ? user : (typeof locals !== 'undefined' ? locals.user : null);
              
              // Nur Guilds anzeigen, auf denen der Bot vorhanden ist UND User Admin-Rechte hat
              const allUserGuilds = sessionUser?.guilds || [];
              const userGuilds = allUserGuilds.filter(hasGuildPermission);
              
              const currentGuildId = locals.guild?.id || locals.guildId;
              const currentGuild = userGuilds.find(g => g.id === currentGuildId);
            %>
            <%# Nur anzeigen wenn User mehrere verwaltbare Guilds mit Bot hat %>
            <% if (userGuilds.length > 1) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="guildSwitcher" role="button" data-toggle="dropdown" aria-expanded="false">
                <% if (currentGuild?.icon) { %>
                  <img 
                    src="https://cdn.discordapp.com/icons/<%= currentGuild.id %>/<%= currentGuild.icon %>.png" 
                    class="rounded-circle" 
                    style="width: 24px; height: 24px; margin-right: 8px;" 
                    alt="<%= currentGuild.name %>"
                  />
                <% } else { %>
                  <i class="bi bi-server" style="margin-right: 8px;"></i>
                <% } %>
                <span class="d-none d-md-inline"><%= currentGuild?.name || 'Server' %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="guildSwitcher" style="max-height: 400px; overflow-y: auto;">
                <li class="dropdown-header"><%= tr('GUILD_SWITCHER.TITLE') || 'Deine Server' %></li>
                <li><hr class="dropdown-divider"></li>
                <% userGuilds.forEach(guild => { %>
                  <li>
                    <a class="dropdown-item <%= guild.id === currentGuildId ? 'active' : '' %>" 
                       href="/guild/<%= guild.id %>/"
                       style="display: flex; align-items: center; padding: 8px 16px;">
                      <% if (guild.icon) { %>
                        <img 
                          src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" 
                          class="rounded-circle" 
                          style="width: 32px; height: 32px; margin-right: 12px;" 
                          alt="<%= guild.name %>"
                        />
                      <% } else { %>
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" 
                             style="width: 32px; height: 32px; margin-right: 12px; color: white; font-weight: bold;">
                          <%= guild.name.substring(0, 2).toUpperCase() %>
                        </div>
                      <% } %>
                      <div style="flex: 1;">
                        <div style="font-weight: 500;"><%= guild.name %></div>
                        <% if (guild.id === currentGuildId) { %>
                          <small class="text-success"><i class="bi bi-check-circle-fill"></i> <%= tr('GUILD_SWITCHER.ACTIVE') || 'Aktiv' %></small>
                        <% } %>
                      </div>
                    </a>
                  </li>
                <% }); %>
              </ul>
            </li>
            <% } %>
            <!--end::Guild Switcher-->
           
            <!--begin::Language Switcher-->
            <li class="nav-item dropdown">
              <a class="nav-link" href="#" data-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-translate"></i>
              </a>
              <ul class="dropdown-menu dropdown-menu-right">
                <li class="dropdown-header">
                  <i class="bi bi-translate me-2"></i><%= tr('LANDING.LANGUAGE_SELECTOR') || 'Sprache' %>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a href="#" class="dropdown-item lang-switch-link <%= locals.locale === 'de-DE' ? 'active' : '' %>" data-lang="de-DE">
                    🇩🇪 <%= tr('LANDING.LANGUAGE_DE') || 'Deutsch' %>
                  </a>
                </li>
                <li>
                  <a href="#" class="dropdown-item lang-switch-link <%= locals.locale === 'en-GB' ? 'active' : '' %>" data-lang="en-GB">
                    🇬🇧 <%= tr('LANDING.LANGUAGE_EN') || 'English' %>
                  </a>
                </li>
              </ul>
            </li>
            <!--end::Language Switcher-->
           
            <!--begin::Toast Notification Center-->
            <li class="nav-item dropdown" id="toastNotificationCenter">
              <a class="nav-link" href="#" data-toggle="dropdown" aria-expanded="false" id="toastNotificationBell">
                <i class="bi bi-bell"></i>
                <span class="badge badge-danger navbar-badge" id="toastNotificationBadge" style="display: none;">0</span>
              </a>
              <ul class="dropdown-menu dropdown-menu-right" style="min-width: 320px; max-height: 400px; overflow-y: auto;" aria-labelledby="toastNotificationBell">
                <li class="dropdown-header">
                  <i class="bi bi-bell me-2"></i>
                  <%= tr('TOAST_NOTIFICATIONS.TITLE') || 'Toast Benachrichtigungen' %>
                </li>
                <li><hr class="dropdown-divider"></li>
                
                <!-- Toast-Liste wird hier dynamisch eingefügt -->
                <div id="toastNotificationList">
                  <li class="dropdown-item text-center text-muted py-3">
                    <i class="bi bi-hourglass-split me-1"></i>
                    <%= tr('TOAST_NOTIFICATIONS.LOADING') || 'Lade...' %>
                  </li>
                </div>
                
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a href="/guild/<%= currentGuildId %>/plugins/core/toast-history" class="dropdown-item text-center">
                    <i class="bi bi-list-ul me-2"></i>
                    <%= tr('TOAST_NOTIFICATIONS.VIEW_ALL') || 'Alle anzeigen' %>
                  </a>
                </li>
              </ul>
            </li>
            <!--end::Toast Notification Center-->
           
            <!--begin::Fullscreen Toggle-->
            <li class="nav-item">
              <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
              </a>
            </li>
            <!--end::Fullscreen Toggle-->
            <!--begin::User Menu Dropdown-->
            <li class="nav-item dropdown user-menu">
              <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                <% 
                  // WordPress-Stil: Variablen sind direkt verfügbar (user, nicht locals.user)
                  // Fallback auf locals.user für Backward Compatibility
                  const currentUser = typeof user !== 'undefined' ? user : (typeof locals !== 'undefined' ? locals.user : null);
                  // Normalisierung: unterstützt sowohl { info: {...} } als auch flaches { id, username, ... }
                  const currentUserInfo = (currentUser && currentUser.info) ? currentUser.info : currentUser;
                %>
                <% if (currentUserInfo && (currentUserInfo.id || currentUserInfo.username)) { %>
                <img
                  src="<%= getUserAvatar(currentUser, 128) %>"
                  class="user-image rounded-circle shadow"
                  alt="User Image"
                />
                <span class="d-none d-md-inline"><%= currentUserInfo.username %></span>
                <% } else { %>
                <span class="d-none d-md-inline">Guest</span>
                <% } %>
              </a>
              <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                <% if (currentUserInfo && (currentUserInfo.id || currentUserInfo.username)) { %>
                <li class="user-header text-bg-primary">
                  <img src="<%= getUserAvatar(currentUser, 256) %>"
                    class="rounded-circle shadow" alt="User Image" />
                  <p>
                    <%= currentUserInfo.username %>
                    <% 
                      // Letzter Login anstatt Mitglied seit X Tagen
                      let lastLogin = currentUserInfo.lastLogin;
                      let lastLoginText = '-';
                      if (lastLogin) {
                        let dateObj = typeof lastLogin === 'string' ? new Date(lastLogin) : lastLogin;
                        if (!isNaN(dateObj.getTime())) {
                          // Formatiere Datum: DD.MM.YYYY HH:MM (falls heute) oder DD.MM.YYYY (sonst)
                          const today = new Date();
                          const isToday = dateObj.toDateString() === today.toDateString();
                          
                          const day = String(dateObj.getDate()).padStart(2, '0');
                          const month = String(dateObj.getMonth() + 1).padStart(2, '0');
                          const year = dateObj.getFullYear();
                          const hours = String(dateObj.getHours()).padStart(2, '0');
                          const minutes = String(dateObj.getMinutes()).padStart(2, '0');
                          
                          if (isToday) {
                            lastLoginText = `${day}.${month}.${year} ${hours}:${minutes}`;
                          } else {
                            lastLoginText = `${day}.${month}.${year}`;
                          }
                        }
                      }
                    %>
                    <small><%= tr('DASHBOARD_COMMON.LAST_LOGIN') || 'Letzter Login am' %>: <%= lastLoginText %></small>
                  </p>
                </li>
                <li class="user-body">
                  <div class="row">
                    <div class="col-12 text-center">
                      <a href="/" class="btn btn-sm btn-outline-light w-100 mb-2">
                        <i class="bi bi-globe"></i> <%= tr('DASHBOARD_COMMON.TO_FRONTEND') || 'Zur Startseite' %>
                      </a>
                      <a href="/guild/<%= currentGuildId %>/settings" class="btn btn-sm btn-outline-light w-100">
                        <i class="bi bi-gear"></i> <%= tr('DASHBOARD_COMMON.USER_SETTINGS') || 'Einstellungen' %>
                      </a>
                    </div>
                  </div>
                </li>
                <li class="user-footer text-center">
                  <a href="/auth/logout" class="btn btn-danger btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>
                    <%= tr('DASHBOARD.LOGOUT') %>
                  </a>
                </li>
                <% } %>
              </ul>
            </li>
            <!--end::User Menu Dropdown-->
          </ul>
          <!--end::End Navbar Links-->
        </div>
        <!--end::Container-->
      </nav>
      <!--end::Header-->