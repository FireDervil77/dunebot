<!--begin::Header-->
      <nav class="app-header navbar navbar-expand bg-body">
        <!--begin::Container-->
        <div class="container-fluid">
          <!--begin::Start Navbar Links-->
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                <i class="bi bi-list"></i>
              </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="/guild" class="nav-link"><%= tr('SIDEBAR.HOME') %></a></li>
            <li class="nav-item d-none d-md-block"><a href="<%= tr('SIDEBAR.SUPPORT_DISCORD_LINK') %>" class="nav-link"><%= tr('SIDEBAR.SUPPORT_DISCORD') %></a></li>
          </ul>
          <!--end::Start Navbar Links-->
          <!--begin::End Navbar Links-->
          <ul class="navbar-nav ms-auto">
            <!--begin::Guild Switcher-->
            <% 
              // Discord Permission Flags
              const MANAGE_GUILD = 0x0000000020n;
              const ADMINISTRATOR = 0x0000000008n;
              
              // Permission-Check Helper-Funktion (ohne Error-Handling für bessere Performance)
              const hasGuildPermission = (g) => {
                if (!g.botPresent) return false; // Bot muss auf Server sein
                if (g.owner) return true; // Owner hat immer Zugriff
                
                // Permission Check mit Safe-Parse
                if (!g.permissions) return false;
                const permBigInt = BigInt(g.permissions);
                const hasManageGuild = (permBigInt & MANAGE_GUILD) === MANAGE_GUILD;
                const hasAdministrator = (permBigInt & ADMINISTRATOR) === ADMINISTRATOR;
                return hasManageGuild || hasAdministrator;
              };
              
              // WordPress-Stil: user ist direkt verfügbar, Fallback auf locals.user
              const sessionUser = typeof user !== 'undefined' ? user : (typeof locals !== 'undefined' ? locals.user : null);
              
              // Nur Guilds anzeigen, auf denen der Bot vorhanden ist UND User Admin-Rechte hat
              const allUserGuilds = sessionUser?.guilds || [];
              const userGuilds = allUserGuilds.filter(hasGuildPermission);
              
              const currentGuildId = locals.guild?.id || locals.guildId;
              const currentGuild = userGuilds.find(g => g.id === currentGuildId);
            %>
            <%# Nur anzeigen wenn User mehrere verwaltbare Guilds mit Bot hat %>
            <% if (userGuilds.length > 1) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="guildSwitcher" role="button" data-toggle="dropdown" aria-expanded="false">
                <% if (currentGuild?.icon) { %>
                  <img 
                    src="https://cdn.discordapp.com/icons/<%= currentGuild.id %>/<%= currentGuild.icon %>.png" 
                    class="rounded-circle" 
                    style="width: 24px; height: 24px; margin-right: 8px;" 
                    alt="<%= currentGuild.name %>"
                  />
                <% } else { %>
                  <i class="bi bi-server" style="margin-right: 8px;"></i>
                <% } %>
                <span class="d-none d-md-inline"><%= currentGuild?.name || 'Server' %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="guildSwitcher" style="max-height: 400px; overflow-y: auto;">
                <li class="dropdown-header"><%= tr('GUILD_SWITCHER.TITLE') || 'Deine Server' %></li>
                <li><hr class="dropdown-divider"></li>
                <% userGuilds.forEach(guild => { %>
                  <li>
                    <a class="dropdown-item <%= guild.id === currentGuildId ? 'active' : '' %>" 
                       href="/guild/<%= guild.id %>/"
                       style="display: flex; align-items: center; padding: 8px 16px;">
                      <% if (guild.icon) { %>
                        <img 
                          src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" 
                          class="rounded-circle" 
                          style="width: 32px; height: 32px; margin-right: 12px;" 
                          alt="<%= guild.name %>"
                        />
                      <% } else { %>
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" 
                             style="width: 32px; height: 32px; margin-right: 12px; color: white; font-weight: bold;">
                          <%= guild.name.substring(0, 2).toUpperCase() %>
                        </div>
                      <% } %>
                      <div style="flex: 1;">
                        <div style="font-weight: 500;"><%= guild.name %></div>
                        <% if (guild.id === currentGuildId) { %>
                          <small class="text-success"><i class="bi bi-check-circle-fill"></i> <%= tr('GUILD_SWITCHER.ACTIVE') || 'Aktiv' %></small>
                        <% } %>
                      </div>
                    </a>
                  </li>
                <% }); %>
              </ul>
            </li>
            <% } %>
            <!--end::Guild Switcher-->
           
            <!--begin::Fullscreen Toggle-->
            <li class="nav-item">
              <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
              </a>
            </li>
            <!--end::Fullscreen Toggle-->
            <!--begin::User Menu Dropdown-->
            <li class="nav-item dropdown user-menu">
              <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                <% 
                  // WordPress-Stil: Variablen sind direkt verfügbar (user, nicht locals.user)
                  // Fallback auf locals.user für Backward Compatibility
                  const currentUser = typeof user !== 'undefined' ? user : (typeof locals !== 'undefined' ? locals.user : null);
                %>
                <% if (currentUser && currentUser.info) { %>
                <img
                  src="<%= getUserAvatar(currentUser, 128) %>"
                  class="user-image rounded-circle shadow"
                  alt="User Image"
                />
                <span class="d-none d-md-inline"><%= currentUser.info.username || currentUser.username %></span>
                <% } else { %>
                <span class="d-none d-md-inline">Guest</span>
                <% } %>
              </a>
              <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                <% if (currentUser && currentUser.info) { %>
                <li class="user-header text-bg-primary">
                  <img src="<%= getUserAvatar(currentUser, 256) %>"
                    class="rounded-circle shadow" alt="User Image" />
                  <p>
                    <%= currentUser.info.username || currentUser.username %>
                    <% 
                      let createdAt = currentUser.createdAt;
                      let days = '-';
                      if (createdAt) {
                        let dateObj = typeof createdAt === 'string' ? new Date(createdAt) : createdAt;
                        if (!isNaN(dateObj.getTime())) {
                          days = Math.floor((Date.now() - dateObj.getTime()) / (1000 * 60 * 60 * 24));
                        }
                      }
                    %>
                    <small>Mitglied seit <%= days %> Tagen</small>
                  </p>
                </li>
                <li class="user-body">
                  <div class="row">
                    <!-- Hier können weitere Profilinfos ergänzt werden -->
                  </div>
                </li>
                <li class="user-footer">
                  <a href="/" class="btn btn-primary btn-xs">
                    <i class="bi bi-house-door me-1"></i>
                    Zum Dashboard
                  </a>
                  <a href="/auth/logout" class="btn btn-danger btn-flat float-end">
                    <i class="bi bi-box-arrow-right me-1"></i>
                    <%= tr('DASHBOARD.LOGOUT') %>
                  </a>
                </li>
                <% } %>
              </ul>
            </li>
            <!--end::User Menu Dropdown-->
          </ul>
          <!--end::End Navbar Links-->
        </div>
        <!--end::Container-->
      </nav>
      <!--end::Header-->