<%#  
  * Admin-Topnav-Partial
  * Enthält die obere Navigationsleiste für AdminLTE
  * 
  * @author FireDervil
    %>

<!-- Right navbar links -->
<ul class="navbar-nav ml-auto">
  <!-- Messages Dropdown Menu -->
  <li class="nav-item dropdown">
    <a class="nav-link" data-toggle="dropdown" href="#">
      <i class="far fa-comments"></i>
      <span class="badge badge-danger navbar-badge"><%= locals.unreadMessages || 0 %></span>
    </a>
    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
      <% if (locals.messages && messages.length > 0) { %>
        <% messages.slice(0, 3).forEach(message => { %>
          <a href="<%= message.url || '#' %>" class="dropdown-item">
            <div class="media">
              <img src="<%= message.avatar || '/themes/default/assets/images/default-avatar.png' %>" alt="User Avatar" class="img-size-50 mr-3 img-circle">
              <div class="media-body">
                <h3 class="dropdown-item-title">
                  <%= message.sender %>
                  <% if (message.priority === 'high') { %>
                    <span class="float-right text-sm text-danger"><i class="fas fa-star"></i></span>
                  <% } else if (message.priority === 'medium') { %>
                    <span class="float-right text-sm text-warning"><i class="fas fa-star"></i></span>
                  <% } %>
                </h3>
                <p class="text-sm"><%= message.content.substring(0, 60) %><%= message.content.length > 60 ? '...' : '' %></p>
                <p class="text-sm text-muted"><i class="far fa-clock mr-1"></i> <%= message.time %></p>
              </div>
            </div>
          </a>
          <div class="dropdown-divider"></div>
        <% }); %>
        <a href="/guild/messages" class="dropdown-item dropdown-footer">Alle Nachrichten anzeigen</a>
      <% } else { %>
        <span class="dropdown-item dropdown-footer">Keine neuen Nachrichten</span>
      <% } %>
    </div>
  </li>

  <!-- Notifications Dropdown Menu -->
  <li class="nav-item dropdown">
    <a class="nav-link" data-toggle="dropdown" href="#">
      <i class="far fa-bell"></i>
      <span class="badge badge-warning navbar-badge" id="notification-badge" style="<%= (locals.notifications?.length || 0) === 0 ? 'display: none;' : '' %>"><%= locals.notifications?.length || 0 %></span>
    </a>
    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
      <span class="dropdown-item dropdown-header"><%= locals.notifications?.length || 0 %> Benachrichtigungen</span>
      <div class="dropdown-divider"></div>
      
      <% if (locals.notifications && notifications.length > 0) { %>
        <% notifications.slice(0, 5).forEach(notification => { %>
          <div class="dropdown-item d-flex justify-content-between align-items-center notification-item" data-notification-id="<%= notification.id %>">
            <div class="flex-grow-1">
              <div class="d-flex align-items-start">
                <i class="fas fa-<%= notification.type === 'error' ? 'exclamation-circle text-danger' : notification.type === 'warning' ? 'exclamation-triangle text-warning' : notification.type === 'success' ? 'check-circle text-success' : 'info-circle text-info' %> mr-2 mt-1"></i>
                <div>
                  <strong><%= notification.title %></strong>
                  <br>
                  <small class="text-muted"><%= notification.message.substring(0, 60) %><%= notification.message.length > 60 ? '...' : '' %></small>
                  <% if (notification.action_url) { %>
                    <br>
                    <a href="<%= notification.action_url %>" class="btn btn-sm btn-outline-primary mt-1">
                      <%= notification.action_text || 'Mehr erfahren' %>
                    </a>
                  <% } %>
                </div>
              </div>
            </div>
            <button type="button" class="btn btn-sm btn-link text-muted dismiss-notification" data-id="<%= notification.id %>" title="Schließen">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <div class="dropdown-divider"></div>
        <% }); %>
        <% if (notifications.length > 5) { %>
          <span class="dropdown-item text-muted text-center">
            <small>+ <%= notifications.length - 5 %> weitere Benachrichtigungen</small>
          </span>
          <div class="dropdown-divider"></div>
        <% } %>
      <% } else { %>
        <span class="dropdown-item">Keine Benachrichtigungen</span>
        <div class="dropdown-divider"></div>
      <% } %>
    </div>
  </li>

  <!-- Sprache wechseln -->
  <li class="nav-item dropdown">
    <a class="nav-link" data-toggle="dropdown" href="#">
      <i class="fas fa-globe"></i>
    </a>
    <div class="dropdown-menu dropdown-menu-right p-0">
      <a href="/guild/locale?lang=de-DE" class="dropdown-item <%= locals.locale === 'de-DE' ? 'active' : '' %>">
        <i class="flag-icon flag-icon-de mr-2"></i> Deutsch
      </a>
      <a href="/guild/locale?lang=en-US" class="dropdown-item <%= locals.locale === 'en-US' ? 'active' : '' %>">
        <i class="flag-icon flag-icon-us mr-2"></i> English
      </a>
    </div>
  </li>

  <!-- Fullscreen Toggle -->
  <li class="nav-item">
    <a class="nav-link" data-widget="fullscreen" href="#" role="button">
      <i class="fas fa-expand-arrows-alt"></i>
    </a>
  </li>

  <!-- Hook: content_header_actions -->
  <% if (locals.hooks && hooks.getViewHooks) { %>
    <% const headerActionHooks = hooks.getViewHooks('content_header_actions'); %>
    <% if (headerActionHooks && headerActionHooks.length > 0) { %>
      <% headerActionHooks.forEach(hook => { %>
        <%- include(hook.component, { plugin: hook.plugin, context: hook.context || {} }) %>
      <% }); %>
    <% } %>
  <% } %>

  <!-- Abmelden -->
  <li class="nav-item">
    <a class="nav-link" href="/auth/logout" role="button" title="Abmelden">
      <i class="fas fa-sign-out-alt"></i>
    </a>
  </li>
</ul>

<script>
// Notification Dismiss Handler
document.addEventListener('DOMContentLoaded', function() {
  // Event Delegation für Dismiss-Buttons
  document.addEventListener('click', async function(e) {
    const dismissBtn = e.target.closest('.dismiss-notification');
    if (!dismissBtn) return;
    
    e.preventDefault();
    e.stopPropagation();
    
    const notificationId = dismissBtn.getAttribute('data-id');
    const notificationItem = dismissBtn.closest('.notification-item');
    
    if (!notificationId) return;
    
    try {
      const response = await fetch(`/api/notifications/dismiss/${notificationId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });
      
      const result = await response.json();
      
      if (result.success) {
        // Fade out Animation
        notificationItem.style.transition = 'opacity 0.3s';
        notificationItem.style.opacity = '0';
        
        setTimeout(() => {
          // Entferne Item und Divider
          const nextDivider = notificationItem.nextElementSibling;
          notificationItem.remove();
          if (nextDivider && nextDivider.classList.contains('dropdown-divider')) {
            nextDivider.remove();
          }
          
          // Update Badge
          const badge = document.getElementById('notification-badge');
          if (badge) {
            const currentCount = parseInt(badge.textContent) || 0;
            const newCount = Math.max(0, currentCount - 1);
            badge.textContent = newCount;
            if (newCount === 0) {
              badge.style.display = 'none';
            }
          }
          
          // Wenn keine Notifications mehr: Zeige "Keine Benachrichtigungen"
          const dropdown = document.querySelector('.dropdown-menu-lg .dropdown-divider').parentElement;
          const items = dropdown.querySelectorAll('.notification-item');
          if (items.length === 0) {
            const noNotifItem = document.createElement('span');
            noNotifItem.className = 'dropdown-item';
            noNotifItem.textContent = 'Keine Benachrichtigungen';
            dropdown.querySelector('.dropdown-divider').insertAdjacentElement('afterend', noNotifItem);
          }
        }, 300);
      } else {
        console.error('Fehler beim Dismissing:', result.message);
      }
    } catch (error) {
      console.error('Fehler beim Dismissing:', error);
    }
  });
});
</script>