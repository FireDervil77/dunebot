<%# 
  * Language Switcher Script für Dashboard
  * Ermöglicht Sprachwechsel für authentifizierte User
  * Nutzt POST /api/language Route
  * 
  * @author FireDervil
  %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const langLinks = document.querySelectorAll('.lang-switch-link');
    
    langLinks.forEach(link => {
        link.addEventListener('click', async function(e) {
            e.preventDefault();
            
            const langCode = this.getAttribute('data-lang');
            const currentLang = '<%= locals.locale %>';
            
            // Wenn bereits aktive Sprache, nichts tun
            if (langCode === currentLang) {
                return;
            }
            
            // Loading-Indikator hinzufügen
            const icon = this.querySelector('span') || this;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Lädt...';
            this.style.pointerEvents = 'none';
            
            try {
                const response = await fetch('/api/language', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        language_code: langCode
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Erfolg - Seite neu laden
                    window.location.reload();
                } else {
                    // Fehler anzeigen
                    this.innerHTML = originalHTML;
                    this.style.pointerEvents = '';
                    alert('Fehler beim Wechseln der Sprache: ' + (data.error || 'Unbekannter Fehler'));
                }
            } catch (error) {
                console.error('Language switch error:', error);
                this.innerHTML = originalHTML;
                this.style.pointerEvents = '';
                alert('Fehler beim Wechseln der Sprache. Bitte versuche es erneut.');
            }
        });
    });
});
</script>

<style>
/* Aktive Sprache hervorheben */
.lang-switch-link.active {
    font-weight: bold;
    color: #007bff !important;
    background-color: rgba(0, 123, 255, 0.1);
    pointer-events: none;
    cursor: default;
}

.lang-switch-link.active::before {
    content: "✓ ";
    color: #28a745;
    font-weight: bold;
    margin-right: 4px;
}

/* Hover-Effekt für nicht-aktive Sprachen */
.lang-switch-link:not(.active):hover {
    background-color: rgba(0, 0, 0, 0.05);
}

/* Loading-Spinner-Animation */
@keyframes spinner-border {
    to { transform: rotate(360deg); }
}

.spinner-border {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    vertical-align: text-bottom;
    border: 0.2em solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: spinner-border 0.75s linear infinite;
}

.spinner-border-sm {
    width: 0.875rem;
    height: 0.875rem;
    border-width: 0.15em;
}
</style>
