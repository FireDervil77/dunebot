<%#  
  * Admin-Breadcrumb-Partial
  * Zeigt den Navigationspfad (Breadcrumb) im Admin-Bereich an
  * 
  * @author FireDervil
  * @context {Array} breadcrumbs - Array von Objekten mit Eigenschaften title und url
    %>

<!--begin::App Main-->
      <main class="app-main">
        <!--begin::App Content Header-->
        <div class="app-content-header">
          <!--begin::Container-->
          <div class="container-fluid">
            
            <!--begin::Row-->
            <div class="row">
              <div class="col-sm-6">
                <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : (typeof locals !== 'undefined' && locals.title ? locals.title : 'Dashboard') %></h3>
              </div>
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                  <% 
                    // WordPress-Stil: Variablen direkt verfügbar mit Fallback
                    const currentGuildId = typeof guildId !== 'undefined' ? guildId : (typeof locals !== 'undefined' ? locals.guildId : null);
                    const currentGuild = typeof guild !== 'undefined' ? guild : (typeof locals !== 'undefined' ? locals.guild : null);
                    const currentPlugin = typeof plugin !== 'undefined' ? plugin : (typeof locals !== 'undefined' ? locals.plugin : null);
                  %>
                  <% if (currentGuildId) { %>
                  <li class="breadcrumb-item"><a href="/guild/<%=currentGuildId%>"> <%= tr('SIDEBAR.SERVERS') %></a></li>
                  <% } %>
                  <% if (currentGuild) { %>
                    <li class="breadcrumb-item active" aria-current="page"><a href="/guild/<%=currentGuildId%>"><%=currentGuild.guild_name%></a></li>
                  <% } %>
                  <% if (currentPlugin) { %>
                  <% const name = currentPlugin.name.charAt(0).toUpperCase() + currentPlugin.name.slice(1); %>
                    <li class="breadcrumb-item active" aria-current="page"><%=name%></li>
                  <% } %>
                </ol>
              </div>
              
            </div>
            <!--end::Row-->
          </div>
          <!--end::Container-->
        </div>
        <!--end::App Content Header-->