<% if (feedback && feedback.length > 0) { %>
<div class="table-responsive">
    <table class="table table-hover table-sm">
        <thead>
            <tr>
                <th>#</th>
                <th>Typ</th>
                <th>Titel</th>
                <th>Guild</th>
                <th>User</th>
                <th>Priorität</th>
                <th>Status</th>
                <th>Datum</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            <% feedback.forEach(f => { %>
            <tr class="feedback-row" data-toggle="collapse" data-target="#desc-<%= f.id %>" style="cursor: pointer;">
                <td><%= f.id %></td>
                <td>
                    <% if (f.type === 'bug') { %>
                        <span class="badge badge-danger"><i class="fa-solid fa-bug me-1"></i>Bug</span>
                    <% } else { %>
                        <span class="badge badge-info"><i class="fa-solid fa-lightbulb me-1"></i>Feature</span>
                    <% } %>
                </td>
                <td>
                    <%= f.title %>
                    <i class="fa-solid fa-chevron-down ml-1 text-muted" style="font-size: 0.7em;"></i>
                </td>
                <td><small class="text-muted"><%= f.guild_id %></small></td>
                <td><small class="text-muted"><%= f.user_id %></small></td>
                <td>
                    <% if (f.priority === 'critical') { %>
                        <span class="badge badge-danger">Kritisch</span>
                    <% } else if (f.priority === 'high') { %>
                        <span class="badge badge-warning">Hoch</span>
                    <% } else if (f.priority === 'medium') { %>
                        <span class="badge badge-info">Mittel</span>
                    <% } else { %>
                        <span class="badge badge-secondary">Niedrig</span>
                    <% } %>
                </td>
                <td onclick="event.stopPropagation()">
                    <select class="form-control form-control-sm feedback-status-select"
                            data-id="<%= f.id %>"
                            style="min-width: 130px; font-size: 0.8em; padding: 2px 4px;">
                        <option value="open"        <%- f.status === 'open'        ? 'selected' : '' %>>🟡 Offen</option>
                        <option value="in_progress" <%- f.status === 'in_progress' ? 'selected' : '' %>>🔵 In Bearbeitung</option>
                        <option value="planned"     <%- f.status === 'planned'     ? 'selected' : '' %>>🟣 Geplant</option>
                        <option value="resolved"    <%- f.status === 'resolved'    ? 'selected' : '' %>>🟢 Gelöst</option>
                        <option value="implemented" <%- f.status === 'implemented' ? 'selected' : '' %>>✅ Umgesetzt</option>
                        <option value="rejected"    <%- f.status === 'rejected'    ? 'selected' : '' %>>🔴 Abgelehnt</option>
                        <option value="closed"      <%- f.status === 'closed'      ? 'selected' : '' %>>⚫ Geschlossen</option>
                        <option value="wontfix"     <%- f.status === 'wontfix'     ? 'selected' : '' %>>🚫 Wird nicht behoben</option>
                    </select>
                </td>
                <td><small><%= new Date(f.created_at).toLocaleDateString('de-DE') %></small></td>
                <td>
                    <button class="btn btn-xs btn-outline-primary" 
                            onclick="event.stopPropagation(); editFeedback('<%= f.id %>', '<%= f.status %>', '<%= f.priority %>', `<%= (f.admin_notes || '').replace(/`/g, "'") %>`, `<%= (f.admin_response || '').replace(/`/g, "'") %>`, `<%= (f.title || '').replace(/`/g, "'") %>`, `<%= (f.description || '').replace(/`/g, "'").replace(/\n/g, '\\n') %>`, '<%= f.type %>', '<%= f.category || '' %>')">
                        <i class="fa-solid fa-edit"></i>
                    </button>
                </td>
            </tr>
            <tr class="collapse" id="desc-<%= f.id %>">
                <td colspan="9" style="background: #f8f9fa; border-top: none;">
                    <div class="p-2">
                        <% if (f.category) { %><span class="badge badge-secondary mr-2"><%= f.category %></span><% } %>
                        <strong>Beschreibung:</strong>
                        <p class="mb-0 mt-1" style="white-space: pre-wrap;"><%= f.description %></p>
                    </div>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
</div>
<% } else { %>
<div class="text-center text-muted py-4">
    <i class="fa-solid fa-inbox fa-2x mb-2"></i>
    <p>Kein Feedback vorhanden</p>
</div>
<% } %>
