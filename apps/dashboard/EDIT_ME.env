# Shared
# IPC_SERVER_HOST mit localhost für ipv4 oder "::1" für ipv6
IPC_SERVER_HOST=
IPC_SERVER_PORT=3000

# Redis verbdinungs URL
REDIS_URL=redis://localhost:6379

# Owner IDS
OWNER_IDS=


# Path settings
REGISTRY_PATH=../../plugins/registry.json
PLUGINS_DIR=../../plugins


# Debug Settings
LOG_LEVEL=debug
NODE_ENV=development
DEBUG_HOOKS=true
VEZA_DEBUG=true

# DASHBOARD SETTINGS
DASHBOARD_BASE_URL=http://127.0.0.1:8900
DASHBOARD_PORT=8900
SESSION_COOKIE=dashboard.sid
SESSION_SECRET=YOUR_SESSION_SECRET


# DISCORD SETTINGS
CLIENT_ID=
CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8900/auth/callback
TOKEN_ENCRYPTION_KEY=YOUR_TOKEN_ENCRYPTION_KEY

# DATABASE CONFIG
DB_TYPE=mysql 
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=dunebot
MYSQL_USER=
MYSQL_PASSWORD=

# VERSIONS
DASHBOARD_VERSION=0.1.5.1545
BOT_VERSION=0.1.5.1545